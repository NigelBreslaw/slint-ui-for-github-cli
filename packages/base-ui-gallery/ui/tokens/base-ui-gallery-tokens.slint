import { BaseUiColors } from "../../../base-ui-slint/tokens.slint";

/// Gallery chrome layout; semantic colors come from base-ui-slint.
export global BaseUiGalleryColors {
    out property <brush> bg-default: BaseUiColors.bg-default;
    out property <brush> bg-subtle: BaseUiColors.bg-subtle;
    out property <brush> fg-default: BaseUiColors.fg-default;
    out property <brush> fg-muted: BaseUiColors.fg-muted;
    out property <brush> border-default: BaseUiColors.border-default;
    out property <brush> header-bg: BaseUiColors.surface-elevated;
}

export global BaseUiGalleryLayout {
    out property <length> sidebar-width: 240px;
    out property <length> header-height: 64px;
}
