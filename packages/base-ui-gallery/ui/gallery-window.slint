import { BaseUiAppWindow } from "../../base-ui-slint/tokens.slint";
import { BaseUiGalleryColors } from "./tokens/base-ui-gallery-tokens.slint";
import { GalleryHeader } from "./components/gallery-header.slint";
import { GallerySidebar } from "./components/gallery-sidebar.slint";
import { GalleryWelcomePage } from "./views/gallery-welcome-page.slint";
import { GalleryStubPage } from "./views/gallery-stub-page.slint";
import { GalleryFoundationTokensPage } from "./views/gallery-foundation-tokens-page.slint";
import { GalleryFoundationAnchorPage } from "./views/gallery-foundation-anchor-page.slint";
import { GalleryFoundationDismissPage } from "./views/gallery-foundation-dismiss-page.slint";
import { GalleryFoundationFocusPage } from "./views/gallery-foundation-focus-page.slint";
import { GalleryFoundationFloatingTreePage } from "./views/gallery-foundation-floating-tree-page.slint";
import { GalleryFoundationCompositePage } from "./views/gallery-foundation-composite-page.slint";
import { GalleryFoundationFieldPage } from "./views/gallery-foundation-field-page.slint";
import { GalleryFoundationStorePage } from "./views/gallery-foundation-store-page.slint";
import { GalleryFoundationA11yPage } from "./views/gallery-foundation-a11y-page.slint";
import { GalleryState } from "./state/gallery-state.slint";
import { GallerySidebarNav } from "./state/gallery-sidebar-nav.slint";
import { GalleryStubContent } from "./state/gallery-stub-content.slint";
export { Icons } from "../../primer-slint/primer.slint";

export { GalleryState } from "./state/gallery-state.slint";
export { GallerySidebarNav } from "./state/gallery-sidebar-nav.slint";
export { GalleryStubContent } from "./state/gallery-stub-content.slint";

export component GalleryWindow inherits Window {
    preferred-width: 1000px;
    preferred-height: 800px;
    min-width: 360px;
    min-height: 360px;
    title: "Base UI gallery";
    background: BaseUiGalleryColors.bg-default;

    changed width => {
        BaseUiAppWindow.window-width = root.width;
    }
    changed height => {
        BaseUiAppWindow.window-height = root.height;
    }
    init => {
        BaseUiAppWindow.window-width = root.width;
        BaseUiAppWindow.window-height = root.height;
    }

    VerticalLayout {
        GalleryHeader { }

        HorizontalLayout {
            vertical-stretch: 1;

            GallerySidebar { }

            main-scroll := Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: BaseUiGalleryColors.bg-default;

                gallery-flick := Flickable {
                    width: main-scroll.width;
                    height: main-scroll.height;
                    viewport-width: self.width;
                    viewport-height: gallery-main.preferred-height;

                    gallery-main := VerticalLayout {
                        width: gallery-flick.width;
                        min-height: gallery-flick.height;
                        alignment: start;

                        if GalleryState.selected-page-id == "welcome": GalleryWelcomePage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-tokens": GalleryFoundationTokensPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-anchor": GalleryFoundationAnchorPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-dismiss": GalleryFoundationDismissPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-focus": GalleryFoundationFocusPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-floating-tree": GalleryFoundationFloatingTreePage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-composite": GalleryFoundationCompositePage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-field": GalleryFoundationFieldPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-store": GalleryFoundationStorePage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "foundation-a11y": GalleryFoundationA11yPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id != "welcome"
                            && GalleryState.selected-page-id != "foundation-tokens"
                            && GalleryState.selected-page-id != "foundation-anchor"
                            && GalleryState.selected-page-id != "foundation-dismiss"
                            && GalleryState.selected-page-id != "foundation-focus"
                            && GalleryState.selected-page-id != "foundation-floating-tree"
                            && GalleryState.selected-page-id != "foundation-composite"
                            && GalleryState.selected-page-id != "foundation-field"
                            && GalleryState.selected-page-id != "foundation-store"
                            && GalleryState.selected-page-id != "foundation-a11y": GalleryStubPage {
                            height: main-scroll.height;
                        }
                    }
                }
            }
        }
    }
}
