import {
    BaseUiAnchoredPopup,
    BaseUiAnchorAlign,
    BaseUiAnchorSide,
    BaseUiColors,
    BaseUiLayoutTokens,
    BaseUiOpenChangeReasons,
} from "../../../base-ui-slint/base-ui.slint";
import { GalleryDemoOptionsSidebar } from "../components/gallery-demo-options-sidebar.slint";
import { CheckBox } from "std-widgets.slint";

/// Foundation → Dismiss — Escape / outside-press with live close reason.
export component GalleryFoundationDismissPage {
    property <bool> preview-modal: false;
    property <bool> preview-allow-dismiss: true;

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: BaseUiLayoutTokens.stack-gap-large;
            alignment: center;
            vertical-stretch: 1;

            Text {
                text: "Dismiss";
                color: BaseUiColors.fg-default;
                font-size: BaseUiLayoutTokens.text-body-size-large;
                font-weight: BaseUiLayoutTokens.font-weight-semibold;
            }

            Text {
                text: "Open the popup, then press Escape or click outside the panel. Toggle Modal for a dimmed scrim.";
                color: BaseUiColors.fg-muted;
                font-size: BaseUiLayoutTokens.text-body-size-medium;
                wrap: word-wrap;
            }

            open-anchor := Rectangle {
                width: 120px;
                height: 40px;
                background: BaseUiColors.bg-muted;
                border-radius: BaseUiLayoutTokens.border-radius-medium;
                border-width: 1px;
                border-color: BaseUiColors.border-default;

                Text {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    text: "Open popup";
                    color: BaseUiColors.fg-default;
                    font-size: BaseUiLayoutTokens.text-body-size-medium;
                }

                TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => {
                        demo-popup.show();
                    }
                }
            }

            demo-popup := BaseUiAnchoredPopup {
                position-props: {
                    absolute-position: open-anchor.absolute-position,
                    source-size: { width: open-anchor.width, height: open-anchor.height },
                };
                side: BaseUiAnchorSide.outside_bottom;
                align: BaseUiAnchorAlign.center;
                allow-dismiss: preview-allow-dismiss;
                show-backdrop: preview-modal;
                panel-width: 300px;
                panel-height: 140px;

                VerticalLayout {
                    spacing: 8px;

                    Text {
                        text: "Dismiss demo panel";
                        color: BaseUiColors.fg-default;
                        font-size: BaseUiLayoutTokens.text-body-size-medium;
                        font-weight: BaseUiLayoutTokens.font-weight-semibold;
                    }

                    close-btn := Rectangle {
                        width: 80px;
                        height: 32px;
                        background: BaseUiColors.bg-muted;
                        border-radius: BaseUiLayoutTokens.border-radius-medium;

                        Text {
                            x: 16px;
                            y: 8px;
                            text: "Close";
                            color: BaseUiColors.fg-default;
                            font-size: BaseUiLayoutTokens.text-body-size-small;
                        }

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => {
                                demo-popup.last-close-reason = BaseUiOpenChangeReasons.close-press;
                                demo-popup.close();
                            }
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 12px;

                Text {
                    text: "Options";
                    font-size: BaseUiLayoutTokens.text-body-size-medium;
                    font-weight: BaseUiLayoutTokens.font-weight-semibold;
                    color: BaseUiColors.fg-default;
                }

                CheckBox {
                    text: "Modal (dimmed backdrop)";
                    checked <=> preview-modal;
                    toggled => {
                        demo-popup.close();
                    }
                }

                CheckBox {
                    text: "Allow dismiss";
                    checked <=> preview-allow-dismiss;
                    toggled => {
                        demo-popup.close();
                    }
                }

                Rectangle {
                    height: 1px;
                    background: BaseUiColors.border-default;
                }

                Text {
                    text: "Last close reason";
                    font-size: BaseUiLayoutTokens.text-body-size-medium;
                    font-weight: BaseUiLayoutTokens.font-weight-semibold;
                    color: BaseUiColors.fg-default;
                }

                Text {
                    text: demo-popup.last-close-reason;
                    color: BaseUiColors.fg-default;
                    font-size: BaseUiLayoutTokens.text-body-size-small;
                    font-family: "monospace";
                }

                Text {
                    text: "Expect escape-key or outside-press after dismiss. close-press when using the panel Close button.";
                    color: BaseUiColors.fg-muted;
                    font-size: BaseUiLayoutTokens.text-body-size-small;
                    wrap: word-wrap;
                }
            }
        }
    }
}
