import { BaseUiGalleryColors } from "../tokens/base-ui-gallery-tokens.slint";

export component GalleryWelcomePage {
    vertical-stretch: 1;

    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        alignment: start;

        Text {
            text: "Base UI Slint port";
            color: BaseUiGalleryColors.fg-default;
            font-size: 20px;
            font-weight: 600;
        }

        Text {
            text: "Open Foundation → Design tokens for the neutral palette, or pick any component stub in the sidebar.";
            color: BaseUiGalleryColors.fg-muted;
            font-size: 14px;
            wrap: word-wrap;
        }

        Rectangle {
            height: 1px;
            width: 480px;
            background: BaseUiGalleryColors.border-default;
        }

        Text {
            text: "Run: pnpm dev:base-ui-gallery";
            color: BaseUiGalleryColors.fg-default;
            font-size: 13px;
            font-family: "monospace";
        }
    }
}
