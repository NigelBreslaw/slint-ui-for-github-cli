// Primer **ActionList.Divider** — block margins + hairline (not `showDividers` seam).

import { ActionListTokens, LayoutTokens } from "../tokens.slint";

export component ActionListItemDivider {
    in property <length> margin-inline: 0px;

    divider-shell := VerticalLayout {
        padding-left: root.margin-inline;
        padding-right: root.margin-inline;
        padding-top: LayoutTokens.action-list-item-divider-margin-block-start;
        padding-bottom: LayoutTokens.action-list-item-divider-margin-block-end;
        alignment: start;

        Rectangle {
            height: LayoutTokens.table-border-width;
            background: ActionListTokens.item-divider-borderColor;
        }
    }
}
