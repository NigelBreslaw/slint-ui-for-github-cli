// ActionList — vertical list of rows and item dividers (upstream: Primer ActionList).

import { ActionListCustomHeading } from "./action-list-custom-heading.slint";
import { ActionListItemDivider } from "./action-list-item-divider.slint";
import { ActionListListVisualHeading } from "./action-list-list-visual-heading.slint";
import { ActionListRow } from "./action-list-row.slint";
import { ActionListSectionHeading } from "./action-list-section-heading.slint";
import { ActionListLine, ActionListLineKind, ActionListSelectionMode } from "./types.slint";

export component ActionList {
    /// Lines top to bottom: rows, item dividers, list/custom visual headings, and subtle section headings.
    in property <[ActionListLine]> lines: [];
    /// Primer `ActionList` **`showDividers`**: draw a **seam** hairline (`borderColor-muted`) between consecutive **rows** only — not after the last row, and no block margins (unlike explicit [`item_divider`](ActionListLineKind.item_divider) / [`ActionListItemDivider`]).
    in property <bool> show-dividers: false;
    /// Primer `selectionVariant`: **`single`** uses **`selected-index`**; **`multiple`** uses **`multi-selected`** (index **`ix`** into **`lines`**; treat out-of-range / missing entries as unchecked).
    in property <ActionListSelectionMode> selection-mode: ActionListSelectionMode.none;
    in property <int> selected-index: -1;
    /// **`selection-mode`** **`multiple`**: row **`ix`** is checked when **`multi-selected[ix]`** is true. Ignored for **`single`** / **`none`**.
    in property <[bool]> multi-selected: [];
    /// Fired with index into `lines` when a non-disabled **row** is activated (not for dividers, **inactive**, or **`show-trailing-loading`** rows).
    callback item-activated(int);

    VerticalLayout {
        alignment: start;

        for line[ix] in root.lines: VerticalLayout {
            alignment: start;

            if line.kind == ActionListLineKind.row: ActionListRow {
                inactive-text: line.inactive-text;
                active: line.active;
                show-trailing-loading: line.show-trailing-loading;
                has-trailing-visual: line.has-trailing-visual;
                trailing-icon: line.trailing-icon;
                label-markdown: line.label-markdown;
                label: line.label;
                has-markdown: line.has-markdown;
                disabled: line.disabled;
                row-variant: line.row-variant;
                has-leading-avatar: line.has-leading-avatar;
                avatar-source: line.avatar-source;
                has-leading-visual: line.has-leading-visual;
                leading-icon: line.leading-icon;
                description: line.description;
                description-layout: line.description-layout;
                show-top-seam: root.show-dividers && ix > 0 && root.lines[ix - 1].kind == ActionListLineKind.row;
                selected: line.inactive-text == ""
                    && (
                        (root.selection-mode == ActionListSelectionMode.single && root.selected-index == ix)
                        || (
                            root.selection-mode == ActionListSelectionMode.multiple
                            && ix < root.multi-selected.length
                            && root.multi-selected[ix]
                        )
                    );
                show-single-select-check: root.selection-mode == ActionListSelectionMode.single;
                show-multi-select-checkbox: root.selection-mode == ActionListSelectionMode.multiple;
                clicked => {
                    if line.inactive-text == "" && !line.show-trailing-loading {
                        root.item-activated(ix);
                    }
                }
            }

            if line.kind == ActionListLineKind.item_divider: ActionListItemDivider {
                width: 100%;
            }

            if line.kind == ActionListLineKind.list_visual_heading: ActionListListVisualHeading {
                width: 100%;
                title: line.label;
            }

            if line.kind == ActionListLineKind.custom_heading: ActionListCustomHeading {
                width: 100%;
                title: line.label;
            }

            if line.kind == ActionListLineKind.section_heading: ActionListSectionHeading {
                width: 100%;
                title: line.label;
            }
        }
    }
}
