// Primer-style ActionList shell — upstream: https://primer.style/product/components/action-list/
// PR1: flat `[ActionListLine]` with `row` (default [`ActionListRow`]) and `divider` only.

import { ActionListRow } from "./action-list-row.slint";
import { LayoutTokens, PrimerColors } from "../tokens.slint";
import { ActionListLine, ActionListLineKind } from "./types.slint";

export component ActionList {
    /// Flat list: each entry is a [`ActionListRow`] or a horizontal divider.
    in property <[ActionListLine]> lines: [];
    /// Index into `lines` for the activated row; not fired for dividers or `disabled` rows.
    callback item-activated(int);

    min-width: 0px;
    width: 100%;

    VerticalLayout {
        spacing: 0px;
        width: 100%;
        alignment: start;

        for line[ix] in root.lines: VerticalLayout {
            width: 100%;
            spacing: 0px;
            alignment: start;

            if line.kind == ActionListLineKind.row: ActionListRow {
                width: 100%;
                label: line.label;
                selected: line.selected;
                disabled: line.disabled;
                clicked => {
                    if line.disabled {
                        return;
                    }
                    root.item-activated(ix);
                }
            }

            if line.kind == ActionListLineKind.divider: VerticalLayout {
                width: 100%;
                padding-top: 4px;
                padding-bottom: 4px;
                alignment: start;

                Rectangle {
                    width: 100%;
                    height: 1px;
                    background: PrimerColors.borderColor-default;
                }
            }
        }
    }
}
