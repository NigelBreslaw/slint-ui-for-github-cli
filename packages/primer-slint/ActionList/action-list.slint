// ActionList2 — list chrome (variant padding). Place **`ActionList2Row`**, dividers, or **`ActionList2Lines`** as **`@children`**.
// Width comes from the parent layout (`VerticalLayout` / overlay panel), not from `horizontal-stretch` on every child.

import { ActionList2Tokens } from "../tokens.slint";
import { ALVariant } from "./types.slint";

export component ActionList2 {
    in property <ALVariant> list-variant: ALVariant.inset;

    property <length> list-padding-top:
        root.list-variant == ALVariant.inset ? ActionList2Tokens.list-padding-block-inset : 0px;
    property <length> list-padding-bottom:
        root.list-variant == ALVariant.inset ? ActionList2Tokens.list-padding-block-inset
        : root.list-variant == ALVariant.horizontal_inset ? ActionList2Tokens.list-padding-block-horizontal-inset-end : 0px;

    list-body := VerticalLayout {
        alignment: start;
        padding-top: root.list-padding-top;
        padding-bottom: root.list-padding-bottom;

        @children
    }
}
