// ActionList — list chrome (variant padding). Place **`ActionListRow`**, dividers, or **`ActionListLines`** as **`@children`**.
// Width comes from the parent layout (`VerticalLayout` / overlay panel), not from `horizontal-stretch` on every child.

import { ActionListTokens } from "../tokens.slint";
import { ActionListVariant } from "./types.slint";

export component ActionList {
    in property <ActionListVariant> list-variant: ActionListVariant.inset;

    property <length> list-padding-top:
        root.list-variant == ActionListVariant.inset ? ActionListTokens.list-padding-block-inset : 0px;
    property <length> list-padding-bottom:
        root.list-variant == ActionListVariant.inset ? ActionListTokens.list-padding-block-inset
        : root.list-variant == ActionListVariant.horizontal_inset ? ActionListTokens.list-padding-block-horizontal-inset-end : 0px;

    list-body := VerticalLayout {
        alignment: start;
        padding-top: root.list-padding-top;
        padding-bottom: root.list-padding-bottom;

        @children
    }
}
