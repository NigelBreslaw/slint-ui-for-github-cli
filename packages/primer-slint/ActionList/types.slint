// ActionList models — upstream: https://primer.style/product/components/action-list/ (Item, Divider, Group, GroupHeading).

/// Visual variant for a [`ActionListLineKind.row`] line (default / danger / inactive / loading).
export enum ActionListRowVariant {
    default,
    danger,
    inactive,
    loading,
}

/// Block: description under title. Inline: description after title on one line (upstream inline description).
export enum ActionListDescriptionLayout {
    block,
    inline,
}

/// [`ActionListLineKind.section_heading`] style (Primer `GroupHeading` subtle vs filled).
export enum ActionListSectionHeadingVariant {
    subtle,
    filled,
}

/// Discriminator for each entry in [`ActionList`](action-list.slint).
export enum ActionListLineKind {
    row,
    /// Hairline between items (Primer item divider).
    divider,
    /// Full-width rule between sections (Primer section divider).
    section_divider,
    /// Non-interactive section title (Primer `GroupHeading`).
    section_heading,
}

/// One list line: interactive row, dividers, or section heading. Unused fields are ignored per `kind`.
export struct ActionListLine {
    kind: ActionListLineKind,
    label: string,
    description: string,
    description-layout: ActionListDescriptionLayout,
    trailing-text: string,
    has-leading-visual: bool,
    leading-icon: image,
    selected: bool,
    disabled: bool,
    row-variant: ActionListRowVariant,
    large: bool,
    section-heading-variant: ActionListSectionHeadingVariant,
}
