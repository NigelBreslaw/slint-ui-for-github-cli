// ActionList models — Primer ActionList (fresh port).

/// List container variant (`ActionList` **`variant`**).
export enum ActionListVariant {
  inset,
  horizontal_inset,
  full,
}

/// Row visual variant (default action vs danger).
export enum ActionListRowVariant {
  default,
  danger,
}

/// Primer **`ActionList.Item`** **`size`** — `medium` (default) or `large`.
export enum ActionListRowSize {
  medium,
  large,
}

/// Primary label vs optional **Description**.
export enum ActionListDescriptionLayout {
  none,
  inline,
  block,
}

/// Primer **`selectionVariant`**: none, single, or multiple.
export enum ActionListSelectionMode {
  none,
  single,
  multiple,
}

export enum ActionListListRole {
  none,
  menu,
  listbox,
}

/// **ActionList.GroupHeading** variant (`Group.module.css` **`data-variant`**).
export enum ActionListSectionHeadingVariant {
  subtle,
  filled,
}

/// Leading selection affordance — mutually exclusive per row (upstream `ActionList/Selection.tsx`).
/// Derive from **`selection-mode`** + **`list-role`** on **`ActionListLines`**, or set explicitly when composing rows.
export enum ActionListSelectionLead {
  /// No selection column.
  none,
  /// **`.SingleSelectCheckmark`** — `CheckIcon`; **`single`**, or **`multiple`** + **`menu`** (incl. Storybook **ListboxMultiSelect**).
  checkmark,
  /// **`.MultiSelectCheckbox`** — boxed control; **`multiple`** + **`listbox`** (true listbox, not menu).
  checkbox,
}

/// Line kind in [`ActionList`](action-list.slint).
export enum ActionListLineKind {
  row,
  item_divider,
  list_visual_heading,
  custom_heading,
  section_heading,
}

/// One list entry. Unused fields ignored per **`kind`**.
export struct ActionListLine {
  kind: ActionListLineKind,
  label: string,
  row-variant: ActionListRowVariant,
  row-size: ActionListRowSize,
  disabled: bool,
  has-leading-avatar: bool,
  avatar-source: image,
  has-leading-visual: bool,
  leading-icon: image,
  /// Secondary line when **`description-layout`** is **inline** or **block**.
  description: string,
  description-layout: ActionListDescriptionLayout,
  /// Inline description only — Primer **`Description truncate`** (`overflow: ellipsis`).
  truncate-inline-description: bool,
  trailing-text: string,
  /// Non-empty → Primer **`inactiveText`**: no activation; **`.InactiveWarning`** under the label.
  inactive-text: string,
  /// Primer **`loading`**: trailing spinner; row not activatable; muted label/description.
  show-trailing-loading: bool,
  /// Primer **`active`** / **`[data-active]`** — accent bar + surface (orthogonal to **`selected`**).
  active: bool,
  /// Used when **`kind`** is **`section_heading`** — subtle (default) or **filled** group title.
  section-heading-variant: ActionListSectionHeadingVariant,
}
