// ActionList row — Primer ActionList item (default | danger); ButtonTokens + ActionListTokens.

import { Avatar } from "../Avatar/avatar.slint";
import { Icons } from "../assets/icons.slint";
import { Spinner } from "../Progress/spinner.slint";
import {
    ActionListTokens,
    ButtonTokens,
    CheckboxTokens,
    LayoutTokens,
    PrimerColors,
    Size,
} from "../tokens.slint";
import {
    ActionListDescriptionLayout,
    ActionListRowVariant,
} from "./types.slint";

export component ActionListRow {
    in property <styled-text> label-markdown;
    in property <string> label;
    in property <bool> has-markdown: false;
    in property <bool> disabled: false;
    in property <ActionListRowVariant> row-variant: ActionListRowVariant.default;
    in property <bool> has-leading-avatar: false;
    in property <image> avatar-source: Icons.dot_fill;
    in property <bool> has-leading-visual: false;
    in property <image> leading-icon: Icons.dot_fill;
    /// Primer `ActionList` `showDividers`: hairline between consecutive rows (`borderColor-muted`), no block margins (unlike [`ActionListItemDivider`]).
    in property <bool> show-top-seam: false;
    in property <string> description: "";
    in property <ActionListDescriptionLayout> description-layout: ActionListDescriptionLayout.none;
    /// Primer **`active`** / **`[data-active]`** — left accent bar + surface (orthogonal to **`selected`** / listbox selection).
    in property <bool> active: false;
    /// Primer **`[data-active]`** / `selected` on **Item** (single listbox / `selectionVariant="single"`).
    in property <bool> selected: false;
    /// Primer **ActionList.Selection** + **CheckIcon** (`.SingleSelectCheckmark` in **ActionList.module.css**): tick only, not the multi-select checkbox; column width reserved when unselected.
    in property <bool> show-single-select-check: false;
    /// Primer **`.MultiSelectCheckbox`** lead cell (same token family as **ActionList** row, not **`Checkbox`** component).
    in property <bool> show-multi-select-checkbox: false;
    /// Primer **`inactiveText`** — non-empty marks **`data-inactive`**: no activation, muted label, **`.InactiveWarning`** copy (attention).
    in property <string> inactive-text: "";
    /// Primer **LoadingItem**: trailing **`Spinner`**; row is not activatable; label and description use **`item-loading-label-fgColor`**.
    in property <bool> show-trailing-loading: false;
    /// Trailing **icon** (e.g. chevron). Not shown when **`show-trailing-loading`**.
    in property <bool> has-trailing-visual: false;
    in property <image> trailing-icon: Icons.dot_fill;

    callback clicked;

    property <bool> is-inactive: root.inactive-text != "";
    property <bool> is-loading-row: root.show-trailing-loading;
    /// Primer **`[data-active]`** visuals (bar + surface + label override); not combined with **inactive** / **loading** / **disabled**.
    property <bool> show-active-chrome:
        root.active && !root.disabled && !root.is-inactive && !root.is-loading-row;

    property <length> cell-min-height: LayoutTokens.action-list-item-min-height;
    property <length> avatar-diameter: LayoutTokens.action-list-avatar-diameter;
    property <length> cell-padding-block: LayoutTokens.action-list-item-padding-block;

    property <color> label-color:
        root.is-loading-row
        ? ActionListTokens.item-loading-label-fgColor
        : root.disabled ? (root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-disabled : ButtonTokens.control-fgColor-disabled) 
        : root.is-inactive ? PrimerColors.fgColor-muted
        : root.show-active-chrome
        ? ActionListTokens.item-active-label-fgColor-rest
            : root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-rest
            : PrimerColors.fgColor-default;

    property <color> leading-icon-tint:
        root.disabled ? ButtonTokens.control-fgColor-disabled : root.is-inactive
        ? PrimerColors.fgColor-muted : root.row-variant == ActionListRowVariant.danger
        ? ActionListTokens.item-danger-fgColor-rest : PrimerColors.fgColor-muted;

    /// Trailing affordance stays **muted** (including danger rows — label carries danger color).
    property <color> trailing-icon-tint:
        root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-muted;

    property <color> single-select-check-tint:
        root.disabled ? ButtonTokens.control-fgColor-disabled : root.is-inactive ? PrimerColors.fgColor-muted : PrimerColors.fgColor-default;

    property <color> multi-select-lead-bg:
        root.disabled ? (root.selected ? CheckboxTokens.checkbox-bgColor-checked-disabled : CheckboxTokens.checkbox-bgColor-rest) : (root.selected ? CheckboxTokens.checkbox-bgColor-checked : CheckboxTokens.checkbox-bgColor-rest);
    property <color> multi-select-lead-border:
        root.disabled ? (root.selected ? CheckboxTokens.checkbox-borderColor-checked-disabled : CheckboxTokens.checkbox-borderColor-rest) : (root.selected ? CheckboxTokens.checkbox-borderColor-checked : CheckboxTokens.checkbox-borderColor-rest);

    property <bool> show-inline-description:
        root.description != "" && root.description-layout == ActionListDescriptionLayout.inline;

    property <bool> show-block-description:
        root.description != "" && root.description-layout == ActionListDescriptionLayout.block;

    property <color> inline-description-color:
        root.is-loading-row ? ActionListTokens.item-loading-label-fgColor : root.disabled ? ButtonTokens.control-fgColor-disabled : root.is-inactive ? ActionListTokens.item-inactive-description-fgColor : PrimerColors.fgColor-muted;

    /// Selected “chip” + semibold only when not using lead-only selection affordance (single check / multi checkbox).
    property <bool> use-selected-surface:
        root.selected && !root.show-single-select-check && !root.show-multi-select-checkbox;

    property <int> label-font-weight:
        root.is-loading-row ? LayoutTokens.base-text-weight-medium : !root.disabled && (root.use-selected-surface || root.show-active-chrome) ? LayoutTokens.base-text-weight-semibold : LayoutTokens.base-text-weight-medium;

    min-height: root.cell-min-height + (root.show-top-seam ? LayoutTokens.table-border-width : 0px);
    width: 100%;

    VerticalLayout {
        alignment: start;

        if root.show-top-seam: HorizontalLayout {
            padding-left: LayoutTokens.action-list-item-padding-inline;
            padding-right: LayoutTokens.action-list-item-padding-inline;
            spacing: LayoutTokens.button-content-gap;
            if root.show-single-select-check: Rectangle {
                horizontal-stretch: 0;
                min-height: LayoutTokens.iconButton-icon-size-medium;
                width: LayoutTokens.iconButton-icon-size-medium;
            }
            if root.show-multi-select-checkbox: Rectangle {
                horizontal-stretch: 0;
                min-height: LayoutTokens.iconButton-icon-size-medium;
                width: LayoutTokens.iconButton-icon-size-medium;
            }
            Rectangle {
                height: LayoutTokens.table-border-width;
                background: PrimerColors.borderColor-muted;
            }
        }

        row-chrome-shell := Rectangle {

            if root.show-active-chrome: Rectangle {
                x: -LayoutTokens.button-content-gap;
                y: LayoutTokens.base-size-4;
                width: LayoutTokens.base-size-4;
                height: parent.height - LayoutTokens.button-content-gap;
                background: ActionListTokens.item-active-indicator-bgColor;
                border-radius: LayoutTokens.borderRadius-medium;
            }

            ta := TouchArea {
                min-height: root.cell-min-height;
                enabled: !root.disabled && !root.is-inactive && !root.is-loading-row;
                clicked => {
                    root.clicked();
                }

                row-bg := Rectangle {
                    border-radius: LayoutTokens.borderRadius-medium;
                    background: transparent;

                    HorizontalLayout {
                        width: 100%;
                        align-items: center;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            padding-top: root.cell-padding-block;
                            padding-bottom: root.cell-padding-block;
                            spacing: 2px;
                            hl := HorizontalLayout {
                        // min-height: root.cell-min-height;
                        padding-left: LayoutTokens.action-list-item-padding-inline;
                                padding-right: LayoutTokens.action-list-item-padding-inline;
                                spacing: LayoutTokens.button-content-gap;
                                alignment: start;
                                align-items: center;

                                if root.show-single-select-check: HorizontalLayout {
                                    horizontal-stretch: 0;
                                    min-height: LayoutTokens.iconButton-icon-size-medium;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    alignment: center;
                                    if root.selected: Image {
                                        horizontal-stretch: 0;
                                        width: 16px;
                                        height: 16px;
                                        vertical-alignment: center;
                                        source: Icons.check;
                                        colorize: root.single-select-check-tint;
                                    }
                                }

                                if root.show-multi-select-checkbox: Rectangle {
                                    horizontal-stretch: 0;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: self.width;
                                    border-radius: LayoutTokens.checkbox-border-radius;
                                    border-width: 1px;
                                    border-color: root.multi-select-lead-border;
                                    background: root.multi-select-lead-bg;
                                    clip: true;

                                    if root.selected: Image {
                                        width: 12px;
                                        height: 12px;
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        source: Icons.check;
                                        colorize: root.disabled ? CheckboxTokens.checkbox-fgColor-checked-disabled : PrimerColors.fgOnEmphasis;
                                    }
                                }

                                if root.has-leading-avatar: Avatar {
                                    horizontal-stretch: 0;
                                    size: root.avatar-diameter;
                                    source: root.avatar-source;
                                }

                                if !root.has-leading-avatar && root.has-leading-visual: Image {
                                    horizontal-stretch: 0;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: LayoutTokens.iconButton-icon-size-medium;
                                    vertical-alignment: center;
                                    source: root.leading-icon;
                                    colorize: leading-icon-tint;
                                }

                                if root.show-inline-description: HorizontalLayout {
                                    horizontal-stretch: 1;
                                    spacing: LayoutTokens.button-content-gap;
                                    alignment: center;
                                    align-items: center;

                                    if !root.has-markdown: Text {
                                        horizontal-stretch: 1;
                                        text: root.label;
                                        color: root.label-color;
                                        font-size: LayoutTokens.text-body-size-medium;
                                        font-weight: root.label-font-weight;
                                        wrap: word-wrap;
                                        vertical-alignment: center;
                                    }

                                    if root.has-markdown: StyledText {
                                        horizontal-stretch: 1;
                                        text: root.label-markdown;
                                        default-color: root.label-color;
                                        default-font-size: LayoutTokens.text-body-size-medium;
                                        vertical-alignment: center;
                                    }

                                    if root.description != "": Text {
                                        horizontal-stretch: 0;
                                        text: root.description;
                                        color: root.inline-description-color;
                                        font-size: LayoutTokens.text-body-size-small;
                                        font-weight: LayoutTokens.base-text-weight-medium;
                                        wrap: word-wrap;
                                        vertical-alignment: center;
                                    }
                                }

                                if root.show-block-description: VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    alignment: center;

                                    if !root.has-markdown: Text {
                                        horizontal-stretch: 1;
                                        text: root.label;
                                        color: root.label-color;
                                        font-size: LayoutTokens.text-body-size-medium;
                                        font-weight: root.label-font-weight;
                                        wrap: word-wrap;
                                    }

                                    if root.has-markdown: StyledText {
                                        horizontal-stretch: 1;
                                        text: root.label-markdown;
                                        default-color: root.label-color;
                                        default-font-size: LayoutTokens.text-body-size-medium;
                                    }
                                }

                                if !root.show-inline-description && !root.show-block-description && !root.has-markdown: Text {
                                    horizontal-stretch: 1;
                                    text: root.label;
                                    color: root.label-color;
                                    font-size: LayoutTokens.text-body-size-medium;
                                    font-weight: root.label-font-weight;
                                    vertical-alignment: center;
                                }

                                if !root.show-inline-description && !root.show-block-description && root.has-markdown: StyledText {
                                    horizontal-stretch: 1;
                                    text: root.label-markdown;
                                    default-color: root.label-color;
                                    default-font-size: LayoutTokens.text-body-size-medium;
                                    vertical-alignment: center;
                                }
                            }

                            if root.show-block-description: HorizontalLayout {
                        // min-height: root.cell-min-height;
                        padding-left: LayoutTokens.action-list-item-padding-inline;
                                padding-right: LayoutTokens.action-list-item-padding-inline;
                        // padding-top: root.cell-padding-block;
                        // padding-bottom: root.cell-padding-block;
                        spacing: LayoutTokens.button-content-gap;
                                alignment: start;
                                align-items: center;
                                if root.show-single-select-check: HorizontalLayout {
                                    horizontal-stretch: 0;
                                    min-height: LayoutTokens.iconButton-icon-size-medium;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    alignment: center;
                                }
                                if root.show-multi-select-checkbox: Rectangle {
                                    horizontal-stretch: 0;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: LayoutTokens.iconButton-icon-size-medium;
                                }
                                if root.has-leading-avatar: Avatar {
                                    horizontal-stretch: 0;
                                    size: root.avatar-diameter;
                                    visible: false;
                                }

                                if !root.has-leading-avatar && root.has-leading-visual: Rectangle {
                                    horizontal-stretch: 0;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: LayoutTokens.iconButton-icon-size-medium;
                                }
                                Text {
                                    horizontal-stretch: 1;
                                    text: root.description;
                                    color: root.inline-description-color;
                                    font-size: LayoutTokens.text-body-size-small;
                                    font-weight: LayoutTokens.base-text-weight-medium;
                                    wrap: word-wrap;
                                }
                            }

                            if root.inactive-text != "": HorizontalLayout {
                                padding-left: LayoutTokens.action-list-item-padding-inline;
                                padding-right: LayoutTokens.action-list-item-padding-inline;
                                spacing: LayoutTokens.button-content-gap;
                                if root.show-single-select-check: Rectangle {
                                    horizontal-stretch: 0;
                                    min-height: LayoutTokens.iconButton-icon-size-medium;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                }
                                if root.show-multi-select-checkbox: Rectangle {
                                    horizontal-stretch: 0;
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: LayoutTokens.iconButton-icon-size-medium;
                                }
                                Text {
                                    text: root.inactive-text;
                                    color: PrimerColors.fgColor-attention;
                                    font-size: LayoutTokens.text-body-size-small;
                                    font-weight: LayoutTokens.base-text-weight-medium;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        if root.has-trailing-visual && !root.show-trailing-loading: HorizontalLayout {
                            horizontal-stretch: 0;
                            padding-right: LayoutTokens.action-list-item-padding-inline;
                            alignment: center;
                            Image {
                                width: LayoutTokens.iconButton-icon-size-medium;
                                height: LayoutTokens.iconButton-icon-size-medium;
                                vertical-alignment: center;
                                source: root.trailing-icon;
                                colorize: root.trailing-icon-tint;
                            }
                        }

                        if root.show-trailing-loading: HorizontalLayout {
                            horizontal-stretch: 0;
                            padding-right: LayoutTokens.action-list-item-padding-inline;
                            alignment: center;
                            Spinner {
                                size: Size.small;
                                segment-color: ActionListTokens.item-loading-label-fgColor;
                            }
                        }
                    }

                    states [
                        disabled when root.disabled: {
                            row-bg.background: root.use-selected-surface ? ButtonTokens.color-action-list-item-default-selected-bg : transparent;
                        }
                        inactive when !root.disabled && root.is-inactive: {
                            row-bg.background: transparent;
                        }
                        active-pressed when !root.disabled && root.show-active-chrome && ta.pressed: {
                            row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                        }
                        active-hover when !root.disabled && root.show-active-chrome && !ta.pressed && ta.has-hover: {
                            row-bg.background: ActionListTokens.item-active-bgColor-hover;
                        }
                        active-rest when !root.disabled && root.show-active-chrome && !ta.pressed && !ta.has-hover: {
                            row-bg.background: ActionListTokens.item-active-bgColor-rest;
                        }
                        danger-selected-pressed when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.use-selected-surface && ta.pressed: {
                            row-bg.background: ActionListTokens.item-danger-bgColor-active;
                        }
                        danger-selected-hover when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.use-selected-surface && !ta.pressed && ta.has-hover: {
                            row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                        }
                        danger-selected-rest when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.use-selected-surface && !ta.pressed && !ta.has-hover: {
                            row-bg.background: ActionListTokens.item-danger-bgColor-selected;
                        }
                        danger-pressed when !root.disabled && root.row-variant == ActionListRowVariant.danger && !root.use-selected-surface && ta.pressed: {
                            row-bg.background: ActionListTokens.item-danger-bgColor-active;
                        }
                        danger-hover when !root.disabled && root.row-variant == ActionListRowVariant.danger && !root.use-selected-surface && !ta.pressed && ta.has-hover: {
                            row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                        }
                        default-selected-pressed when !root.disabled && root.row-variant == ActionListRowVariant.default && root.use-selected-surface && ta.pressed: {
                            row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                        }
                        default-selected-hover when !root.disabled && root.row-variant == ActionListRowVariant.default && root.use-selected-surface && !ta.pressed && ta.has-hover: {
                            row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                        }
                        default-selected-rest when !root.disabled && root.row-variant == ActionListRowVariant.default && root.use-selected-surface && !ta.pressed && !ta.has-hover: {
                            row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                        }
                        default-pressed when !root.disabled && root.row-variant == ActionListRowVariant.default && (!root.selected || root.show-single-select-check || root.show-multi-select-checkbox) && ta.pressed: {
                            row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                        }
                        default-hover when !root.disabled && root.row-variant == ActionListRowVariant.default && (!root.selected || root.show-single-select-check || root.show-multi-select-checkbox) && !ta.pressed && ta.has-hover: {
                            row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                        }
                    ]
                }
            }
        }
    }
}
