// ActionList row — default + danger visuals; optional `showDividers` seam above.

import { Avatar } from "../Avatar/avatar.slint";
import { Icons } from "../assets/icons.slint";
import { Spinner } from "../Progress/spinner.slint";
import {
    ActionListTokens,
    ButtonTokens,
    CheckboxTokens,
    LayoutTokens,
    PrimerColors,
    Size,
} from "../tokens.slint";
import { ActionListTrailingAction } from "./action-list-trailing-action.slint";
import {
    ActionListDescriptionLayout,
    ActionListRowSize,
    ActionListRowVariant,
    ActionListSelectionLead,
} from "./types.slint";

export component ActionListRow {
    in property <string> label;
    in property <ActionListRowVariant> row-variant: ActionListRowVariant.default;
    in property <ActionListRowSize> row-size: ActionListRowSize.medium;
    in property <bool> disabled: false;
    in property <bool> has-leading-avatar: false;
    in property <image> avatar-source: Icons.dot_fill;
    in property <bool> has-leading-visual: false;
    in property <image> leading-icon: Icons.dot_fill;
    in property <string> description: "";
    in property <ActionListDescriptionLayout> description-layout: ActionListDescriptionLayout.none;
    in property <bool> truncate-inline-description: false;
    in property <string> trailing-text;
    in property <string> inactive-text: "";
    in property <bool> show-trailing-loading: false;
    in property <bool> active: false;
    in property <length> margin-inline;
    in property <bool> show-divider: false;
    in property <bool> selected: false;
    in property <ActionListSelectionLead> selection-lead: ActionListSelectionLead.none;
    in property <bool> roving-focused: false;
    in property <bool> has-trailing-action: false;
    in property <bool> trailing-action-has-icon: false;
    in property <image> trailing-action-icon: Icons.dot_fill;
    in property <string> trailing-action-label: "";
    in property <bool> trailing-action-loading: false;
    callback clicked;
    callback trailing-action-clicked();
    callback focus-claimed();

    property <bool> show-selection-checkmark: root.selection-lead == ActionListSelectionLead.checkmark;
    property <bool> show-selection-checkbox: root.selection-lead == ActionListSelectionLead.checkbox;

    changed roving-focused => {
        if root.roving-focused {
            row-fs.focus();
        }
    }

    property <bool> is-danger: root.row-variant == ActionListRowVariant.danger;
    property <bool> is-inactive: root.inactive-text != "";
    property <bool> is-loading-row: root.show-trailing-loading;
    property <bool> is-interactive: !root.disabled && !root.is-inactive && !root.is-loading-row;
    /// Accent bar + active surface; not combined with inactive / loading / disabled.
    property <bool> show-active-chrome:
        root.active && !root.disabled && !root.is-inactive && !root.is-loading-row;

    property <color> single-select-check-tint:
        root.disabled
        ? ButtonTokens.control-fgColor-disabled
        : root.is-inactive ? PrimerColors.fgColor-muted
        : PrimerColors.fgColor-default;

    property <color> multi-select-lead-bg:
        root.disabled
        ? (root.selected ? CheckboxTokens.checkbox-bgColor-checked-disabled : CheckboxTokens.checkbox-bgColor-rest)
        : (root.selected ? CheckboxTokens.checkbox-bgColor-checked : CheckboxTokens.checkbox-bgColor-rest);
    property <color> multi-select-lead-border:
        root.disabled
        ? (root.selected ? CheckboxTokens.checkbox-borderColor-checked-disabled : CheckboxTokens.checkbox-borderColor-rest)
        : (root.selected ? CheckboxTokens.checkbox-borderColor-checked : CheckboxTokens.checkbox-borderColor-rest);

    property <bool> use-selected-surface:
        root.selected && root.selection-lead == ActionListSelectionLead.none;

    property <int> label-font-weight:
        root.is-loading-row
        ? LayoutTokens.base-text-weight-medium
        : !root.disabled && (root.use-selected-surface || root.show-active-chrome)
        ? LayoutTokens.base-text-weight-semibold
        : LayoutTokens.base-text-weight-medium;

    property <color> label-color:
        root.is-loading-row
        ? ActionListTokens.item-loading-label-fgColor
        : root.disabled
        ? (root.is-danger ? ActionListTokens.item-danger-fgColor-disabled : ButtonTokens.control-fgColor-disabled)
        : root.is-inactive ? ActionListTokens.item-inactive-label-fgColor
        : root.show-active-chrome ? ActionListTokens.item-active-label-fgColor-rest
        : (root.is-danger ? ActionListTokens.item-danger-fgColor-rest : PrimerColors.fgColor-default);

    property <color> leading-icon-tint:
        root.disabled
        ? ButtonTokens.control-fgColor-disabled
        : root.is-inactive ? ActionListTokens.item-inactive-label-fgColor
        : (root.is-danger ? ActionListTokens.item-danger-fgColor-rest : PrimerColors.fgColor-muted);

    property <color> trailing-text-color:
        root.disabled
        ? ButtonTokens.control-fgColor-disabled
        : root.is-inactive ? ActionListTokens.item-inactive-trailing-fgColor
        : PrimerColors.fgColor-muted;

    property <bool> show-inline-description:
        root.description != "" && root.description-layout == ActionListDescriptionLayout.inline;

    property <bool> show-block-description:
        root.description != "" && root.description-layout == ActionListDescriptionLayout.block;

    property <color> description-color:
        root.is-loading-row
        ? ActionListTokens.item-loading-label-fgColor
        : root.disabled
        ? ButtonTokens.control-fgColor-disabled
        : root.is-inactive ? ActionListTokens.item-inactive-description-fgColor
        : ActionListTokens.item-description-fgColor;

    property <length> cell-padding-block:
        root.row-size == ActionListRowSize.large
        ? LayoutTokens.action-list-item-padding-block-large
        : LayoutTokens.action-list-item-padding-block;
    property <length> cell-min-height:
        root.row-size == ActionListRowSize.large
        ? LayoutTokens.action-list-item-min-height-large
        : LayoutTokens.action-list-item-min-height;
    property <length> avatar-diameter:
        root.row-size == ActionListRowSize.large
        ? LayoutTokens.action-list-avatar-diameter-large
        : LayoutTokens.action-list-avatar-diameter;

    min-height: root.cell-min-height + (root.show-divider ? LayoutTokens.table-border-width : 0px);

    if root.show-divider: HorizontalLayout {
        y: 0px;
        padding-left: root.margin-inline;
        padding-right: root.margin-inline;
        spacing: LayoutTokens.button-content-gap;
        height: 0px;

        if root.show-selection-checkmark: Rectangle {
            width: LayoutTokens.iconButton-icon-size-medium;
        }

        if root.show-selection-checkbox: Rectangle {
            width: LayoutTokens.iconButton-icon-size-medium;
        }

        Rectangle {
            width: LayoutTokens.action-list-item-padding-inline - root.margin-inline;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: LayoutTokens.table-border-width;
            background: ActionListTokens.item-seam-borderColor;
        }

        Rectangle {
            width: LayoutTokens.action-list-item-padding-inline - root.margin-inline;
        }
    }
    row-fs := FocusScope {
        enabled: !root.is-loading-row;
        focus-on-click: false;
        focus-on-tab-navigation: root.is-interactive;

        focus-gained => {
            root.focus-claimed();
        }

        key-pressed(event) => {
            if !root.is-interactive {
                return reject;
            }
            if event.text == Key.Return || event.text == Key.Space {
                root.clicked();
                return accept;
            }
            return reject;
        }

        row-shell := VerticalLayout {
            alignment: start;
            padding-left: root.margin-inline;
            padding-right: root.margin-inline;

            focus-chrome := Rectangle {
                border-width: (row-fs.has-focus || root.roving-focused) && !root.is-loading-row ? ActionListTokens.item-focus-ring-width : 0px;
                border-color: ActionListTokens.item-focus-ring-color;
                border-radius: LayoutTokens.borderRadius-medium;

                row-chrome-shell := HorizontalLayout {
                    alignment: stretch;
                    spacing: 0px;
                    min-height: root.cell-min-height;

                    main-cell := Rectangle {
                        horizontal-stretch: 1;
                        min-height: root.cell-min-height;

                        if root.show-active-chrome: Rectangle {
                            x: -LayoutTokens.button-content-gap;
                            y: LayoutTokens.base-size-4;
                            width: LayoutTokens.base-size-4;
                            height: parent.height - LayoutTokens.button-content-gap;
                            background: ActionListTokens.item-active-indicator-bgColor;
                            border-radius: LayoutTokens.borderRadius-medium;
                        }

                        ta := TouchArea {
                        enabled: root.is-interactive;
                        mouse-cursor: root.is-interactive ? pointer : default;
                        clicked => {
                            root.clicked();
                        }

                        if root.disabled: TouchArea {
                            enabled: true;
                            mouse-cursor: not-allowed;
                        }

                        row-bg := Rectangle {
                        border-radius: LayoutTokens.borderRadius-medium;

                        content-row := HorizontalLayout {
                            align-items: center;
                            padding-left: LayoutTokens.action-list-item-padding-inline;
                            padding-right: LayoutTokens.action-list-item-padding-inline;
                            padding-top: root.cell-padding-block;
                            padding-bottom: root.cell-padding-block;
                            spacing: LayoutTokens.button-content-gap;

                            primary-column := VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: root.show-block-description ? 2px : 0px;
                                alignment: start;

                                primary-line := HorizontalLayout {
                                    spacing: LayoutTokens.button-content-gap;
                                    alignment: start;
                                    align-items: center;

                                    if root.show-selection-checkmark: HorizontalLayout {
                                        horizontal-stretch: 0;
                                        min-height: LayoutTokens.iconButton-icon-size-medium;
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        alignment: center;

                                        if root.selected: Image {
                                            width: 16px;
                                            height: 16px;
                                            vertical-alignment: center;
                                            source: Icons.check;
                                            colorize: root.single-select-check-tint;
                                        }
                                    }

                                    if root.show-selection-checkbox: Rectangle {
                                        horizontal-stretch: 0;
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: self.width;
                                        border-radius: LayoutTokens.checkbox-border-radius;
                                        border-width: 1px;
                                        border-color: root.multi-select-lead-border;
                                        background: root.multi-select-lead-bg;
                                        clip: true;

                                        if root.selected: Image {
                                            width: 12px;
                                            height: 12px;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                            source: Icons.check;
                                            colorize:
                                                root.disabled
                                                ? CheckboxTokens.checkbox-fgColor-checked-disabled
                                                : PrimerColors.fgOnEmphasis;
                                        }
                                    }

                                    if root.has-leading-avatar: Avatar {
                                        horizontal-stretch: 0;
                                        size: root.avatar-diameter;
                                        source: root.avatar-source;
                                        alt-text: root.label;
                                    }

                                    if !root.has-leading-avatar && root.has-leading-visual: Image {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                        vertical-alignment: center;
                                        source: root.leading-icon;
                                        colorize: root.leading-icon-tint;
                                    }

                                    if root.show-inline-description && root.truncate-inline-description: HorizontalLayout {
                                        horizontal-stretch: 1;
                                        spacing: LayoutTokens.button-content-gap;
                                        alignment: center;
                                        align-items: center;

                                        Text {
                                            horizontal-stretch: 0;
                                            text: root.label;
                                            color: root.label-color;
                                            font-size: LayoutTokens.text-body-size-medium;
                                            font-weight: root.label-font-weight;
                                            overflow: elide;
                                            wrap: no-wrap;
                                            vertical-alignment: center;
                                        }

                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.description;
                                            color: root.description-color;
                                            font-size: LayoutTokens.text-body-size-small;
                                            font-weight: LayoutTokens.base-text-weight-medium;
                                            overflow: elide;
                                            wrap: no-wrap;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if root.show-inline-description && !root.truncate-inline-description: HorizontalLayout {
                                        horizontal-stretch: 1;
                                        spacing: LayoutTokens.button-content-gap;
                                        alignment: center;
                                        align-items: center;

                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.label;
                                            color: root.label-color;
                                            font-size: LayoutTokens.text-body-size-medium;
                                            font-weight: root.label-font-weight;
                                            wrap: word-wrap;
                                            vertical-alignment: center;
                                        }

                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.description;
                                            color: root.description-color;
                                            font-size: LayoutTokens.text-body-size-small;
                                            font-weight: LayoutTokens.base-text-weight-medium;
                                            wrap: word-wrap;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if root.show-block-description: VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        alignment: start;

                                        Text {
                                            text: root.label;
                                            color: root.label-color;
                                            font-size: LayoutTokens.text-body-size-medium;
                                            font-weight: root.label-font-weight;
                                            wrap: word-wrap;
                                        }
                                    }

                                    if !root.show-inline-description && !root.show-block-description: Text {
                                        horizontal-stretch: 1;
                                        text: root.label;
                                        color: root.label-color;
                                        font-size: LayoutTokens.text-body-size-medium;
                                        font-weight: root.label-font-weight;
                                        wrap: word-wrap;
                                        vertical-alignment: center;
                                    }
                                }

                                if root.show-block-description: HorizontalLayout {
                                    spacing: LayoutTokens.button-content-gap;
                                    alignment: start;
                                    align-items: center;

                                    if root.show-selection-checkmark: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    if root.show-selection-checkbox: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    if root.has-leading-avatar: Rectangle {
                                        width: root.avatar-diameter;
                                        height: root.avatar-diameter;
                                    }

                                    if !root.has-leading-avatar && root.has-leading-visual: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.description;
                                        color: root.description-color;
                                        font-size: LayoutTokens.text-body-size-small;
                                        font-weight: LayoutTokens.base-text-weight-medium;
                                        wrap: word-wrap;
                                    }
                                }

                                if root.inactive-text != "": HorizontalLayout {
                                    spacing: LayoutTokens.button-content-gap;
                                    alignment: start;
                                    align-items: center;

                                    if root.show-selection-checkmark: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    if root.show-selection-checkbox: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    if root.has-leading-avatar: Rectangle {
                                        width: root.avatar-diameter;
                                        height: root.avatar-diameter;
                                    }

                                    if !root.has-leading-avatar && root.has-leading-visual: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.inactive-text;
                                        color: PrimerColors.fgColor-attention;
                                        font-size: LayoutTokens.text-body-size-small;
                                        font-weight: LayoutTokens.base-text-weight-medium;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            if root.trailing-text != "" && !root.show-trailing-loading: Text {
                                text: root.trailing-text;
                                color: root.trailing-text-color;
                                font-size: LayoutTokens.text-body-size-medium;
                                font-weight: LayoutTokens.base-text-weight-medium;
                                vertical-alignment: center;
                            }

                            if root.show-trailing-loading: HorizontalLayout {
                                horizontal-stretch: 0;
                                alignment: center;
                                Spinner {
                                    size: Size.small;
                                    segment-color: ActionListTokens.item-loading-label-fgColor;
                                }
                            }
                        }

                        states [
                            disabled when root.disabled: {
                                row-bg.background:
                                    root.use-selected-surface
                                    ? ButtonTokens.color-action-list-item-default-selected-bg
                                    : transparent;
                            }
                            inactive when !root.disabled && root.is-inactive: {
                                row-bg.background: transparent;
                            }
                            loading when !root.disabled && root.is-loading-row: {
                                row-bg.background: transparent;
                            }
                            active-pressed when root.is-interactive && root.show-active-chrome && ta.pressed: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                            }
                            active-hover when root.is-interactive && root.show-active-chrome && !ta.pressed && ta.has-hover: {
                                row-bg.background: ActionListTokens.item-active-bgColor-hover;
                            }
                            active-rest when root.is-interactive && root.show-active-chrome && !ta.pressed && !ta.has-hover: {
                                row-bg.background: ActionListTokens.item-active-bgColor-rest;
                            }
                            danger-selected-pressed when root.is-interactive && root.is-danger && root.use-selected-surface && ta.pressed: {
                                row-bg.background: ActionListTokens.item-danger-bgColor-active;
                            }
                            danger-selected-hover when root.is-interactive && root.is-danger && root.use-selected-surface && !ta.pressed && ta.has-hover: {
                                row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                            }
                            danger-selected-rest when root.is-interactive && root.is-danger && root.use-selected-surface && !ta.pressed && !ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                            }
                            danger-pressed when root.is-interactive && root.is-danger && !root.use-selected-surface && ta.pressed: {
                                row-bg.background: ActionListTokens.item-danger-bgColor-active;
                            }
                            danger-hover when root.is-interactive && root.is-danger && !root.use-selected-surface && !ta.pressed && ta.has-hover: {
                                row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                            }
                            default-selected-pressed when root.is-interactive && !root.is-danger && root.use-selected-surface && ta.pressed: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                            }
                            default-selected-hover when root.is-interactive && !root.is-danger && root.use-selected-surface && !ta.pressed && ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                            }
                            default-selected-rest when root.is-interactive && !root.is-danger && root.use-selected-surface && !ta.pressed && !ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                            }
                            default-pressed when root.is-interactive && !root.is-danger && (!root.selected || root.selection-lead != ActionListSelectionLead.none) && ta.pressed: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                            }
                            default-hover when root.is-interactive && !root.is-danger && (!root.selected || root.selection-lead != ActionListSelectionLead.none) && !ta.pressed && ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                            }
                        ]
                    }
                    }
                    }

                    if root.has-trailing-action: ActionListTrailingAction {
                        label: root.trailing-action-label;
                        has-icon: root.trailing-action-has-icon;
                        icon: root.trailing-action-icon;
                        loading: root.trailing-action-loading;
                        disabled: root.disabled;
                        clicked => {
                            root.trailing-action-clicked();
                        }
                    }
                }
            }
        }
    }
}
