// Shared ActionList row chrome — upstream: Primer ActionList default item (ButtonTokens action-list hover/active/selected).
// PR3: danger / inactive / loading, block vs inline description, large density. Interaction via `states`
// (see .cursor/skills/primer-slint-interaction-states/SKILL.md).

import { Icons } from "../assets/icons.slint";
import { Spinner } from "../Progress/spinner.slint";
import {
    ActionListDescriptionLayout,
    ActionListRowVariant,
} from "./types.slint";
import {
    ActionListTokens,
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
    Size,
} from "../tokens.slint";

export component ActionListRow {
    /// Lets this row shrink inside flex parents so labels stay visible (Slint flex default min-width).
    min-width: 0px;
    in property <bool> disabled: false;
    in property <bool> selected: false;
    in property <string> label: "";
    /// Optional leading icon (16px); omit with `has-leading-visual: false` (ignored when `row-variant` is **loading** — spinner leads).
    in property <bool> has-leading-visual: false;
    in property <image> leading-icon: Icons.dot_fill;
    in property <string> description: "";
    in property <ActionListDescriptionLayout> description-layout: ActionListDescriptionLayout.block;
    in property <string> trailing-text: "";
    in property <ActionListRowVariant> row-variant: ActionListRowVariant.default;
    in property <bool> large: false;
    /// Primer sidebar NavList selection: muted surface + semibold label; NavList draws the blue accent bar beside the row.
    in property <bool> sidebar-selection-style: false;

    callback clicked;

    private property <length> cell-min-height:
        root.large ? LayoutTokens.action-list-item-min-height-large : LayoutTokens.action-list-item-min-height;
    private property <length> cell-padding-block:
        root.large ? LayoutTokens.action-list-item-padding-block-large : LayoutTokens.action-list-item-padding-block;
    private property <bool> is-interactive:
        !root.disabled && root.row-variant != ActionListRowVariant.inactive && root.row-variant != ActionListRowVariant.loading;
    private property <bool> show-inline-desc:
        root.description != "" && root.description-layout == ActionListDescriptionLayout.inline;

    min-height: root.cell-min-height;
    width: 100%;

    private property <color> leading-icon-tint:
        root.disabled ? ButtonTokens.control-fgColor-disabled : root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-rest : root.row-variant == ActionListRowVariant.inactive ? ActionListTokens.item-inactive-label-fgColor : root.row-variant == ActionListRowVariant.loading ? ActionListTokens.item-loading-label-fgColor : root.selected ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;

    ta := TouchArea {
        width: 100%;
        min-height: root.cell-min-height;
        enabled: root.is-interactive;
        clicked => {
            root.clicked();
        }

        row-bg := Rectangle {
            border-radius: LayoutTokens.borderRadius-medium;
            background: #00000000;

            hl := HorizontalLayout {
                min-height: root.cell-min-height;
                padding-left: LayoutTokens.action-list-item-padding-inline;
                padding-right: LayoutTokens.action-list-item-padding-block;
                padding-top: root.cell-padding-block;
                padding-bottom: root.cell-padding-block;
                spacing: LayoutTokens.button-content-gap;
                alignment: start;

                if root.row-variant == ActionListRowVariant.loading: Spinner {
                    horizontal-stretch: 0;
                    size: Size.small;
                    segment-color: ActionListTokens.item-loading-label-fgColor;
                }

                if root.row-variant != ActionListRowVariant.loading && root.has-leading-visual: Image {
                    width: LayoutTokens.iconButton-icon-size-medium;
                    height: LayoutTokens.iconButton-icon-size-medium;
                    vertical-alignment: top;
                    source: root.leading-icon;
                    colorize: leading-icon-tint;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    min-width: 0px;
                    spacing: 0px;

                    if root.show-inline-desc: HorizontalLayout {
                        spacing: 8px;
                        alignment: center;
                        horizontal-stretch: 1;
                        min-width: 0px;

                        if root.label != "": primary-inline := Text {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            text: root.label;
                            color: root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-rest : root.row-variant == ActionListRowVariant.inactive ? ActionListTokens.item-inactive-label-fgColor : root.row-variant == ActionListRowVariant.loading ? ActionListTokens.item-loading-label-fgColor : PrimerColors.fgColor-default;
                            font-size: LayoutTokens.text-body-size-medium;
                            font-weight: root.disabled ? LayoutTokens.base-text-weight-medium : root.sidebar-selection-style ? (root.selected ? LayoutTokens.base-text-weight-semibold : LayoutTokens.base-text-weight-medium) : LayoutTokens.base-text-weight-medium;
                            wrap: word-wrap;
                            states [
                                disabled when root.disabled: {
                                    primary-inline.color: root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-disabled : ButtonTokens.control-fgColor-disabled;
                                }
                                inactive when root.row-variant == ActionListRowVariant.inactive: {
                                    primary-inline.color: ActionListTokens.item-inactive-label-fgColor;
                                }
                                loading when root.row-variant == ActionListRowVariant.loading: {
                                    primary-inline.color: ActionListTokens.item-loading-label-fgColor;
                                }
                            ]
                        }

                        if root.description != "": desc-inline := Text {
                            horizontal-stretch: 0;
                            text: root.description;
                            color: root.row-variant == ActionListRowVariant.inactive ? ActionListTokens.item-inactive-description-fgColor : PrimerColors.fgColor-muted;
                            font-size: LayoutTokens.text-body-size-small;
                            font-weight: LayoutTokens.base-text-weight-medium;
                            wrap: word-wrap;
                            states [
                                disabled when root.disabled: {
                                    desc-inline.color: ButtonTokens.control-fgColor-disabled;
                                }
                                inactive when root.row-variant == ActionListRowVariant.inactive: {
                                    desc-inline.color: ActionListTokens.item-inactive-description-fgColor;
                                }
                                loading when root.row-variant == ActionListRowVariant.loading: {
                                    desc-inline.color: ActionListTokens.item-loading-label-fgColor;
                                }
                            ]
                        }
                    }

                    if !root.show-inline-desc: VerticalLayout {
                        horizontal-stretch: 1;
                        min-width: 0px;
                        spacing: 2px;

                        if root.label != "": primary-label := Text {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            text: root.label;
                            color: root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-rest : root.row-variant == ActionListRowVariant.inactive ? ActionListTokens.item-inactive-label-fgColor : root.row-variant == ActionListRowVariant.loading ? ActionListTokens.item-loading-label-fgColor : PrimerColors.fgColor-default;
                            font-size: LayoutTokens.text-body-size-medium;
                            font-weight: root.disabled ? LayoutTokens.base-text-weight-medium : root.sidebar-selection-style ? (root.selected ? LayoutTokens.base-text-weight-semibold : LayoutTokens.base-text-weight-medium) : LayoutTokens.base-text-weight-medium;
                            wrap: word-wrap;
                            states [
                                disabled when root.disabled: {
                                    primary-label.color: root.row-variant == ActionListRowVariant.danger ? ActionListTokens.item-danger-fgColor-disabled : ButtonTokens.control-fgColor-disabled;
                                }
                                inactive when root.row-variant == ActionListRowVariant.inactive: {
                                    primary-label.color: ActionListTokens.item-inactive-label-fgColor;
                                }
                                loading when root.row-variant == ActionListRowVariant.loading: {
                                    primary-label.color: ActionListTokens.item-loading-label-fgColor;
                                }
                            ]
                        }

                        if root.description != "": desc-label := Text {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            text: root.description;
                            color: root.row-variant == ActionListRowVariant.inactive ? ActionListTokens.item-inactive-description-fgColor : PrimerColors.fgColor-muted;
                            font-size: LayoutTokens.text-body-size-small;
                            font-weight: LayoutTokens.base-text-weight-medium;
                            wrap: word-wrap;

                            states [
                                disabled when root.disabled: {
                                    desc-label.color: ButtonTokens.control-fgColor-disabled;
                                }
                                inactive when root.row-variant == ActionListRowVariant.inactive: {
                                    desc-label.color: ActionListTokens.item-inactive-description-fgColor;
                                }
                                loading when root.row-variant == ActionListRowVariant.loading: {
                                    desc-label.color: ActionListTokens.item-loading-label-fgColor;
                                }
                            ]
                        }
                    }
                }

                trailing-t := Text {
                    visible: root.trailing-text != "";
                    vertical-alignment: top;
                    text: root.trailing-text;
                    color: root.row-variant == ActionListRowVariant.inactive ? ActionListTokens.item-inactive-trailing-fgColor : PrimerColors.fgColor-muted;
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                }
            }

            states [
                disabled when root.disabled: {
                    row-bg.background: root.selected ? ButtonTokens.color-action-list-item-default-selected-bg : #00000000;
                    trailing-t.color: ButtonTokens.control-fgColor-disabled;
                }
                inactive when root.row-variant == ActionListRowVariant.inactive: {
                    row-bg.background: ActionListTokens.item-inactive-bgColor-hover;
                    trailing-t.color: ActionListTokens.item-inactive-trailing-fgColor;
                }
                loading when root.row-variant == ActionListRowVariant.loading: {
                    row-bg.background: #00000000;
                    trailing-t.color: ActionListTokens.item-loading-label-fgColor;
                }
                danger-selected-pressed when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.selected && !root.sidebar-selection-style && ta.pressed: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-active;
                }
                danger-selected-pressed-sidebar when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.selected && root.sidebar-selection-style && ta.pressed: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-active;
                }
                danger-selected-hover when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.selected && !root.sidebar-selection-style && !ta.pressed && ta.has-hover: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                }
                danger-selected-hover-sidebar when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.selected && root.sidebar-selection-style && !ta.pressed && ta.has-hover: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                }
                danger-selected-rest when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.selected && !root.sidebar-selection-style && !ta.pressed && !ta.has-hover: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-selected;
                }
                danger-selected-rest-sidebar when !root.disabled && root.row-variant == ActionListRowVariant.danger && root.selected && root.sidebar-selection-style && !ta.pressed && !ta.has-hover: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-selected;
                }
                danger-unselected-pressed when !root.disabled && root.row-variant == ActionListRowVariant.danger && !root.selected && ta.pressed: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-active;
                }
                danger-unselected-hover when !root.disabled && root.row-variant == ActionListRowVariant.danger && !root.selected && !ta.pressed && ta.has-hover: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                }
                selected-pressed when !root.disabled && root.row-variant == ActionListRowVariant.default && root.selected && !root.sidebar-selection-style && ta.pressed: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                }
                selected-pressed-sidebar when !root.disabled && root.row-variant == ActionListRowVariant.default && root.selected && root.sidebar-selection-style && ta.pressed: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                }
                selected-hover when !root.disabled && root.row-variant == ActionListRowVariant.default && root.selected && !root.sidebar-selection-style && !ta.pressed && ta.has-hover: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                }
                selected-hover-sidebar when !root.disabled && root.row-variant == ActionListRowVariant.default && root.selected && root.sidebar-selection-style && !ta.pressed && ta.has-hover: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                }
                selected-rest when !root.disabled && root.row-variant == ActionListRowVariant.default && root.selected && !root.sidebar-selection-style && !ta.pressed && !ta.has-hover: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                }
                selected-rest-sidebar when !root.disabled && root.row-variant == ActionListRowVariant.default && root.selected && root.sidebar-selection-style && !ta.pressed && !ta.has-hover: {
                    row-bg.background: PrimerColors.bgColor-neutral-muted;
                }
                unselected-pressed when !root.disabled && root.row-variant == ActionListRowVariant.default && !root.selected && ta.pressed: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                }
                unselected-hover when !root.disabled && root.row-variant == ActionListRowVariant.default && !root.selected && !ta.pressed && ta.has-hover: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                }
            ]
        }
    }
}
