// Model-driven **`ActionList`** body — maps **`ActionListLine`** arrays to row/divider instances.
// Prefer composing **`ActionListRow`** directly when static; use this for TS **`ArrayModel`** / menu data.

import { ActionListCustomHeading } from "./action-list-custom-heading.slint";
import { ActionListItemDivider } from "./action-list-item-divider.slint";
import { ActionListListVisualHeading } from "./action-list-list-visual-heading.slint";
import { ActionListRow } from "./action-list-row.slint";
import { ActionListSectionHeading } from "./action-list-section-heading.slint";
import { ActionListFocusLogic } from "./action-list-focus-logic.slint";
import { ActionListTokens } from "../tokens.slint";
import {
    ActionListLine,
    ActionListLineKind,
    ActionListListRole,
    ActionListVariant,
    ActionListSelectionLead,
    ActionListSelectionMode,
} from "./types.slint";

export component ActionListLines {
    in property <[ActionListLine]> lines: [];
    in property <ActionListVariant> list-variant: ActionListVariant.inset;
    /// Primer **`showDividers`**: muted seam between consecutive **rows** (not after the last row).
    in property <bool> show-dividers: false;
    in property <ActionListListRole> list-role: ActionListListRole.none;
    in property <bool> disable-focus-zone: false;
    in property <ActionListSelectionMode> selection-mode: ActionListSelectionMode.none;
    in property <int> selected-index: -1;
    in property <[bool]> multi-selected: [];
    in-out property <int> focused-index: -1;
    callback item-activated(int);

    property <length> item-margin-inline:
        root.list-variant == ActionListVariant.full ? 0px : ActionListTokens.item-margin-inline-inset;

    property <ActionListSelectionLead> row-selection-lead:
        root.selection-mode == ActionListSelectionMode.none ? ActionListSelectionLead.none
        : root.selection-mode == ActionListSelectionMode.single ? ActionListSelectionLead.checkmark
        : root.list-role == ActionListListRole.menu ? ActionListSelectionLead.checkmark
        : ActionListSelectionLead.checkbox;

    property <bool> focus-zone-enabled:
        !root.disable-focus-zone
        && (root.list-role == ActionListListRole.menu || root.list-role == ActionListListRole.listbox);

    property <bool> focus-wrap: root.list-role == ActionListListRole.menu;

    function focus-first-row() {
        root.focused-index = ActionListFocusLogic.first-row(root.lines);
    }

    function focus-last-row() {
        root.focused-index = ActionListFocusLogic.last-row(root.lines);
    }

    function step-focus(delta: int) {
        if root.lines.length == 0 {
            return;
        }
        if root.focused-index < 0 {
            if delta >= 0 {
                root.focus-first-row();
            } else {
                root.focus-last-row();
            }
            return;
        }
        if ActionListFocusLogic.step-from(root.lines, root.focused-index, delta, root.focus-wrap) >= 0 {
            root.focused-index = ActionListFocusLogic.step-from(
                root.lines,
                root.focused-index,
                delta,
                root.focus-wrap,
            );
        }
    }

    horizontal-stretch: 1;

    list-fs := FocusScope {
        horizontal-stretch: 1;
        focus-on-click: false;
        focus-on-tab-navigation: root.focus-zone-enabled;

        key-pressed(event) => {
            if !root.focus-zone-enabled {
                return reject;
            }
            if event.text == Key.DownArrow {
                root.step-focus(1);
                return accept;
            }
            if event.text == Key.UpArrow {
                root.step-focus(-1);
                return accept;
            }
            if event.text == Key.Home {
                root.focus-first-row();
                return accept;
            }
            if event.text == Key.End {
                root.focus-last-row();
                return accept;
            }
            if event.text == Key.Return || event.text == Key.Space {
                if root.focused-index >= 0 && ActionListFocusLogic.line-is-row(root.lines, root.focused-index) {
                    if !root.lines[root.focused-index].disabled
                        && root.lines[root.focused-index].inactive-text == ""
                        && !root.lines[root.focused-index].show-trailing-loading {
                        root.item-activated(root.focused-index);
                    }
                    return accept;
                }
            }
            return reject;
        }

        lines-body := VerticalLayout {
            alignment: start;

            for line[ix] in root.lines: VerticalLayout {
                alignment: start;

                if line.kind == ActionListLineKind.row: ActionListRow {
                    label: line.label;
                    row-variant: line.row-variant;
                    row-size: line.row-size;
                    disabled: line.disabled;
                    has-leading-avatar: line.has-leading-avatar;
                    avatar-source: line.avatar-source;
                    has-leading-visual: line.has-leading-visual;
                    leading-icon: line.leading-icon;
                    description: line.description;
                    description-layout: line.description-layout;
                    truncate-inline-description: line.truncate-inline-description;
                    trailing-text: line.trailing-text;
                    inactive-text: line.inactive-text;
                    show-trailing-loading: line.show-trailing-loading;
                    active: line.active;
                    margin-inline: root.item-margin-inline;
                    show-divider:
                        root.show-dividers && ix > 0 && root.lines[ix - 1].kind == ActionListLineKind.row;
                    selected:
                        (root.selection-mode == ActionListSelectionMode.single && root.selected-index == ix)
                        || (
                            root.selection-mode == ActionListSelectionMode.multiple
                            && ix < root.multi-selected.length
                            && root.multi-selected[ix]
                        );
                    selection-lead: root.row-selection-lead;
                    roving-focused: root.focus-zone-enabled && root.focused-index == ix;
                    focus-claimed => {
                        root.focused-index = ix;
                    }
                    clicked => {
                        if !line.disabled && line.inactive-text == "" && !line.show-trailing-loading {
                            root.item-activated(ix);
                        }
                    }
                }

                if line.kind == ActionListLineKind.item_divider: ActionListItemDivider {
                    margin-inline: root.item-margin-inline;
                }

                if line.kind == ActionListLineKind.list_visual_heading: ActionListListVisualHeading {
                    title: line.label;
                    margin-inline: root.item-margin-inline;
                }

                if line.kind == ActionListLineKind.custom_heading: ActionListCustomHeading {
                    title: line.label;
                    margin-inline: root.item-margin-inline;
                }

                if line.kind == ActionListLineKind.section_heading: ActionListSectionHeading {
                    title: line.label;
                    variant: line.section-heading-variant;
                    margin-inline: root.item-margin-inline;
                }
            }
        }
    }
}
