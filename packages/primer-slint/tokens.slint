// primer-tokens **`control.borderColor.emphasis`** (unchecked native input chrome), **`control.bgColor/borderColor.disabled`**, **`control.checked.*`** with **radio** role swap (inner fill = **`fgColor`**, ring = **`bgColor`** per **`Radio.module.css`**). Composes **`PrimerColors`**, **`CheckboxTokens`**, **`ButtonTokens`** only.
//
// Token audit: | Intent | primer-tokens / upstream | Owner | `out` | Consumers |
// |--------|---------------------------|-------|-------|-----------|
// | Unchecked fill | **`bgColor.default`** / shared **`.Input`** | RadioTokens | **`radio-bgColor-rest`** | **`Radio`** |
// | Unchecked border | **`control.borderColor.emphasis`** → **`borderColor.emphasis`** | RadioTokens | **`radio-borderColor-rest`** | **`Radio`** |
// | Unchecked disabled fill/border | **`control.bgColor.disabled`**, **`control.borderColor.disabled`** | RadioTokens | **`radio-bgColor-disabled`**, **`radio-borderColor-disabled`** | **`Radio`** |
// | Checked inner disk | **`control.checked.fgColor.rest`** | RadioTokens | **`radio-checked-dot-fgColor-rest`** | **`Radio`** |
// | Checked outer ring | **`control.checked.bgColor.rest`** | RadioTokens | **`radio-checked-ring-bgColor-rest`** | **`Radio`** |
// | Checked dot disabled | **`control.checked.fgColor.disabled`** | RadioTokens | **`radio-checked-dot-fgColor-disabled`** | **`Radio`** |
// | Checked ring disabled | **`control.checked.bgColor.disabled`** | RadioTokens | **`radio-checked-ring-bgColor-disabled`** | **`Radio`** |
export global RadioTokens {
    property <ColorScheme> color-scheme: Palette.color-scheme;

    /// **`control.borderColor.emphasis`** — light **`neutral.8`** aligns with **`fgColor.subtle`**; dark **`neutral.8`** aligns with **`bgColor.neutral.emphasis`** (same hex as semantic neutral emphasis in dark).
    out property <color> radio-borderColor-rest: color-scheme == ColorScheme.dark ? PrimerColors.bgColor-neutral-emphasis : PrimerColors.fgColor-subtle;

    out property <color> radio-bgColor-rest: PrimerColors.bgColor-default;

    out property <color> radio-bgColor-disabled: ButtonTokens.button-default-bgColor-disabled;
    out property <color> radio-borderColor-disabled: ButtonTokens.button-default-borderColor-disabled;

    out property <color> radio-checked-dot-fgColor-rest: PrimerColors.fgOnEmphasis;
    out property <color> radio-checked-ring-bgColor-rest: PrimerColors.bgColor-accent-emphasis;

    out property <color> radio-checked-dot-fgColor-disabled: CheckboxTokens.checkbox-fgColor-checked-disabled;
    out property <color> radio-checked-ring-bgColor-disabled: CheckboxTokens.checkbox-bgColor-checked-disabled;
}

// primer-tokens `functional/color/control.json5` — **`controlTrack`**, **`control.checked`**, **`controlKnob`**. React: **`ToggleSwitch.module.css`**. Composes **`PrimerColors`**, **`CheckboxTokens`**, **`ButtonTokens`**.
//
// Token audit: | Intent | primer-tokens / upstream | Owner | `out` | Consumers |
// |--------|---------------------------|-------|-------|-----------|
// | Track bg unchecked rest | **`controlTrack.bgColor.rest`** | ToggleSwitchTokens | **`track-bgColor-rest`** | **`ToggleSwitch`** |
// | Track bg unchecked hover | **`controlTrack.bgColor.hover`** | ToggleSwitchTokens | **`track-bgColor-hover`** | PR4+ |
// | Track bg unchecked active | **`controlTrack.bgColor.active`** | ToggleSwitchTokens | **`track-bgColor-active`** | PR4+ |
// | Track bg disabled | **`controlTrack.bgColor.disabled`** | ToggleSwitchTokens | **`track-bgColor-disabled`** | **`ToggleSwitch`** |
// | Track border rest | **`controlTrack.borderColor.rest`** | ToggleSwitchTokens | **`track-borderColor-rest`** | **`ToggleSwitch`** |
// | Track border checked | **`control.checked.borderColor.rest`** | ToggleSwitchTokens | **`track-borderColor-checked`** | **`ToggleSwitch`** |
// | Checked track rest/hover/active | **`control.checked.bgColor.*`** | ToggleSwitchTokens | **`track-bgColor-checked-*`** | **`ToggleSwitch`** / PR4 |
// | Line icon fg | **`control.checked.fgColor.rest/disabled`** | ToggleSwitchTokens | **`line-icon-fgColor-*`** | **`ToggleSwitch`** |
// | Circle icon fg | **`controlTrack.fgColor.rest/disabled`** | ToggleSwitchTokens | **`circle-icon-fgColor-*`** | **`ToggleSwitch`** |
// | Knob fill/border | **`controlKnob.bgColor/borderColor.*`** | ToggleSwitchTokens | **`knob-*`** | **`ToggleSwitch`** |
export global ToggleSwitchTokens {
    property <ColorScheme> color-scheme: Palette.color-scheme;

    // `controlTrack.bgColor.*` → `base.color.neutral.*` (light/dark.json5 hex)
    property <color> track-bg-rest-light: #e6eaef;
    property <color> track-bg-rest-dark: #010409;
    out property <color> track-bgColor-rest: color-scheme == ColorScheme.dark ? track-bg-rest-dark : track-bg-rest-light;

    property <color> track-bg-hover-light: #e0e6eb;
    property <color> track-bg-hover-dark: #2a313c;
    out property <color> track-bgColor-hover: color-scheme == ColorScheme.dark ? track-bg-hover-dark : track-bg-hover-light;

    property <color> track-bg-active-light: #dae0e7;
    property <color> track-bg-active-dark: #2f3742;
    out property <color> track-bgColor-active: color-scheme == ColorScheme.dark ? track-bg-active-dark : track-bg-active-light;

    out property <color> track-bgColor-disabled: CheckboxTokens.checkbox-bgColor-checked-disabled;

    out property <color> track-borderColor-rest: PrimerColors.borderColor-default;
    out property <color> track-borderColor-checked: transparent;
    out property <color> track-borderColor-disabled: transparent;

    out property <color> track-bgColor-checked-rest: PrimerColors.bgColor-accent-emphasis;
    out property <color> track-bgColor-checked-hover: CheckboxTokens.checkbox-bgColor-checked-hover;
    out property <color> track-bgColor-checked-active: CheckboxTokens.checkbox-bgColor-checked-active;

    out property <color> line-icon-fgColor-rest: PrimerColors.fgOnEmphasis;
    out property <color> line-icon-fgColor-disabled: CheckboxTokens.checkbox-fgColor-checked-disabled;

    out property <color> circle-icon-fgColor-rest: PrimerColors.fgColor-muted;
    out property <color> circle-icon-fgColor-disabled: PrimerColors.fgOnEmphasis;

    property <color> knob-bg-rest-light: #ffffff;
    property <color> knob-bg-rest-dark: #343b43;
    out property <color> knob-bgColor-rest: color-scheme == ColorScheme.dark ? knob-bg-rest-dark : knob-bg-rest-light;

    out property <color> knob-bgColor-disabled: ButtonTokens.button-default-bgColor-disabled;

    property <color> knob-border-rest-light: #858f99;
    property <color> knob-border-rest-dark: #656d76;
    out property <color> knob-borderColor-rest: color-scheme == ColorScheme.dark ? knob-border-rest-dark : knob-border-rest-light;

    out property <color> knob-borderColor-checked: PrimerColors.borderColor-accent-emphasis;
    out property <color> knob-borderColor-disabled: CheckboxTokens.checkbox-bgColor-checked-disabled;
}

export global TextInputTokens {
    out property <color> borderColor-rest: PrimerColors.borderColor-default;
    out property <color> borderColor-focus: PrimerColors.fgColor-link;
    out property <color> borderColor-error: PrimerColors.borderColor-danger-emphasis;
    out property <color> borderColor-success: PrimerColors.borderColor-success-emphasis;
    out property <color> bg-rest: PrimerColors.bgColor-default;
    /// `data-contrast` field fill — upstream `--control-bgColor-contrast` / `--bgColor-inset`.
    out property <color> bg-contrast: PrimerColors.bgColor-inset;
    out property <color> bg-hover: PrimerColors.bgColor-canvas-subtle;
    out property <color> bg-disabled: ButtonTokens.button-default-bgColor-disabled;
    out property <color> border-disabled: ButtonTokens.button-default-borderColor-disabled;
}

export global OverlayTokens {
    out property <color> backdrop-scrim: PrimerColors.overlay-scrim;
    out property <color> panel-background: PrimerColors.bgColor-default;
    out property <color> panel-border: PrimerColors.borderColor-muted;
    out property <length> panel-border-width: LayoutTokens.table-border-width;
    out property <length> panel-border-radius: LayoutTokens.borderRadius-large;
    out property <[DropShadowLayer]> panel-elevation-shadow: ShadowTokens.shadow-floating-small;
    /// Primer modal panel max size vs host viewport (**`AppWindow`**, e.g. gallery `changed width` / `height`). Used by **`ModalOverlay`** and **`Dialog`** (single source — do not duplicate `64px` / `120px` off **`AppWindow`** here).
    out property <length> modal-viewport-max-width: max(AppWindow.window-width - 64px, 120px);
    out property <length> modal-viewport-max-height: max(AppWindow.window-height - 64px, 120px);
}

// primer-ui-react `Dialog.module.css` + `Dialog.tsx` **`widthMap`**, plus primer-tokens **`functional/size`**. Composes **`LayoutTokens`** `out` only (width literals below are **React-shipped** exceptions vs **`overlay.size`** in JSON5 — see audit).
//
// Token audit (PR3): | Intent | primer-tokens / upstream | Owner | `out` / source | Consumers |
// |--------|---------------------------|-------|----------------|-----------|
// | Panel width **small** | React **`widthMap.small`** **296px** — *not* **`overlay.width.small`** (320px in tokens) | DialogTokens | **`width-small`** literal | **`Dialog`** `panel-w` |
// | Panel width **medium** | React **320px** — tokens **`overlay.width.medium`** often 480px: **parity = React** | DialogTokens | **`width-medium`** literal | **`Dialog`** |
// | Panel width **large** | React **480px** | DialogTokens | **`width-large`** literal | **`Dialog`** |
// | Panel width **xlarge** | React **640px** — aligns tokens **`overlay.width.xlarge`** | DialogTokens | **`width-xlarge`** literal | **`Dialog`** |
// | Panel height **small** | React **`heightMap.small`** **480px** | DialogTokens | **`height-small`** literal | **`Dialog`** `panel-max-height` |
// | Panel height **large** | React **`heightMap.large`** **640px** | DialogTokens | **`height-large`** literal | **`Dialog`** |
// | Panel height **auto** | React **`heightMap.auto`** — max = viewport overlay cap | OverlayTokens | **`modal-viewport-max-height`** | **`ModalOverlay`** |
// | Viewport margin (max panel) | `--overlay-height-[breakpoint]` math → **64px** inset | OverlayTokens | **`modal-viewport-max-*`** | **`ModalOverlay`**, **`Dialog`** |
// | Dialog header outer padding | **base-size-8** | LayoutTokens | **`base-size-8`** | **`header-padding`** |
// | Header content inline / block | **base-size-8**, **base-size-6** | LayoutTokens | same | **`header-content-*`** |
// | Title / subtitle typography | **`text-body-size-*`**, weights | LayoutTokens | composed | **`title-font-size`**, **`subtitle-*`** |
// | Title ↔ subtitle gap | **base-size-4** | LayoutTokens | **`base-size-4`** | **`header-title-subtitle-gap`** |
// | Body stack gap (blocks) | **base-size-12** | LayoutTokens | **`base-size-12`** | **`body-block-spacing`** |
// | Body + footer inset | **base-size-16** | LayoutTokens | **`base-size-16`** | **`body-padding`**, **`footer-padding`** |
// | Footer button row gap | **base-size-8** | LayoutTokens | **`button-content-gap`** | **`footer-actions-gap`** |
// | Narrow breakpoint (**`Dialog.module.css`** `@media`) | **`767px`** — CSS **`max-width`** / **`min-width`** bridge | DialogTokens | **`narrow-max-width`** literal | **`Dialog`** narrow vs regular positions |
// | **`align`** top/bottom viewport inset | React docs **~4rem** from edge (**`base-size-16` × 4**) | DialogTokens | **`align-viewport-edge-inset`** | **`ModalOverlay`** `panel-shell` **`y`** |
// | Enter motion (center / scaleFade) | **base.duration.200** | LayoutTokens **`duration-200`** | **`overlay-enter-duration`** | **`ModalOverlay`** |
// | Enter motion (side / bottom sheet) | **250ms** CSS — no **`timing.json5`** step | LayoutTokens **`duration-250`** | **`overlay-sheet-enter-duration`** | future side/bottom PRs |
// | Easing curve | React **`cubic-bezier(0.33, 1, 0.68, 1)`** — not **`base.easing.easeOut`** | — | inlined in **`modal-overlay.slint`** `animate` | **`ModalOverlay`** |
export global DialogTokens {
    out property <length> header-padding: LayoutTokens.base-size-8;
    out property <length> header-content-padding-inline: LayoutTokens.base-size-8;
    out property <length> header-content-padding-block: LayoutTokens.base-size-6;
    out property <length> body-padding: LayoutTokens.base-size-16;
    out property <length> footer-padding: LayoutTokens.base-size-16;
    out property <length> footer-actions-gap: LayoutTokens.button-content-gap;
    /// Vertical gap between title and subtitle (**`base-size-4`**).
    out property <length> header-title-subtitle-gap: LayoutTokens.base-size-4;
    /// Vertical spacing between stacked blocks in the scroll body (**`base-size-12`**).
    out property <length> body-block-spacing: LayoutTokens.base-size-12;
    /// Header title — matches **`.Header`** primary line.
    out property <length> title-font-size: LayoutTokens.text-body-size-medium;
    /// Subtitle — matches **`.Header`** secondary line.
    out property <length> subtitle-font-size: LayoutTokens.text-body-size-small;
    out property <int> title-font-weight: LayoutTokens.base-text-weight-semibold;
    out property <int> subtitle-font-weight: LayoutTokens.base-text-weight-normal;

    /// React **`Dialog.tsx`** **`widthMap`** — use these instead of **`overlay.width.*`** where JSON5 differs (see audit table).
    out property <length> width-small: 296px;
    out property <length> width-medium: 320px;
    out property <length> width-large: 480px;
    out property <length> width-xlarge: 640px;

    /// React **`Dialog.tsx`** **`heightMap.small`** (**not** tied to **`width`** — upstream comment “296×480” is illustrative).
    out property <length> height-small: 480px;
    /// React **`Dialog.tsx`** **`heightMap.large`**.
    out property <length> height-large: 640px;

    /// React **`Dialog`** **`align`** top / bottom: inset from viewport edge (**4rem** — **`base-size-16` × 4**).
    out property <length> align-viewport-edge-inset: 4 * LayoutTokens.base-size-16;

    /// React **`Dialog.module.css`** narrow viewport breakpoint (**≤767px**) — **`position.narrow`** (**bottom** / **fullscreen** / **`center`**) vs **`position.regular`**.
    out property <length> narrow-max-width: 767px;

    /// React **`Dialog.module.css`** — `.Backdrop` + default dialog **`Overlay--motion-scaleFade`** enter.
    out property <duration> overlay-enter-duration: LayoutTokens.duration-200;
    /// Side sheet + bottom sheet panel enter (**250ms** in upstream CSS) — consumers in position PRs.
    out property <duration> overlay-sheet-enter-duration: LayoutTokens.duration-250;
}

export global SelectPanelTokens {
    out property <length> wrapper-stack-gap: 10px;
    out property <length> list-max-height-default: 240px;
    out property <length> message-region-padding: 24px;
    out property <length> message-stack-gap: LayoutTokens.base-size-4;
}

// primer-tokens **`component/skeletonLoader.json5`** + **`SkeletonBox.module.css`** — composes **`PrimerColors.skeletonLoader-bgColor`**, **`LayoutTokens`** radii / shimmer duration.
//
// Token audit: | Intent | primer-tokens / upstream | Owner | `out` | Consumers |
// |--------|---------------------------|-------|-------|-----------|
// | Track bg | **`skeletonLoader.bgColor`** | SkeletonTokens | **`bgColor`** | **`SkeletonBox`** |
// | Corner | **`borderRadius.small`** | SkeletonTokens | **`box-border-radius`** | **`SkeletonBox`** |
// | Shimmer period | **`base.duration.1000`** | SkeletonTokens | **`shimmer-period`** | **`SkeletonBox`** |
export global SkeletonTokens {
    out property <color> bgColor: PrimerColors.skeletonLoader-bgColor;
    out property <length> box-border-radius: LayoutTokens.borderRadius-small;
    out property <duration> shimmer-period: LayoutTokens.duration-1000;
}

/// **`FilteredActionListLoaders.module.css`** — body skeleton chrome only (spinner padding reuses **`LayoutTokens.stack-padding-normal`** like **`SelectPanel`**).
/// Select-all strip: **`FilteredActionList.module.css`** **`.SelectAllContainer`** / **`.SelectAllLabel`** — spacing aliases only (no new literals).
export global FilteredActionListTokens {
    /// **`.SelectAllContainer`** padding-block (**`base-size-4`**).
    out property <length> select-all-padding-block: LayoutTokens.base-size-4;
    /// **`.SelectAllContainer`** padding-inline (**`base-size-16`**).
    out property <length> select-all-padding-inline: LayoutTokens.base-size-16;
    /// Gap between checkbox control and label (**`.SelectAllCheckbox`** margin-inline-end **`base-size-8`**).
    out property <length> select-all-control-label-gap: LayoutTokens.base-size-8;
    /// **`.LoadingSkeletonContainer`** padding (**8px**).
    out property <length> skeleton-container-padding: LayoutTokens.base-size-8;
    /// Vertical gap between skeleton bars.
    out property <length> skeleton-stack-gap: LayoutTokens.base-size-8;
    /// **`SkeletonBox`** bar height in upstream loaders — composed from **`LayoutTokens.control-large-paddingInline-spacious`** (**10px**).
    out property <length> skeleton-line-height: LayoutTokens.control-large-paddingInline-spacious;
    /// **`.LoadingSkeleton`** border-radius (**4px**).
    out property <length> skeleton-bar-border-radius: LayoutTokens.base-size-4;
}

/// **`UnderlineTabbedInterface.module.css`** **`LoadingCounter`** + **`UnderlineNav2`** tab counter chrome (dedupes literals vs row component).
export global UnderlineNavTokens {
    /// Upstream **1.5rem** — **`base-size-8` × 3**.
    out property <length> loading-counter-width: 3 * LayoutTokens.base-size-8;
    /// Upstream **1rem** — **`base-size-16`** in default root sizing.
    out property <length> loading-counter-height: LayoutTokens.base-size-16;
    /// **`loadingCounterKeyFrames`**: **1.2s** each leg × **2** for a full ping-pong cycle.
    out property <duration> loading-counter-animation-period: 2400ms;
    out property <float> loading-counter-opacity-min: 0.2;
    out property <float> loading-counter-opacity-max: 1.0;
}
