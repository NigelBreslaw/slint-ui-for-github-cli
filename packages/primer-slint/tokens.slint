    out property <length> control-medium-size: 32px;
    out property <length> control-large-size: 40px;
    out property <length> control-xlarge-size: 48px;
    out property <length> stack-padding-normal: 16px;

    out property <length> control-small-paddingInline-condensed: 6px;
    out property <length> control-medium-paddingInline-normal: 8px;
    out property <length> control-large-paddingInline-spacious: 10px;

    out property <length> iconButton-icon-size-small: 14px;
    out property <length> iconButton-icon-size-medium: 16px;
    out property <length> iconButton-icon-size-large: 18px;

    out property <length> borderRadius-small: 3px;
    out property <length> borderRadius-medium: 6px;
    out property <length> base-size-4: 4px;
    out property <length> base-size-6: 6px;
    out property <length> base-size-8: 8px;
    out property <length> base-size-12: 12px;
    out property <length> base-size-16: 16px;
    out property <length> borderRadius-large: 12px;

    out property <length> checkbox-border-radius: borderRadius-small;

    out property <length> banner-padding-default: 8px;
    out property <length> banner-padding-compact: 4px;
    out property <length> banner-icon-size-default: 20px;
    out property <length> banner-icon-size-title-hidden: 16px;
    out property <length> banner-icon-container-padding: 8px;
    out property <int> base-text-weight-semibold: 600;
    out property <length> banner-actions-gap: 12px;
    out property <length> banner-dismiss-margin-when-actions: 2px;

    out property <length> button-content-gap: 8px;

    out property <length> counter-label-padding-block: 2px;
    out property <length> counter-label-padding-inline: 6px;
    out property <length> counter-label-border-radius: 20px;
    out property <length> counter-label-border-width: 1px;

    out property <length> label-height-small: 20px;
    out property <length> label-height-large: 24px;
    out property <length> label-padding-inline-small: 6px;
    out property <length> label-padding-inline-large: 8px;
    out property <length> label-border-width: 1px;
    out property <length> label-border-radius-pill: 100px;

    out property <length> label-group-gap: 4px;

    out property <length> table-cell-padding-block-condensed: 4px;
    out property <length> table-cell-padding-inline-condensed: 8px;
    out property <length> table-cell-padding-block-normal: 8px;
    out property <length> table-cell-padding-inline-normal: 12px;
    out property <length> table-cell-padding-block-spacious: 12px;
    out property <length> table-cell-padding-inline-spacious: 16px;
    out property <length> table-cell-edge-inset-inline: 16px;
    out property <length> table-border-radius: borderRadius-medium;
    out property <length> table-border-width: 1px;
    out property <length> border-width-thicker: 4px;

    // ActionList row — density aligned with control-medium (ActionList.module.css item)
    out property <length> action-list-item-padding-inline: 8px;
    out property <length> action-list-item-padding-block: 6px;
    out property <length> action-list-item-min-height: control-medium-size;
    // Primer ActionList `size` large variant (control-large / spacious row); PR3+ item wiring
    out property <length> action-list-item-padding-block-large: 8px;
    out property <length> action-list-item-min-height-large: control-large-size;
    /// ActionList leading **Avatar** (20px — compact row; large rows use **`action-list-avatar-diameter-large`**).
    out property <length> action-list-avatar-diameter: 20px;
    out property <length> action-list-avatar-diameter-large: 24px;
    /// App chrome (**AppHeader** / **UserMenu**) profile avatar — matches former implicit **`Avatar`** default width (**34px**).
    out property <length> avatar-size-header: 34px;
    out property <length> action-list-item-divider-margin-block-start: button-content-gap - table-border-width;
    out property <length> action-list-item-divider-margin-block-end: button-content-gap;

    out property <duration> duration-80: 80ms;
    out property <duration> duration-200: 200ms;
    out property <duration> duration-250: 250ms;
    out property <duration> duration-1000: 1000ms;
}

export global AvatarTokens {

    property <ColorScheme> color-scheme: Palette.color-scheme;

    property <color> avatar-bg-light: #ffffff;
    property <color> avatar-bg-dark: rgba(255, 255, 255, 0.1);
    property <color> avatar-border-light: rgba(1, 4, 9, 0.15);
    property <color> avatar-border-dark: rgba(255, 255, 255, 0.15);

    out property <color> avatar-bgColor: color-scheme == ColorScheme.dark ? avatar-bg-dark : avatar-bg-light;
    out property <color> avatar-borderColor: color-scheme == ColorScheme.dark ? avatar-border-dark : avatar-border-light;
}

