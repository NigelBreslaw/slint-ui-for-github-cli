export global OverlayTokens {
    out property <color> backdrop-scrim: PrimerColors.overlay-scrim;
    out property <color> panel-background: PrimerColors.bgColor-default;
    out property <color> panel-border: PrimerColors.borderColor-muted;
    out property <length> panel-border-width: LayoutTokens.table-border-width;
    out property <length> panel-border-radius: LayoutTokens.borderRadius-large;
    out property <[DropShadowLayer]> panel-elevation-shadow: ShadowTokens.shadow-floating-small;
    /// Primer modal panel max size vs host viewport (**`AppWindow`**, e.g. gallery `changed width` / `height`). Used by **`ModalOverlay`** and **`Dialog`** (single source — do not duplicate `64px` / `120px` off **`AppWindow`** here).
    out property <length> modal-viewport-max-width: max(AppWindow.window-width - 64px, 300px);
    out property <length> modal-viewport-max-height: max(AppWindow.window-height - 64px, 200px);
    /// React **`Overlay.module.css`** **`min-width: 192px`** when **`width: auto`**.
    out property <length> anchored-overlay-auto-min-width: 192px;
    /// React **`max-width: calc(100vw - 2rem)`** for floating overlays.
    out property <length> anchored-overlay-auto-max-width: max(AppWindow.window-width - 32px, anchored-overlay-auto-min-width);
}

export global DialogTokens {
    out property <length> header-padding: LayoutTokens.base-size-8;
    out property <length> header-content-padding-inline: LayoutTokens.base-size-8;
    out property <length> header-content-padding-block: LayoutTokens.base-size-6;
    out property <length> body-padding: LayoutTokens.base-size-16;
    out property <length> footer-padding: LayoutTokens.base-size-16;
    out property <length> footer-actions-gap: LayoutTokens.button-content-gap;
    /// Vertical gap between title and subtitle (**`base-size-4`**).
    out property <length> header-title-subtitle-gap: LayoutTokens.base-size-4;
    /// Vertical spacing between stacked blocks in the scroll body (**`base-size-12`**).
    out property <length> body-block-spacing: LayoutTokens.base-size-12;
    /// Header title — matches **`.Header`** primary line.
    out property <length> title-font-size: LayoutTokens.text-body-size-medium;
    /// Subtitle — matches **`.Header`** secondary line.
    out property <length> subtitle-font-size: LayoutTokens.text-body-size-small;
    out property <int> title-font-weight: LayoutTokens.base-text-weight-semibold;
    out property <int> subtitle-font-weight: LayoutTokens.base-text-weight-normal;

    /// React **`Dialog.tsx`** **`widthMap`** — use these instead of **`overlay.width.*`** where JSON5 differs (see audit table).
    out property <length> width-small: 296px;
    out property <length> width-medium: 320px;
    out property <length> width-large: 480px;
    out property <length> width-xlarge: 640px;

    /// React **`Dialog.tsx`** **`heightMap.small`** (**not** tied to **`width`** — upstream comment “296×480” is illustrative).
    out property <length> height-small: 480px;
    /// React **`Dialog.tsx`** **`heightMap.large`**.
    out property <length> height-large: 640px;

    /// React **`Dialog`** **`align`** top / bottom: inset from viewport edge (**4rem** — **`base-size-16` × 4**).
    out property <length> align-viewport-edge-inset: 4 * LayoutTokens.base-size-16;

    /// React **`Dialog.module.css`** narrow viewport breakpoint (**≤767px**) — **`position.narrow`** (**bottom** / **fullscreen** / **`center`**) vs **`position.regular`**.
    out property <length> narrow-max-width: 767px;

    /// React **`Dialog.module.css`** — `.Backdrop` + default dialog **`Overlay--motion-scaleFade`** enter.
    out property <duration> overlay-enter-duration: LayoutTokens.duration-200;
    /// Side sheet + bottom sheet panel enter (**250ms** in upstream CSS) — consumers in position PRs.
    out property <duration> overlay-sheet-enter-duration: LayoutTokens.duration-250;
}

export global SelectPanelTokens {
    out property <length> wrapper-stack-gap: 10px;
    out property <length> list-max-height-default: 240px;
    out property <length> message-region-padding: 24px;
    out property <length> message-stack-gap: LayoutTokens.base-size-4;
}



/// **`FilteredActionListLoaders.module.css`** — body skeleton chrome only (spinner padding reuses **`LayoutTokens.stack-padding-normal`** like **`SelectPanel`**).
/// Select-all strip: **`FilteredActionList.module.css`** **`.SelectAllContainer`** / **`.SelectAllLabel`** — spacing aliases only (no new literals).
export global FilteredActionListTokens {
    /// **`.SelectAllContainer`** padding-block (**`base-size-4`**).
    out property <length> select-all-padding-block: LayoutTokens.base-size-4;
    /// **`.SelectAllContainer`** padding-inline (**`base-size-16`**).
    out property <length> select-all-padding-inline: LayoutTokens.base-size-16;
    /// Gap between checkbox control and label (**`.SelectAllCheckbox`** margin-inline-end **`base-size-8`**).
    out property <length> select-all-control-label-gap: LayoutTokens.base-size-8;
    /// **`.LoadingSkeletonContainer`** padding (**8px**).
    out property <length> skeleton-container-padding: LayoutTokens.base-size-8;
    /// Vertical gap between skeleton bars.
    out property <length> skeleton-stack-gap: LayoutTokens.base-size-8;
    /// **`SkeletonBox`** bar height in upstream loaders — composed from **`LayoutTokens.control-large-paddingInline-spacious`** (**10px**).
    out property <length> skeleton-line-height: LayoutTokens.control-large-paddingInline-spacious;
    /// **`.LoadingSkeleton`** border-radius (**4px**).
    out property <length> skeleton-bar-border-radius: LayoutTokens.base-size-4;
}

export global UnderlineNavTokens {
    out property <length> loading-counter-width: 3 * LayoutTokens.base-size-8;
    out property <length> loading-counter-height: LayoutTokens.base-size-16;
    out property <duration> loading-counter-animation-period: 2400ms;
    out property <float> loading-counter-opacity-min: 0.2;
    out property <float> loading-counter-opacity-max: 1.0;
}
