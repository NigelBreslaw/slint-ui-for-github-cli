import { Palette } from "std-widgets.slint";
import { DropShadowLayer } from "./Effects/multi-drop-shadow.slint";

export enum Size {
    small,
    medium,
    large,
}

export global AppWindow {
    in-out property <length> window-width;
    in-out property <length> window-height;
}

export global ShadowTokens {

    property <[DropShadowLayer]> shadow-floating-small-light: [
        { color: #d1d9e080, offset-x: 0px, offset-y: 0px, blur: 1px },
        { color: #25292e0a, offset-x: 0px, offset-y: 6px, blur: 12px },
        { color: #25292e1f, offset-x: 0px, offset-y: 6px, blur: 18px },
    ];
    property <[DropShadowLayer]> shadow-floating-small-dark: [
        { color: #3d444d, offset-x: 0px, offset-y: 0px, blur: 1px },
        { color: #01040966, offset-x: 0px, offset-y: 6px, blur: 12px },
        { color: #01040966, offset-x: 0px, offset-y: 6px, blur: 18px },
    ];

    out property <[DropShadowLayer]> shadow-floating-small: Palette.color-scheme == ColorScheme.dark ? shadow-floating-small-dark : shadow-floating-small-light;

}

// Primer functional/size + typography (no color-scheme). Matches ButtonBase.module.css variable names.
export global LayoutTokens {
    out property <length> text-body-size-small: 12px;
    out property <length> text-body-size-medium: 14px;
    out property <length> text-body-size-large: 16px;

    out property <length> text-body-lineHeight-small: 18px;
    out property <length> text-body-lineHeight-medium: 20px;
    out property <length> text-body-lineHeight-large: 24px;

    out property <int> base-text-weight-medium: 500;
    /// primer-ui-react / Primer typography — normal body weight (`--base-text-weight-normal`).
    out property <int> base-text-weight-normal: 400;

    out property <length> control-small-size: 28px;
    out property <length> control-medium-size: 32px;
    out property <length> control-large-size: 40px;
    // UnderlineTabbedInterface.module.css — .UnderlineWrapper min-height (--control-xlarge-size)
    out property <length> control-xlarge-size: 48px;
    // Primer stack padding (--stack-padding-normal); UnderlineWrapper inset horizontal padding
    out property <length> stack-padding-normal: 16px;

    out property <length> control-small-paddingInline-condensed: 6px;
    out property <length> control-medium-paddingInline-normal: 8px;
    out property <length> control-large-paddingInline-spacious: 10px;

    out property <length> iconButton-icon-size-small: 14px;
    out property <length> iconButton-icon-size-medium: 16px;
    out property <length> iconButton-icon-size-large: 18px;

    /// primer-tokens **`functional/size/radius.json5`** — **`borderRadius.small`** (**3px**) — skeleton bars, small controls.
    out property <length> borderRadius-small: 3px;
    out property <length> borderRadius-medium: 6px;
    /// primer-tokens functional size **`base-size-4`** (used by ActionList **`activeIndicatorLine`** mixin top/width).
    out property <length> base-size-4: 4px;
    /// primer-tokens functional size **`base-size-6`** (`Dialog.module.css` header content block padding).
    out property <length> base-size-6: 6px;
    /// primer-tokens functional size **`base-size-8`** (`Dialog.module.css` header outer / content inline padding).
    out property <length> base-size-8: 8px;
    /// primer-tokens functional size **`base-size-12`** (dialog body block gap, banner gaps, tables).
    out property <length> base-size-12: 12px;
    /// primer-tokens functional size **`base-size-16`** (`Dialog.module.css` body + footer padding).
    out property <length> base-size-16: 16px;
    /// primer-tokens `functional/size/radius.json5` — **`borderRadius.large`** (12px): dialogs, modals, larger containers.
    out property <length> borderRadius-large: 12px;

    out property <length> checkbox-border-radius: borderRadius-small;

    // Banner (Banner.module.css padding / icon box; legacy-theme base-size-8 / base-size-4 / base-size-20 / base-size-16)
    out property <length> banner-padding-default: 8px;
    out property <length> banner-padding-compact: 4px;
    out property <length> banner-icon-size-default: 20px;
    out property <length> banner-icon-size-title-hidden: 16px;
    out property <length> banner-icon-container-padding: 8px;
    out property <int> base-text-weight-semibold: 600;
    // BannerActions: Banner.module.css --base-size-12 column-gap, --base-size-2 dismiss margin when data-has-actions
    out property <length> banner-actions-gap: 12px;
    out property <length> banner-dismiss-margin-when-actions: 2px;

    // Button inner row: Primer ButtonBase.module.css .ButtonContent gap (--base-size-8)
    out property <length> button-content-gap: 8px;

    // CounterLabel.module.css: padding --base-size-2 --base-size-6, border-radius 20px, border thin
    out property <length> counter-label-padding-block: 2px;
    out property <length> counter-label-padding-inline: 6px;
    out property <length> counter-label-border-radius: 20px;
    out property <length> counter-label-border-width: 1px;

    // Label.module.css — height --base-size-20 / --base-size-24, padding 0 --base-size-6 / --base-size-8, --borderWidth-thin, --borderRadius-full
    out property <length> label-height-small: 20px;
    out property <length> label-height-large: 24px;
    out property <length> label-padding-inline-small: 6px;
    out property <length> label-padding-inline-large: 8px;
    out property <length> label-border-width: 1px;
    out property <length> label-border-radius-pill: 100px;

    // LabelGroup.module.css .Container — gap --base-size-4; .ItemWrapper min-height matches control-small-size (28px)
    out property <length> label-group-gap: 4px;

    // DataTable/Table.module.css — .Table [data-cell-padding] sets --cell-padding-block / --cell-padding-inline (condensed | normal | spacious)
    out property <length> table-cell-padding-block-condensed: 4px;
    out property <length> table-cell-padding-inline-condensed: 8px;
    out property <length> table-cell-padding-block-normal: 8px;
    out property <length> table-cell-padding-inline-normal: 12px;
    out property <length> table-cell-padding-block-spacious: 12px;
    out property <length> table-cell-padding-inline-spacious: 16px;
    // Table.module.css — .TableRow > *:first-child / :last-child extra padding-inline (--base-size-16)
    out property <length> table-cell-edge-inset-inline: 16px;
    // Table.module.css — --table-border-radius: 0.375rem (same as borderRadius-medium)
    out property <length> table-border-radius: borderRadius-medium;
    // Table.module.css — borders use --borderWidth-thin (1px)
    out property <length> table-border-width: 1px;

    // ActionList / NavList row — density aligned with control-medium (ActionList.module.css item)
    out property <length> action-list-item-padding-inline: 8px;
    out property <length> action-list-item-padding-block: 6px;
    out property <length> action-list-item-min-height: control-medium-size;
    // Primer ActionList `size` large variant (control-large / spacious row); PR3+ item wiring
    out property <length> action-list-item-padding-block-large: 8px;
    out property <length> action-list-item-min-height-large: control-large-size;
    /// ActionList leading **Avatar** (20px — compact row; large rows use **`action-list-avatar-diameter-large`**).
    out property <length> action-list-avatar-diameter: 20px;
    out property <length> action-list-avatar-diameter-large: 24px;
    // ActionList.module.css `.Divider` — margin-block-start: calc(var(--base-size-8) - var(--borderWidth-thin)); margin-block-end: var(--base-size-8). [`button-content-gap`] is `--base-size-8`; [`table-border-width`] is `--borderWidth-thin`.
    out property <length> action-list-item-divider-margin-block-start: button-content-gap - table-border-width;
    out property <length> action-list-item-divider-margin-block-end: button-content-gap;

    /// Full-width hairline between NavList groups (Primer `NavList.Divider`).
    out property <length> nav-list-divider-height: 1px;
    /// Indent per nesting level for NavList SubNav (Primer nested items).
    out property <length> nav-list-subnav-indent: 16px;
    /// Vertical accent bar for [`NavList`] `sidebar-current-indicator` (Primer sidebar current item).
    out property <length> nav-list-sidebar-indicator-width: 4px;
    out property <length> nav-list-sidebar-indicator-height: 20px;
    out property <length> nav-list-sidebar-indicator-gap: 8px;
    out property <length> nav-list-sidebar-indicator-radius: 2px;

    /// React **`ToggleSwitch.module.css`** **`--toggleSwitch-transition-duration`** (**80ms**); easing in component **`cubic-bezier(0.5, 1, 0.89, 1)`**.
    out property <duration> duration-80: 80ms;
    /// primer-tokens **`base/motion/timing.json5`** — **`base.duration.200`** (React **`Dialog.module.css`** backdrop + **`Overlay--motion-scaleFade`** enter).
    out property <duration> duration-200: 200ms;
    /// React **`Dialog.module.css`** side-sheet + bottom-sheet enter — **250ms** (no named **250** step in **`timing.json5`**; literal tied to upstream CSS).
    out property <duration> duration-250: 250ms;
    /// primer-tokens **`base/motion/timing.json5`** — **`base.duration.1000`** — **`SkeletonBox.module.css`** shimmer cycle (`var(--base-duration-1000)`).
    out property <duration> duration-1000: 1000ms;
}

// Semantic fg/bg/border/canvas (Primer functional/color). Shared across views; includes primitives reused by ButtonTokens (greens, fg-on-emphasis).
export global PrimerColors {

    property <ColorScheme> color-scheme: Palette.color-scheme;

    // Private literals from primer-ui-react legacy-theme colors/dark.ts + light.ts innermost fallbacks.
    // Single storage per hex/rgb/hsv; semantic tokens alias primitives (also shared with ButtonTokens via `out`).
    property <color> bgColor-inset-dark: #010409;
    property <color> canvas-subtle-light: #f6f8fa;
    property <color> bgColor-inset-light: canvas-subtle-light;
    property <color> bgColor-default-dark: #0d1117;
    property <color> bgColor-default-light: #ffffff;
    property <color> fgColor-default-dark: #e6edf3;
    property <color> fgColor-default-light: #1f2328;
    property <color> borderColor-default-dark: #30363d;
    property <color> borderColor-default-light: #d0d7de;

    property <color> fgColor-muted-dark: #848d97;
    property <color> fgColor-muted-light: #656d76;
    property <color> fgColor-subtle-dark: #6e7681;
    property <color> fgColor-subtle-light: #6e7781;

    property <color> bgColor-canvas-subtle-dark: #161b22;
    property <color> bgColor-canvas-subtle-light: canvas-subtle-light;

    property <color> bgColor-neutral-muted-dark: rgba(110, 118, 129, 0.1);
    property <color> bgColor-neutral-muted-light: rgba(234, 238, 242, 0.5);
    // primer-tokens **`component/skeletonLoader.json5`** — **`bgColor`**: **`base.color.neutral.8`** @ **α 0.1** (light **`#818B98`**); dark override **α 0.2** (**`#656C76`**).
    property <color> skeletonLoader-bg-light: rgba(129, 139, 152, 0.1);
    property <color> skeletonLoader-bg-dark: rgba(101, 108, 118, 0.2);
    // bgColor.neutral.emphasis (primer-tokens functional); CounterLabel primary variant
    property <color> bgColor-neutral-emphasis-light: #24292f;
    property <color> bgColor-neutral-emphasis-dark: #656d76;

    property <color> borderColor-muted-dark: #21262d;

    property <color> borderColor-muted-light: hsv(210, 5.263157894736848%, 89.41176470588236%, 1);

    property <color> accent-underline-dark: #f78166;
    property <color> accent-underline-light: #fd8c73;

    property <color> fgColor-placeholder-dark: #6e7681;
    property <color> fgColor-placeholder-light: #8c959f;

    property <color> fgColor-link-dark: #2f81f7;
    property <color> fgColor-link-light: #0969da;

    property <color> overlay-scrim-dark: rgba(33, 40, 48, 0.4);
    property <color> overlay-scrim-light: rgba(200, 209, 218, 0.4);

    property <color> drop-shadow-dark: #010409;
    property <color> drop-shadow-light: rgba(140, 149, 159, 0.15);

    property <color> actionListItem-inline-divider-dark: rgba(48, 54, 61, 0.48);
    property <color> actionListItem-inline-divider-light: rgba(208, 215, 222, 0.48);

    // Table.module.css .TableRow:hover .TableCell — var(--control-transparent-bgColor-hover) (primer-tokens control); single storage for table row hover + ButtonTokens action-list hover
    property <color> control-transparent-bgColor-hover-dark: rgba(177, 186, 196, 0.12);
    property <color> control-transparent-bgColor-hover-light: rgba(208, 215, 222, 0.32);

    // Greens: primer scale / success fg + success emphasis (same hex as GitHub primary button bg in each mode).
    property <color> green-success-fg-light: #1a7f37;
    property <color> fgColor-success-dark: #3fb950;
    property <color> fgColor-success-light: green-success-fg-light;
    property <color> green-emphasis-dark: #238636;
    property <color> green-emphasis-light: #1f883d;
    property <color> borderColor-success-emphasis-dark: green-emphasis-dark;
    property <color> borderColor-success-emphasis-light: green-emphasis-light;
    // Primary button selected bg (light): hsv from legacy theme — stored once here for ButtonTokens.
    property <color> button-primary-selected-bg-light: hsv(137.053, 0.798319, 0.466667, 1);
    property <color> fg-on-emphasis: #ffffff;
    property <color> green-primary-hover-dark: #2ea043;
    property <color> green-primary-disabled-bg-dark: rgba(35, 134, 54, 0.6);

    // Stacked inset shadow on control triggers (Select); dark: #010409 @ ~40% / ~60% alpha. Light: soft neutral layers.
    property <color> shadow-controlTrigger-back-dark: #01040966;
    property <color> shadow-controlTrigger-front-dark: #01040999;
    property <color> shadow-controlTrigger-back-light: rgba(31, 35, 40, 0.12);
    property <color> shadow-controlTrigger-front-light: rgba(31, 35, 40, 0.18);

    // Banner surfaces: primer-tokens bgColor/borderColor/fgColor + primer-ui-react legacy-theme light.ts / dark.ts fallbacks.
    property <color> bgColor-accent-muted-light: #ddf4ff;
    property <color> bgColor-accent-muted-dark: rgba(56, 139, 253, 0.1);
    property <color> borderColor-accent-muted-light: rgba(84, 174, 255, 0.4);
    property <color> borderColor-accent-muted-dark: rgba(56, 139, 253, 0.4);
    // borderColor.accent.emphasis — primer-tokens `functional/color/borderColor.json5` (`{base.color.blue.5}` + mode).
    property <color> borderColor-accent-emphasis-light: #0969da;
    property <color> borderColor-accent-emphasis-dark: #388bfd;

    property <color> bgColor-success-muted-light: #dafbe1;
    property <color> bgColor-success-muted-dark: rgba(46, 160, 67, 0.15);
    property <color> borderColor-success-muted-light: rgba(74, 194, 107, 0.4);
    property <color> borderColor-success-muted-dark: rgba(46, 160, 67, 0.4);

    property <color> bgColor-attention-muted-light: #fff8c5;
    property <color> bgColor-attention-muted-dark: rgba(187, 128, 9, 0.15);
    property <color> borderColor-attention-muted-light: rgba(212, 167, 44, 0.4);
    property <color> borderColor-attention-muted-dark: rgba(187, 128, 9, 0.4);
    property <color> fgColor-attention-light: #9a6700;
    property <color> fgColor-attention-dark: #d29922;

    property <color> bgColor-danger-muted-light: #ffebe9;
    property <color> bgColor-danger-muted-dark: rgba(248, 81, 73, 0.1);
    property <color> borderColor-danger-muted-light: rgba(255, 129, 130, 0.4);
    property <color> borderColor-danger-muted-dark: rgba(248, 81, 73, 0.4);
    property <color> fgColor-danger-light: #d1242f;
    property <color> fgColor-danger-dark: #f85149;

    // upsell banner uses done.* muted surfaces; fgColor-upsell aliases fgColor.done in primer-tokens.
    property <color> bgColor-done-muted-light: #fbefff;
    property <color> bgColor-done-muted-dark: rgba(163, 113, 247, 0.1);
    property <color> borderColor-done-muted-light: rgba(194, 151, 255, 0.4);
    property <color> borderColor-done-muted-dark: rgba(163, 113, 247, 0.4);
    property <color> fgColor-done-light: #8250df;
    property <color> fgColor-done-dark: #a371f7;

    // Label.module.css + legacy-theme — light: emphasis matches fg where primer-tokens uses one hex (accent/attention/sponsors/done/severe); dark keeps distinct literals.
    // bgColor.accent.emphasis (light) == fgColor.accent == fgColor.link (primer-tokens functional color fallbacks).
    property <color> bgColor-accent-emphasis-light: fgColor-link-light;
    property <color> bgColor-accent-emphasis-dark: #1f6feb;
    property <color> bgColor-attention-emphasis-light: fgColor-attention-light;
    property <color> bgColor-attention-emphasis-dark: #9e6a03;
    property <color> fgColor-severe-light: #bc4c00;
    property <color> fgColor-severe-dark: #db6d28;
    property <color> bgColor-severe-emphasis-light: fgColor-severe-light;
    property <color> bgColor-severe-emphasis-dark: #bd561d;
    // borderColor.danger.emphasis — single storage; ButtonTokens danger fg/hover reuse (legacy-theme danger.emphasis).
    property <color> borderColor-danger-emphasis-light: #cf222e;
    property <color> borderColor-danger-emphasis-dark: #da3633;
    property <color> bgColor-done-emphasis-light: fgColor-done-light;
    property <color> bgColor-done-emphasis-dark: #8957e5;
    property <color> fgColor-sponsors-light: #bf3989;
    property <color> fgColor-sponsors-dark: #db61a2;
    property <color> bgColor-sponsors-emphasis-light: fgColor-sponsors-light;
    property <color> bgColor-sponsors-emphasis-dark: #bf4b8a;

    out property <color> bgColor-inset: color-scheme == ColorScheme.dark ? bgColor-inset-dark : bgColor-inset-light;
    out property <color> bgColor-default: color-scheme == ColorScheme.dark ? bgColor-default-dark : bgColor-default-light;
    out property <color> fgColor-default: color-scheme == ColorScheme.dark ? fgColor-default-dark : fgColor-default-light;
    out property <color> borderColor-default: color-scheme == ColorScheme.dark ? borderColor-default-dark : borderColor-default-light;

    out property <color> fgColor-muted: color-scheme == ColorScheme.dark ? fgColor-muted-dark : fgColor-muted-light;
    out property <color> fgColor-subtle: color-scheme == ColorScheme.dark ? fgColor-subtle-dark : fgColor-subtle-light;
    out property <color> bgColor-canvas-subtle: color-scheme == ColorScheme.dark ? bgColor-canvas-subtle-dark : bgColor-canvas-subtle-light;
    out property <color> bgColor-muted: color-scheme == ColorScheme.dark ? bgColor-canvas-subtle-dark : bgColor-canvas-subtle-light;
    out property <color> bgColor-neutral-muted: color-scheme == ColorScheme.dark ? bgColor-neutral-muted-dark : bgColor-neutral-muted-light;
    out property <color> skeletonLoader-bgColor: color-scheme == ColorScheme.dark ? skeletonLoader-bg-dark : skeletonLoader-bg-light;
    out property <color> bgColor-neutral-emphasis: color-scheme == ColorScheme.dark ? bgColor-neutral-emphasis-dark : bgColor-neutral-emphasis-light;
    out property <color> counter-borderColor: transparent;
    out property <color> borderColor-muted: color-scheme == ColorScheme.dark ? borderColor-muted-dark : borderColor-muted-light;
    out property <color> accent-underline: color-scheme == ColorScheme.dark ? accent-underline-dark : accent-underline-light;
    out property <color> fgColor-placeholder: color-scheme == ColorScheme.dark ? fgColor-placeholder-dark : fgColor-placeholder-light;
    out property <color> fgColor-link: color-scheme == ColorScheme.dark ? fgColor-link-dark : fgColor-link-light;
    out property <color> overlay-scrim: color-scheme == ColorScheme.dark ? overlay-scrim-dark : overlay-scrim-light;
    out property <color> drop-shadow: color-scheme == ColorScheme.dark ? drop-shadow-dark : drop-shadow-light;
    out property <color> actionListItem-inline-divider: color-scheme == ColorScheme.dark ? actionListItem-inline-divider-dark : actionListItem-inline-divider-light;
    out property <color> table-row-bgColor-hover: color-scheme == ColorScheme.dark ? control-transparent-bgColor-hover-dark : control-transparent-bgColor-hover-light;
    out property <color> fgColor-success: color-scheme == ColorScheme.dark ? fgColor-success-dark : fgColor-success-light;
    out property <color> borderColor-success-emphasis: color-scheme == ColorScheme.dark ? borderColor-success-emphasis-dark : borderColor-success-emphasis-light;
    out property <color> shadow-controlTrigger-back: color-scheme == ColorScheme.dark ? shadow-controlTrigger-back-dark : shadow-controlTrigger-back-light;
    out property <color> shadow-controlTrigger-front: color-scheme == ColorScheme.dark ? shadow-controlTrigger-front-dark : shadow-controlTrigger-front-light;
    out property <color> buttonPrimarySelectedBackgroundLight: button-primary-selected-bg-light;
    out property <color> fgOnEmphasis: fg-on-emphasis;
    out property <color> greenPrimaryHoverDark: green-primary-hover-dark;
    out property <color> greenPrimaryDisabledBgDark: green-primary-disabled-bg-dark;

    out property <color> fgColor-accent: fgColor-link;
    out property <color> bgColor-accent-muted: color-scheme == ColorScheme.dark ? bgColor-accent-muted-dark : bgColor-accent-muted-light;
    out property <color> borderColor-accent-muted: color-scheme == ColorScheme.dark ? borderColor-accent-muted-dark : borderColor-accent-muted-light;
    out property <color> borderColor-accent-emphasis: color-scheme == ColorScheme.dark ? borderColor-accent-emphasis-dark : borderColor-accent-emphasis-light;
    out property <color> bgColor-success-muted: color-scheme == ColorScheme.dark ? bgColor-success-muted-dark : bgColor-success-muted-light;
    out property <color> borderColor-success-muted: color-scheme == ColorScheme.dark ? borderColor-success-muted-dark : borderColor-success-muted-light;
    out property <color> bgColor-attention-muted: color-scheme == ColorScheme.dark ? bgColor-attention-muted-dark : bgColor-attention-muted-light;
    out property <color> borderColor-attention-muted: color-scheme == ColorScheme.dark ? borderColor-attention-muted-dark : borderColor-attention-muted-light;
    out property <color> fgColor-attention: color-scheme == ColorScheme.dark ? fgColor-attention-dark : fgColor-attention-light;
    out property <color> bgColor-danger-muted: color-scheme == ColorScheme.dark ? bgColor-danger-muted-dark : bgColor-danger-muted-light;
    out property <color> borderColor-danger-muted: color-scheme == ColorScheme.dark ? borderColor-danger-muted-dark : borderColor-danger-muted-light;
    out property <color> fgColor-danger: color-scheme == ColorScheme.dark ? fgColor-danger-dark : fgColor-danger-light;
    out property <color> bgColor-done-muted: color-scheme == ColorScheme.dark ? bgColor-done-muted-dark : bgColor-done-muted-light;
    out property <color> borderColor-done-muted: color-scheme == ColorScheme.dark ? borderColor-done-muted-dark : borderColor-done-muted-light;
    out property <color> fgColor-done: color-scheme == ColorScheme.dark ? fgColor-done-dark : fgColor-done-light;
    out property <color> bgColor-upsell-muted: bgColor-done-muted;
    out property <color> borderColor-upsell-muted: borderColor-done-muted;
    out property <color> fgColor-upsell: fgColor-done;

    out property <color> bgColor-accent-emphasis: color-scheme == ColorScheme.dark ? bgColor-accent-emphasis-dark : bgColor-accent-emphasis-light;
    out property <color> bgColor-attention-emphasis: color-scheme == ColorScheme.dark ? bgColor-attention-emphasis-dark : bgColor-attention-emphasis-light;
    out property <color> fgColor-severe: color-scheme == ColorScheme.dark ? fgColor-severe-dark : fgColor-severe-light;
    out property <color> bgColor-severe-emphasis: color-scheme == ColorScheme.dark ? bgColor-severe-emphasis-dark : bgColor-severe-emphasis-light;
    out property <color> borderColor-danger-emphasis: color-scheme == ColorScheme.dark ? borderColor-danger-emphasis-dark : borderColor-danger-emphasis-light;
    out property <color> bgColor-done-emphasis: color-scheme == ColorScheme.dark ? bgColor-done-emphasis-dark : bgColor-done-emphasis-light;
    out property <color> fgColor-sponsors: color-scheme == ColorScheme.dark ? fgColor-sponsors-dark : fgColor-sponsors-light;
    out property <color> bgColor-sponsors-emphasis: color-scheme == ColorScheme.dark ? bgColor-sponsors-emphasis-dark : bgColor-sponsors-emphasis-light;
}

// color-btn-*, button-*, filled-button shadows, iconButton palette, control disabled fg. Used by Button / IconButton.
// Hex/rgb/hsv literals live in PrimerColors when shared; this global only composes scheme + internal aliases.
export global ButtonTokens {

    property <ColorScheme> color-scheme: Palette.color-scheme;

    property <color> color-btn-text-dark: #c9d1d9;
    property <color> color-btn-text-light: #24292f;

    property <color> color-btn-neutral-border-dark: #3f444c;
