import {
    DialogBase,
    DialogBaseAlign,
    DialogBaseSide,
    Button,
    ButtonAlignContent,
    Checkbox,
    CheckboxGroup,
    Icons,
    LayoutTokens,
    PrimerTextInput,
    Select,
    SelectOption,
    Size,
    ValidationStatus,
} from "../primer.slint";
import { PrimerColors } from "../tokens.slint";

/// Select, PrimerTextInput (PR1 spike), DialogBase demo, Checkbox, CheckboxGroup gallery demos.
export component GalleryFormsPage inherits VerticalLayout {
    spacing: 28px;
    width: 100%;

    in property <length> window-inner-width: 800px;
    in property <length> window-inner-height: 800px;

    private property <[SelectOption]> demo-select-options: [
        { value: "one", label: "First option", enabled: true },
        { value: "two", label: "Second option", enabled: true },
        { value: "three", label: "Third option", enabled: false },
    ];
    private property <int> demo-select-index: 0;

    private property <bool> demo-cb-off: false;
    private property <bool> demo-cb-on: true;
    private property <bool> demo-cb-label: false;
    private property <bool> demo-cb-indet: true;
    private property <bool> demo-cg-opt1: false;
    private property <bool> demo-cg-opt2: true;

    private property <string> demo-p1-block: "";
    private property <string> demo-p1-small: "";
    private property <string> demo-p1-large: "";
    private property <string> demo-p1-disabled: "Cannot edit";
    private property <string> demo-p1-caption: "";
    private property <string> demo-p1-error: "";
    private property <string> demo-p1-success: "";
    private property <string> demo-p1-required: "";

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Select";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            width: 100%;
            block: true;
            label-text: "Demo select";
            placeholder: "Choose an option…";
            options: demo-select-options;
            selected-index <=> demo-select-index;
            validation-status: ValidationStatus.success;
            validation-message: "Static gallery model.";
            selected-changed(_idx) => {
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "PrimerTextInput";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "PR1 spike: block, sizes, disabled, caption, validation, required — further interaction polish in later PRs.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            label-text: "Block";
            placeholder: "Placeholder…";
            text <=> demo-p1-block;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            size: Size.small;
            label-text: "Small";
            placeholder: "Small height";
            text <=> demo-p1-small;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            size: Size.large;
            label-text: "Large";
            placeholder: "Large height";
            text <=> demo-p1-large;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            label-text: "Disabled";
            text <=> demo-p1-disabled;
            disabled: true;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            label-text: "With caption";
            caption: "Helper text sits below the field.";
            placeholder: "Type…";
            text <=> demo-p1-caption;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            label-text: "Validation error";
            validation-status: ValidationStatus.error;
            validation-message: "Something went wrong";
            text <=> demo-p1-error;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            label-text: "Validation success";
            validation-status: ValidationStatus.success;
            validation-message: "Looks good.";
            text <=> demo-p1-success;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 150px;
            block: true;
            label-text: "Required label";
            required: true;
            placeholder: "Required field";
            text <=> demo-p1-required;
            edited(_) => {
            }
        }
    }

    dialog-base-demo-column := VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "DialogBase (anchored popup)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "DialogBase: vertical-side auto (flip), align start, panel-width 280px (narrower than the button); window-inner-width clamps horizontally. Escape closes. See gallery/anchored-popupwindow.md.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        btn-select-panel := Button {
            width: 100%;
            max-width: 420px;
            align-content: ButtonAlignContent.start;
            label: "bug, good first issue";
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                dialog-base-select-panel.open = true;
            }
        }

        dialog-base-select-panel := DialogBase {
            window-inner-width: window-inner-width;
            window-inner-height: window-inner-height;
            vertical-side: DialogBaseSide.auto;
            align: DialogBaseAlign.start;
            panel-width: 280px;
            anchor-abs-x: btn-select-panel.absolute-position.x;
            anchor-abs-y: btn-select-panel.absolute-position.y;
            anchor-width: btn-select-panel.width;
            anchor-height: btn-select-panel.height;
            close-requested => {
            }

            Text {
                text: "Panel body (empty — next PRs)";
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-medium;
                wrap: word-wrap;
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Checkbox";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Single 16px control (matches Primer); optional label, indeterminate (click resolves to checked), and optional leading icon.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Unchecked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Checkbox {
                    checked <=> demo-cb-off;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Checked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Checkbox {
                    checked <=> demo-cb-on;
                }
            }
        }

        Checkbox {
            width: 100%;
            label: "Send email notifications";
            checked <=> demo-cb-label;
        }

        Checkbox {
            width: 100%;
            label: "Indeterminate (first click checks)";
            checked: false;
            indeterminate <=> demo-cb-indet;
        }

        Checkbox {
            width: 100%;
            label: "Leading icon + label";
            checked: true;
        }

        Text {
            text: "CheckboxGroup";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Legend, caption, required asterisk, validation, disabled dimming (mirror disabled on each Checkbox), and visually hidden legend.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        CheckboxGroup {
            width: 100%;
            label: "Features";
            caption: "Choose one or more options.";
            required: true;
            validation-status: !demo-cg-opt1 && !demo-cg-opt2 ? ValidationStatus.error : ValidationStatus.success;
            validation-message: !demo-cg-opt1 && !demo-cg-opt2 ? "Pick at least one." : "Looks good.";

            Checkbox {
                width: 100%;
                label: "Option A";
                checked <=> demo-cg-opt1;
            }

            Checkbox {
                width: 100%;
                label: "Option B";
                checked <=> demo-cg-opt2;
            }
        }

        CheckboxGroup {
            width: 100%;
            label: "Disabled group";
            disabled: true;

            Checkbox {
                width: 100%;
                label: "Cannot toggle";
                disabled: true;
                checked: false;
            }

            Checkbox {
                width: 100%;
                label: "Also off";
                disabled: true;
                checked: true;
            }
        }

        CheckboxGroup {
            width: 100%;
            label: "Screen-reader legend (hidden in UI)";
            label-visually-hidden: true;
            caption: "Legend text is not shown; caption remains.";

            Checkbox {
                width: 100%;
                label: "Alpha";
            }

            Checkbox {
                width: 100%;
                label: "Beta";
            }
        }
    }
}
