import { NavList, NavListItem, Icons } from "../primer.slint";
import { PrimerColors, LayoutTokens } from "../tokens.slint";

export component GallerySidebar {
    in property <int> selected-index: 0;
    callback group-selected(int);

    width: 240px;
    height: 100%;

    private property <[NavListItem]> rail-items: [
        {
            data: {
                label: "Buttons",
                current: root.selected-index == 0,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Navs",
                current: root.selected-index == 1,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Feedback",
                current: root.selected-index == 2,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Forms",
                current: root.selected-index == 3,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Data",
                current: root.selected-index == 4,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Layout",
                current: root.selected-index == 5,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
    ];

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-inset;

        Rectangle {
            x: parent.width - self.width;
            width: 1px;
            height: 100%;
            background: PrimerColors.borderColor-default;
        }

        VerticalLayout {
            width: parent.width;
            padding-top: 12px;
            padding-bottom: 12px;
            padding-left: 8px;
            padding-right: 8px;
            spacing: 8px;
            alignment: start;

            Text {
                text: "Components";
                font-size: 11px;
                font-weight: 600;
                color: PrimerColors.fgColor-muted;
                padding-left: 4px;
            }

            NavList {
                width: 100%;
                horizontal-stretch: 1;
                items: rail-items;
                groups: [];
                sidebar-current-indicator: true;
                item-activated(_gi, path) => {
                    root.group-selected(
                        path == "0"
                            ? 0
                            : path == "1"
                                ? 1
                                : path == "2"
                                    ? 2
                                    : path == "3"
                                        ? 3
                                        : path == "4"
                                            ? 4
                                            : path == "5" ? 5 : root.selected-index,
                    );
                }
            }
        }
    }
}
