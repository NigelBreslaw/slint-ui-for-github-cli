import { PrimerColors, LayoutTokens } from "../tokens.slint";

export component GallerySidebar {
    in property <int> selected-index: 0;
    callback group-selected(int);

    width: 240px;
    height: 100%;

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-inset;

        Rectangle {
            x: parent.width - self.width;
            width: 1px;
            height: 100%;
            background: PrimerColors.borderColor-default;
        }

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-top: 12px;
            padding-bottom: 12px;
            padding-left: 12px;
            padding-right: 12px;
            spacing: 0px;

            Text {
                text: "Components";
                font-size: 11px;
                font-weight: 600;
                color: PrimerColors.fgColor-muted;
                padding-bottom: 8px;
            }

            Rectangle {
                height: 36px;
                border-radius: LayoutTokens.borderRadius-medium;
                background: root.selected-index == 0 ? PrimerColors.bgColor-neutral-muted : #00000000;

                TouchArea {
                    clicked => {
                        root.group-selected(0);
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Buttons";
                    font-size: 14px;
                    color: PrimerColors.fgColor-default;
                }
            }

            Rectangle {
                height: 36px;
                border-radius: LayoutTokens.borderRadius-medium;
                background: root.selected-index == 1 ? PrimerColors.bgColor-neutral-muted : #00000000;

                TouchArea {
                    clicked => {
                        root.group-selected(1);
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Navs";
                    font-size: 14px;
                    color: PrimerColors.fgColor-default;
                }
            }

            Rectangle {
                height: 36px;
                border-radius: LayoutTokens.borderRadius-medium;
                background: root.selected-index == 2 ? PrimerColors.bgColor-neutral-muted : #00000000;

                TouchArea {
                    clicked => {
                        root.group-selected(2);
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Feedback";
                    font-size: 14px;
                    color: PrimerColors.fgColor-default;
                }
            }

            Rectangle {
                height: 36px;
                border-radius: LayoutTokens.borderRadius-medium;
                background: root.selected-index == 3 ? PrimerColors.bgColor-neutral-muted : #00000000;

                TouchArea {
                    clicked => {
                        root.group-selected(3);
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Forms";
                    font-size: 14px;
                    color: PrimerColors.fgColor-default;
                }
            }

            Rectangle {
                height: 36px;
                border-radius: LayoutTokens.borderRadius-medium;
                background: root.selected-index == 4 ? PrimerColors.bgColor-neutral-muted : #00000000;

                TouchArea {
                    clicked => {
                        root.group-selected(4);
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Data";
                    font-size: 14px;
                    color: PrimerColors.fgColor-default;
                }
            }

            Rectangle {
                height: 36px;
                border-radius: LayoutTokens.borderRadius-medium;
                background: root.selected-index == 5 ? PrimerColors.bgColor-neutral-muted : #00000000;

                TouchArea {
                    clicked => {
                        root.group-selected(5);
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: "Layout";
                    font-size: 14px;
                    color: PrimerColors.fgColor-default;
                }
            }
        }
    }
}
