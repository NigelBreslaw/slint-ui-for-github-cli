import { PrimerColors } from "../tokens.slint";
import { GalleryHeader } from "./gallery-header.slint";
import { GallerySidebar } from "./gallery-sidebar.slint";
import { GalleryButtonsPage } from "./gallery-buttons-page.slint";
import { GalleryNavsPage } from "./gallery-navs-page.slint";

import "../assets/fonts/MonaSans-VariableFont.ttf";
import "../assets/fonts/MonaSans-Italic-VariableFont.ttf";
import "../assets/fonts/VeraMono.ttf";

export global GalleryState {
    in-out property <int> selected-group-index: 0;
}

export component GalleryWindow inherits Window {
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 640px;
    min-height: 480px;
    title: "Primer gallery";
    default-font-family: "Mona Sans";
    icon: @image-url("../assets/16px/palette.svg");

    background: PrimerColors.bgColor-default;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        GalleryHeader {
            width: 100%;
            height: 64px;
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            GallerySidebar {
                width: 240px;
                vertical-stretch: 1;
                selected-index: GalleryState.selected-group-index;
                group-selected(idx) => {
                    GalleryState.selected-group-index = idx;
                }
            }

            Rectangle {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                background: PrimerColors.bgColor-default;

                gallery-flick := Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: gallery-main.preferred-height;

                    gallery-main := VerticalLayout {
                        width: gallery-flick.width;
                        height: self.preferred-height;
                        padding: 24px;
                        spacing: 8px;

                        if GalleryState.selected-group-index == 0: GalleryButtonsPage {
                            width: 100%;
                        }

                        if GalleryState.selected-group-index == 1: GalleryNavsPage {
                            width: 100%;
                        }

                        if GalleryState.selected-group-index != 0 && GalleryState.selected-group-index != 1: VerticalLayout {
                            spacing: 8px;
                            width: 100%;

                            Text {
                                text: "Storybook-style catalog";
                                font-size: 16px;
                                font-weight: 600;
                                color: PrimerColors.fgColor-default;
                            }

                            Text {
                                text: "Component demos for this group will appear in a later PR. Use the sidebar to switch groups.";
                                font-size: 14px;
                                color: PrimerColors.fgColor-muted;
                                wrap: word-wrap;
                            }

                            Text {
                                text: "Selected group index: \{GalleryState.selected-group-index}";
                                font-size: 12px;
                                color: PrimerColors.fgColor-muted;
                            }
                        }
                    }
                }
            }
        }
    }
}
