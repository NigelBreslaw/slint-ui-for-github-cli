import { LabelLogic } from "./logic.slint";
import { LayoutTokens } from "../tokens.slint";
import { LabelSize, LabelVariant } from "./types.slint";

export { LabelSize, LabelVariant }

// Primer product Label — transparent fill, thin border + fg per variant (Label.module.css).
export component Label {
    in property <string> text: "";
    in property <LabelVariant> variant: default;
    in property <LabelSize> size: small;

    visible: text != "";
    horizontal-stretch: 0;

    property <length> effective-height: size == LabelSize.large ? LayoutTokens.label-height-large : LayoutTokens.label-height-small;
    property <length> effective-padding-inline: size == LabelSize.large
    ? LayoutTokens.label-padding-inline-large
    : LayoutTokens.label-padding-inline-small;
    property <color> effective-fg: LabelLogic.label-fg(variant);
    property <color> effective-border: LabelLogic.label-border(variant);

    Rectangle {
        height: effective-height;
        border-radius: Math.min(LayoutTokens.label-border-radius-pill, effective-height / 2);
        border-width: LayoutTokens.label-border-width;
        border-color: effective-border;
        background: transparent;

        HorizontalLayout {
            padding-left: effective-padding-inline;
            padding-right: effective-padding-inline;
            alignment: center;

            Text {
                text: root.text;
                color: effective-fg;
                font-size: LayoutTokens.text-body-size-small;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }
        }
    }
}
