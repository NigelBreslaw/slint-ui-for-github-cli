import { AppWindow, DialogTokens, LayoutTokens, OverlayTokens } from "../tokens.slint";
import { OverlayPanelChrome } from "../Overlays/overlay-panel-chrome.slint";

export struct PositionProps {
    absolute-position: Point,
    source-size: Size,
}

/// Pixel offset from the **final** clamped position at enter start (Primer `Overlay.tsx` `getSlideAnimationStartingVector` × `base-size-8`).
export struct AnchoredOverlayEnterSlideDelta {
    dx: length,
    dy: length,
}

export enum AnchoredOverlaySide {
    outside_bottom,
    outside_top,
    outside_left,
    outside_right,
}

export enum AnchoredOverlayAlign {
    start,
    center,
    end,
}

export enum AnchoredOverlayWidth {
    auto,
    small,
    medium,
    large,
    xlarge,
    xxlarge,
}

export enum AnchoredOverlayHeight {
    auto,
    xsmall,
    small,
    medium,
    large,
    xlarge,
}

export component AnchoredOverlay {
    width: 0px;
    height: 0px;

    property <bool> open: false;
    /// True after `show()` until `open` is set (one-frame arm so enter `states` can start from slide offset).
    property <bool> enter-armed: false;
    in property <PositionProps> position-props;
    in property <AnchoredOverlaySide> side: AnchoredOverlaySide.outside_bottom;
    in property <AnchoredOverlayAlign> align: AnchoredOverlayAlign.start;
    /// Gap along the attachment axis (Primer default gap is often `base-size-4`; extra margin is folded into `anchor-offset` if needed).
    in property <length> margin: LayoutTokens.base-size-4;
    /// Offset along the attachment axis (Primer `anchorOffset`).
    in property <length> anchor-offset: 0px;
    /// Offset perpendicular to the attachment axis (Primer `alignmentOffset`).
    in property <length> alignment-offset: 0px;
    in property <bool> prevent-overflow: true;
    in property <AnchoredOverlayWidth> width-preset: AnchoredOverlayWidth.large;
    in property <AnchoredOverlayHeight> height-preset: AnchoredOverlayHeight.auto;
    in property <bool> allow-dismiss: true;
    /// Optional dimmed scrim behind the panel (anchored popovers are often undimmed).
    in property <bool> show-backdrop: false;
    in property <length> panel-padding: 16px;
    /// When true, skip enter motion (matches `prefers-reduced-motion`).
    in property <bool> reduce-motion: false;

    pure function enter-slide-delta(side: AnchoredOverlaySide) -> AnchoredOverlayEnterSlideDelta {
        return {
            dx: side == AnchoredOverlaySide.outside_right ? 0px - LayoutTokens.base-size-8
                : side == AnchoredOverlaySide.outside_left ? LayoutTokens.base-size-8
                : 0px,
            dy: side == AnchoredOverlaySide.outside_bottom ? 0px - LayoutTokens.base-size-8
                : side == AnchoredOverlaySide.outside_top ? LayoutTokens.base-size-8
                : 0px,
        };
    }

    open-enter-delay := Timer {
        interval: 1ms;
        running: false;
        triggered() => {
            root.open = true;
            root.enter-armed = false;
            root.opened();
            self.stop();
        }
    }

    callback show();
    callback close();
    /// Fired when the user requests dismiss (outside tap, Escape) before `close()` runs.
    callback close-requested();
    callback opened();
    callback closed();

    property <length> ax: root.position-props.absolute-position.x;
    property <length> ay: root.position-props.absolute-position.y;
    property <length> aw: root.position-props.source-size.width;
    property <length> ah: root.position-props.source-size.height;
    property <length> vw: AppWindow.window-width;
    property <length> vh: AppWindow.window-height;

    property <bool> width-is-auto: root.width-preset == AnchoredOverlayWidth.auto;

    property <length> panel-width-fixed: root.width-preset == AnchoredOverlayWidth.small ? 256px
        : root.width-preset == AnchoredOverlayWidth.medium ? 320px
        : root.width-preset == AnchoredOverlayWidth.large ? 480px
        : root.width-preset == AnchoredOverlayWidth.xlarge ? 640px
        : 960px;

    show => {
        root.enter-armed = !root.reduce-motion;
        popup.show();
        if root.reduce-motion {
            root.open = true;
            root.opened();
        } else {
            open-enter-delay.start();
        }
    }

    close => {
        root.open = false;
        root.enter-armed = false;
        popup.close();
        root.closed();
    }

    popup := PopupWindow {
        x: 0px - root.absolute-position.x;
        y: 0px - root.absolute-position.y;
        width: AppWindow.window-width;
        height: AppWindow.window-height;

        close-policy: no-auto-close;
        forward-focus: overlay-scope;

        overlay-scope := FocusScope {

            key-pressed(event) => {
                if root.allow-dismiss && event.text == Key.Escape {
                    root.close-requested();
                    root.close();
                    return accept;
                }
                return reject;
            }

            dismiss-layer := Rectangle {
                width: AppWindow.window-width;
                height: AppWindow.window-height;
                background: root.show-backdrop ? OverlayTokens.backdrop-scrim : #00000000;

                dismiss-ta := TouchArea {
                    enabled: root.allow-dismiss;
                    clicked => {
                        root.close-requested();
                        root.close();
                    }
                }
            }

            pane := Rectangle {
                width: root.width-is-auto
                    ? max(
                        OverlayTokens.anchored-overlay-auto-min-width,
                        min(panel-chrome.chrome-preferred-width, OverlayTokens.anchored-overlay-auto-max-width),
                    )
                    : root.panel-width-fixed;
                height: root.height-preset == AnchoredOverlayHeight.auto ? min(panel-chrome.chrome-preferred-height, OverlayTokens.modal-viewport-max-height)
                    : root.height-preset == AnchoredOverlayHeight.xsmall ? 192px
                    : root.height-preset == AnchoredOverlayHeight.small ? 256px
                    : root.height-preset == AnchoredOverlayHeight.medium ? 320px
                    : root.height-preset == AnchoredOverlayHeight.large ? 432px
                    : 600px;

                property <length> align-h: root.align == AnchoredOverlayAlign.start ? root.ax
                    : root.align == AnchoredOverlayAlign.center ? root.ax + (root.aw - self.width) / 2
                    : root.ax + root.aw - self.width;

                property <length> align-v: root.align == AnchoredOverlayAlign.start ? root.ay
                    : root.align == AnchoredOverlayAlign.center ? root.ay + (root.ah - self.height) / 2
                    : root.ay + root.ah - self.height;

                property <length> raw-x: root.side == AnchoredOverlaySide.outside_bottom || root.side == AnchoredOverlaySide.outside_top ? self.align-h + root.alignment-offset
                    : root.side == AnchoredOverlaySide.outside_right ? root.ax + root.aw + root.margin + root.anchor-offset
                    : root.ax - root.margin - root.anchor-offset - self.width;

                property <length> raw-y: root.side == AnchoredOverlaySide.outside_bottom ? root.ay + root.ah + root.margin + root.anchor-offset
                    : root.side == AnchoredOverlaySide.outside_top ? root.ay - root.margin - root.anchor-offset - self.height
                    : self.align-v + root.alignment-offset;

                property <length> final-x: root.prevent-overflow ? max(0px, min(self.raw-x, root.vw - self.width)) : self.raw-x;
                property <length> final-y: root.prevent-overflow ? max(0px, min(self.raw-y, root.vh - self.height)) : self.raw-y;

                states [
                    pane-open-animated when root.open && !root.reduce-motion: {
                        x: self.final-x;
                        y: self.final-y;
                        opacity: 1.0;
                        in {
                            animate x, y, opacity {
                                duration: DialogTokens.overlay-enter-duration;
                                easing: cubic-bezier(0.33, 1, 0.68, 1);
                            }
                        }
                    }
                    pane-arm when root.enter-armed && !root.open: {
                        x: self.final-x + enter-slide-delta(root.side).dx;
                        y: self.final-y + enter-slide-delta(root.side).dy;
                        opacity: 0.0;
                    }
                    pane-open-instant when root.open && root.reduce-motion: {
                        x: self.final-x;
                        y: self.final-y;
                        opacity: 1.0;
                    }
                    pane-idle when !root.open: {
                        x: self.final-x;
                        y: self.final-y;
                        opacity: 0.0;
                    }
                ]

                touch-blocker := TouchArea { }

                panel-chrome := OverlayPanelChrome {
                    width: parent.width;
                    height: parent.height;
                    background: OverlayTokens.panel-background;
                    border-color: OverlayTokens.panel-border;
                    border-width: OverlayTokens.panel-border-width;
                    shadow-border-radius: OverlayTokens.panel-border-radius;
                    border-top-left-radius: OverlayTokens.panel-border-radius;
                    border-top-right-radius: OverlayTokens.panel-border-radius;
                    border-bottom-left-radius: OverlayTokens.panel-border-radius;
                    border-bottom-right-radius: OverlayTokens.panel-border-radius;
                    surface-shadows: OverlayTokens.panel-elevation-shadow;
                    panel-padding: root.panel-padding;

                    @children
                }

            }
        }
    }
}
