// Shared floating panel host: `PopupWindow` aligned to an anchor (no full-viewport dimmer — matches Primer AnchoredOverlay).
// Coordinate math matches [`anchored-popupwindow.md`](../../slint-gallery/gallery/anchored-popupwindow.md).
// Place as a 0×0 sibling under the same layout parent as the anchor; bind anchor-*, window-inner-width / height for placement.
// Panel chrome: OverlayTokens. If the popup closes via the platform, sync `open` from the parent if needed.

import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { AnchoredOverlayAlign, AnchoredOverlaySide } from "./types.slint";
import { LayoutTokens, OverlayTokens } from "../tokens.slint";

export component AnchoredOverlay {
    in-out property <bool> open: false;
    /// Viewport width for horizontal clamp (root `Window` inner width).
    in property <length> window-inner-width: 800px;
    in property <length> window-inner-height: 800px;
    in property <length> anchor-abs-x: 0px;
    in property <length> anchor-abs-y: 0px;
    in property <length> anchor-width: 0px;
    in property <length> anchor-height: 0px;
    /// Panel content height (ignored for popup geometry when **`shrink-wrap`** — height follows **`panel-slot`** preferred height).
    in property <length> panel-height: 240px;
    /// When `> 0`, panel width; otherwise matches `anchor-width` (dropdown-style default).
    in property <length> panel-width: 0px;
    /// When true, popup **`height`** follows slot content (**`panel-slot.preferred-height`**) instead of **`panel-height`**; slot does not stretch vertically. Use for compact menus (e.g. **`ActionList2`** only).
    in property <bool> shrink-wrap: false;
    in property <length> anchor-gap: 5px;
    /// Vertical placement; `auto` flips above when below would overflow (Primer default for anchored menus).
    in property <AnchoredOverlaySide> vertical-side: auto;
    /// Horizontal alignment of the panel relative to the anchor (LTR).
    in property <AnchoredOverlayAlign> align: start;
    callback close-requested();

    width: 0px;
    height: 0px;

    private property <length> effective-panel-width: panel-width > 0px ? panel-width : anchor-width;

    changed open => {
        if root.open {
            popup.show();
        } else {
            popup.close();
        }
    }

    popup := PopupWindow {
        // Placement + popup height must be computed here: Slint forbids reading `PopupWindow` internals
        // (e.g. `panel-slot.preferred-height`) from the enclosing `AnchoredOverlay`.
        private property <length> body-height: root.shrink-wrap ? panel-slot.preferred-height : root.panel-height;
        private property <length> body-width: panel-slot.preferred-width;

        private property <bool> flip-above:
            root.anchor-abs-y + root.anchor-height + root.anchor-gap + body-height > root.window-inner-height
            && root.anchor-abs-y >= root.anchor-gap + body-height;

        private property <length> panel-window-y:
            root.vertical-side == AnchoredOverlaySide.outside_top ? root.anchor-abs-y - root.anchor-gap - body-height
            : root.vertical-side == AnchoredOverlaySide.outside_bottom ? root.anchor-abs-y + root.anchor-height + root.anchor-gap
            : flip-above ? root.anchor-abs-y - root.anchor-gap - body-height
            : root.anchor-abs-y + root.anchor-height + root.anchor-gap;

        private property <length> panel-window-x-raw:
            root.align == AnchoredOverlayAlign.start ? root.anchor-abs-x
            : root.align == AnchoredOverlayAlign.center ? root.anchor-abs-x + (root.anchor-width - root.effective-panel-width) / 2
            : root.anchor-abs-x + root.anchor-width - root.effective-panel-width;

        private property <length> panel-window-x-max: max(0px, root.window-inner-width - root.effective-panel-width);

        private property <length> panel-window-x: max(0px, min(panel-window-x-raw, panel-window-x-max));

        x: panel-window-x - root.absolute-position.x;
        y: panel-window-y - root.absolute-position.y;
        width: body-width;
        height: body-height;

        panel-scope := FocusScope {
            width: 100%;
            height: 100%;

            key-pressed(event) => {
                if event.text == Key.Escape {
                    root.open = false;
                    root.close-requested();
                    return accept;
                }
                return reject;
            }

            panel-bg := Rectangle {
                width: 100%;
                height: 100%;

                MultiDropShadow {
                    width: parent.width;
                    height: parent.height;
                    border-radius: OverlayTokens.panel-border-radius;
                    shadows: OverlayTokens.panel-elevation-shadow;
                }

                // Clip only the fill + children so rounded corners hold; do not clip the wrapper or shadow blur is cut off.
                Rectangle {
                    // width: parent.width;
                    // height: parent.height;
                    clip: true;
                    background: OverlayTokens.panel-background;
                    border-radius: OverlayTokens.panel-border-radius;
                    border-width: OverlayTokens.panel-border-width;
                    border-color: OverlayTokens.panel-border;

                    panel-slot := VerticalLayout {
                        // width: 100%;
                        vertical-stretch: root.shrink-wrap ? 0 : 1;
                        padding: LayoutTokens.stack-padding-normal;
                        alignment: start;

                        @children
                    }
                }
            }
        }
    }
}
