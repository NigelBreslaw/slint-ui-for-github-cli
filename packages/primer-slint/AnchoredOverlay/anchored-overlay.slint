// Primer-style anchored overlay: floating panel only (no full-screen dimmer — matches upstream AnchoredOverlay / SelectPanel anchored).
// Coordinate math matches [`gallery/anchored-popupwindow.md`](../gallery/anchored-popupwindow.md).
// Place as a 0×0 sibling under the same layout parent as the anchor; bind anchor-* and window-inner-height for flip.
// Panel chrome: OverlayTokens. If the popup closes via the platform, sync `open` from the parent if needed.

import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { LayoutTokens, OverlayTokens } from "../tokens.slint";

export component AnchoredOverlay {
    in-out property <bool> open: false;
    in property <length> window-inner-height: 800px;
    in property <length> anchor-abs-x: 0px;
    in property <length> anchor-abs-y: 0px;
    in property <length> anchor-width: 0px;
    in property <length> anchor-height: 0px;
    in property <length> panel-height: 240px;
    in property <length> anchor-gap: 5px;
    callback close-requested();

    width: 0px;
    height: 0px;

    private property <bool> place-above:
        anchor-abs-y + anchor-height + anchor-gap + panel-height > window-inner-height
        && anchor-abs-y >= anchor-gap + panel-height;

    private property <length> panel-window-y:
        place-above ? anchor-abs-y - anchor-gap - panel-height : anchor-abs-y + anchor-height + anchor-gap;

    changed open => {
        if root.open {
            popup.show();
        } else {
            popup.close();
        }
    }

    popup := PopupWindow {
        x: anchor-abs-x - root.absolute-position.x;
        y: panel-window-y - root.absolute-position.y;
        width: anchor-width;
        height: panel-height;

        panel-scope := FocusScope {
            width: 100%;
            height: 100%;

            key-pressed(event) => {
                if event.text == Key.Escape {
                    root.open = false;
                    root.close-requested();
                    return accept;
                }
                return reject;
            }

            panel-bg := Rectangle {
                width: 100%;
                height: 100%;

                MultiDropShadow {
                    width: parent.width;
                    height: parent.height;
                    border-radius: OverlayTokens.panel-border-radius;
                    shadows: OverlayTokens.panel-elevation-shadow;
                }

                // Clip only the fill + children so rounded corners hold; do not clip the wrapper or shadow blur is cut off.
                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    clip: true;
                    background: OverlayTokens.panel-background;
                    border-radius: OverlayTokens.panel-border-radius;
                    border-width: OverlayTokens.panel-border-width;
                    border-color: OverlayTokens.panel-border;

                    VerticalLayout {
                        width: 100%;
                        height: 100%;
                        padding: LayoutTokens.stack-padding-normal;
                        alignment: start;

                        @children
                    }
                }
            }
        }
    }
}
