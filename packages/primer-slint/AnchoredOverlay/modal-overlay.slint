// Viewport modal: fullscreen `PopupWindow` with **`OverlayTokens.backdrop-scrim`**, backdrop dismiss, centered **`OverlayPanelChrome`**, and **`Dialog.module.css`** enter motion (backdrop fade + **`Overlay--motion-scaleFade`**).
// Parent-relative **`x`** / **`y`** match **`AnchoredOverlay`** (window origin minus **`absolute-position`**).

import { OverlayPanelChrome } from "./overlay-panel-chrome.slint";
import { DialogTokens, OverlayTokens, AppWindow } from "../tokens.slint";

export component ModalOverlay {
    in-out property <bool> open: false;
    in property <bool> allow-dismiss: true;
    /// Target panel width (clamped to viewport âˆ’ 64px, min 120px â€” Primer **`Dialog`**).
    in property <length> panel-width: 640px;
    /// Requested max panel body height (clamped to viewport âˆ’ 64px, min 120px).
    in property <length> panel-max-height: 640px;
    /// Padding inside **`OverlayPanelChrome`** around **`@children`** (dialog shell uses **`0px`**).
    in property <length> slot-padding: 0px;
    callback close-requested();

    private property <length> panel-w: min(root.panel-width, OverlayTokens.modal-viewport-max-width);
    /// Height cap for the modal shell (`panel-max-height` âˆ© viewport overlay max).
    private property <length> viewport-cap-h: min(root.panel-max-height, OverlayTokens.modal-viewport-max-height);

    /// Shared **0â€“1** for backdrop opacity + panel **`Overlay--motion-scaleFade`** (React curve in **`animate`** below).
    private property <float> presented: root.open ? 1.0 : 0.0;

    animate presented {
        duration: DialogTokens.overlay-enter-duration;
        easing: cubic-bezier(0.33, 1, 0.68, 1);
    }

    /// Shell scale **0.5 â†’ 1** (`Overlay--motion-scaleFade`).
    private property <float> shell-scale: 0.5 + 0.5 * presented;

    changed open => {
        if root.open {
            popup.show();
        } else {
            popup.close();
        }
    }

    popup := PopupWindow {
        close-policy: no-auto-close;
        x: 0px - root.absolute-position.x;
        y: 0px - root.absolute-position.y;
        width: AppWindow.window-width;
        height: AppWindow.window-height;

        Rectangle {
            width: parent.width;
            height: parent.height;

            modal-scope := FocusScope {
                width: 100%;
                height: 100%;

                key-pressed(event) => {
                    if root.allow-dismiss && event.text == Key.Escape {
                        root.open = false;
                        root.close-requested();
                        return accept;
                    }
                    return reject;
                }

                // Bottom: fullscreen scrim (fade).
                Rectangle {
                    width: 100%;
                    height: 100%;
                    background: OverlayTokens.backdrop-scrim;
                    opacity: presented;
                }

                // Middle: backdrop dismiss â€” must stay **below** the panel shell so clicks outside the card hit here.
                TouchArea {
                    enabled: root.allow-dismiss && root.open;
                    width: 100%;
                    height: 100%;
                    clicked => {
                        root.open = false;
                        root.close-requested();
                    }
                }

                // Top: viewport-centered shell (tight bounds â€” not a fullscreen layout) + enter motion.
                panel-shell := Rectangle {
                    x: (AppWindow.window-width - root.panel-w) / 2;
                    y: max(0px, (AppWindow.window-height - self.height) / 2);
                    width: root.panel-w;
                    height: min(panel-chrome.slot-preferred-height, root.viewport-cap-h);
                    opacity: presented;
                    transform-scale: shell-scale;
                    clip: false;

                    panel-chrome := OverlayPanelChrome {
                        width: root.panel-w;
                        surface-background: OverlayTokens.panel-background;
                        surface-border: OverlayTokens.panel-border;
                        surface-border-width: OverlayTokens.panel-border-width;
                        surface-border-radius: OverlayTokens.panel-border-radius;
                        surface-shadow: OverlayTokens.panel-elevation-shadow;
                        slot-padding: root.slot-padding;
                        slot-fill-height: true;

                        @children
                    }
                }
            }
        }
    }
}
