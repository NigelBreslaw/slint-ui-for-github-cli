// Viewport modal: fullscreen `PopupWindow` with **`OverlayTokens.backdrop-scrim`**, backdrop segments for dismiss, and centered **`OverlayPanelChrome`**. Parent-relative **`x`** / **`y`** match **`AnchoredOverlay`** (window origin minus `absolute-position`).

import { OverlayPanelChrome } from "./overlay-panel-chrome.slint";
import { OverlayTokens } from "../tokens.slint";
import { AppWindow } from "../tokens.slint";

export component ModalOverlay {
    in-out property <bool> open: false;
    in property <bool> allow-dismiss: true;
    /// Target panel width (clamped to viewport − 64px, min 120px — Primer **`Dialog`**).
    in property <length> panel-width: 640px;
    /// Requested max panel body height (clamped to viewport − 64px, min 120px).
    in property <length> panel-max-height: 640px;
    /// Padding inside **`OverlayPanelChrome`** around **`@children`** (dialog shell uses **`0px`**).
    in property <length> slot-padding: 0px;
    callback close-requested();

    private property <length> panel-w: min(root.panel-width, OverlayTokens.modal-viewport-max-width);
    /// Requested max height ∩ viewport cap (when **`OverlayPanelChrome`** height is wired again, bind here).
    private property <length> panel-h: min(root.panel-max-height, OverlayTokens.modal-viewport-max-height);

    changed open => {
        if root.open {
            popup.show();
        } else {
            popup.close();
        }
    }

    popup := PopupWindow {
        close-policy: no-auto-close;
        x: 0px - root.absolute-position.x;
        y: 0px - root.absolute-position.y;
        width: AppWindow.window-width;
        height: AppWindow.window-height;
        Rectangle {
            x: 0;
            y: 0;
            width: AppWindow.window-width;
            height: AppWindow.window-height;

            modal-scope := FocusScope {
                key-pressed(event) => {
                    if root.allow-dismiss && event.text == Key.Escape {
                        root.open = false;
                        root.close-requested();
                        return accept;
                    }
                    return reject;
                }
                Rectangle {
                    background: OverlayTokens.backdrop-scrim;
                    TouchArea {
                        enabled: root.allow-dismiss;
                        clicked => {
                            root.open = false;
                            root.close-requested();
                        }
                    }
                    VerticalLayout {
                        width: self.preferred-width;
                        height: self.preferred-height;
                        panel-chrome := OverlayPanelChrome {
                            width: root.panel-w;
                            surface-background: OverlayTokens.panel-background;
                            surface-border: OverlayTokens.panel-border;
                            surface-border-width: OverlayTokens.panel-border-width;
                            surface-border-radius: OverlayTokens.panel-border-radius;
                            surface-shadow: OverlayTokens.panel-elevation-shadow;
                            slot-padding: root.slot-padding;
                            slot-fill-height: true;

                            @children
                        }
                    }
                }
            }
        }
    }
}
