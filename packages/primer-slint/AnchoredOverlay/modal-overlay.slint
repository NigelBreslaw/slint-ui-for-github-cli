// Viewport modal: fullscreen `PopupWindow` with **`OverlayTokens.backdrop-scrim`**, backdrop dismiss, **`OverlayPanelChrome`**, and **`Dialog.module.css`** enter motion:
// **center** / **narrow center** / **narrow fullscreen**: backdrop fade + **`Overlay--motion-scaleFade`** (**`DialogTokens.overlay-enter-duration`**);
// **side sheets**: **`Overlay--motion-slideInLeft`** / **`slideInRight`** (**`DialogTokens.overlay-sheet-enter-duration`**);
// **narrow bottom sheet**: **`Overlay--motion-slideUp`** (**`DialogTokens.overlay-sheet-enter-duration`**).
// Parent-relative **`x`** / **`y`** match **`AnchoredOverlay`** (window origin minus **`absolute-position`**).
//
// Enter motion uses a **`Timer`** arm step: while the popup is closed, Slint does not keep a stable “from” value for animated props on first paint after **`show()`**, so binding **`presented`** directly to **`open`** snaps. We set **`presented := 0`**, **`show()`**, then **`presented := 1`** on the next tick so **`animate presented`** runs **0→1**.
//
// **`PopupWindow.close()`** must not run until **`presented`** finishes animating **1→0** on dismiss; closing immediately can strand the animator so the **next** **`show()`** does not run **0→1** enter motion reliably.

import { OverlayPanelChrome } from "./overlay-panel-chrome.slint";
import { DialogAlignPreset, DialogNarrowPositionPreset, DialogPositionPreset } from "../Dialog/types.slint";
import { DialogTokens, OverlayTokens, AppWindow } from "../tokens.slint";

export component ModalOverlay {
    in-out property <bool> open: false;
    in property <bool> allow-dismiss: true;
    /// Target panel width (clamped to viewport − 64px, min 120px — Primer **`Dialog`**).
    in property <length> panel-width: 640px;
    /// Requested max panel body height (clamped to viewport − 64px, min 120px).
    in property <length> panel-max-height: 640px;
    /// Padding inside **`OverlayPanelChrome`** around **`@children`** (dialog shell uses **`0px`**).
    in property <length> slot-padding: 0px;
    /// Vertical placement of the panel in the viewport (**Primer **`Dialog`** **`align`** when **`position`** is center). Ignored for **side sheets** (**`left`** / **`right`**) and **narrow bottom** / **fullscreen**.
    in property <DialogAlignPreset> panel-vertical-align: DialogAlignPreset.center;
    /// **`Dialog`** **`position`** (**regular** breakpoint): centered modal vs side sheet (**`Overlay--motion-slideInRight`** / **`slideInLeft`**).
    in property <DialogPositionPreset> panel-position: DialogPositionPreset.center;
    /// When **`true`** (**viewport `≤ DialogTokens.narrow-max-width`** or gallery **`narrow-layout`**), **`narrow-position`** drives geometry/motion instead of **`panel-position`** (**`left`** / **`right`** side sheets apply only when this is **`false`**).
    in property <bool> narrow-viewport: false;
    /// **`Dialog`** **`position.narrow`** (**center** \| **`bottom`** slide-up \| **`fullscreen`** **`scaleFade`**).
    in property <DialogNarrowPositionPreset> narrow-position: DialogNarrowPositionPreset.center;
    callback close-requested();

    private property <length> panel-w: min(root.panel-width, OverlayTokens.modal-viewport-max-width);
    /// Height cap for the modal shell (`panel-max-height` ∩ viewport overlay max).
    private property <length> viewport-cap-h: min(root.panel-max-height, OverlayTokens.modal-viewport-max-height);

    /// Shared **0–1** for backdrop opacity + panel enter motion — driven by **`Timer`**, not **`open`**, so **`animate`** has a real previous value after **`PopupWindow.show()`**.
    private property <float> presented: 0.0;

    private property <bool> is-side-sheet:
        !root.narrow-viewport && (root.panel-position == DialogPositionPreset.left || root.panel-position == DialogPositionPreset.right);

    private property <bool> is-narrow-bottom:
        root.narrow-viewport && root.narrow-position == DialogNarrowPositionPreset.bottom;

    private property <bool> is-narrow-fullscreen:
        root.narrow-viewport && root.narrow-position == DialogNarrowPositionPreset.fullscreen;

    /// **`scaleFade`** opacity path — not side sheet / not narrow bottom sheet slide-only.
    private property <bool> use-scale-fade-opacity:
        !root.is-side-sheet && !root.is-narrow-bottom;

    private property <duration> presented-enter-duration:
        root.is-side-sheet || root.is-narrow-bottom ? DialogTokens.overlay-sheet-enter-duration : DialogTokens.overlay-enter-duration;

    animate presented {
        duration: root.presented-enter-duration;
        easing: cubic-bezier(0.33, 1, 0.68, 1);
    }

    /// Shell scale **0.5 → 1** (`Overlay--motion-scaleFade`) — side sheets + narrow bottom use scale **1**.
    private property <float> shell-scale: 0.5 + 0.5 * presented;

    private property <float> shell-scale-effective:
        root.is-side-sheet || root.is-narrow-bottom ? 1.0 : root.shell-scale;

    /// Full-bleed width (**narrow bottom** / **narrow fullscreen**).
    private property <length> shell-width:
        root.is-narrow-bottom || root.is-narrow-fullscreen ? AppWindow.window-width : root.panel-w;

    /// Side sheet **`x`** (**`narrow-viewport`** off): **`slideInRight`** / **`slideInLeft`**; else horizontally centered (**full-bleed** shells **`x == 0`**).
    private property <length> panel-shell-x:
        root.is-side-sheet && root.panel-position == DialogPositionPreset.left ? root.panel-w * root.presented - root.panel-w
        : root.is-side-sheet && root.panel-position == DialogPositionPreset.right ? AppWindow.window-width - root.panel-w * root.presented
        : (AppWindow.window-width - root.shell-width) / 2;

    private property <length> chrome-corner-tl:
        root.is-narrow-fullscreen ? 0px
        : root.is-narrow-bottom ? OverlayTokens.panel-border-radius
        : root.panel-position == DialogPositionPreset.left ? 0px
        : OverlayTokens.panel-border-radius;

    private property <length> chrome-corner-tr:
        root.is-narrow-fullscreen ? 0px
        : root.is-narrow-bottom ? OverlayTokens.panel-border-radius
        : root.panel-position == DialogPositionPreset.right ? 0px
        : OverlayTokens.panel-border-radius;

    private property <length> chrome-corner-br:
        root.is-narrow-fullscreen ? 0px
        : root.is-narrow-bottom ? 0px
        : root.panel-position == DialogPositionPreset.right ? 0px
        : OverlayTokens.panel-border-radius;

    private property <length> chrome-corner-bl:
        root.is-narrow-fullscreen ? 0px
        : root.is-narrow-bottom ? 0px
        : root.panel-position == DialogPositionPreset.left ? 0px
        : OverlayTokens.panel-border-radius;

    private property <length> elevation-radius:
        root.is-narrow-fullscreen ? 0px : OverlayTokens.panel-border-radius;

    /// One tick after **`show()`**, bump **`presented`** to **1** so enter animation runs (see file comment).
    presented-enter-arm := Timer {
        interval: 1ms;
        running: false;
        triggered() => {
            if root.open {
                root.presented = 1.0;
            }
            self.running = false;
        }
    }

    /// After **`open`** becomes false, wait for **`presented`** exit animation (**duration** matches **`animate presented`**) before **`popup.close()`** — see file header.
    popup-close-after-exit := Timer {
        interval: root.presented-enter-duration;
        running: false;
        triggered() => {
            if !root.open {
                popup.close();
            }
            self.running = false;
        }
    }

    changed open => {
        if root.open {
            popup-close-after-exit.running = false;
            root.presented = 0.0;
            popup.show();
            presented-enter-arm.running = true;
        } else {
            presented-enter-arm.running = false;
            root.presented = 0.0;
            popup-close-after-exit.running = true;
        }
    }

    popup := PopupWindow {
        close-policy: no-auto-close;
        x: 0px - root.absolute-position.x;
        y: 0px - root.absolute-position.y;
        width: AppWindow.window-width;
        height: AppWindow.window-height;

        Rectangle {
            x: 0px;
            y: 0px;
            width: AppWindow.window-width;
            height: AppWindow.window-height;

            modal-scope := FocusScope {
                width: 100%;
                height: 100%;

                key-pressed(event) => {
                    if root.allow-dismiss && event.text == Key.Escape {
                        root.open = false;
                        root.close-requested();
                        return accept;
                    }
                    return reject;
                }

                Rectangle {
                    background: OverlayTokens.backdrop-scrim;
                    opacity: root.presented;
                }

                // Middle: backdrop dismiss — must stay **below** the panel shell so clicks outside the card hit here.
                TouchArea {
                    enabled: root.allow-dismiss && root.open;
                    clicked => {
                        root.open = false;
                        root.close-requested();
                    }
                }

                // Top: dialog shell + enter motion.
                panel-shell := Rectangle {
                    x: root.panel-shell-x;
                    // **`narrow bottom`**: `slideUp` — **`y`** uses **`self.height`** so it resolves after layout (see **`Dialog.module.css`** **`Overlay--motion-slideUp`**).
                    y:
                        root.is-narrow-bottom ? AppWindow.window-height - self.height * root.presented
                        : root.is-side-sheet ? 0px
                        : root.is-narrow-fullscreen ? 0px
                        : root.panel-vertical-align == DialogAlignPreset.top ? DialogTokens.align-viewport-edge-inset
                        : root.panel-vertical-align == DialogAlignPreset.bottom ? max(0px, AppWindow.window-height - self.height - DialogTokens.align-viewport-edge-inset)
                        : max(0px, (AppWindow.window-height - self.height) / 2);
                    width: root.shell-width;
                    height: root.is-side-sheet || root.is-narrow-fullscreen ? AppWindow.window-height : min(panel-chrome.slot-preferred-height, root.viewport-cap-h);
                    opacity: root.use-scale-fade-opacity ? root.presented : 1.0;
                    transform-scale: root.shell-scale-effective;

                    panel-chrome := OverlayPanelChrome {
                        width: root.shell-width;
                        surface-background: OverlayTokens.panel-background;
                        surface-border: OverlayTokens.panel-border;
                        surface-border-width: OverlayTokens.panel-border-width;
                        elevation-border-radius: root.elevation-radius;
                        surface-border-top-left-radius: root.chrome-corner-tl;
                        surface-border-top-right-radius: root.chrome-corner-tr;
                        surface-border-bottom-right-radius: root.chrome-corner-br;
                        surface-border-bottom-left-radius: root.chrome-corner-bl;
                        surface-shadow: OverlayTokens.panel-elevation-shadow;
                        slot-padding: root.slot-padding;
                        slot-fill-height: true;

                        @children
                    }
                }
            }
        }
    }
}
