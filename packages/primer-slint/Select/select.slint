import { Icons } from "../assets/icons.slint";
import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import {
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
    Size,
} from "../tokens.slint";

export struct SelectOption {
    value: string,
    label: string,
    enabled: bool,
}

export enum ValidationStatus {
    none,
    error,
    success,
}

export component Select {
    in property <string> label-text: "";
    in-out property <string> selected-value: selected-index > -1 ? options[selected-index].value : "";
    out property <string> selected-label: selected-index > -1 ? options[selected-index].label : "";
    in-out property <int> selected-index: -1;
    in property <string> placeholder: "Select…";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <Size> size: medium;
    in property <[SelectOption]> options;

    in property <int> option-count: -1;
    callback selected-changed(value_index: int);

    property <int> effective-len: option-count >= 0 ? option-count : options.length;
    property <bool> has-options: effective-len > 0;

    property <length> trigger-height:
        size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    property <length> trigger-font:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    property <color> trigger-border-color:
        validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : validation-status == ValidationStatus.success ? PrimerColors.borderColor-success-emphasis : PrimerColors.borderColor-default;

    function apply-pick-at(ix: int) {
        if ix < 0 || ix >= root.effective-len {
            return;
        }
        if !options[ix].enabled {
            return;
        }
        root.selected-index = ix;
        root.selected-changed(ix);
    }

    height: vl.preferred-height;

    vl := VerticalLayout {
        spacing: 6px;

        if label-text != "": Text {
            text: label-text;
            font-size: LayoutTokens.text-body-size-medium;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
            wrap: word-wrap;
        }

        trigger-wrap := Rectangle {
            height: trigger-height;

            select-ctx := ContextMenuArea {
                enabled: !root.disabled;

                Menu {
                    for opt[index] in options: MenuItem {
                        title: opt.label;
                        enabled: opt.enabled;
                        activated => {
                            root.apply-pick-at(index);
                        }
                    }
                }

                MultiDropShadow {
                    border-radius: LayoutTokens.borderRadius-medium;
                    shadows: [
                        {
                            color: PrimerColors.shadow-controlTrigger-back,
                            offset-x: 0px,
                            offset-y: 1px,
                            blur: 2px
                        },
                        {
                            color: PrimerColors.shadow-controlTrigger-front,
                            offset-x: 0px,
                            offset-y: 1px,
                            blur: 1px
                        },
                    ];
                }

                Rectangle {
                    background: disabled ? PrimerColors.bgColor-default : ta.has-hover ? PrimerColors.bgColor-canvas-subtle : PrimerColors.bgColor-default;
                    border-radius: LayoutTokens.borderRadius-medium;
                    border-width: 1px;
                    border-color: trigger-border-color;
                    horizontal-stretch: 1;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 8px;
                        spacing: 8px;
                        horizontal-stretch: 1;

                        Text {
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            text: selected-label != "" ? selected-label : placeholder;
                            font-size: trigger-font;
                            color: selected-label != "" ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                        }

                        Image {
                            vertical-alignment: center;
                            source: Icons.select_chevron;
                            colorize: PrimerColors.fgColor-muted;
                        }
                    }
                }

                ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => {
                        if !root.disabled && root.has-options {
                            select-ctx.show({ x: 0px, y: 0px });
                        }
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: LayoutTokens.text-body-size-small;
            color: PrimerColors.fgColor-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;

            Image {
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.iconButton-icon-size-medium;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ? Icons.alert : Icons.check_circle;
                colorize: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: LayoutTokens.text-body-size-medium;
                color: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
                wrap: word-wrap;
            }
        }
    }
}
