// Primer-style single-line text field. Upstream: https://primer.style/product/components/text-input/
// PR1: shell + label/caption/validation/size/block/disabled/required — minimal chrome (matches Select patterns).

import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { Icons } from "../assets/icons.slint";
import { ValidationStatus } from "../Select/select.slint";
import {
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
    Size,
} from "../tokens.slint";

export component PrimerTextInput {
    in property <string> label-text: "";
    in-out property <string> text: "";
    in property <string> placeholder: "";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <Size> size: medium;
    /// When true, show a trailing asterisk on the label row (Slint has no `required` on builtin `TextInput`).
    in property <bool> required: false;

    callback edited(text: string);

    private property <length> field-height:
        size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    private property <length> field-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    /// Inner horizontal padding for the typing area (Primer TextInputWrapper — no leading/trailing visuals).
    private property <length> field-pad-inline:
        size == Size.small ? 8px : size == Size.large ? 12px : 12px;

    private property <color> field-border-color:
        validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : validation-status == ValidationStatus.success ? PrimerColors.borderColor-success-emphasis : PrimerColors.borderColor-default;

    height: vl.preferred-height;

    vl := VerticalLayout {
        spacing: 6px;
        width: block ? root.width : self.preferred-width;

        if label-text != "": HorizontalLayout {
            spacing: 4px;
            alignment: start;

            Text {
                text: label-text;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: 600;
                color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            if required: Text {
                text: "*";
                color: PrimerColors.fgColor-danger;
                font-size: LayoutTokens.text-body-size-medium;
                vertical-alignment: top;
            }
        }

        Rectangle {
            height: field-height;

            MultiDropShadow {
                width: parent.width;
                height: parent.height;
                border-radius: LayoutTokens.borderRadius-medium;
                shadows: [
                    {
                        color: PrimerColors.shadow-controlTrigger-back,
                        offset-x: 0px,
                        offset-y: 1px,
                        blur: 2px,
                    },
                    {
                        color: PrimerColors.shadow-controlTrigger-front,
                        offset-x: 0px,
                        offset-y: 1px,
                        blur: 1px,
                    },
                ];
            }

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: root.disabled ? PrimerColors.bgColor-muted : PrimerColors.bgColor-default;
                border-radius: LayoutTokens.borderRadius-medium;
                border-width: 1px;
                border-color: field-border-color;
                clip: true;

                // Slint `TextInput` has no built-in placeholder — draw hint behind a transparent full-field editor.
                Rectangle {
                    width: 100%;
                    height: 100%;

                    if root.text == "" && root.placeholder != "": Text {
                        x: field-pad-inline;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - field-pad-inline * 2;
                        text: root.placeholder;
                        font-size: field-font-size;
                        color: PrimerColors.fgColor-muted;
                        overflow: elide;
                    }

                    TextInput {
                        x: field-pad-inline;
                        y: 0px;
                        width: parent.width - field-pad-inline * 2;
                        height: parent.height;
                        vertical-alignment: center;
                        text <=> root.text;
                        read-only: root.disabled;
                        font-size: field-font-size;
                        color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                        edited => {
                            root.edited(self.text);
                        }
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: LayoutTokens.text-body-size-small;
            color: PrimerColors.fgColor-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;

            Image {
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.iconButton-icon-size-medium;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ? Icons.alert : Icons.check_circle;
                colorize: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: LayoutTokens.text-body-size-medium;
                color: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
                wrap: word-wrap;
            }
        }
    }
}
