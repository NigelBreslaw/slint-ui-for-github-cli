// Primer-style single-line text field. Upstream: https://primer.style/product/components/text-input/
// PR1: shell; PR2: TextInputTokens + states (hover, focus, disabled, validation) — TextInputWrapper.module.css.

import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { Icons } from "../assets/icons.slint";
import { ValidationStatus } from "../Select/select.slint";
import {
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
    Size,
    TextInputTokens,
} from "../tokens.slint";

export component PrimerTextInput {
    in property <string> label-text: "";
    in-out property <string> text: "";
    in property <string> placeholder: "";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <Size> size: medium;
    in property <bool> required: false;

    callback edited(text: string);

    private property <bool> input-has-focus: false;

    private property <length> field-height:
        size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    private property <length> field-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    private property <length> field-pad-inline:
        size == Size.small ? 8px : size == Size.large ? 12px : 12px;

    height: vl.preferred-height;

    vl := VerticalLayout {
        spacing: 6px;
        width: block ? root.width : self.preferred-width;

        if label-text != "": HorizontalLayout {
            spacing: 4px;
            alignment: start;

            Text {
                text: label-text;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: 600;
                color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            if required: Text {
                text: "*";
                color: PrimerColors.fgColor-danger;
                font-size: LayoutTokens.text-body-size-medium;
                vertical-alignment: top;
            }
        }

        Rectangle {
            height: field-height;

            MultiDropShadow {
                visible: !root.disabled;
                width: parent.width;
                height: parent.height;
                border-radius: LayoutTokens.borderRadius-medium;
                shadows: [
                    {
                        color: PrimerColors.shadow-controlTrigger-back,
                        offset-x: 0px,
                        offset-y: 1px,
                        blur: 2px,
                    },
                    {
                        color: PrimerColors.shadow-controlTrigger-front,
                        offset-x: 0px,
                        offset-y: 1px,
                        blur: 1px,
                    },
                ];
            }

            ta := TouchArea {
                enabled: !root.disabled;
                width: parent.width;
                height: parent.height;

                field-chrome := Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: TextInputTokens.bg-rest;
                    border-radius: LayoutTokens.borderRadius-medium;
                    border-width: 1px;
                    border-color: TextInputTokens.borderColor-rest;
                    clip: true;

                    Rectangle {
                        width: 100%;
                        height: 100%;

                        if root.text == "" && root.placeholder != "": Text {
                            x: field-pad-inline;
                            y: (parent.height - self.height) / 2;
                            width: parent.width - field-pad-inline * 2;
                            text: root.placeholder;
                            font-size: field-font-size;
                            color: PrimerColors.fgColor-muted;
                            overflow: elide;
                        }

                        inp := TextInput {
                            x: field-pad-inline;
                            y: 0px;
                            width: parent.width - field-pad-inline * 2;
                            height: parent.height;
                            vertical-alignment: center;
                            text <=> root.text;
                            read-only: root.disabled;
                            font-size: field-font-size;
                            color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                            edited => {
                                root.edited(self.text);
                            }
                            changed has-focus => {
                                root.input-has-focus = self.has-focus;
                            }
                        }
                    }

                    states [
                        disabled when root.disabled: {
                            field-chrome.background: TextInputTokens.bg-disabled;
                            field-chrome.border-color: TextInputTokens.border-disabled;
                            field-chrome.border-width: 1px;
                        }
                        focused-error when !root.disabled && root.input-has-focus && root.validation-status == ValidationStatus.error: {
                            field-chrome.background: TextInputTokens.bg-rest;
                            field-chrome.border-color: TextInputTokens.borderColor-error;
                            field-chrome.border-width: 2px;
                        }
                        focused-success when !root.disabled && root.input-has-focus && root.validation-status == ValidationStatus.success: {
                            field-chrome.background: TextInputTokens.bg-rest;
                            field-chrome.border-color: TextInputTokens.borderColor-success;
                            field-chrome.border-width: 2px;
                        }
                        focused when !root.disabled && root.input-has-focus && root.validation-status == ValidationStatus.none: {
                            field-chrome.background: TextInputTokens.bg-rest;
                            field-chrome.border-color: TextInputTokens.borderColor-focus;
                            field-chrome.border-width: 2px;
                        }
                        error when !root.disabled && !root.input-has-focus && root.validation-status == ValidationStatus.error: {
                            field-chrome.background: TextInputTokens.bg-rest;
                            field-chrome.border-color: TextInputTokens.borderColor-error;
                            field-chrome.border-width: 1px;
                        }
                        success when !root.disabled && !root.input-has-focus && root.validation-status == ValidationStatus.success: {
                            field-chrome.background: TextInputTokens.bg-rest;
                            field-chrome.border-color: TextInputTokens.borderColor-success;
                            field-chrome.border-width: 1px;
                        }
                        hover-none when !root.disabled && parent.has-hover && !root.input-has-focus && root.validation-status == ValidationStatus.none: {
                            field-chrome.background: TextInputTokens.bg-hover;
                            field-chrome.border-color: TextInputTokens.borderColor-rest;
                            field-chrome.border-width: 1px;
                        }
                    ]
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: LayoutTokens.text-body-size-small;
            color: PrimerColors.fgColor-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;

            Image {
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.iconButton-icon-size-medium;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ? Icons.alert : Icons.check_circle;
                colorize: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: LayoutTokens.text-body-size-medium;
                color: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
                wrap: word-wrap;
            }
        }
    }
}
