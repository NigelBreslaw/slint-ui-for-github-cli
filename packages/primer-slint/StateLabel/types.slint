/// Mirrors primer-ui-react **`StateLabel.tsx`** `status` (`issueOpened`, **`pullOpened`**, …).
export enum StateLabelStatus {
    IssueOpened,
    PullOpened,
    IssueClosed,
    PullClosed,
    PullMerged,
    Draft,
    IssueDraft,
    PullQueued,
    Unavailable,
    AlertOpened,
    AlertFixed,
    AlertDismissed,
    AlertClosed,
    Open,
    Closed,
    Archived,
}

export enum StateLabelSize {
    small,
    medium,
}
