/// Matches primer-ui-react **`Dialog`** `width` map (`Dialog.tsx` **`widthMap`**).
export enum DialogWidthPreset {
    small,
    medium,
    large,
    xlarge,
}

/// Matches primer-ui-react **`Dialog`** `height` map (`Dialog.tsx` **`heightMap`**).
export enum DialogHeightPreset {
    auto,
    small,
    large,
}

/// Matches primer-ui-react **`Dialog`** **`align`** when **`position`** is **`center`** (viewport modal).
export enum DialogAlignPreset {
    top,
    center,
    bottom,
}

/// Matches **`Dialog`** **`position`** for the **regular** breakpoint (**center** \| **side sheet** **`left`** \| **`right`** — PR7 **`ModalOverlay`**).
export enum DialogPositionPreset {
    center,
    left,
    right,
}

/// Matches **`Dialog`** **`position.narrow`** when viewport **`≤ DialogTokens.narrow-max-width`** (**slideUp** bottom sheet, **`scaleFade`** fullscreen — PR8 **`ModalOverlay`**).
export enum DialogNarrowPositionPreset {
    center,
    bottom,
    fullscreen,
}

export enum DialogFillMode {
    auto,
    screen-height,
    screen-width,
}

/// Footer default actions: wrap when narrow (**`FlexboxLayout`**) vs single row + horizontal pan (**`Flickable`**) — Storybook **`data-footer-button-layout`** (`PR10`).
export enum DialogFooterButtonLayout {
    wrap,
    scroll,
}

/// Which default footer **`Button`** should receive initial keyboard focus (React **`footerButtons` `autoFocus`**, `PR11`). Until footer actions use key-focusable hosts, this is **API parity** only (see **`Dialog`** README).
export enum DialogFooterAutoFocus {
    none,
    default-action,
    danger-action,
    primary-action,
    extra-1,
    extra-2,
}
