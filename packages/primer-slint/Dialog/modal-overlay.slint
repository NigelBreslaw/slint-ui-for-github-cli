import { AppWindow, DialogTokens, OverlayTokens } from "../tokens.slint";
import { OverlayPanelChrome } from "../AO2/overlay-panel-chrome.slint";

export enum OverlayAlign {
    center,
    top,
    bottom,
}

export enum OverlayWidth {
    small,
    medium,
    large,
    xlarge,
}

export enum OverlayHeight {
    auto,
    small,
    large,
}

export component ModalOverlay {

    property <bool> open: false;
    in property <bool> allow-dismiss: true;
    in property <OverlayAlign> align-preset: OverlayAlign.center;
    in property <OverlayWidth> width-preset: OverlayWidth.medium;
    in property <OverlayHeight> height-preset: OverlayHeight.auto;
    in property <length> default-width: width-preset == OverlayWidth.small ? DialogTokens.width-small : root.width-preset == OverlayWidth.medium ? DialogTokens.width-medium : root.width-preset == OverlayWidth.large ? DialogTokens.width-large : DialogTokens.width-xlarge;
    in property <length> default-height: height-preset == OverlayHeight.small ? DialogTokens.height-small : root.height-preset == OverlayHeight.large ? DialogTokens.height-large : OverlayTokens.modal-viewport-max-height;
    property <length> panel-width: min(root.default-width, OverlayTokens.modal-viewport-max-width);
    property <length> panel-height: min(root.default-height, OverlayTokens.modal-viewport-max-height);

    // animation system
    in property <bool> reduce-motion: false;
    property <float> presented: 0.0;
    property <float> pane-scale: 0.5 + 0.5 * presented;

    callback closed();

    states [
        show-animated-pane when root.open && !reduce-motion: {
            presented: 1.0;
            in-out {
                animate presented {
                    duration: DialogTokens.overlay-enter-duration;
                    easing: cubic-bezier(0.33, 1, 0.68, 1);
                }
            }
        }
        show-unanimated-pane when root.open && reduce-motion: {
            presented: 1.0;
        }
    ]

    presented-enter-arm := Timer {
        interval: 1ms;
        running: false;
        triggered() => {
            root.open = true;
            self.stop();
        }
    }

    popup-close-after-exit := Timer {
        interval: DialogTokens.overlay-enter-duration;
        running: false;
        triggered() => {
            popup.close();
            root.closed();
            self.stop();
        }
    }

    callback show();
    show => {
        // Shame root.open cannot be set directly to true. Is this a bug?
        presented-enter-arm.start();
        popup.show();
    }

    callback close();
    close => {
        root.open = false;
        if reduce-motion {
            popup.close();
            root.closed();
        } else {
            popup-close-after-exit.start();
        }
    }

    popup := PopupWindow {
        x: 0px - root.absolute-position.x;
        y: 0px - root.absolute-position.y;
        width: AppWindow.window-width;
        height: AppWindow.window-height;

        close-policy: no-auto-close;
        forward-focus: modal-scope;

        modal-scope := FocusScope {

            key-pressed(event) => {
                if root.allow-dismiss && event.text == Key.Escape {
                    root.close();
                    return accept;
                }
                return reject;
            }

            popup-screen := Rectangle {
                background: OverlayTokens.backdrop-scrim;
                opacity: root.presented;

                ta := TouchArea {
                    clicked => {
                        root.close();
                    }
                }

                pane := Rectangle {
                    width: panel-width;
                    height: min(panel-chrome.chrome-preferred-height, root.panel-height);
                    opacity: presented;
                    transform-scale: pane-scale;

                    touch-blocker := TouchArea { }

                    panel-chrome := OverlayPanelChrome {
                        width: parent.width;
                        height: parent.height;
                        background: OverlayTokens.panel-background;
                        border-color: OverlayTokens.panel-border;
                        border-width: OverlayTokens.panel-border-width;
                        border-radius: OverlayTokens.panel-border-radius;
                        surface-shadows: OverlayTokens.panel-elevation-shadow;

                        @children
                    }

                    states [
                        top when root.align-preset == OverlayAlign.top: {
                            y: 64px;
                        }
                        bottom when root.align-preset == OverlayAlign.bottom: {
                            y: max(0px, AppWindow.window-height - pane.height - 64px);
                        }
                        center when root.align-preset == OverlayAlign.center: {
                            y: (AppWindow.window-height - pane.height) / 2;
                        }
                    ]
                }
            }
        }
    }
}
