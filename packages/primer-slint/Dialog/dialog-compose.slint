// Full-panel composition host (**`@children`** = entire inner shell). Use with **`DialogHeader`**, **`DialogBody`**, **`DialogFooter`** for Storybook **`WithCustomRenderers`** / **`WithDirectSubcomponents`** (`PR9`).
// Sheet-style layouts (**`ModalOverlay`** left / right / narrow bottom): set **`fill-mode`** to **`screen-height`** or **`screen-width`** and drive edge attachment with **`position-preset`** / **`narrow-position-preset`** — do not infer from position alone.
// Viewport modal: **`ModalOverlay`** + clipped inner **`Rectangle`** (formerly **`DialogSurface`**, PR9).

import { ModalOverlay } from "../AnchoredOverlay/modal-overlay.slint";
import {
    AppWindow,
    DialogTokens,
    OverlayTokens,
} from "../tokens.slint";
import {
    DialogAlignPreset,
    DialogHeightPreset,
    DialogNarrowPositionPreset,
    DialogPositionPreset,
    DialogWidthPreset,
    DialogFillMode,
} from "./types.slint";

export component DialogCompose {
    in-out property <bool> open: false;
    in property <DialogWidthPreset> width-preset: DialogWidthPreset.medium;
    in property <DialogHeightPreset> height-preset: DialogHeightPreset.auto;
    in property <DialogAlignPreset> align-preset: DialogAlignPreset.center;
    in property <DialogPositionPreset> position-preset: DialogPositionPreset.center;
    in property <DialogNarrowPositionPreset> narrow-position-preset: DialogNarrowPositionPreset.center;
    in property <bool> narrow-layout: false;
    in property <bool> allow-dismiss: true;
    in property <DialogFillMode> fill-mode: DialogFillMode.auto;
    callback on-close(gesture: string);

    width: 0px;
    height: 0px;

    private property <bool> narrow-active:
        root.narrow-layout || AppWindow.window-width <= DialogTokens.narrow-max-width;

    private property <bool> fill-viewport-height:
        root.fill-mode == DialogFillMode.screen-height
        || (root.narrow-active && root.narrow-position-preset == DialogNarrowPositionPreset.fullscreen);

    private property <length> panel-w:
        width-preset == DialogWidthPreset.small ? DialogTokens.width-small
        : width-preset == DialogWidthPreset.medium ? DialogTokens.width-medium
        : width-preset == DialogWidthPreset.large ? DialogTokens.width-large
        : DialogTokens.width-xlarge;

    private property <length> dialog-panel-max-height:
        root.height-preset == DialogHeightPreset.small ? min(DialogTokens.height-small, OverlayTokens.modal-viewport-max-height)
        : root.height-preset == DialogHeightPreset.large ? min(DialogTokens.height-large, OverlayTokens.modal-viewport-max-height)
        : OverlayTokens.modal-viewport-max-height;

    private property <length> dialog-overlay-max-height:
        root.fill-viewport-height ? AppWindow.window-height : root.dialog-panel-max-height;

    modal-layer := ModalOverlay {
        open <=> root.open;
        panel-width: root.panel-w;
        panel-max-height: root.dialog-overlay-max-height;
        panel-vertical-align: root.align-preset;
        panel-position: root.position-preset;
        narrow-viewport: root.narrow-active;
        narrow-position: root.narrow-position-preset;
        allow-dismiss: root.allow-dismiss;
        slot-padding: 0px;
        close-requested => {
            root.on-close("escape");
        }

        Rectangle {
            min-height: root.fill-mode == DialogFillMode.screen-height ? AppWindow.window-height : 0px;
            min-width: root.fill-mode == DialogFillMode.screen-width ? AppWindow.window-width : 0px;
            max-height: root.dialog-overlay-max-height;
            vertical-stretch: root.fill-viewport-height ? 1 : 0;
            clip: true;

            VerticalLayout {

                @children
            }
        }
    }
}
