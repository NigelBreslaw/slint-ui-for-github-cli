// Primer **Dialog** (default chrome): viewport **`ModalOverlay`**, header + scrollable body + footer actions. Upstream: primer-ui-react `Dialog/Dialog.tsx` + `Dialog.module.css`.

import { ModalOverlay } from "../AnchoredOverlay/modal-overlay.slint";
import {
    Button,
    ButtonVariant,
    IconButton,
    IconButtonVariant,
} from "../Buttons/buttons.slint";
import {
    AppWindow,
    DialogTokens,
    LayoutTokens,
    OverlayTokens,
    PrimerColors,
    Size,
} from "../tokens.slint";
import { Icons } from "../assets/icons.slint";
import {
    DialogAlignPreset,
    DialogHeightPreset,
    DialogNarrowPositionPreset,
    DialogPositionPreset,
    DialogWidthPreset,
} from "./types.slint";

export component Dialog {
    in-out property <bool> open: false;
    in property <string> title: "Dialog";
    in property <string> subtitle: "";
    in property <DialogWidthPreset> width-preset: DialogWidthPreset.xlarge;
    /// Matches React **`Dialog`** **`height`** (**`heightMap`**: **small** = **480px**, **large** = **640px**, **auto** = content up to viewport).
    in property <DialogHeightPreset> height-preset: DialogHeightPreset.auto;
    /// Matches React **`Dialog`** **`align`** when **`position-preset`** is **`center`** (ignored for side sheets **left** / **right**).
    in property <DialogAlignPreset> align-preset: DialogAlignPreset.center;
    /// Matches React **`Dialog`** **`position`** (**regular** breakpoint): **`center`** (default **`ModalOverlay`**) or side sheet **`left`** / **`right`** (**slideIn** motion, full viewport height). When **`narrow-active`** (**`narrow-layout`** or **`AppWindow.window-width ≤ DialogTokens.narrow-max-width`**), **`narrow-position-preset`** wins over **`left`** / **`right`** (**PR8** narrow **`bottom`** / **`fullscreen`**).
    in property <DialogPositionPreset> position-preset: DialogPositionPreset.center;
    /// Matches React **`Dialog`** **`position.narrow`** (**≤767px**): **`center`** (**scaleFade**), **`bottom`** (**slideUp**), **`fullscreen`** (**scaleFade**, full viewport).
    in property <DialogNarrowPositionPreset> narrow-position-preset: DialogNarrowPositionPreset.center;
    /// When **`true`**, **`ModalOverlay`** uses **`narrow-position-preset`** as if the viewport were narrow (gallery / tests). When **`false`**, narrow layout applies when **`AppWindow.window-width ≤ DialogTokens.narrow-max-width`**.
    in property <bool> narrow-layout: false;
    in property <bool> allow-dismiss: true;
    /// When false, no footer row (matches React **`Dialog`** with no **`footerButtons`**). Side sheets (**`left`** / **`right`**) never show a footer regardless of this flag (Primer **Side sheet**).
    in property <bool> show-footer: true;
    in property <bool> show-header: true;

    /// Regular breakpoint **left** / **right** side sheet (not active when **`narrow-active`** — narrow **`bottom`** / **`fullscreen`** use the footer like Storybook).
    private property <bool> regular-side-sheet:
        !root.narrow-active && (root.position-preset == DialogPositionPreset.left || root.position-preset == DialogPositionPreset.right);

    private property <bool> footer-visible:
        root.show-footer && !root.regular-side-sheet;

    /// **`AppWindow`** ≤ **`DialogTokens.narrow-max-width`** or **`narrow-layout`** override.
    private property <bool> narrow-active:
        root.narrow-layout || AppWindow.window-width <= DialogTokens.narrow-max-width;

    /// Regular **left** / **right** side sheet shell (**`narrow-active`** uses **`narrow-position-preset`** instead).
    private property <bool> is-side-sheet-layout:
        !root.narrow-active && root.position-preset != DialogPositionPreset.center;

    /// Full viewport height shell: side sheet or **narrow fullscreen**.
    private property <bool> is-tall-shell:
        root.is-side-sheet-layout || (root.narrow-active && root.narrow-position-preset == DialogNarrowPositionPreset.fullscreen);

    in property <string> footer-default-label: "Open Second Dialog";
    in property <string> footer-danger-label: "Delete the universe";
    in property <string> footer-primary-label: "Proceed";

    callback footer-default-clicked();
    callback footer-danger-clicked();
    callback footer-primary-clicked();
    /// **`close-button`** (×), **`escape`** (Escape or backdrop — matches React `onClose` argument for backdrop).
    callback on-close(gesture: string);

    width: 0px;
    height: 0px;

    private property <length> panel-w:
        width-preset == DialogWidthPreset.small ? DialogTokens.width-small
        : width-preset == DialogWidthPreset.medium ? DialogTokens.width-medium
        : width-preset == DialogWidthPreset.large ? DialogTokens.width-large
        : DialogTokens.width-xlarge;

    /// Center-mode cap for **`ModalOverlay.panel-max-height`** (**`height-preset`** ∩ **`OverlayTokens.modal-viewport-max-height`** in **`ModalOverlay`**).
    private property <length> dialog-panel-max-height:
        root.height-preset == DialogHeightPreset.small ? min(DialogTokens.height-small, OverlayTokens.modal-viewport-max-height)
        : root.height-preset == DialogHeightPreset.large ? min(DialogTokens.height-large, OverlayTokens.modal-viewport-max-height)
        : OverlayTokens.modal-viewport-max-height;

    /// Passed to **`ModalOverlay.panel-max-height`** — side sheets and **narrow fullscreen** use **`AppWindow.window-height`**; otherwise **`height-preset`** cap (**narrow bottom** uses the same cap as centered modals).
    private property <length> dialog-overlay-max-height:
        root.is-side-sheet-layout || (root.narrow-active && root.narrow-position-preset == DialogNarrowPositionPreset.fullscreen) ? AppWindow.window-height : root.dialog-panel-max-height;

    /// Upper bound for the body **`Flickable`** viewport (**`shell max`** − header/footer estimates). Uses tokens only — avoids **`height: parent.height`** ↔ **`OverlayPanelChrome`** preferred-height cycles.
    private property <length> dialog-header-region-est:
        root.show-header
        ? DialogTokens.header-padding * 2
        + DialogTokens.header-content-padding-block * 2
        + DialogTokens.title-font-size
        + (root.subtitle != "" ? DialogTokens.header-title-subtitle-gap + DialogTokens.subtitle-font-size : 0px)
        + 1px
        : 0px;

    private property <length> dialog-footer-region-est:
        root.footer-visible ? 1px + DialogTokens.footer-padding * 2 + LayoutTokens.control-medium-size : 0px;

    private property <length> body-flick-max-h: max(root.dialog-overlay-max-height - root.dialog-header-region-est - root.dialog-footer-region-est, DialogTokens.body-padding * 2 + LayoutTokens.text-body-size-small);

    modal-layer := ModalOverlay {
        open <=> root.open;
        panel-width: root.panel-w;
        panel-max-height: root.dialog-overlay-max-height;
        panel-vertical-align: root.align-preset;
        panel-position: root.position-preset;
        narrow-viewport: root.narrow-active;
        narrow-position: root.narrow-position-preset;
        allow-dismiss: root.allow-dismiss;
        slot-padding: 0px;
        close-requested => {
            root.on-close("escape");
        }

        Rectangle {
            max-height: root.dialog-overlay-max-height;
            vertical-stretch: root.is-tall-shell ? 1 : 0;
            clip: true;

            VerticalLayout {
                alignment: start;
                vertical-stretch: root.is-tall-shell ? 1 : 0;

                if root.show-header: VerticalLayout {
                    padding-left: DialogTokens.header-padding;
                    padding-right: DialogTokens.header-padding;
                    padding-top: DialogTokens.header-padding;
                    padding-bottom: DialogTokens.header-padding;

                    HorizontalLayout {
                        width: 100%;
                        spacing: LayoutTokens.button-content-gap;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            padding-left: DialogTokens.header-content-padding-inline;
                            padding-right: DialogTokens.header-content-padding-inline;
                            padding-top: DialogTokens.header-content-padding-block;
                            padding-bottom: DialogTokens.header-content-padding-block;
                            spacing: root.subtitle != "" ? DialogTokens.header-title-subtitle-gap : 0px;

                            Text {
                                text: root.title;
                                color: PrimerColors.fgColor-default;
                                font-size: DialogTokens.title-font-size;
                                font-weight: DialogTokens.title-font-weight;
                                wrap: word-wrap;
                            }

                            if root.subtitle != "": Text {
                                text: root.subtitle;
                                color: PrimerColors.fgColor-muted;
                                font-size: DialogTokens.subtitle-font-size;
                                font-weight: DialogTokens.subtitle-font-weight;
                                wrap: word-wrap;
                            }
                        }

                        IconButton {
                            variant: IconButtonVariant.invisible;
                            size: Size.medium;
                            icon-source: Icons.x;
                            clicked => {
                                root.open = false;
                                root.on-close("close-button");
                            }
                        }
                    }

                    Rectangle {
                        width: 100%;
                        height: 1px;
                        background: PrimerColors.borderColor-default;
                    }
                }

                body-flick := Flickable {
                    height: root.is-tall-shell ? root.body-flick-max-h : min(body-inner.preferred-height, root.body-flick-max-h);
                    viewport-width: self.width;
                    viewport-height: body-inner.preferred-height;

                    body-inner := VerticalLayout {
                        width: parent.width;
                        padding: DialogTokens.body-padding;
                        spacing: DialogTokens.body-block-spacing;
                        alignment: start;

                        @children
                    }
                }

                if root.footer-visible: VerticalLayout {
                    Rectangle {
                        height: 1px;
                        background: PrimerColors.borderColor-default;
                    }

                    FlexboxLayout {
                        flex-direction: row;
                        flex-wrap: wrap;
                        alignment: end;
                        padding: DialogTokens.footer-padding;
                        spacing: DialogTokens.footer-actions-gap;

                        Button {
                            label: root.footer-default-label;
                            variant: ButtonVariant.default;
                            clicked => {
                                root.footer-default-clicked();
                            }
                        }

                        Button {
                            label: root.footer-danger-label;
                            variant: ButtonVariant.danger;
                            clicked => {
                                root.footer-danger-clicked();
                            }
                        }

                        Button {
                            label: root.footer-primary-label;
                            variant: ButtonVariant.primary;
                            clicked => {
                                root.footer-primary-clicked();
                            }
                        }
                    }
                }
            }
        }
    }
}
