// Storybook **`Dialog.Header`** / **`Dialog.Body`** / **`Dialog.Footer`**-style building blocks for **`DialogCompose`** (`PR9`) â€” footer layout / visibility aligned with **`Dialog`** (`PR10`).

import {
    Button,
    ButtonVariant,
    IconButton,
    IconButtonVariant,
} from "../Buttons/buttons.slint";
import { DialogTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";
import { Icons } from "../assets/icons.slint";
import { DialogFooterButtonLayout } from "./types.slint";

/// Header row + optional Ă— close + bottom divider â€” main region is **`@children`** (custom **`renderHeader`** body).
export component DialogHeader {
    in property <bool> show-close-button: true;
    callback close-requested();

    VerticalLayout {
        padding-left: DialogTokens.header-padding;
        padding-right: DialogTokens.header-padding;
        padding-top: DialogTokens.header-padding;
        padding-bottom: DialogTokens.header-padding;

        HorizontalLayout {
            width: 100%;
            spacing: LayoutTokens.button-content-gap;

            VerticalLayout {
                horizontal-stretch: 1;
                padding-left: DialogTokens.header-content-padding-inline;
                padding-right: DialogTokens.header-content-padding-inline;
                padding-top: DialogTokens.header-content-padding-block;
                padding-bottom: DialogTokens.header-content-padding-block;
                spacing: DialogTokens.body-block-spacing;
                alignment: start;

                @children
            }

            if root.show-close-button: IconButton {
                variant: IconButtonVariant.invisible;
                size: Size.medium;
                icon-source: Icons.x;
                clicked => {
                    root.close-requested();
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 1px;
            background: PrimerColors.borderColor-default;
        }
    }
}

/// Scrollable body â€” fills remaining height between **`DialogHeader`** and **`DialogFooter`** inside a stretching **`VerticalLayout`**.
export component DialogBody {
    vertical-stretch: 1;
    min-height: 0px;

    flick := Flickable {
        vertical-stretch: 1;
        viewport-width: self.width;
        viewport-height: inner.preferred-height;

        inner := VerticalLayout {
            width: parent.width;
            padding: DialogTokens.body-padding;
            spacing: DialogTokens.body-block-spacing;
            alignment: start;

            @children
        }
    }
}

/// Footer divider + default actions (**`use-default-actions`**) or custom **`@children`** (**`HorizontalLayout`** slot).
export component DialogFooter {
    in property <bool> use-default-actions: true;
    in property <string> default-label: "Open Second Dialog";
    in property <string> danger-label: "Delete the universe";
    in property <string> primary-label: "Proceed";
    in property <DialogFooterButtonLayout> footer-button-layout: DialogFooterButtonLayout.wrap;
    in property <bool> footer-has-default-button: true;
    in property <bool> footer-has-danger-button: true;
    in property <bool> footer-has-primary-button: true;
    in property <string> footer-extra-1-label: "";
    in property <string> footer-extra-2-label: "";

    callback default-clicked();
    callback danger-clicked();
    callback primary-clicked();
    callback footer-extra-1-clicked();
    callback footer-extra-2-clicked();

    private property <length> footer-strip-height:
        DialogTokens.footer-padding * 2 + LayoutTokens.control-medium-size;

    private property <bool> default-actions-shown:
        root.footer-has-default-button
        || root.footer-has-danger-button
        || root.footer-has-primary-button
        || root.footer-extra-1-label != ""
        || root.footer-extra-2-label != "";

    VerticalLayout {
        visible: !root.use-default-actions || root.default-actions-shown;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        if root.use-default-actions && root.footer-button-layout == DialogFooterButtonLayout.scroll: Flickable {
            width: 100%;
            height: root.footer-strip-height;
            viewport-width: footer-scroll-inner.preferred-width;
            viewport-height: self.height;

            footer-scroll-inner := HorizontalLayout {
                spacing: DialogTokens.footer-actions-gap;
                alignment: end;
                padding: DialogTokens.footer-padding;

                if root.footer-has-default-button: Button {
                    label: root.default-label;
                    variant: ButtonVariant.default;
                    clicked => {
                        root.default-clicked();
                    }
                }

                if root.footer-extra-1-label != "": Button {
                    label: root.footer-extra-1-label;
                    variant: ButtonVariant.default;
                    clicked => {
                        root.footer-extra-1-clicked();
                    }
                }

                if root.footer-extra-2-label != "": Button {
                    label: root.footer-extra-2-label;
                    variant: ButtonVariant.default;
                    clicked => {
                        root.footer-extra-2-clicked();
                    }
                }

                if root.footer-has-danger-button: Button {
                    label: root.danger-label;
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.danger-clicked();
                    }
                }

                if root.footer-has-primary-button: Button {
                    label: root.primary-label;
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.primary-clicked();
                    }
                }
            }
        }

        if root.use-default-actions && root.footer-button-layout == DialogFooterButtonLayout.wrap: FlexboxLayout {
            flex-direction: row;
            flex-wrap: wrap;
            alignment: end;
            padding: DialogTokens.footer-padding;
            spacing: DialogTokens.footer-actions-gap;

            if root.footer-has-default-button: Button {
                label: root.default-label;
                variant: ButtonVariant.default;
                clicked => {
                    root.default-clicked();
                }
            }

            if root.footer-extra-1-label != "": Button {
                label: root.footer-extra-1-label;
                variant: ButtonVariant.default;
                clicked => {
                    root.footer-extra-1-clicked();
                }
            }

            if root.footer-extra-2-label != "": Button {
                label: root.footer-extra-2-label;
                variant: ButtonVariant.default;
                clicked => {
                    root.footer-extra-2-clicked();
                }
            }

            if root.footer-has-danger-button: Button {
                label: root.danger-label;
                variant: ButtonVariant.danger;
                clicked => {
                    root.danger-clicked();
                }
            }

            if root.footer-has-primary-button: Button {
                label: root.primary-label;
                variant: ButtonVariant.primary;
                clicked => {
                    root.primary-clicked();
                }
            }
        }

        HorizontalLayout {
            visible: !root.use-default-actions;
            width: 100%;
            padding: DialogTokens.footer-padding;
            spacing: DialogTokens.footer-actions-gap;
            alignment: end;

            @children
        }
    }
}
