// Standalone Primer Pagination (nav strip only) — upstream: primer-ui-react `Pagination/Pagination.tsx`.
// Reuses `PaginationLogic` / `PaginationPiece` from `../Pagination/` (shared strip model with composed table footers).
// Callback `page-changed` emits **0-based page index** (app state); `current-page` is **1-based** (React-style).
import { Icons } from "../assets/icons.slint";
import { ButtonTokens, LayoutTokens, PrimerColors } from "../tokens.slint";
import { PaginationPiece, PaginationPieceKind } from "../Pagination/types.slint";
import { PaginationLogic } from "../Pagination/pagination-logic.slint";

/// Link-style page control (32×32 parity with Primer `.Page` / `Pagination.module.css`).
component Pagination2LinkCell {
    in property <bool> disabled;
    in property <bool> selected;
    /// Prev/next use **`fgColor-accent`** when enabled.
    in property <bool> accent-fg;
    in property <string> label;
    in property <bool> has-leading-icon: false;
    in property <bool> has-trailing-icon: false;
    in property <image> leading-icon;
    in property <image> trailing-icon;
    callback clicked;

    property <color> symbol-fg: root.disabled
        ? ButtonTokens.button-invisible-fgColor-disabled
        : root.selected
            ? PrimerColors.fgOnEmphasis
            : root.accent-fg
                ? PrimerColors.fgColor-accent
                : PrimerColors.fgColor-default;

    fs := FocusScope {
        enabled: !root.disabled;
        focus-on-click: false;

        key-pressed(event) => {
            if root.disabled {
                return reject;
            }
            if event.text == Key.Return || event.text == Key.Space {
                root.clicked();
                return accept;
            }
            return reject;
        }

        touch := TouchArea {
            enabled: !root.disabled;
            mouse-cursor: root.disabled ? default : pointer;
            clicked => {
                root.clicked();
            }

            cell := Rectangle {
                min-width: LayoutTokens.control-medium-size;
                min-height: LayoutTokens.control-medium-size;
                border-radius: LayoutTokens.borderRadius-medium;
                border-width: (fs.has-focus && !root.disabled) ? 2px : 0px;
                border-color: PrimerColors.bgColor-accent-emphasis;

                HorizontalLayout {
                    alignment: center;
                    padding-left: LayoutTokens.control-medium-paddingInline-normal;
                    padding-right: LayoutTokens.control-medium-paddingInline-normal;
                    spacing: (root.has-leading-icon || root.has-trailing-icon) ? LayoutTokens.base-size-4 : 0px;
                    align-items: center;
                    if root.has-leading-icon: Image {
                        width: LayoutTokens.iconButton-icon-size-medium;
                        height: LayoutTokens.iconButton-icon-size-medium;
                        vertical-alignment: center;
                        source: root.leading-icon;
                        colorize: root.symbol-fg;
                    }

                    Text {
                        text: root.label;
                        color: root.symbol-fg;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: root.selected && !root.disabled
                            ? LayoutTokens.base-text-weight-semibold
                            : LayoutTokens.base-text-weight-medium;
                        vertical-alignment: center;
                        wrap: no-wrap;
                    }

                    if root.has-trailing-icon: Image {
                        width: LayoutTokens.iconButton-icon-size-medium;
                        height: LayoutTokens.iconButton-icon-size-medium;
                        vertical-alignment: center;
                        source: root.trailing-icon;
                        colorize: root.symbol-fg;
                    }
                }

                states [
                    disabled when root.disabled: {
                        border-width: 0px;
                    }
                    selected when !root.disabled && root.selected: {
                        background: PrimerColors.bgColor-accent-emphasis;
                    }
                    pressed when !root.disabled && !root.selected && touch.pressed: {
                        background: ButtonTokens.button-invisible-bgColor-active;
                    }
                    hover when !root.disabled && !root.selected && !touch.pressed && touch.has-hover: {
                        background: PrimerColors.table-row-bgColor-hover;
                    }
                ]
            }
        }
    }
}

component Pagination2NavItem inherits HorizontalLayout {
    in property <PaginationPiece> piece;
    callback activate(int);

    horizontal-stretch: 0;
    min-height: LayoutTokens.control-medium-size;

    if piece.kind == PaginationPieceKind.Prev: Pagination2LinkCell {
        disabled: piece.disabled;
        selected: false;
        accent-fg: true;
        label: "Previous";
        has-leading-icon: true;
        leading-icon: Icons.chevron_left;
        clicked => {
            activate(piece.page_num - 1);
        }
    }

    if piece.kind == PaginationPieceKind.Next: Pagination2LinkCell {
        disabled: piece.disabled;
        selected: false;
        accent-fg: true;
        label: "Next";
        has-trailing-icon: true;
        trailing-icon: Icons.chevron_right;
        clicked => {
            activate(piece.page_num - 1);
        }
    }

    if piece.kind == PaginationPieceKind.Num: Pagination2LinkCell {
        disabled: piece.disabled;
        selected: piece.selected;
        accent-fg: false;
        label: piece.page_num;
        clicked => {
            activate(piece.page_num - 1);
        }
    }

    if piece.kind == PaginationPieceKind.Break: HorizontalLayout {
        min-height: LayoutTokens.control-medium-size;
        min-width: LayoutTokens.control-medium-size;

        Text {
            text: "…";
            color: PrimerColors.fgColor-muted;
            font-size: LayoutTokens.text-body-size-medium;
            vertical-alignment: center;
        }
    }
}

export component Pagination2 {
    in property <int> page-count: 1;
    in-out property <int> current-page: 1;
    in property <bool> show-pages: true;
    in property <int> margin-page-count: 1;
    in property <int> surrounding-page-count: 2;
    callback page-changed(int);

    /// Non-negative margins (negative **`margin-page-count`** / **`surrounding-page-count`** are treated as 0).
    property <int> margin-safe: max(0, margin-page-count);
    property <int> surrounding-safe: max(0, surrounding-page-count);

    property <int> current-1based: PaginationLogic.clamp_current_page_1based(current-page, page-count);
    property <int> model-len: PaginationLogic.model_len(
        page-count,
        current-1based,
        show-pages,
        margin-safe,
        surrounding-safe,
    );

    // Use `clamp_current_page_1based(current-page, page-count)` here, not `current-1based`: `changed` can run
    // before dependent properties are refreshed, so reading `current-1based` would compare against a stale value
    // and overwrite every navigation (e.g. page 2 snapped back to 1).
    changed current-page => {
        if root.current-page != PaginationLogic.clamp_current_page_1based(root.current-page, root.page-count) {
            root.current-page = PaginationLogic.clamp_current_page_1based(root.current-page, root.page-count);
        }
    }

    changed page-count => {
        if root.current-page != PaginationLogic.clamp_current_page_1based(root.current-page, root.page-count) {
            root.current-page = PaginationLogic.clamp_current_page_1based(root.current-page, root.page-count);
        }
    }

    min-height: LayoutTokens.control-medium-size;

    HorizontalLayout {
        spacing: LayoutTokens.button-content-gap;
        alignment: center;

        for i in model-len: Pagination2NavItem {
            piece: PaginationLogic.piece_at(
                i,
                page-count,
                current-1based,
                show-pages,
                margin-safe,
                surrounding-safe,
            );
            activate(idx) => {
                root.page-changed(idx);
            }
        }
    }
}
