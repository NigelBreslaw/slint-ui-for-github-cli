import { Palette } from "std-widgets.slint";
import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { Spinner } from "../Progress/spinner.slint";
import {
    ButtonAlignContent,
    ButtonCounterPaint,
    ButtonPaint,
    ButtonShadowState,
    ButtonVariant,
} from "./types.slint";
import { CounterLabel } from "../CounterLabel/counter-label.slint";
import { ButtonLogic } from "./logic.slint";
import { ButtonTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";

export { ButtonAlignContent, ButtonVariant }

// Filled height/padding follow `size`; link is content-sized (StyledText has no font-size in Slint).
// Colors: ButtonTokens (button palette) + PrimerColors (semantic fg/link/inset). Link label: StyledText + @markdown.
export component Button {
    in property <ButtonVariant> variant: ButtonVariant.default;
    in property <Size> size: Size.medium;
    in property <bool> disabled: false;
    in property <string> label: "";
    in property <bool> loading: false;
    in property <ButtonAlignContent> align-content: ButtonAlignContent.center;
    in property <string> count: "";
    in property <bool> has-leading-icon: false;
    in property <image> leading-icon;
    in property <string> leading-text: "";
    in property <bool> has-trailing-icon: false;
    in property <image> trailing-icon;
    in property <string> trailing-text: "";
    callback clicked <=> ta.clicked;

    // When true, label + adjacent leading/trailing text/icons in the filled row use the overrides below instead of `paint.fg` / default label size+weight (e.g. UnderlineNav selected vs muted).
    in property <bool> label-typography-override: false;
    in property <length> label-font-size-override: 0px;
    in property <int> label-font-weight-override: 500;
    in property <color> label-color-override: #000000;

    // Primer ButtonBase: only [data-size='small'] changes font-size; large keeps text-body-size-medium (L9 + L165–179).
    property <length> filled-label-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    property <length> btn-padding-inline:
        size == Size.small
        ? LayoutTokens.control-small-paddingInline-condensed
        : size == Size.large ? LayoutTokens.control-large-paddingInline-spacious : LayoutTokens.control-medium-paddingInline-normal;

    property <length> btn-control-height:
        size == Size.small
        ? LayoutTokens.control-small-size
        : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;
    property <bool> is-link: variant == ButtonVariant.link;
    property <bool> primary-pressed: variant == ButtonVariant.primary && ta.pressed;
    property <bool> danger-pressed: variant == ButtonVariant.danger && ta.pressed;
    property <bool> danger-hover: variant == ButtonVariant.danger && ta.has-hover && !ta.pressed;
    property <bool> has-leading-slot: leading-text != "" || has-leading-icon;
    property <bool> show-trailing-visual: trailing-text != "" || has-trailing-icon;
    property <bool> show-count: count != "" && !show-trailing-visual;
    property <bool> loading-replaces-leading: loading && has-leading-slot;
    property <bool> loading-replaces-trailing: loading && !has-leading-slot && (show-trailing-visual || show-count);
    property <bool> loading-only-spinner: loading && !has-leading-slot && !show-trailing-visual && !show-count;
    property <bool> danger-counter-hover: variant == ButtonVariant.danger && !disabled && (ta.has-hover || ta.pressed);
    property <length> btn-icon-size:
        size == Size.small
        ? LayoutTokens.iconButton-icon-size-small
        : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;
    property <Size> btn-spinner-size: size == Size.large ? Size.medium : Size.small;
    property <color> btn-spinner-track: is-dark ? #ffffff30 : #1f232830;

    property <ButtonPaint> paint: ButtonLogic.button-paint(variant, disabled, ta.has-hover, ta.pressed);
    property <length> effective-label-font-size: label-typography-override ? label-font-size-override : filled-label-font-size;
    property <int> effective-label-font-weight: label-typography-override ? label-font-weight-override : LayoutTokens.base-text-weight-medium;
    property <color> effective-label-fg: label-typography-override ? label-color-override : paint.fg;
    property <ButtonCounterPaint> btn-counter-paint: ButtonLogic.button-counter-paint(variant, disabled, danger-counter-hover, paint.fg);
    property <ButtonShadowState> btn-sh: ButtonLogic.button-shadow(variant, disabled, is-dark, danger-pressed, primary-pressed, danger-hover);

    MultiDropShadow {
        width: parent.width;
        height: parent.height;
        border-radius: is-link ? 0px : LayoutTokens.borderRadius-medium;
        shadows: [
            { color: btn-sh.back-color, offset-x: 0px, offset-y: btn-sh.back-y, blur: btn-sh.back-blur },
            { color: btn-sh.front-color, offset-x: 0px, offset-y: btn-sh.front-y, blur: btn-sh.front-blur },
        ];
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: paint.bg;
        border-radius: is-link ? 0px : LayoutTokens.borderRadius-medium;
        border-width: is-link ? 0px : 1px;
        border-color: paint.border;
    }

    // HorizontalLayout.alignment is main-axis (horizontal) only; cross-axis defaults to top. Center the row vertically.
    filled-outer := VerticalLayout {
        visible: !is-link;
        height: btn-icon-size;
        alignment: center;


        filled-row := HorizontalLayout {
            height: btn-icon-size;
            padding-left: align-content == ButtonAlignContent.start ? btn-padding-inline: btn-padding-inline * 2;
            padding-right: align-content == ButtonAlignContent.start ? btn-padding-inline: btn-padding-inline * 2;
            spacing: LayoutTokens.button-content-gap;
            align-items: center;


            if loading-only-spinner || loading-replaces-leading: Spinner {
                // y: (parent.height - self.height) / 2;
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-leading && leading-text != "": Text {
                // y: (parent.height - self.height) / 2;
                text: leading-text;
                color: effective-label-fg;
                font-size: effective-label-font-size;
                font-weight: effective-label-font-weight;
                vertical-alignment: center;
            }

            if !loading-replaces-leading && leading-text == "" && has-leading-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: leading-icon;
                colorize: effective-label-fg;
            }

            if !loading-only-spinner: Text {
                // y: (parent.height - self.preferred-height) / 2;
                text: root.label;
                color: effective-label-fg;
                font-size: effective-label-font-size;
                font-weight: effective-label-font-weight;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                height: self.preferred-height;
                overflow: elide;
                font-family: "Mona Sans";
            }

            if loading-replaces-trailing: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-trailing && show-count: CounterLabel {
                text: count;
                background: btn-counter-paint.bg;
                foreground: btn-counter-paint.fg;
                counter-border: ButtonTokens.buttonCounter-borderColor;
            }

            if !loading-replaces-trailing && !show-count && trailing-text != "": Text {
                text: trailing-text;
                color: effective-label-fg;
                font-size: effective-label-font-size;
                font-weight: effective-label-font-weight;
                vertical-alignment: center;
            }

            if !loading-replaces-trailing && !show-count && trailing-text == "" && has-trailing-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: trailing-icon;
                colorize: effective-label-fg;
            }
        }
    }

    // Link: same slot model as filled (leading / trailing / count / loading); label uses StyledText + @markdown per hover.
    link-outer := VerticalLayout {
        visible: is-link;
        height: 100%;
        alignment: align-content == ButtonAlignContent.center ? center : start;

        link-row := HorizontalLayout {
            spacing: LayoutTokens.button-content-gap;
            alignment: align-content == ButtonAlignContent.center ? center : start;

            if loading-only-spinner: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if loading-replaces-leading: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-leading && leading-text != "": Text {
                text: leading-text;
                color: paint.fg;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }
            if !loading-replaces-leading && leading-text == "" && has-leading-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: leading-icon;
                colorize: paint.fg;
            }

            if is-link && disabled && !loading-only-spinner: Text {
                text: root.label;
                color: paint.fg;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                overflow: elide;
                font-family: "Mona Sans";
            }

            link-md := StyledText {
                visible: is-link && !disabled && !loading-only-spinner && !ta.has-hover;
                text: @markdown("[\{label}](#)");
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                link-color: PrimerColors.fgColor-link;
            }

            link-md-hover := StyledText {
                visible: is-link && !disabled && !loading-only-spinner && ta.has-hover;
                text: @markdown("[<u>\{label}</u>](#)");
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                link-color: PrimerColors.fgColor-link;
            }

            if loading-replaces-trailing: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-trailing && show-count: CounterLabel {
                text: count;
                background: btn-counter-paint.bg;
                foreground: btn-counter-paint.fg;
                counter-border: ButtonTokens.buttonCounter-borderColor;
            }

            if !loading-replaces-trailing && !show-count && trailing-text != "": Text {
                text: trailing-text;
                color: paint.fg;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }

            if !loading-replaces-trailing && !show-count && trailing-text == "" && has-trailing-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: trailing-icon;
                colorize: paint.fg;
            }
        }
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: !disabled && !loading;
    }

    width: is-link ? link-row.preferred-width : filled-row.preferred-width;
    height: is-link ? link-outer.preferred-height : btn-control-height;
}


export enum IconButtonVariant {
    default,
    primary,
    danger,
    invisible,
}

struct ButtonStyle {
    button-default-fgColor-rest: color,
    button-default-bgColor-active: color,
    button-default-bgColor-hover: color,
    button-default-borderColor-active: color,
}

export component IconButton {

    in property <Size> size: Size.medium;
    in property <IconButtonVariant> variant: IconButtonVariant.default;
    in property icon-source <=> img.source;
    callback clicked <=> ta.clicked;

    in property <ButtonStyle> style: {
        button-default-fgColor-rest: ButtonTokens.iconButton-fgColor-rest,
        button-default-bgColor-active: PrimerColors.bgColor-inset,
        button-default-bgColor-hover: ButtonTokens.iconButton-bgColor-hover,
        button-default-borderColor-active: ButtonTokens.color-btn-border,
    };

    property <bool> is-invisible: variant == IconButtonVariant.invisible;

    property <length> ib-border-width: is-invisible ? 0px : 1px;

    property <color> ib-border-color: is-invisible ? transparent : style.button-default-borderColor-active;

    property <color> ib-bg-rest: is-invisible ? transparent : style.button-default-bgColor-active;

    property <length> icon-img-size:
        size == Size.small
        ? LayoutTokens.iconButton-icon-size-small
        : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;

    width: size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;
    height: self.width;

    Rectangle {
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: ib-border-width;
        border-color: ib-border-color;
        background: ta.has-hover ? style.button-default-bgColor-hover : ib-bg-rest;

    }

    img := Image {
        width: icon-img-size;
        height: icon-img-size;
        colorize: style.button-default-fgColor-rest;
    }

    ta := TouchArea {

    }
}
