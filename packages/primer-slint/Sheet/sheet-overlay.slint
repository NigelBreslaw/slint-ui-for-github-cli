import { AppWindow, DialogTokens, OverlayTokens } from "../tokens.slint";
import { OverlayPanelChrome } from "../Overlays/overlay-panel-chrome.slint";

export enum SheetSide {
    left,
    right,
    bottom,
}

struct sheet-border-radius { top-left: length, top-right: length, bottom-left: length, bottom-right: length}

export component SheetOverlay {

    in property <SheetSide> side: SheetSide.right;
    property <bool> open: false;
    in property <bool> allow-dismiss: true;
    in property <bool> reduce-motion: false;
    in property <length> default-panel-width: 640px;
    in property <length> default-panel-height: 480px;

    property <length> panel-width: min(root.default-panel-width, OverlayTokens.modal-viewport-max-width);
    property <length> panel-height: min(root.default-panel-height, OverlayTokens.modal-viewport-max-height);

    property <float> presented: 0.0;

    property <sheet-border-radius> left-sheet-border-radius: {
        top-left: 0px,
        top-right: OverlayTokens.panel-border-radius,
        bottom-left: 0px,
        bottom-right: OverlayTokens.panel-border-radius
    };

    property <sheet-border-radius> right-sheet-border-radius: {
        top-left: OverlayTokens.panel-border-radius,
        top-right: 0px,
        bottom-left: OverlayTokens.panel-border-radius,
        bottom-right: 0px
    };

    property <sheet-border-radius> bottom-sheet-border-radius: {
        top-left: OverlayTokens.panel-border-radius,
        top-right: OverlayTokens.panel-border-radius,
        bottom-left: 0px,
        bottom-right: 0px
    };

    property <sheet-border-radius> chrome-border-radius: root.side == SheetSide.left ? root.left-sheet-border-radius : root.side == SheetSide.right ? root.right-sheet-border-radius : root.bottom-sheet-border-radius;

    callback closed();

    states [
        show-animated-pane when root.open && !reduce-motion: {
            presented: 1.0;
            in-out {
                animate presented {
                    duration: DialogTokens.overlay-sheet-enter-duration;
                    easing: cubic-bezier(0.33, 1, 0.68, 1);
                }
            }
        }
        show-unanimated-pane when root.open && reduce-motion: {
            presented: 1.0;
        }
    ]

    presented-enter-arm := Timer {
        interval: 1ms;
        running: false;
        triggered() => {
            root.open = true;
            self.stop();
        }
    }

    popup-close-after-exit := Timer {
        interval: DialogTokens.overlay-sheet-enter-duration;
        running: false;
        triggered() => {
            popup.close();
            root.closed();
            self.stop();
        }
    }

    callback show();
    show => {
        presented-enter-arm.start();
        popup.show();
    }

    callback close();
    close => {
        root.open = false;
        if reduce-motion {
            popup.close();
            root.closed();
        } else {
            popup-close-after-exit.start();
        }
    }

    popup := PopupWindow {
        x: 0px - root.absolute-position.x;
        y: 0px - root.absolute-position.y;
        width: AppWindow.window-width;
        height: AppWindow.window-height;

        close-policy: no-auto-close;
        forward-focus: modal-scope;

        modal-scope := FocusScope {

            key-pressed(event) => {
                if root.allow-dismiss && event.text == Key.Escape {
                    root.close();
                    return accept;
                }
                return reject;
            }

            popup-screen := Rectangle {
                background: OverlayTokens.backdrop-scrim;
                opacity: root.presented;

                ta := TouchArea {
                    enabled: root.allow-dismiss && root.open;
                    clicked => {
                        root.close();
                    }
                }
            }

            pane := Rectangle {

                touch-blocker := TouchArea { }

                panel-chrome := OverlayPanelChrome {
                    width: parent.width;
                    height: parent.height;
                    background: OverlayTokens.panel-background;
                    border-color: OverlayTokens.panel-border;
                    border-width: OverlayTokens.panel-border-width;
                    shadow-border-radius: OverlayTokens.panel-border-radius;
                    border-top-left-radius: root.chrome-border-radius.top-left;
                    border-top-right-radius: root.chrome-border-radius.top-right;
                    border-bottom-left-radius: root.chrome-border-radius.bottom-left;
                    border-bottom-right-radius: root.chrome-border-radius.bottom-right;
                    surface-shadows: OverlayTokens.panel-elevation-shadow;

                    @children
                }

                states [
                    sheet-left when root.side == SheetSide.left: {
                        pane.x: root.panel-width * root.presented - root.panel-width;
                        pane.y: 0px;
                        pane.width: root.panel-width;
                        pane.height: AppWindow.window-height;
                    }
                    sheet-right when root.side == SheetSide.right: {
                        pane.x: AppWindow.window-width - root.panel-width * root.presented;
                        pane.y: 0px;
                        pane.width: root.panel-width;
                        pane.height: AppWindow.window-height;
                    }
                    sheet-bottom when root.side == SheetSide.bottom: {
                        pane.x: 0px;
                        pane.y: AppWindow.window-height - pane.height * root.presented;
                        pane.width: AppWindow.window-width;
                        pane.height: min(panel-chrome.chrome-preferred-height, root.panel-height);
                    }
                ]
            }
        }
    }
}
