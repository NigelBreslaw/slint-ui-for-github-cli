// Primer-style **TreeView** — flat **`[TreeViewRow]`** model, indent + toggle, leading/trailing visuals, **`current`** bar, **`flat`** + **`truncate`**, skeleton rows, optional trailing **secondary actions** kebab. Upstream: `TreeView.module.css`, `TreeView.tsx`.

import { IconButton, IconButtonVariant } from "../Buttons/buttons.slint";
import { CounterLabel, CounterLabelVariant } from "../CounterLabel/counter-label.slint";
import { Icons } from "../assets/icons.slint";
import { SkeletonBox } from "../Skeleton/skeleton-box.slint";
import { LayoutTokens, PrimerColors, Size, TreeViewTokens } from "../tokens.slint";
import { ListView } from "std-widgets.slint";
import { TreeViewRow, TreeViewTrailingVisual } from "./types.slint";

component TreeViewRowView {
    in property <TreeViewRow> tree-row;
    in property <bool> flat;
    in property <length> toggle-w;
    in property <int> gutter-slot-count;
    in property <length> row-min-h;
    callback row-toggle-requested(string);
    callback row-current-requested(string);
    callback row-secondary-actions-requested(string, length, length, length, length);

    property <length> leading-action-w: tree-row.has-leading-action ? 3 * LayoutTokens.base-size-8 : 0px;
    property <int> level-safe: max(1, tree-row.level);
    property <int> gutter-segments: max(0, root.level-safe - 1);

    property <color> trailing-color: tree-row.trailing == TreeViewTrailingVisual.diff-added ? PrimerColors.fgColor-success
        : tree-row.trailing == TreeViewTrailingVisual.diff-modified ? PrimerColors.fgColor-attention
        : tree-row.trailing == TreeViewTrailingVisual.diff-removed ? PrimerColors.fgColor-danger
        : PrimerColors.fgColor-muted;

    property <image> trailing-img: tree-row.trailing == TreeViewTrailingVisual.diff-added ? Icons.diff_added
        : tree-row.trailing == TreeViewTrailingVisual.diff-modified ? Icons.diff_modified
        : tree-row.trailing == TreeViewTrailingVisual.diff-removed ? Icons.diff_removed
        : Icons.diff_renamed;

    property <image> dir-leading-img: tree-row.expanded ? Icons.file_directory_open_fill : Icons.file_directory_fill;

    vertical-stretch: 0;
    horizontal-stretch: 1;

    VerticalLayout {
        alignment: start;
        horizontal-stretch: 1;

        row-fs := FocusScope {
            focus-on-click: false;
            vertical-stretch: 0;
            horizontal-stretch: 1;

            key-pressed(event) => {
                if !tree-row.interactive || tree-row.is-skeleton {
                    return reject;
                }
                if event.text == Key.Return || event.text == Key.Space {
                    root.row-current-requested(tree-row.id);
                    if tree-row.has-children {
                        root.row-toggle-requested(tree-row.id);
                    }
                    return accept;
                }
                return reject;
            }

            row-chrome := Rectangle {
                horizontal-stretch: 1;
                border-radius: TreeViewTokens.item-border-radius;
                min-height: root.row-min-h;
                background: !tree-row.interactive || tree-row.is-skeleton ? transparent
                    : tree-row.current ? TreeViewTokens.item-bgColor-current
                    : main-ta.has-hover ? TreeViewTokens.item-bgColor-hover
                    : transparent;
                border-width: row-fs.has-focus && tree-row.interactive && !tree-row.is-skeleton ? TreeViewTokens.item-focus-ring-width : 0px;
                border-color: TreeViewTokens.item-focus-ring-color;

                if tree-row.current && !tree-row.is-skeleton: Rectangle {
                    x: TreeViewTokens.item-current-indicator-offset-inline;
                    y: (root.row-min-h - self.height) / 2;
                    width: TreeViewTokens.item-current-indicator-width;
                    height: TreeViewTokens.item-current-indicator-height;
                    border-radius: TreeViewTokens.item-border-radius;
                    background: TreeViewTokens.item-current-indicator-fgColor;
                }

                HorizontalLayout {
                    spacing: 0px;
                    alignment: stretch;
                    min-height: root.row-min-h;

                    main-ta := TouchArea {
                        horizontal-stretch: 1;
                        enabled: tree-row.interactive && !tree-row.is-skeleton;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => {
                            root.row-current-requested(tree-row.id);
                            if tree-row.has-children {
                                root.row-toggle-requested(tree-row.id);
                            }
                        }

                        HorizontalLayout {
                            spacing: TreeViewTokens.item-content-gap;
                            alignment: start;
                            padding-left: TreeViewTokens.item-content-padding-inline;
                            padding-right: TreeViewTokens.item-content-padding-inline;
                            min-height: root.row-min-h;
                            align-items: center;

                            if !flat && gutter-segments > 0: HorizontalLayout {
                                spacing: 0;
                                alignment: start;
                                for slot[index] in gutter-slot-count: Rectangle {
                                    width: index < gutter-segments ? toggle-w : 0px;
                                    height: root.row-min-h;
                                    background: transparent;

                                    if index < gutter-segments: Rectangle {
                                        x: parent.width - TreeViewTokens.item-border-width-thin;
                                        y: 0px;
                                        width: TreeViewTokens.item-border-width-thin;
                                        height: root.row-min-h;
                                        background: TreeViewTokens.level-line-borderColor;
                                    }
                                }
                            }

                            if tree-row.has-leading-action: HorizontalLayout {
                                width: leading-action-w;
                                min-height: root.row-min-h;
                                alignment: center;

                                if tree-row.show-leading-action-icon: Image {
                                    width: LayoutTokens.iconButton-icon-size-small;
                                    height: LayoutTokens.iconButton-icon-size-small;
                                    vertical-alignment: center;
                                    source: tree-row.leading-action-icon;
                                    colorize: TreeViewTokens.item-fgColor-muted;
                                }
                            }

                            if !flat: Rectangle {
                                width: toggle-w;
                                min-height: root.row-min-h;

                                VerticalLayout {
                                    alignment: center;
                                    align-items: center;
                                    Image {
                                        visible: tree-row.has-children;
                                        width: 12px;
                                        height: 12px;
                                        source: tree-row.expanded ? Icons.chevron_down : Icons.chevron_right;
                                        colorize: TreeViewTokens.item-fgColor-muted;
                                    }
                                }
                            }

                            if tree-row.is-skeleton: HorizontalLayout {
                                horizontal-stretch: 1;
                                spacing: LayoutTokens.base-size-8;
                                alignment: center;
                                min-height: root.row-min-h;

                                SkeletonBox {
                                    width: 38%;
                                    box-height: 10px;
                                }

                                SkeletonBox {
                                    width: 24%;
                                    box-height: 10px;
                                }
                            }

                            if !tree-row.is-skeleton: HorizontalLayout {
                                horizontal-stretch: 1;
                                spacing: TreeViewTokens.item-content-gap;
                                alignment: start;
                                align-items: center;

                                if tree-row.has-leading-visual: Image {
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: LayoutTokens.iconButton-icon-size-medium;
                                    vertical-alignment: top;
                                    source: tree-row.leading-is-directory ? dir-leading-img : tree-row.leading-file-icon;
                                    colorize: tree-row.leading-is-directory ? TreeViewTokens.item-leadingVisual-icon-fgColor-rest : TreeViewTokens.item-fgColor-muted;
                                }

                                Text {
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                    text: tree-row.label;
                                    color: TreeViewTokens.item-fgColor-default;
                                    font-size: LayoutTokens.text-body-size-medium;
                                    overflow: elide;
                                    wrap: no-wrap;
                                }

                                if tree-row.loading-children-badge != "": CounterLabel {
                                    text: tree-row.loading-children-badge;
                                    use-primer-scheme: true;
                                    scheme: CounterLabelVariant.secondary;
                                }
                            }

                            if !tree-row.is-skeleton && tree-row.trailing != TreeViewTrailingVisual.none: Image {
                                width: LayoutTokens.iconButton-icon-size-medium;
                                height: LayoutTokens.iconButton-icon-size-medium;
                                source: trailing-img;
                                colorize: trailing-color;
                            }
                        }
                    }

                    if tree-row.has-secondary-actions: HorizontalLayout {
                        spacing: TreeViewTokens.item-content-gap;
                        alignment: center;
                        padding-right: TreeViewTokens.item-content-padding-inline;
                        min-height: root.row-min-h;

                        if tree-row.secondary-actions-badge != "": CounterLabel {
                            text: tree-row.secondary-actions-badge;
                            use-primer-scheme: true;
                            scheme: CounterLabelVariant.secondary;
                        }

                        menu-btn := IconButton {
                            size: Size.small;
                            variant: IconButtonVariant.invisible;
                            icon-source: Icons.kebab_horizontal;
                            clicked => {
                                root.row-secondary-actions-requested(
                                    tree-row.id,
                                    menu-btn.absolute-position.x,
                                    menu-btn.absolute-position.y,
                                    menu-btn.width,
                                    menu-btn.height,
                                );
                            }
                        }
                    }
                }
            }
        }
    }
}

export component PrimerTreeView inherits VerticalLayout {
    in property <bool> flat: false;
    in property <bool> truncate: true;
    in property <bool> coarse-pointer: false;
    in property <string> accessible-name: "";
    in property <[TreeViewRow]> rows: [];
    /// How many indent columns to allocate for vertical guides (must be ≥ **`max(row.level) − 1`** when **`flat`** is false).
    in property <int> max-gutter-columns: 12;
    /// When true, rows render inside **`std-widgets::ListView`** (recycled delegates). Host must give this control a **bounded height** (or stretch into a parent with one).
    in property <bool> virtualized: false;

    callback row-toggle-requested(string);
    callback row-current-requested(string);
    callback row-secondary-actions-requested(string, length, length, length, length);

    property <length> toggle-w: root.coarse-pointer ? TreeViewTokens.toggle-width-coarse : TreeViewTokens.toggle-width-default;
    property <length> row-min-h: root.coarse-pointer ? TreeViewTokens.item-min-height-coarse : TreeViewTokens.item-min-height;

    alignment: start;
    horizontal-stretch: 1;
    vertical-stretch: 0;
    accessible-role: AccessibleRole.list;
    accessible-label: root.accessible-name;

    if !root.virtualized: VerticalLayout {
        alignment: start;
        horizontal-stretch: 1;

        for row[i] in root.rows: TreeViewRowView {
            tree-row: row;
            flat: root.flat;
            toggle-w: root.toggle-w;
            gutter-slot-count: root.max-gutter-columns;
            row-min-h: root.row-min-h;
            row-toggle-requested(id) => {
                root.row-toggle-requested(id);
            }
            row-current-requested(id) => {
                root.row-current-requested(id);
            }
            row-secondary-actions-requested(id, ax, ay, aw, ah) => {
                root.row-secondary-actions-requested(id, ax, ay, aw, ah);
            }
        }
    }

    if root.virtualized: ListView {
        width: 100%;
        height: 100%;
        horizontal-stretch: 1;
        vertical-stretch: 1;

        for row[i] in root.rows: Rectangle {
            height: root.row-min-h;
            horizontal-stretch: 1;
            background: transparent;

            TreeViewRowView {
                width: parent.width;
                y: 0px;
                tree-row: row;
                flat: root.flat;
                toggle-w: root.toggle-w;
                gutter-slot-count: root.max-gutter-columns;
                row-min-h: root.row-min-h;
                row-toggle-requested(id) => {
                    root.row-toggle-requested(id);
                }
                row-current-requested(id) => {
                    root.row-current-requested(id);
                }
                row-secondary-actions-requested(id, ax, ay, aw, ah) => {
                    root.row-secondary-actions-requested(id, ax, ay, aw, ah);
                }
            }
        }
    }
}
