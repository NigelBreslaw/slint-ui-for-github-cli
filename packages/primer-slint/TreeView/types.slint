export enum TreeViewTrailingVisual {
    none,
    diff-added,
    diff-modified,
    diff-removed,
    diff-renamed,
}

export struct TreeViewRow {
    id: string,
    label: string,
    level: int,
    has-children: bool,
    expanded: bool,
    current: bool,
    leading-is-directory: bool,
    has-leading-visual: bool,
    trailing: TreeViewTrailingVisual,
    has-leading-action: bool,
    show-leading-action-icon: bool,
    leading-action-icon: image,
    leading-file-icon: image,
    preserve-leading-icon-color: bool,
    interactive: bool,
    is-skeleton: bool,
    has-secondary-actions: bool,
    secondary-actions-badge: string,
    loading-children-badge: string,
}
