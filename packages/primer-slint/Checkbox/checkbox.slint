// Primer-style checkbox — upstream: https://primer.style/product/components/checkbox/ + Checkbox.module.css (16px control, borderRadius-small, control-checked-bgColor-rest when checked/indeterminate).

import { Icons } from "../assets/icons.slint";
import { CheckboxTokens, LayoutTokens, PrimerColors } from "../tokens.slint";

export component Checkbox {
    in-out property <bool> checked: false;
    in-out property <bool> indeterminate: false;
    in property <bool> disabled: false;
    in property <string> label: "";

    callback toggled;

    private property <length> box-size: LayoutTokens.iconButton-icon-size-medium;
    private property <bool> filled: root.checked || root.indeterminate;

    touch := TouchArea {
        enabled: !root.disabled;
        clicked => {
            root.checked = root.indeterminate ? true : !root.checked;
            root.indeterminate = false;
            root.toggled();
        }

        HorizontalLayout {
            spacing: LayoutTokens.button-content-gap;
            alignment: center;

            check-visuals := Rectangle {
                width: box-size;
                height: box-size;
                border-radius: LayoutTokens.checkbox-border-radius;
                border-width: 1px;
                // Default: enabled, empty (unchecked), rest — no explicit state.
                border-color: CheckboxTokens.checkbox-borderColor-rest;
                background: CheckboxTokens.checkbox-bgColor-rest;

                if root.indeterminate: Rectangle {
                    width: box-size * 0.45;
                    height: 2px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    background: root.disabled ? CheckboxTokens.checkbox-fgColor-checked-disabled : PrimerColors.fgOnEmphasis;
                    border-radius: 1px;
                }

                if !root.indeterminate && root.checked: Image {
                    width: parent.width;
                    height: parent.height;
                    source: Icons.check;
                    colorize:  root.disabled ? CheckboxTokens.checkbox-fgColor-checked-disabled : PrimerColors.fgOnEmphasis;
                }

                states [
                    disabled when root.disabled: {
                        check-visuals.border-color: root.filled ? CheckboxTokens.checkbox-borderColor-checked-disabled : CheckboxTokens.checkbox-borderColor-rest;
                        check-visuals.background: root.filled ? CheckboxTokens.checkbox-bgColor-checked-disabled : CheckboxTokens.checkbox-bgColor-rest;
                    }
                    filled-pressed when !root.disabled && root.filled && touch.pressed: {
                        check-visuals.border-color: CheckboxTokens.checkbox-borderColor-checked-active;
                        check-visuals.background: CheckboxTokens.checkbox-bgColor-checked-active;
                    }
                    filled-hover when !root.disabled && root.filled && !touch.pressed && touch.has-hover: {
                        check-visuals.border-color: CheckboxTokens.checkbox-borderColor-checked-hover;
                        check-visuals.background: CheckboxTokens.checkbox-bgColor-checked-hover;
                    }
                    filled-rest when !root.disabled && root.filled && !touch.pressed && !touch.has-hover: {
                        check-visuals.border-color: CheckboxTokens.checkbox-borderColor-checked;
                        check-visuals.background: CheckboxTokens.checkbox-bgColor-checked;
                    }
                    empty-pressed when !root.disabled && !root.filled && touch.pressed: {
                        check-visuals.border-color: CheckboxTokens.checkbox-borderColor-rest;
                        check-visuals.background: CheckboxTokens.checkbox-bgColor-active;
                    }
                    empty-hover when !root.disabled && !root.filled && !touch.pressed && touch.has-hover: {
                        check-visuals.border-color: CheckboxTokens.checkbox-borderColor-rest;
                        check-visuals.background: CheckboxTokens.checkbox-bgColor-hover;
                    }
                ]
            }

            if label != "": Text {
                text: label;
                color: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : PrimerColors.fgColor-default;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                wrap: word-wrap;
                vertical-alignment: center;
            }
        }
    }
}
