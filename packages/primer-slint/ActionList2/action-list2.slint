// ActionList2 — vertical list of rows and item dividers (upstream: Primer ActionList).

import { ActionList2CustomHeading } from "./action-list2-custom-heading.slint";
import { ActionList2ItemDivider } from "./action-list2-item-divider.slint";
import { ActionList2ListVisualHeading } from "./action-list2-list-visual-heading.slint";
import { ActionList2Row } from "./action-list2-row.slint";
import { ActionList2SectionHeading } from "./action-list2-section-heading.slint";
import { ActionList2Line, ActionList2LineKind } from "./types.slint";

export component ActionList2 {
    /// Lines top to bottom: rows, item dividers, list/custom visual headings, and subtle section headings.
    in property <[ActionList2Line]> lines: [];
    /// Primer `ActionList` **`showDividers`**: draw a **seam** hairline (`borderColor-muted`) between consecutive **rows** only — not after the last row, and no block margins (unlike explicit [`item_divider`](ActionList2LineKind.item_divider) / [`ActionList2ItemDivider`]).
    in property <bool> show-dividers: false;
    /// Fired with index into `lines` when a non-disabled **row** is activated (not for dividers).
    callback item-activated(int);

    min-width: 0px;
    width: 100%;

    VerticalLayout {
        spacing: 0px;
        width: 100%;
        alignment: start;

        for line[ix] in root.lines: VerticalLayout {
            width: 100%;
            spacing: 0px;
            alignment: start;

            if line.kind == ActionList2LineKind.row: ActionList2Row {
                width: 100%;
                label-markdown: line.label-markdown;
                label: line.label;
                has-markdown: line.has-markdown;
                disabled: line.disabled;
                row-variant: line.row-variant;
                has-leading-avatar: line.has-leading-avatar;
                avatar-source: line.avatar-source;
                has-leading-visual: line.has-leading-visual;
                leading-icon: line.leading-icon;
                show-top-seam: root.show-dividers && ix > 0 && root.lines[ix - 1].kind == ActionList2LineKind.row;
                clicked => {
                    root.item-activated(ix);
                }
            }

            if line.kind == ActionList2LineKind.item_divider: ActionList2ItemDivider {
                width: 100%;
            }

            if line.kind == ActionList2LineKind.list_visual_heading: ActionList2ListVisualHeading {
                width: 100%;
                title: line.label;
            }

            if line.kind == ActionList2LineKind.custom_heading: ActionList2CustomHeading {
                width: 100%;
                title: line.label;
            }

            if line.kind == ActionList2LineKind.section_heading: ActionList2SectionHeading {
                width: 100%;
                title: line.label;
            }
        }
    }
}
