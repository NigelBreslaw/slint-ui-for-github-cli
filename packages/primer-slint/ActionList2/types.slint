// ActionList2 models — Primer ActionList (fresh port).

/// List container variant (`ActionList` **`variant`**).
export enum ALVariant {
  inset,
  horizontal_inset,
  full,
}

/// Row visual variant (default action vs danger).
export enum ActionList2RowVariant {
  default,
  danger,
}

/// Primary label vs optional **Description**.
export enum ActionList2DescriptionLayout {
  none,
  inline,
  block,
}

/// Primer **`selectionVariant`**: none, single, or multiple.
export enum ActionList2SelectionMode {
  none,
  single,
  multiple,
}

export enum ActionList2ListRole {
  none,
  menu,
  listbox,
}

/// **ActionList.GroupHeading** variant (`Group.module.css` **`data-variant`**).
export enum ActionList2SectionHeadingVariant {
  subtle,
  filled,
}

/// Leading selection affordance — mutually exclusive per row (upstream `ActionList/Selection.tsx`).
/// Derive from **`selection-mode`** + **`list-role`** on **`ActionList2Lines`**, or set explicitly when composing rows.
export enum ActionList2SelectionLead {
  /// No selection column.
  none,
  /// **`.SingleSelectCheckmark`** — `CheckIcon`; **`single`**, or **`multiple`** + **`menu`** (incl. Storybook **ListboxMultiSelect**).
  checkmark,
  /// **`.MultiSelectCheckbox`** — boxed control; **`multiple`** + **`listbox`** (true listbox, not menu).
  checkbox,
}

/// Line kind in [`ActionList2`](action-list2.slint).
export enum ActionList2LineKind {
  row,
  item_divider,
  list_visual_heading,
  custom_heading,
  section_heading,
}

/// One list entry. Unused fields ignored per **`kind`**.
export struct ActionList2Line {
  kind: ActionList2LineKind,
  label: string,
  row-variant: ActionList2RowVariant,
  disabled: bool,
  has-leading-avatar: bool,
  avatar-source: image,
  has-leading-visual: bool,
  leading-icon: image,
  /// Secondary line when **`description-layout`** is **inline** or **block**.
  description: string,
  description-layout: ActionList2DescriptionLayout,
  trailing-text: string,
  /// Non-empty → Primer **`inactiveText`**: no activation; **`.InactiveWarning`** under the label.
  inactive-text: string,
  /// Primer **`loading`**: trailing spinner; row not activatable; muted label/description.
  show-trailing-loading: bool,
  /// Primer **`active`** / **`[data-active]`** — accent bar + surface (orthogonal to **`selected`**).
  active: bool,
  /// Used when **`kind`** is **`section_heading`** — subtle (default) or **filled** group title.
  section-heading-variant: ActionList2SectionHeadingVariant,
}
