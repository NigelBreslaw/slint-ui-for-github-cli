// ActionList2 row — Primer ActionList item (default | danger); ButtonTokens + ActionListTokens.

import { Icons } from "../assets/icons.slint";
import {
    ActionListTokens,
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
} from "../tokens.slint";
import { ActionList2RowVariant } from "./types.slint";

export component ActionList2Row {
    min-width: 0px;
    in property <string> label: "";
    in property <bool> disabled: false;
    in property <ActionList2RowVariant> row-variant: ActionList2RowVariant.default;
    in property <bool> has-leading-visual: false;
    in property <image> leading-icon: Icons.dot_fill;

    callback clicked;

    private property <length> cell-min-height: LayoutTokens.action-list-item-min-height;
    private property <length> cell-padding-block: LayoutTokens.action-list-item-padding-block;

    private property <color> label-color:
        root.row-variant == ActionList2RowVariant.danger
        ? (root.disabled ? ActionListTokens.item-danger-fgColor-disabled : ActionListTokens.item-danger-fgColor-rest)
        : (root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default);

    private property <color> leading-icon-tint:
        root.disabled
        ? ButtonTokens.control-fgColor-disabled
        : root.row-variant == ActionList2RowVariant.danger
        ? ActionListTokens.item-danger-fgColor-rest
        : PrimerColors.fgColor-muted;

    min-height: root.cell-min-height;
    width: 100%;

    ta := TouchArea {
        horizontal-stretch: 1;
        min-width: 0px;
        min-height: root.cell-min-height;
        enabled: !root.disabled;
        clicked => {
            root.clicked();
        }

        row-bg := Rectangle {
            border-radius: LayoutTokens.borderRadius-medium;
            background: #00000000;

            hl := HorizontalLayout {
                min-height: root.cell-min-height;
                padding-left: LayoutTokens.action-list-item-padding-inline;
                padding-right: LayoutTokens.action-list-item-padding-inline;
                padding-top: root.cell-padding-block;
                padding-bottom: root.cell-padding-block;
                spacing: LayoutTokens.button-content-gap;
                alignment: start;
                align-items: center;

                if root.has-leading-visual: Image {
                    horizontal-stretch: 0;
                    width: LayoutTokens.iconButton-icon-size-medium;
                    height: LayoutTokens.iconButton-icon-size-medium;
                    vertical-alignment: center;
                    source: root.leading-icon;
                    colorize: leading-icon-tint;
                }

                primary-label := Text {
                    horizontal-stretch: 1;
                    min-width: 0px;
                    text: root.label;
                    color: root.label-color;
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                }
            }

            states [
                disabled when root.disabled: {
                    row-bg.background: #00000000;
                }
                danger-pressed when !root.disabled && root.row-variant == ActionList2RowVariant.danger && ta.pressed: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-active;
                }
                danger-hover when !root.disabled && root.row-variant == ActionList2RowVariant.danger && !ta.pressed && ta.has-hover: {
                    row-bg.background: ActionListTokens.item-danger-bgColor-hover;
                }
                default-pressed when !root.disabled && root.row-variant == ActionList2RowVariant.default && ta.pressed: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                }
                default-hover when !root.disabled && root.row-variant == ActionList2RowVariant.default && !ta.pressed && ta.has-hover: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                }
            ]
        }
    }
}
