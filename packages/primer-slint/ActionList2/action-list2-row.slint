// ActionList2 row — default + danger visuals; optional `showDividers` seam above.

import { Icons } from "../assets/icons.slint";
import {
    ActionList2Tokens,
    ButtonTokens,
    CheckboxTokens,
    LayoutTokens,
    PrimerColors,
} from "../tokens.slint";
import {
    ActionList2DescriptionLayout,
    ActionList2RowVariant,
    ActionList2SelectionLead,
} from "./types.slint";

export component ActionList2Row {
    in property <string> label;
    in property <ActionList2RowVariant> row-variant: ActionList2RowVariant.default;
    in property <bool> disabled: false;
    in property <bool> has-leading-visual: false;
    in property <image> leading-icon: Icons.dot_fill;
    in property <string> description: "";
    in property <ActionList2DescriptionLayout> description-layout: ActionList2DescriptionLayout.none;
    in property <string> trailing-text;
    in property <length> margin-inline;
    in property <bool> show-divider: false;
    in property <bool> selected: false;
    /// Leading selection column — only one of **none** / **checkmark** / **checkbox** (see **`ActionList2SelectionLead`**).
    in property <ActionList2SelectionLead> selection-lead: ActionList2SelectionLead.none;
    callback clicked;

    property <bool> show-selection-checkmark: root.selection-lead == ActionList2SelectionLead.checkmark;
    property <bool> show-selection-checkbox: root.selection-lead == ActionList2SelectionLead.checkbox;

    property <bool> is-danger: root.row-variant == ActionList2RowVariant.danger;

    property <color> single-select-check-tint:
        root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;

    property <color> multi-select-lead-bg:
        root.disabled
        ? (root.selected ? CheckboxTokens.checkbox-bgColor-checked-disabled : CheckboxTokens.checkbox-bgColor-rest)
        : (root.selected ? CheckboxTokens.checkbox-bgColor-checked : CheckboxTokens.checkbox-bgColor-rest);
    property <color> multi-select-lead-border:
        root.disabled
        ? (root.selected ? CheckboxTokens.checkbox-borderColor-checked-disabled : CheckboxTokens.checkbox-borderColor-rest)
        : (root.selected ? CheckboxTokens.checkbox-borderColor-checked : CheckboxTokens.checkbox-borderColor-rest);

    property <bool> use-selected-surface:
        root.selected && root.selection-lead == ActionList2SelectionLead.none;

    property <int> label-font-weight:
        !root.disabled && root.use-selected-surface
        ? LayoutTokens.base-text-weight-semibold
        : LayoutTokens.base-text-weight-medium;

    property <color> label-color:
        root.disabled
        ? (root.is-danger ? ActionList2Tokens.item-danger-fgColor-disabled : ButtonTokens.control-fgColor-disabled)
        : (root.is-danger ? ActionList2Tokens.item-danger-fgColor-rest : PrimerColors.fgColor-default);

    property <color> leading-icon-tint:
        root.disabled
        ? ButtonTokens.control-fgColor-disabled
        : (root.is-danger ? ActionList2Tokens.item-danger-fgColor-rest : PrimerColors.fgColor-muted);

    property <color> trailing-text-color:
        root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-muted;

    property <bool> show-inline-description:
        root.description != "" && root.description-layout == ActionList2DescriptionLayout.inline;

    property <bool> show-block-description:
        root.description != "" && root.description-layout == ActionList2DescriptionLayout.block;

    property <color> description-color:
        root.disabled ? ButtonTokens.control-fgColor-disabled : ActionList2Tokens.item-description-fgColor;

    property <length> cell-min-height: LayoutTokens.action-list-item-min-height;

    min-height: root.cell-min-height + (root.show-divider ? LayoutTokens.table-border-width : 0px);

    row-shell := VerticalLayout {
        alignment: start;
        padding-left: root.margin-inline;
        padding-right: root.margin-inline;

        if root.show-divider: HorizontalLayout {
            spacing: LayoutTokens.button-content-gap;
            alignment: start;
            align-items: center;

            if root.show-selection-checkmark: Rectangle {
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.table-border-width;
            }

            if root.show-selection-checkbox: Rectangle {
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.table-border-width;
            }

            Rectangle {
                width: parent.width;
                height: LayoutTokens.table-border-width;
                background: ActionList2Tokens.item-seam-borderColor;
            }
        }

        fs := FocusScope {
            enabled: !root.disabled;
            focus-on-click: false;

            key-pressed(event) => {
                if root.disabled {
                    return reject;
                }
                if event.text == Key.Return || event.text == Key.Space {
                    root.clicked();
                    return accept;
                }
                return reject;
            }

            focus-chrome := Rectangle {
                border-width: fs.has-focus && !root.disabled ? ActionList2Tokens.item-focus-ring-width : 0px;
                border-color: ActionList2Tokens.item-focus-ring-color;
                border-radius: LayoutTokens.borderRadius-medium;

                ta := TouchArea {
                    enabled: !root.disabled;
                    min-height: root.cell-min-height;
                    mouse-cursor: root.disabled ? default : pointer;
                    clicked => {
                        root.clicked();
                    }

                    row-bg := Rectangle {
                        border-radius: LayoutTokens.borderRadius-medium;

                        content-row := HorizontalLayout {
                            align-items: center;
                            padding-left: LayoutTokens.action-list-item-padding-inline;
                            padding-right: LayoutTokens.action-list-item-padding-inline;
                            padding-top: LayoutTokens.action-list-item-padding-block;
                            padding-bottom: LayoutTokens.action-list-item-padding-block;
                            spacing: LayoutTokens.button-content-gap;

                            primary-column := VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: root.show-block-description ? 2px : 0px;
                                alignment: start;

                                primary-line := HorizontalLayout {
                                    spacing: LayoutTokens.button-content-gap;
                                    alignment: start;
                                    align-items: center;

                                    if root.show-selection-checkmark: HorizontalLayout {
                                        horizontal-stretch: 0;
                                        min-height: LayoutTokens.iconButton-icon-size-medium;
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        alignment: center;

                                        if root.selected: Image {
                                            width: 16px;
                                            height: 16px;
                                            vertical-alignment: center;
                                            source: Icons.check;
                                            colorize: root.single-select-check-tint;
                                        }
                                    }

                                    if root.show-selection-checkbox: Rectangle {
                                        horizontal-stretch: 0;
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: self.width;
                                        border-radius: LayoutTokens.checkbox-border-radius;
                                        border-width: 1px;
                                        border-color: root.multi-select-lead-border;
                                        background: root.multi-select-lead-bg;
                                        clip: true;

                                        if root.selected: Image {
                                            width: 12px;
                                            height: 12px;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                            source: Icons.check;
                                            colorize:
                                                root.disabled
                                                ? CheckboxTokens.checkbox-fgColor-checked-disabled
                                                : PrimerColors.fgOnEmphasis;
                                        }
                                    }

                                    if root.has-leading-visual: Image {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                        vertical-alignment: center;
                                        source: root.leading-icon;
                                        colorize: root.leading-icon-tint;
                                    }

                                    if root.show-inline-description: HorizontalLayout {
                                        horizontal-stretch: 1;
                                        spacing: LayoutTokens.button-content-gap;
                                        alignment: center;
                                        align-items: center;

                                        Text {
                                            horizontal-stretch: 1;
                                            text: root.label;
                                            color: root.label-color;
                                            font-size: LayoutTokens.text-body-size-medium;
                                            font-weight: root.label-font-weight;
                                            wrap: word-wrap;
                                            vertical-alignment: center;
                                        }

                                        Text {
                                            text: root.description;
                                            color: root.description-color;
                                            font-size: LayoutTokens.text-body-size-small;
                                            font-weight: LayoutTokens.base-text-weight-medium;
                                            wrap: word-wrap;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if root.show-block-description: VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        alignment: start;

                                        Text {
                                            text: root.label;
                                            color: root.label-color;
                                            font-size: LayoutTokens.text-body-size-medium;
                                            font-weight: root.label-font-weight;
                                            wrap: word-wrap;
                                        }
                                    }

                                    if !root.show-inline-description && !root.show-block-description: Text {
                                        horizontal-stretch: 1;
                                        text: root.label;
                                        color: root.label-color;
                                        font-size: LayoutTokens.text-body-size-medium;
                                        font-weight: root.label-font-weight;
                                        wrap: word-wrap;
                                        vertical-alignment: center;
                                    }
                                }

                                if root.show-block-description: HorizontalLayout {
                                    spacing: LayoutTokens.button-content-gap;
                                    alignment: start;
                                    align-items: center;

                                    if root.show-selection-checkmark: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    if root.show-selection-checkbox: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    if root.has-leading-visual: Rectangle {
                                        width: LayoutTokens.iconButton-icon-size-medium;
                                        height: LayoutTokens.iconButton-icon-size-medium;
                                    }

                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.description;
                                        color: root.description-color;
                                        font-size: LayoutTokens.text-body-size-small;
                                        font-weight: LayoutTokens.base-text-weight-medium;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            if root.trailing-text != "": Text {
                                text: root.trailing-text;
                                color: root.trailing-text-color;
                                font-size: LayoutTokens.text-body-size-medium;
                                font-weight: LayoutTokens.base-text-weight-medium;
                                vertical-alignment: center;
                            }
                        }

                        states [
                            disabled when root.disabled: {
                                row-bg.background:
                                    root.use-selected-surface
                                    ? ButtonTokens.color-action-list-item-default-selected-bg
                                    : transparent;
                            }
                            danger-selected-pressed when !root.disabled && root.is-danger && root.use-selected-surface && ta.pressed: {
                                row-bg.background: ActionList2Tokens.item-danger-bgColor-active;
                            }
                            danger-selected-hover when !root.disabled && root.is-danger && root.use-selected-surface && !ta.pressed && ta.has-hover: {
                                row-bg.background: ActionList2Tokens.item-danger-bgColor-hover;
                            }
                            danger-selected-rest when !root.disabled && root.is-danger && root.use-selected-surface && !ta.pressed && !ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                            }
                            danger-pressed when !root.disabled && root.is-danger && !root.use-selected-surface && ta.pressed: {
                                row-bg.background: ActionList2Tokens.item-danger-bgColor-active;
                            }
                            danger-hover when !root.disabled && root.is-danger && !root.use-selected-surface && !ta.pressed && ta.has-hover: {
                                row-bg.background: ActionList2Tokens.item-danger-bgColor-hover;
                            }
                            default-selected-pressed when !root.disabled && !root.is-danger && root.use-selected-surface && ta.pressed: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                            }
                            default-selected-hover when !root.disabled && !root.is-danger && root.use-selected-surface && !ta.pressed && ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                            }
                            default-selected-rest when !root.disabled && !root.is-danger && root.use-selected-surface && !ta.pressed && !ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                            }
                            default-pressed when !root.disabled && !root.is-danger && (!root.selected || root.selection-lead != ActionList2SelectionLead.none) && ta.pressed: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                            }
                            default-hover when !root.disabled && !root.is-danger && (!root.selected || root.selection-lead != ActionList2SelectionLead.none) && !ta.pressed && ta.has-hover: {
                                row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                            }
                        ]
                    }
                }
            }
        }
    }
}
