// Primer ActionList **item** divider — hairline between rows (not section divider).
// Spacing from [`ActionList.module.css`](https://github.com/primer/react/blob/main/packages/react/src/ActionList/ActionList.module.css) `.Divider` (margin-block via [`LayoutTokens`] `action-list-item-divider-margin-block-*`).
// Line: [`ActionListTokens.item-divider-borderColor`](../tokens.slint) (product list hairline; module uses `--borderColor-muted` for standalone `Divider` — list lines stay on audit).

import { ActionListTokens, LayoutTokens } from "../tokens.slint";

export component ActionList2ItemDivider {

    VerticalLayout {
        padding-top: LayoutTokens.action-list-item-divider-margin-block-start;
        padding-bottom: LayoutTokens.action-list-item-divider-margin-block-end;
        alignment: start;

        Rectangle {
            height: LayoutTokens.table-border-width;
            background: ActionListTokens.item-divider-borderColor;
        }
    }
}
