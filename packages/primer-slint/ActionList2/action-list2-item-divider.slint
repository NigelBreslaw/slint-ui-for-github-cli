// Primer ActionList **item** divider — hairline between rows (not section divider).
// Uses **`ActionListTokens.item-divider-borderColor`** (see audit in [`tokens.slint`](../tokens.slint)).

import { ActionListTokens } from "../tokens.slint";

export component ActionList2ItemDivider {
    min-width: 0px;
    width: 100%;

    VerticalLayout {
        width: 100%;
        padding-top: 4px;
        padding-bottom: 4px;
        alignment: start;

        Rectangle {
            width: 100%;
            height: 1px;
            background: ActionListTokens.item-divider-borderColor;
        }
    }
}
