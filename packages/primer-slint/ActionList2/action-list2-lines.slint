// Model-driven **`ActionList2`** body — maps **`ActionList2Line`** arrays to row/divider instances.
// Prefer composing **`ActionList2Row`** directly when static; use this for TS **`ArrayModel`** / menu data.

import { ActionList2CustomHeading } from "./action-list2-custom-heading.slint";
import { ActionList2ItemDivider } from "./action-list2-item-divider.slint";
import { ActionList2ListVisualHeading } from "./action-list2-list-visual-heading.slint";
import { ActionList2Row } from "./action-list2-row.slint";
import { ActionList2SectionHeading } from "./action-list2-section-heading.slint";
import { ActionList2FocusLogic } from "./action-list2-focus-logic.slint";
import { ActionList2Tokens } from "../tokens.slint";
import {
    ActionList2Line,
    ActionList2LineKind,
    ActionList2ListRole,
    ALVariant,
    ActionList2SelectionLead,
    ActionList2SelectionMode,
} from "./types.slint";

export component ActionList2Lines {
    in property <[ActionList2Line]> lines: [];
    in property <ALVariant> list-variant: ALVariant.inset;
    /// Primer **`showDividers`**: muted seam between consecutive **rows** (not after the last row).
    in property <bool> show-dividers: false;
    in property <ActionList2ListRole> list-role: ActionList2ListRole.none;
    in property <bool> disable-focus-zone: false;
    in property <ActionList2SelectionMode> selection-mode: ActionList2SelectionMode.none;
    in property <int> selected-index: -1;
    in property <[bool]> multi-selected: [];
    in-out property <int> focused-index: -1;
    callback item-activated(int);

    property <length> item-margin-inline:
        root.list-variant == ALVariant.full ? 0px : ActionList2Tokens.item-margin-inline-inset;

    property <ActionList2SelectionLead> row-selection-lead:
        root.selection-mode == ActionList2SelectionMode.none ? ActionList2SelectionLead.none
        : root.selection-mode == ActionList2SelectionMode.single ? ActionList2SelectionLead.checkmark
        : root.list-role == ActionList2ListRole.menu ? ActionList2SelectionLead.checkmark
        : ActionList2SelectionLead.checkbox;

    property <bool> focus-zone-enabled:
        !root.disable-focus-zone
        && (root.list-role == ActionList2ListRole.menu || root.list-role == ActionList2ListRole.listbox);

    property <bool> focus-wrap: root.list-role == ActionList2ListRole.menu;

    function focus-first-row() {
        root.focused-index = ActionList2FocusLogic.first-row(root.lines);
    }

    function focus-last-row() {
        root.focused-index = ActionList2FocusLogic.last-row(root.lines);
    }

    function step-focus(delta: int) {
        if root.lines.length == 0 {
            return;
        }
        if root.focused-index < 0 {
            if delta >= 0 {
                root.focus-first-row();
            } else {
                root.focus-last-row();
            }
            return;
        }
        if ActionList2FocusLogic.step-from(root.lines, root.focused-index, delta, root.focus-wrap) >= 0 {
            root.focused-index = ActionList2FocusLogic.step-from(
                root.lines,
                root.focused-index,
                delta,
                root.focus-wrap,
            );
        }
    }

    horizontal-stretch: 1;

    list-fs := FocusScope {
        horizontal-stretch: 1;
        focus-on-click: false;
        focus-on-tab-navigation: root.focus-zone-enabled;

        key-pressed(event) => {
            if !root.focus-zone-enabled {
                return reject;
            }
            if event.text == Key.DownArrow {
                root.step-focus(1);
                return accept;
            }
            if event.text == Key.UpArrow {
                root.step-focus(-1);
                return accept;
            }
            if event.text == Key.Home {
                root.focus-first-row();
                return accept;
            }
            if event.text == Key.End {
                root.focus-last-row();
                return accept;
            }
            if event.text == Key.Return || event.text == Key.Space {
                if root.focused-index >= 0 && ActionList2FocusLogic.line-is-row(root.lines, root.focused-index) {
                    if !root.lines[root.focused-index].disabled
                        && root.lines[root.focused-index].inactive-text == ""
                        && !root.lines[root.focused-index].show-trailing-loading {
                        root.item-activated(root.focused-index);
                    }
                    return accept;
                }
            }
            return reject;
        }

        lines-body := VerticalLayout {
            alignment: start;

            for line[ix] in root.lines: VerticalLayout {
                alignment: start;

                if line.kind == ActionList2LineKind.row: ActionList2Row {
                    label: line.label;
                    row-variant: line.row-variant;
                    row-size: line.row-size;
                    disabled: line.disabled;
                    has-leading-avatar: line.has-leading-avatar;
                    avatar-source: line.avatar-source;
                    has-leading-visual: line.has-leading-visual;
                    leading-icon: line.leading-icon;
                    description: line.description;
                    description-layout: line.description-layout;
                    truncate-inline-description: line.truncate-inline-description;
                    trailing-text: line.trailing-text;
                    inactive-text: line.inactive-text;
                    show-trailing-loading: line.show-trailing-loading;
                    active: line.active;
                    margin-inline: root.item-margin-inline;
                    show-divider:
                        root.show-dividers && ix > 0 && root.lines[ix - 1].kind == ActionList2LineKind.row;
                    selected:
                        (root.selection-mode == ActionList2SelectionMode.single && root.selected-index == ix)
                        || (
                            root.selection-mode == ActionList2SelectionMode.multiple
                            && ix < root.multi-selected.length
                            && root.multi-selected[ix]
                        );
                    selection-lead: root.row-selection-lead;
                    roving-focused: root.focus-zone-enabled && root.focused-index == ix;
                    focus-claimed => {
                        root.focused-index = ix;
                    }
                    clicked => {
                        if !line.disabled && line.inactive-text == "" && !line.show-trailing-loading {
                            root.item-activated(ix);
                        }
                    }
                }

                if line.kind == ActionList2LineKind.item_divider: ActionList2ItemDivider {
                    margin-inline: root.item-margin-inline;
                }

                if line.kind == ActionList2LineKind.list_visual_heading: ActionList2ListVisualHeading {
                    title: line.label;
                    margin-inline: root.item-margin-inline;
                }

                if line.kind == ActionList2LineKind.custom_heading: ActionList2CustomHeading {
                    title: line.label;
                    margin-inline: root.item-margin-inline;
                }

                if line.kind == ActionList2LineKind.section_heading: ActionList2SectionHeading {
                    title: line.label;
                    variant: line.section-heading-variant;
                    margin-inline: root.item-margin-inline;
                }
            }
        }
    }
}
