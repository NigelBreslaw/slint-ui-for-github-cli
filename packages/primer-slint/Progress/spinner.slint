import { PrimerColors, Size } from "../tokens.slint";

export component Spinner {
    in property <Size> size: large;
    in property <color> segment-color: PrimerColors.fgColor-default;
    in property <color> track-color: #f0f6fc40;

    property <length> box: size == Size.small ? 16px : size == Size.large ? 64px : 32px;
    property <angle> spin-angle: animation-tick() / 1000ms * 360deg;
    property <float> spin-cos: cos(spin-angle);
    property <float> spin-sin: sin(spin-angle);

    width: box;
    height: box;

    Rectangle {
        Path {
            viewbox-width: 16;
            viewbox-height: 16;
            fill: transparent;
            stroke: segment-color;
            stroke-width: 2px;
            stroke-line-cap: round;
            MoveTo {
                x: 8 + 7 * spin-cos;
                y: 8 + 7 * spin-sin;
            }
            ArcTo {
                radius-x: 7.002;
                radius-y: 7.002;
                x: 8 + 7 * spin-sin;
                y: 8 - 7 * spin-cos;
                large-arc: false;
                sweep: false;
            }
        }

        Path {
            viewbox-width: 16;
            viewbox-height: 16;
            fill: transparent;
            stroke: track-color;
            stroke-width: 2px;
            commands: "M 15 8 A 7 7 0 1 1 1 8 A 7 7 0 1 1 15 8";
        }
    }
}
