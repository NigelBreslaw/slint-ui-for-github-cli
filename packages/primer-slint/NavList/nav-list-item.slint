// **NavList.Item** — link row. Use **`NavListExpandableItem`** + **`NavListSubNav`** for collapsible parents (PR2).

import { ActionListLinkRow } from "../ActionList/action-list-link-row.slint";
import { ActionListRowSize } from "../ActionList/types.slint";
import { ActionListTokens, LayoutTokens } from "../tokens.slint";

export component NavListItem {
    in property <string> label;
    /// Mirrors upstream **`aria-current`** → **`active`** on **ActionList.LinkItem**.
    in property <bool> active: false;
    in property <string> href: "#";
    in property <int> subitem-depth: 0;
    in property <length> margin-inline: ActionListTokens.item-margin-inline-inset;
    in property <ActionListRowSize> row-size: ActionListRowSize.medium;
    /// When non-empty, row is non-interactive and shows attention copy (upstream **`inactiveText`**).
    in property <string> inactive-text: "";
    /// Fires on pointer / keyboard activation when not inactive (host opens **`href`**).
    callback clicked;

    /// Upstream **`.SubGroup`** drops item **`margin-inline`**; depth comes from **`.Spacer`** only.
    property <length> subitem-indent: max(0px, root.subitem-depth * LayoutTokens.base-size-8 - root.margin-inline);

    ActionListLinkRow {
        width: parent.width;
        label: root.label;
        active: root.active;
        href: root.href;
        margin-inline: root.margin-inline;
        subitem-indent: root.subitem-indent;
        compact-label: root.subitem-depth > 0;
        row-size: root.row-size;
        inactive-text: root.inactive-text;
        clicked => {
            root.clicked();
        }
    }
}
