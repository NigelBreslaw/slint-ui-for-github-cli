// **NavList.Item** — link row. Use **`NavListExpandableItem`** + **`NavListSubNav`** for collapsible parents (PR2).

import { Icons } from "../assets/icons.slint";
import { ActionListLinkRow } from "../ActionList/action-list-link-row.slint";
import { ActionListDescriptionLayout, ActionListRowSize } from "../ActionList/types.slint";
import { ActionListTokens, LayoutTokens } from "../tokens.slint";

export component NavListItem {
    in property <string> label;
    /// Mirrors upstream **`aria-current`** → **`active`** on **ActionList.LinkItem**.
    in property <bool> active: false;
    in property <string> href: "#";
    in property <int> subitem-depth: 0;
    in property <length> margin-inline: ActionListTokens.item-margin-inline-inset;
    in property <ActionListRowSize> row-size: ActionListRowSize.medium;
    in property <bool> has-leading-visual: false;
    in property <image> leading-icon: Icons.dot_fill;
    in property <string> description: "";
    in property <ActionListDescriptionLayout> description-layout: ActionListDescriptionLayout.none;
    in property <bool> truncate-inline-description: false;
    in property <string> trailing-text: "";
    in property <bool> has-trailing-visual: false;
    in property <image> trailing-icon: Icons.dot_fill;
    in property <bool> has-trailing-action: false;
    in property <bool> trailing-action-has-icon: false;
    in property <image> trailing-action-icon: Icons.dot_fill;
    in property <string> trailing-action-label: "";
    in property <bool> trailing-action-loading: false;
    /// When non-empty, row is non-interactive and shows attention copy (upstream **`inactiveText`**).
    in property <string> inactive-text: "";
    /// Fires on pointer / keyboard activation when not inactive (host opens **`href`**).
    callback clicked;
    callback trailing-action-clicked();

    /// Upstream **`.SubGroup`** drops item **`margin-inline`**; depth comes from **`.Spacer`** only.
    property <length> subitem-indent: max(0px, root.subitem-depth * LayoutTokens.base-size-8 - root.margin-inline);

    ActionListLinkRow {
        width: parent.width;
        label: root.label;
        active: root.active;
        href: root.href;
        margin-inline: root.margin-inline;
        subitem-indent: root.subitem-indent;
        compact-label: root.subitem-depth > 0;
        row-size: root.row-size;
        has-leading-visual: root.has-leading-visual;
        leading-icon: root.leading-icon;
        description: root.description;
        description-layout: root.description-layout;
        truncate-inline-description: root.truncate-inline-description;
        trailing-text: root.trailing-text;
        has-trailing-visual: root.has-trailing-visual;
        trailing-icon: root.trailing-icon;
        has-trailing-action: root.has-trailing-action;
        trailing-action-has-icon: root.trailing-action-has-icon;
        trailing-action-icon: root.trailing-action-icon;
        trailing-action-label: root.trailing-action-label;
        trailing-action-loading: root.trailing-action-loading;
        inactive-text: root.inactive-text;
        clicked => {
            root.clicked();
        }
        trailing-action-clicked => {
            root.trailing-action-clicked();
        }
    }
}
