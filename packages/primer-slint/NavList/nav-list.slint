// Primer-style NavList — flat, grouped (PR4), SubNav expand/collapse (PR6). Upstream: https://primer.style/product/components/nav-list/
// Interactive rows use [`ActionList2Row`](../ActionList2/action-list2-row.slint): upstream `aria-current` → `active`; `sidebar-current-indicator` uses `selected` + external bar.

import { Icons } from "../assets/icons.slint";
import { ActionList2Row } from "../ActionList2/action-list2-row.slint";
import {
    ActionList2DescriptionLayout,
    ActionList2RowSize,
    ActionList2RowVariant,
    ActionList2SelectionLead,
} from "../ActionList2/types.slint";
import { ButtonTokens, LayoutTokens, PrimerColors } from "../tokens.slint";
import {
    NavListGroup,
    NavListGroupHeadingVariant,
    NavListItem,
    NavListLeaf,
    NavListRowData,
    NavListSub1,
    NavListSub2,
    NavListSub3,
} from "./types.slint";

/// SubNav indent + optional sidebar accent + single [`ActionList2Row`]. Upstream `aria-current` maps to `active` when not using sidebar bar; with `sidebar-indicator`, `current` uses `selected` on the row so the inner accent does not double the external bar.
component NavListActionRow {
    in property <NavListRowData> nav-row;
    in property <int> indent-depth: 0;
    in property <bool> sidebar-indicator: false;
    /// When true, sidebar accent bar stretches to row height (expandable parents); when false, fixed-height bar centered (leaf rows).
    in property <bool> sidebar-bar-full-height: false;
    in property <bool> force-leading: false;
    in property <image> forced-leading-icon: Icons.chevron_right;
    callback clicked;

    HorizontalLayout {
        horizontal-stretch: 1;
        spacing: sidebar-indicator ? LayoutTokens.nav-list-sidebar-indicator-gap : 0px;
        padding-left: indent-depth * LayoutTokens.nav-list-subnav-indent;
        alignment: sidebar-indicator ? stretch : start;

        if sidebar-indicator && !sidebar-bar-full-height: Rectangle {
            y: (parent.height - self.height) / 2;
            horizontal-stretch: 0;
            width: LayoutTokens.nav-list-sidebar-indicator-width;
            height: LayoutTokens.nav-list-sidebar-indicator-height;
            border-radius: LayoutTokens.nav-list-sidebar-indicator-radius;
            background: nav-row.current ? PrimerColors.bgColor-accent-emphasis : transparent;
        }

        if sidebar-indicator && sidebar-bar-full-height: Rectangle {
            horizontal-stretch: 0;
            vertical-stretch: 1;
            width: LayoutTokens.nav-list-sidebar-indicator-width;
            border-radius: LayoutTokens.nav-list-sidebar-indicator-radius;
            background: nav-row.current ? PrimerColors.bgColor-accent-emphasis : transparent;
        }

        ActionList2Row {
            horizontal-stretch: 1;
            margin-inline: 0px;
            label: nav-row.label;
            row-variant: ActionList2RowVariant.default;
            row-size: ActionList2RowSize.medium;
            disabled: false;
            has-leading-avatar: false;
            has-leading-visual: force-leading || nav-row.has-leading-visual;
            leading-icon: force-leading ? forced-leading-icon : nav-row.leading-icon;
            description: nav-row.description;
            description-layout: nav-row.description != "" ? ActionList2DescriptionLayout.block : ActionList2DescriptionLayout.none;
            trailing-text: nav-row.trailing-text;
            inactive-text: "";
            active: nav-row.current && !sidebar-indicator;
            selected: nav-row.current && sidebar-indicator;
            selection-lead: ActionList2SelectionLead.none;
            show-divider: false;
            clicked => {
                root.clicked();
            }
        }
    }
}

/// Single nav row — inactive (explanation) or interactive [`ActionList2Row`].
/// One root [`VerticalLayout`] so rows stack vertically (multiple root `if` branches overlap at 0×0).
component NavListItemRow {
    in property <NavListRowData> nav-row;
    /// Left inset for nested SubNav rows (multiply by depth).
    in property <int> indent-depth: 0;
    /// Primer sidebar pattern: blue vertical bar + muted surface on current (see NavList sidebar-current-indicator).
    in property <bool> sidebar-indicator: false;
    callback clicked;

    VerticalLayout {
        horizontal-stretch: 1;

        if nav-row.inactive && nav-row.inactive-text == "": Rectangle {
            horizontal-stretch: 1;
            border-radius: LayoutTokens.borderRadius-medium;

            HorizontalLayout {
                horizontal-stretch: 1;
                min-height: LayoutTokens.action-list-item-min-height;
                padding-left: indent-depth * LayoutTokens.nav-list-subnav-indent
                    + LayoutTokens.action-list-item-padding-inline;
                padding-right: LayoutTokens.action-list-item-padding-inline;
                padding-top: LayoutTokens.action-list-item-padding-block;
                padding-bottom: LayoutTokens.action-list-item-padding-block;
                spacing: LayoutTokens.button-content-gap;
                alignment: start;

                if nav-row.has-leading-visual: Image {
                    width: LayoutTokens.iconButton-icon-size-medium;
                    height: LayoutTokens.iconButton-icon-size-medium;
                    vertical-alignment: top;
                    source: nav-row.leading-icon;
                    colorize: ButtonTokens.control-fgColor-disabled;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;

                    Text {
                        horizontal-stretch: 1;
                        text: nav-row.label;
                        color: ButtonTokens.control-fgColor-disabled;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-medium;
                        wrap: word-wrap;
                    }

                    if nav-row.description != "": Text {
                        horizontal-stretch: 1;
                        text: nav-row.description;
                        color: ButtonTokens.control-fgColor-disabled;
                        font-size: LayoutTokens.text-body-size-small;
                        font-weight: LayoutTokens.base-text-weight-medium;
                        wrap: word-wrap;
                    }
                }

                if nav-row.trailing-text != "": Text {
                    vertical-alignment: top;
                    text: nav-row.trailing-text;
                    color: ButtonTokens.control-fgColor-disabled;
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                }
            }
        }

        if nav-row.inactive && nav-row.inactive-text != "": HorizontalLayout {
            horizontal-stretch: 1;
            padding-left: indent-depth * LayoutTokens.nav-list-subnav-indent;

            ActionList2Row {
                horizontal-stretch: 1;
                margin-inline: 0px;
                label: nav-row.label;
                row-variant: ActionList2RowVariant.default;
                row-size: ActionList2RowSize.medium;
                disabled: false;
                has-leading-avatar: false;
                has-leading-visual: nav-row.has-leading-visual;
                leading-icon: nav-row.leading-icon;
                description: nav-row.description;
                description-layout: nav-row.description != "" ? ActionList2DescriptionLayout.block : ActionList2DescriptionLayout.none;
                trailing-text: nav-row.trailing-text;
                inactive-text: nav-row.inactive-text;
                active: false;
                selected: false;
                selection-lead: ActionList2SelectionLead.none;
                show-divider: false;
            }
        }

        if !nav-row.inactive: NavListActionRow {
            indent-depth: indent-depth;
            sidebar-indicator: sidebar-indicator;
            sidebar-bar-full-height: false;
            nav-row: nav-row;
            clicked => {
                root.clicked();
            }
        }
    }
}

// Levels are declared innermost-first so each Expandable row can reference the next deeper level.
component NavListLevel4 {
    in property <[NavListLeaf]> items: [];
    in property <int> depth: 0;
    in property <string> path-prefix: "";
    in property <bool> sidebar-indicator: false;
    callback item-activated(path: string);

    VerticalLayout {
        horizontal-stretch: 1;

        for item[ix] in items: VerticalLayout {
            horizontal-stretch: 1;

            NavListItemRow {
                indent-depth: depth;
                sidebar-indicator: sidebar-indicator;
                nav-row: item.data;
                clicked => {
                    root.item-activated(path-prefix == "" ? "" + ix : path-prefix + "." + ix);
                }
            }
        }
    }
}

component NavListExpandableRow3 {
    in property <NavListSub3> item;
    in property <string> item-path;
    in property <int> depth: 0;
    in property <bool> sidebar-indicator: false;
    callback item-activated(path: string);

    property <bool> expanded: item.subnav-default-open;

    VerticalLayout {
        horizontal-stretch: 1;

        NavListActionRow {
            indent-depth: depth;
            sidebar-indicator: sidebar-indicator;
            sidebar-bar-full-height: true;
            force-leading: true;
            forced-leading-icon: expanded ? Icons.chevron_down : Icons.chevron_right;
            nav-row: item.data;
            clicked => {
                expanded = !expanded;
            }
        }

        if expanded: NavListLevel4 {
            items: item.children;
            depth: depth + 1;
            path-prefix: item-path;
            sidebar-indicator: sidebar-indicator;
            item-activated(path) => {
                root.item-activated(path);
            }
        }
    }
}

component NavListLevel3 {
    in property <[NavListSub3]> items: [];
    in property <int> depth: 0;
    in property <string> path-prefix: "";
    in property <bool> sidebar-indicator: false;
    callback item-activated(path: string);

    VerticalLayout {
        horizontal-stretch: 1;

        for item[ix] in items: VerticalLayout {
            horizontal-stretch: 1;

            if item.children.length > 0 && depth < 4 && !item.data.inactive: NavListExpandableRow3 {
                item: item;
                item-path: path-prefix == "" ? "" + ix : path-prefix + "." + ix;
                depth: depth;
                sidebar-indicator: sidebar-indicator;
                item-activated(path) => {
                    root.item-activated(path);
                }
            }

            if item.children.length == 0 || depth >= 4 || item.data.inactive: NavListItemRow {
                indent-depth: depth;
                sidebar-indicator: sidebar-indicator;
                nav-row: item.data;
                clicked => {
                    root.item-activated(path-prefix == "" ? "" + ix : path-prefix + "." + ix);
                }
            }
        }
    }
}

