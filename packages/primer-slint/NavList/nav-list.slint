// Primer-style NavList — flat, grouped (PR4), SubNav expand/collapse (PR6). Upstream: https://primer.style/product/components/nav-list/
// Interactive rows reuse [`ActionListRow`](../ActionList/action-list-row.slint); `current` maps to `selected`.

import { Icons } from "../assets/icons.slint";
import { ActionListRow } from "../ActionList/action-list-row.slint";
import { ActionListDescriptionLayout } from "../ActionList/types.slint";
import { ButtonTokens, LayoutTokens, PrimerColors } from "../tokens.slint";
import {
    NavListGroup,
    NavListGroupHeadingVariant,
    NavListItem,
    NavListLeaf,
    NavListRowData,
    NavListSub1,
    NavListSub2,
    NavListSub3,
} from "./types.slint";

/// Single nav row — inactive (explanation) or interactive [`ActionListRow`].
/// One root [`VerticalLayout`] so rows stack vertically (multiple root `if` branches overlap at 0×0).
component NavListItemRow {
    in property <NavListRowData> nav-row;
    /// Left inset for nested SubNav rows (multiply by depth).
    in property <int> indent-depth: 0;
    /// Primer sidebar pattern: blue vertical bar + muted surface on current (see NavList sidebar-current-indicator).
    in property <bool> sidebar-indicator: false;
    callback clicked;

    VerticalLayout {
        horizontal-stretch: 1;

        if nav-row.inactive: Rectangle {
            horizontal-stretch: 1;
            border-radius: LayoutTokens.borderRadius-medium;
            background: transparent;

            HorizontalLayout {
                horizontal-stretch: 1;
                min-height: LayoutTokens.action-list-item-min-height;
                padding-left: indent-depth * LayoutTokens.nav-list-subnav-indent
                    + LayoutTokens.action-list-item-padding-inline;
                padding-right: LayoutTokens.action-list-item-padding-inline;
                padding-top: LayoutTokens.action-list-item-padding-block;
                padding-bottom: LayoutTokens.action-list-item-padding-block;
                spacing: LayoutTokens.button-content-gap;
                alignment: start;

                if nav-row.has-leading-visual: Image {
                    width: LayoutTokens.iconButton-icon-size-medium;
                    height: LayoutTokens.iconButton-icon-size-medium;
                    vertical-alignment: top;
                    source: nav-row.leading-icon;
                    colorize: ButtonTokens.control-fgColor-disabled;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;

                    Text {
                        horizontal-stretch: 1;
                        text: nav-row.label;
                        color: ButtonTokens.control-fgColor-disabled;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-medium;
                        wrap: word-wrap;
                    }

                    if nav-row.description != "": Text {
                        horizontal-stretch: 1;
                        text: nav-row.description;
                        color: ButtonTokens.control-fgColor-disabled;
                        font-size: LayoutTokens.text-body-size-small;
                        font-weight: LayoutTokens.base-text-weight-medium;
                        wrap: word-wrap;
                    }

                    if nav-row.inactive-text != "": Text {
                        horizontal-stretch: 1;
                        text: nav-row.inactive-text;
                        color: PrimerColors.fgColor-muted;
                        font-size: LayoutTokens.text-body-size-small;
                        wrap: word-wrap;
                    }
                }

                if nav-row.trailing-text != "": Text {
                    vertical-alignment: top;
                    text: nav-row.trailing-text;
                    color: ButtonTokens.control-fgColor-disabled;
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                }
            }
        }

        if !nav-row.inactive: HorizontalLayout {
            horizontal-stretch: 1;
            spacing: sidebar-indicator ? LayoutTokens.nav-list-sidebar-indicator-gap : 0px;
            padding-left: indent-depth * LayoutTokens.nav-list-subnav-indent;
            alignment: start;

            // Full row height (cross-axis stretch) so the bar lines up with the row highlight; fixed width only.
            if sidebar-indicator: Rectangle {
                y: (parent.height - self.height) / 2;
                horizontal-stretch: 0;
                width: LayoutTokens.nav-list-sidebar-indicator-width;
                height: LayoutTokens.nav-list-sidebar-indicator-height;
                border-radius: LayoutTokens.nav-list-sidebar-indicator-radius;
                background: nav-row.current ? PrimerColors.bgColor-accent-emphasis : transparent;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: LayoutTokens.button-content-gap;
                alignment: stretch;

                ActionListRow {
                    horizontal-stretch: 1;
                    label-markdown: @markdown("");
                    label: nav-row.label;
                    has-markdown: false;
                    selected: nav-row.current;
                    disabled: false;
                    has-leading-visual: nav-row.has-leading-visual;
                    leading-icon: nav-row.leading-icon;
                    description: nav-row.description;
                    description-layout: nav-row.description != "" ? ActionListDescriptionLayout.block : ActionListDescriptionLayout.none;
                    clicked => {
                        root.clicked();
                    }
                }

                if nav-row.trailing-text != "": Text {
                    horizontal-stretch: 0;
                    vertical-alignment: center;
                    text: nav-row.trailing-text;
                    color: PrimerColors.fgColor-muted;
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                }
            }
        }
    }
}

// Levels are declared innermost-first so each Expandable row can reference the next deeper level.
component NavListLevel4 {
    in property <[NavListLeaf]> items: [];
    in property <int> depth: 0;
    in property <string> path-prefix: "";
    in property <bool> sidebar-indicator: false;
    callback item-activated(path: string);

    VerticalLayout {
        horizontal-stretch: 1;

        for item[ix] in items: VerticalLayout {
            horizontal-stretch: 1;

            NavListItemRow {
                indent-depth: depth;
                sidebar-indicator: sidebar-indicator;
                nav-row: item.data;
                clicked => {
                    root.item-activated(path-prefix == "" ? "" + ix : path-prefix + "." + ix);
                }
            }
        }
    }
}

component NavListExpandableRow3 {
    in property <NavListSub3> item;
    in property <string> item-path;
    in property <int> depth: 0;
    in property <bool> sidebar-indicator: false;
    callback item-activated(path: string);

    private property <bool> expanded: item.subnav-default-open;

    VerticalLayout {
        horizontal-stretch: 1;

        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: sidebar-indicator ? LayoutTokens.nav-list-sidebar-indicator-gap : 0px;
            padding-left: depth * LayoutTokens.nav-list-subnav-indent;
            alignment: sidebar-indicator ? stretch : start;

            if sidebar-indicator: Rectangle {
                horizontal-stretch: 0;
                width: LayoutTokens.nav-list-sidebar-indicator-width;
                border-radius: LayoutTokens.nav-list-sidebar-indicator-radius;
                background: item.data.current ? PrimerColors.bgColor-accent-emphasis : transparent;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: LayoutTokens.button-content-gap;
                alignment: stretch;

                ActionListRow {
                    horizontal-stretch: 1;
                    label-markdown: @markdown("");
                    has-leading-visual: true;
                    leading-icon: expanded ? Icons.chevron_down : Icons.chevron_right;
                    label: item.data.label;
                    has-markdown: false;
                    selected: item.data.current;
                    disabled: false;
                    description: item.data.description;
                    description-layout: item.data.description != "" ? ActionListDescriptionLayout.block : ActionListDescriptionLayout.none;
                    clicked => {
                        expanded = !expanded;
                    }
                }

                if item.data.trailing-text != "": Text {
                    horizontal-stretch: 0;
                    vertical-alignment: center;
                    text: item.data.trailing-text;
                    color: PrimerColors.fgColor-muted;
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                }
            }
        }

        if expanded: NavListLevel4 {
            items: item.children;
            depth: depth + 1;
            path-prefix: item-path;
            sidebar-indicator: sidebar-indicator;
            item-activated(path) => {
                root.item-activated(path);
            }
        }
    }
}

component NavListLevel3 {
    in property <[NavListSub3]> items: [];
    in property <int> depth: 0;
    in property <string> path-prefix: "";
    in property <bool> sidebar-indicator: false;
    callback item-activated(path: string);

    VerticalLayout {
        horizontal-stretch: 1;

        for item[ix] in items: VerticalLayout {
            horizontal-stretch: 1;

            if item.children.length > 0 && depth < 4 && !item.data.inactive: NavListExpandableRow3 {
                item: item;
                item-path: path-prefix == "" ? "" + ix : path-prefix + "." + ix;
                depth: depth;
                sidebar-indicator: sidebar-indicator;
                item-activated(path) => {
                    root.item-activated(path);
                }
            }

            if item.children.length == 0 || depth >= 4 || item.data.inactive: NavListItemRow {
                indent-depth: depth;
                sidebar-indicator: sidebar-indicator;
                nav-row: item.data;
                clicked => {
                    root.item-activated(path-prefix == "" ? "" + ix : path-prefix + "." + ix);
                }
            }
        }
    }
}

