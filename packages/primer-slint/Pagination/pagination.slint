// Primer DataTable footer pagination — upstream: primer-ui-react `DataTable/Pagination.tsx` + `Pagination/model.tsx`.
//
// Layout: do not wrap repeater cells in bare `Rectangle` under `HorizontalLayout` with
// `alignment: center` / `end` — Slint gives `Rectangle` implicit preferred width 0, so each
// cell stays zero-width and `Button` children overlap. Use intrinsic-sized children (`Button` /
// `Text`) per step (`PaginationNavItem`). Outer row uses `alignment: stretch` with range text
// `horizontal-stretch: 0` and the steps row `horizontal-stretch: 1`. The steps strip uses
// `alignment: space-around` so controls space out without bunching (finer tuning than `end`
// alone). See gb-slint `internal/core/layout.rs` (`solve_box_layout`, `implicit_layout_info_call`
// for `Rectangle`).
// (`solve_box_layout`, `implicit_layout_info_call` for `Rectangle`).
import { Button } from "../Buttons/buttons.slint";
import { ButtonVariant } from "../Buttons/types.slint";
import { Icons } from "../assets/icons.slint";
import { LayoutTokens, PrimerColors, Size } from "../tokens.slint";
import { PaginationPiece, PaginationPieceKind } from "./types.slint";
import { PaginationLogic } from "./pagination-logic.slint";

/// One nav control in the page strip (prev / next / number / ellipsis). Not exported.
component PaginationNavItem {
    in property <PaginationPiece> piece;
    callback activate(int);

    min-height: LayoutTokens.control-small-size;
    horizontal-stretch: 0;

    if piece.kind == PaginationPieceKind.Prev: Button {
        variant: ButtonVariant.invisible;
        size: Size.small;
        disabled: piece.disabled;
        has-leading-icon: true;
        leading-icon: Icons.chevron_left;
        label: "Previous";
        clicked => {
            activate(piece.page_num - 1);
        }
    }

    if piece.kind == PaginationPieceKind.Next: Button {
        variant: ButtonVariant.invisible;
        size: Size.small;
        disabled: piece.disabled;
        has-trailing-icon: true;
        trailing-icon: Icons.chevron_right;
        label: "Next";
        clicked => {
            activate(piece.page_num - 1);
        }
    }

    if piece.kind == PaginationPieceKind.Num: Button {
        variant: piece.selected ? ButtonVariant.default : ButtonVariant.invisible;
        size: Size.small;
        disabled: piece.disabled;
        label: "" + piece.page_num;
        clicked => {
            activate(piece.page_num - 1);
        }
    }

    if piece.kind == PaginationPieceKind.Break: Text {
        text: "…";
        color: PrimerColors.fgColor-muted;
        font-size: LayoutTokens.text-body-size-medium;
        vertical-alignment: center;
    }
}

export component Pagination {
    in property <int> total-count: 0;
    in property <int> page-size: 25;
    in-out property <int> page-index: 0;
    in property <bool> show-pages: true;
    in property <int> margin-page-count: 1;
    in property <int> surrounding-page-count: 2;
    callback page-changed(int);

    property <int> page-count: PaginationLogic.page_count_from_total(total-count, page-size);
    property <int> idx-clamped: PaginationLogic.clamp_page_index(page-index, page-count);
    property <int> current-1based: idx-clamped + 1;
    property <int> model-len: PaginationLogic.model_len(
        page-count,
        current-1based,
        show-pages,
        margin-page-count,
        surrounding-page-count,
    );
    property <int> range-start: PaginationLogic.range_display_start(total-count, idx-clamped, page-size);
    property <int> range-end: PaginationLogic.range_display_end(total-count, idx-clamped, page-size);

    width: 100%;
    min-height: LayoutTokens.control-small-size;

    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        border-width: 1px;
        border-color: PrimerColors.borderColor-default;
        border-radius: LayoutTokens.table-border-radius;

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding-top: LayoutTokens.table-cell-padding-block-normal;
            padding-bottom: LayoutTokens.table-cell-padding-block-normal;
            padding-left: LayoutTokens.stack-padding-normal;
            padding-right: LayoutTokens.stack-padding-normal;
            spacing: LayoutTokens.stack-padding-normal;
            alignment: stretch;

            Text {
                horizontal-stretch: 0;
                text: total-count <= 0
                    ? "0‒0 of 0"
                    : "" + range-start + "‒" + range-end + " of " + total-count;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                vertical-alignment: center;
                wrap: no-wrap;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: LayoutTokens.button-content-gap;
                alignment: space-around;

                for i in model-len: PaginationNavItem {
                    piece: PaginationLogic.piece_at(
                        i,
                        page-count,
                        current-1based,
                        show-pages,
                        margin-page-count,
                        surrounding-page-count,
                    );
                    activate(idx) => {
                        root.page-changed(idx);
                    }
                }
            }
        }
    }
}
