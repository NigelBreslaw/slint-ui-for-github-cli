import { LayoutTokens, PrimerColors } from "../tokens.slint";
import { CounterLabelVariant } from "./types.slint";

export { CounterLabelVariant }

// Primer CounterLabel: default **`background`** / **`foreground`** follow **`scheme`**; **`Button`** overrides those + **`counter-border`** for trailing counts.
export component CounterLabel {
    in property <string> text: "";
    in property <CounterLabelVariant> scheme: secondary;
    in property <color> background: scheme == CounterLabelVariant.primary ? PrimerColors.bgColor-neutral-emphasis : PrimerColors.bgColor-neutral-muted;
    in property <color> foreground: scheme == CounterLabelVariant.primary ? PrimerColors.fgOnEmphasis : PrimerColors.fgColor-default;
    in property <color> counter-border;

    visible: text != "";
    horizontal-stretch: 0;


    Rectangle {
        border-radius: Math.min(LayoutTokens.counter-label-border-radius, self.height / 2);
        border-width: LayoutTokens.counter-label-border-width;
        border-color: root.counter-border;
        background: root.background;

        HorizontalLayout {
            padding-top: LayoutTokens.counter-label-padding-block;
            padding-bottom: LayoutTokens.counter-label-padding-block;
            padding-left: LayoutTokens.counter-label-padding-inline;
            padding-right: LayoutTokens.counter-label-padding-inline;
            alignment: center;

            Text {
                text: root.text;
                color: root.foreground;
                font-size: LayoutTokens.text-body-size-small;
                font-weight: LayoutTokens.base-text-weight-semibold;
                vertical-alignment: center;
            }
        }
    }
}
