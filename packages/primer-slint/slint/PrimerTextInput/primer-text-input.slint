import { Palette } from "std-widgets.slint";
import { IconButton, IconButtonVariant } from "../Buttons/buttons.slint";
import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { Icons } from "../assets/icons.slint";
import { Spinner } from "../Progress/spinner.slint";
import { ValidationStatus } from "../Select/select.slint";
import {
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
    Size,
    TextInputTokens,
} from "../tokens.slint";

/// Mirrors Primer React `loaderPosition`: `auto` replaces the leading slot when `has-leading-visual`,
/// otherwise uses the trailing slot (when empty, trailing column is reserved so layout does not jump).
export enum TextInputLoaderPosition {
    auto,
    leading,
    trailing,
}

export component PrimerTextInput {
    in property <string> label-text: "";
    in-out property <string> text: "";
    in property <string> placeholder: "";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <Size> size: medium;
    in property <bool> required: false;
    /// When true, `label-text` is not rendered (screen-reader parity is bridge-side). Caption still visible if set (see [`CheckboxGroup`]).
    in property <bool> label-visually-hidden: false;
    /// Maximum characters (Unicode scalar values); `<= 0` disables counter and limit styling.
    in property <int> character-limit: 0;
    /// Same row style as `validation-message`: shown only when **`text.character-count > character-limit`** (never uses `placeholder`).
    in property <string> character-limit-exceeded-message: "";
    in property <bool> contrast: false;
    in property <bool> monospace: false;
    in property <bool> has-leading-visual: false;
    in property <image> leading-visual;
    in property <bool> has-trailing-visual: false;
    in property <image> trailing-visual;
    /// Trailing **clear** control ([`IconButton`] `invisible`, `Size.small`). Column stays reserved when true (no layout jump when text is empty).
    in property <bool> has-trailing-action: false;
    /// When true, a [`Spinner`] occupies the resolved loader slot (`loader-position`) instead of that slot’s icon.
    in property <bool> loading: false;
    in property <TextInputLoaderPosition> loader-position: auto;

    callback edited(text: string);

    private property <bool> input-has-focus: false;

    private property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;

    /// Match [`Button`] spinner sizing: large control uses medium spinner; small spinner for small/medium controls.
    private property <Size> field-spinner-component-size:
        size == Size.large ? Size.medium : Size.small;

    private property <color> spinner-track-color: is-dark ? #ffffff30 : #1f232830;

    /// `auto`: leading visual slot when present; otherwise trailing (aligned with Primer React TextInput).
    private property <bool> loading-spin-leading:
        loading && (
            loader-position == TextInputLoaderPosition.leading
            || (loader-position == TextInputLoaderPosition.auto && has-leading-visual)
        );

    private property <bool> loading-spin-trailing:
        loading && (
            loader-position == TextInputLoaderPosition.trailing
            || (loader-position == TextInputLoaderPosition.auto && !has-leading-visual)
        );

    private property <bool> reserve-leading-slot: has-leading-visual || loading-spin-leading;
    private property <bool> reserve-trailing-slot:
        has-trailing-visual || loading-spin-trailing || has-trailing-action;

    private property <length> field-height:
        size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    private property <length> field-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    /// Same inline padding as [`Button`] `btn-padding-inline` — edges stay flush; icons/spinner sit in fixed slots after this inset.
    private property <length> field-padding-inline:
        size == Size.small ? LayoutTokens.control-small-paddingInline-condensed : size == Size.large ? LayoutTokens.control-large-paddingInline-spacious : LayoutTokens.control-medium-paddingInline-normal;

    /// Icon column — TextInputInnerVisualSlot uses 16px glyphs for medium controls.
    private property <length> visual-icon-size:
        size == Size.small ? LayoutTokens.iconButton-icon-size-small : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;

    private property <color> chrome-bg-rest: contrast ? TextInputTokens.bg-contrast : TextInputTokens.bg-rest;

    private property <string> field-font-family:
        monospace ? "Bitstream Vera Sans Mono" : "Mona Sans";

    private property <bool> character-limit-active: character-limit > 0;

    private property <bool> character-limit-exceeded:
        character-limit-active && root.text.character-count > character-limit;

    /// Limit exceeded visually matches validation error (Primer counter danger); validation success is suppressed while over limit.
    private property <bool> chrome-validation-error:
        validation-status == ValidationStatus.error || character-limit-exceeded;

    private property <bool> chrome-validation-success:
        validation-status == ValidationStatus.success && !character-limit-exceeded;

    private property <bool> show-status-validation-line:
        validation-message != "" && validation-status != ValidationStatus.none;

    private property <bool> show-limit-validation-line:
        character-limit-exceeded && character-limit-exceeded-message != "";

    height: column.preferred-height;
    vertical-stretch: 0;
    horizontal-stretch: block ? 1 : 0;

    column := VerticalLayout {
        spacing: 6px;
        width: block ? root.width : self.preferred-width;

        if label-text != "" && !label-visually-hidden: HorizontalLayout {
            spacing: 4px;
            alignment: start;
            vertical-stretch: 0;

            Text {
                text: label-text;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: 600;
                color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            if required: Text {
                text: "*";
                color: PrimerColors.fgColor-danger;
                font-size: LayoutTokens.text-body-size-medium;
                vertical-alignment: top;
            }
        }

        VerticalLayout {
            spacing: 6px;
            alignment: start;

            field-shell := Rectangle {
                vertical-stretch: 0;
                height: field-height;

                MultiDropShadow {
                    visible: !root.disabled;
                    border-radius: LayoutTokens.borderRadius-medium;
                    shadows: [
                        {
                            color: PrimerColors.shadow-controlTrigger-back,
                            offset-x: 0px,
                            offset-y: 1px,
                            blur: 2px,
                        },
                        {
                            color: PrimerColors.shadow-controlTrigger-front,
                            offset-x: 0px,
                            offset-y: 1px,
                            blur: 1px,
                        },
                    ];
                }

                ta := TouchArea {
                    enabled: !root.disabled;

                    field-chrome := Rectangle {
                        background: root.chrome-bg-rest;
                        border-radius: LayoutTokens.borderRadius-medium;
                        border-width: 1px;
                        border-color: TextInputTokens.borderColor-rest;
                        clip: true;

                        // `alignment` must be `stretch` (flex): fixed slots hug the padded edges; middle takes `horizontal-stretch`.
                        // `center` distributes free space before/after the row and pulls icons inward — unlike [`Button`] `filled-row`.
                        HorizontalLayout {
                            padding-left: field-padding-inline;
                            padding-right: field-padding-inline;
                            spacing: LayoutTokens.button-content-gap;
                            width: 100%;
                            height: 100%;
                            alignment: stretch;

                            if loading-spin-leading: VerticalLayout {
                                horizontal-stretch: 0;
                                height: parent.height;
                                alignment: center;

                                Spinner {
                                    size: field-spinner-component-size;
                                    segment-color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                                    track-color: spinner-track-color;
                                }
                            }

                            if !loading-spin-leading && has-leading-visual: VerticalLayout {
                                horizontal-stretch: 0;
                                height: parent.height;
                                alignment: center;

                                Image {
                                    width: visual-icon-size;
                                    height: visual-icon-size;
                                    source: leading-visual;
                                    colorize: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-muted;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 100%;

                                if root.text == "" && root.placeholder != "": Text {
                                    x: 0px;
                                    y: (parent.height - self.height) / 2;
                                    width: parent.width;
                                    text: root.placeholder;
                                    font-size: field-font-size;
                                    font-family: field-font-family;
                                    color: PrimerColors.fgColor-muted;
                                    overflow: elide;
                                }

                                inp := TextInput {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    vertical-alignment: center;
                                    text <=> root.text;
                                    read-only: root.disabled;
                                    font-size: field-font-size;
                                    font-family: field-font-family;
                                    color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                                    edited => {
                                        root.edited(self.text);
                                    }
                                    changed has-focus => {
                                        root.input-has-focus = self.has-focus;
                                    }
                                }
                            }

                            if loading-spin-trailing: VerticalLayout {
                                horizontal-stretch: 0;
                                height: parent.height;
                                alignment: center;

                                Spinner {
                                    size: field-spinner-component-size;
                                    segment-color: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-default;
                                    track-color: spinner-track-color;
                                }
                            }

                            if !loading-spin-trailing && has-trailing-visual: VerticalLayout {
                                horizontal-stretch: 0;
                                height: parent.height;
                                alignment: center;

                                Image {
                                    width: visual-icon-size;
                                    height: visual-icon-size;
                                    source: trailing-visual;
                                    colorize: root.disabled ? ButtonTokens.control-fgColor-disabled : PrimerColors.fgColor-muted;
                                }
                            }

                            if has-trailing-action: VerticalLayout {
                                horizontal-stretch: 0;
                                height: parent.height;
                                alignment: center;

                                IconButton {
                                    size: Size.small;
                                    variant: IconButtonVariant.invisible;
                                    icon-source: Icons.x;
                                    opacity: root.disabled ? 0.45 : root.loading ? 0.45 : root.text == "" ? 0.35 : 1.0;

                                    clicked => {
                                        if !root.disabled && !root.loading && root.text != "" {
                                            root.text = "";
                                            root.edited("");
                                        }
                                    }
                                }
                            }
                        }

                        states [
                            disabled when root.disabled: {
                                field-chrome.background: TextInputTokens.bg-disabled;
                                field-chrome.border-color: TextInputTokens.border-disabled;
                                field-chrome.border-width: 1px;
                            }
                            focused-error when !root.disabled && root.input-has-focus && root.chrome-validation-error: {
                                field-chrome.background: root.chrome-bg-rest;
                                field-chrome.border-color: TextInputTokens.borderColor-error;
                                field-chrome.border-width: 2px;
                            }
                            focused-success when !root.disabled && root.input-has-focus && root.chrome-validation-success: {
                                field-chrome.background: root.chrome-bg-rest;
                                field-chrome.border-color: TextInputTokens.borderColor-success;
                                field-chrome.border-width: 2px;
                            }
                            focused when !root.disabled && root.input-has-focus && root.validation-status == ValidationStatus.none && !root.character-limit-exceeded: {
                                field-chrome.background: root.chrome-bg-rest;
                                field-chrome.border-color: TextInputTokens.borderColor-focus;
                                field-chrome.border-width: 2px;
                            }
                            error when !root.disabled && !root.input-has-focus && root.chrome-validation-error: {
                                field-chrome.background: root.chrome-bg-rest;
                                field-chrome.border-color: TextInputTokens.borderColor-error;
                                field-chrome.border-width: 1px;
                            }
                            success when !root.disabled && !root.input-has-focus && root.chrome-validation-success: {
                                field-chrome.background: root.chrome-bg-rest;
                                field-chrome.border-color: TextInputTokens.borderColor-success;
                                field-chrome.border-width: 1px;
                            }
                            hover-none when !root.disabled && parent.has-hover && !root.input-has-focus && root.validation-status == ValidationStatus.none && !root.character-limit-exceeded: {
                                field-chrome.background: TextInputTokens.bg-hover;
                                field-chrome.border-color: TextInputTokens.borderColor-rest;
                                field-chrome.border-width: 1px;
                            }
                        ]
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: LayoutTokens.text-body-size-small;
            color: PrimerColors.fgColor-muted;
            wrap: word-wrap;
        }

        if character-limit-active: HorizontalLayout {
            spacing: 4px;
            width: 100%;

            Text {
                horizontal-stretch: 1;
                horizontal-alignment: right;
                text: "\{root.text.character-count} / \{character-limit}";
                font-size: LayoutTokens.text-body-size-small;
                color: root.character-limit-exceeded ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-muted;
                wrap: word-wrap;
            }
        }

        // Parent `validation-message`/`validation-status`, or limit copy — text/icon use **`root.text`** for limit state (not placeholder/caption).
        if show-status-validation-line || show-limit-validation-line: HorizontalLayout {
            vertical-stretch: 0;
            horizontal-stretch: 1;
            spacing: 6px;

            Image {
                y: (parent.height - self.height) / 2;
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.iconButton-icon-size-medium;
                source: show-status-validation-line && validation-status == ValidationStatus.success ? Icons.check_circle : Icons.alert;
                colorize: show-status-validation-line && validation-status == ValidationStatus.success ? PrimerColors.fgColor-success : ButtonTokens.color-btn-danger-text;
            }

            Text {
                y: (parent.height - self.height) / 2;
                text: show-status-validation-line ? validation-message : character-limit-exceeded-message;
                font-size: LayoutTokens.text-body-size-medium;
                color: show-status-validation-line && validation-status == ValidationStatus.success ? PrimerColors.fgColor-success : ButtonTokens.color-btn-danger-text;
                width: self.preferred-width;
            }
        }
    }
}
