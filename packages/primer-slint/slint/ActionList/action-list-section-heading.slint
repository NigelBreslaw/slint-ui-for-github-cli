// Primer `GroupHeading` **subtle** — upstream subtle group label (see **ActionList** shell + tokens).

import { ActionListTokens, LayoutTokens } from "../tokens.slint";

export component ActionListSectionHeading {
    in property <string> title: "";

    VerticalLayout {
        horizontal-stretch: 1;
        padding-top: 8px;
        padding-bottom: 4px;
        padding-left: LayoutTokens.action-list-item-padding-inline;
        padding-right: LayoutTokens.action-list-item-padding-inline;

        Text {
            horizontal-stretch: 1;
            text: root.title;
            color: ActionListTokens.section-heading-subtle-fgColor;
            font-size: LayoutTokens.text-body-size-small;
            font-weight: LayoutTokens.base-text-weight-semibold;
            wrap: word-wrap;
        }
    }
}
