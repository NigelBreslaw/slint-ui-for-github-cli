// Slint component to simulate CSS style multiple drop-shadows.
export struct DropShadowLayer {
    color: color,
    offset-x: length,
    offset-y: length,
    blur: length,
}

export component MultiDropShadow inherits Rectangle {
    in property <[DropShadowLayer]> shadows;

    for shadow in shadows: Rectangle {
        drop-shadow-color: shadow.color;
        border-radius: root.border-radius;
        drop-shadow-offset-x: shadow.offset-x;
        drop-shadow-offset-y: shadow.offset-y;
        drop-shadow-blur: shadow.blur;
    }
}
