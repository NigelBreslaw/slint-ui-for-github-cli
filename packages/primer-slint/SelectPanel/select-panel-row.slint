// Multi-select row: optional focus accent + non-interactive Checkbox + label swatch + title/description.
// Row chrome aligns with [`ActionListRow`](../ActionList/action-list-row.slint) (ButtonTokens action-list surfaces).

import { Checkbox } from "../Checkbox/checkbox.slint";
import { ButtonTokens, LayoutTokens, PrimerColors } from "../tokens.slint";

export component SelectPanelRow {
    in property <bool> disabled: false;
    in property <bool> checked: false;
    in property <bool> show-focus-accent: false;
    in property <string> label: "";
    in property <string> description: "";
    in property <color> swatch: #808080;
    callback clicked;

    min-height: LayoutTokens.action-list-item-min-height;
    width: 100%;

    ta := TouchArea {
        width: 100%;
        min-height: LayoutTokens.action-list-item-min-height;
        enabled: !root.disabled;
        clicked => {
            root.clicked();
        }

        row-bg := Rectangle {
            border-radius: LayoutTokens.borderRadius-medium;
            background: #00000000;

            hl := HorizontalLayout {
                min-height: LayoutTokens.action-list-item-min-height;
                padding-left: LayoutTokens.action-list-item-padding-inline;
                padding-right: LayoutTokens.action-list-item-padding-inline;
                padding-top: LayoutTokens.action-list-item-padding-block;
                padding-bottom: LayoutTokens.action-list-item-padding-block;
                spacing: LayoutTokens.button-content-gap;
                alignment: center;

                if root.show-focus-accent: Rectangle {
                    horizontal-stretch: 0;
                    width: LayoutTokens.nav-list-sidebar-indicator-width;
                    height: LayoutTokens.nav-list-sidebar-indicator-height;
                    border-radius: LayoutTokens.nav-list-sidebar-indicator-radius;
                    background: PrimerColors.bgColor-accent-emphasis;
                }

                Checkbox {
                    interactive: false;
                    checked: root.checked;
                    disabled: root.disabled;
                    label: "";
                }

                Rectangle {
                    horizontal-stretch: 0;
                    width: 14px;
                    height: 14px;
                    border-radius: 7px;
                    background: root.swatch;
                    border-width: 1px;
                    border-color: PrimerColors.borderColor-muted;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    min-width: 0px;
                    spacing: 2px;

                    primary-label := Text {
                        horizontal-stretch: 1;
                        min-width: 0px;
                        text: root.label;
                        color: PrimerColors.fgColor-default;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-medium;
                        wrap: word-wrap;
                    }

                    desc-label := Text {
                        visible: root.description != "";
                        horizontal-stretch: 1;
                        min-width: 0px;
                        text: root.description;
                        color: PrimerColors.fgColor-muted;
                        font-size: LayoutTokens.text-body-size-small;
                        font-weight: LayoutTokens.base-text-weight-medium;
                        wrap: word-wrap;
                    }
                }
            }

            states [
                disabled when root.disabled: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-selected-bg;
                    primary-label.color: ButtonTokens.control-fgColor-disabled;
                    desc-label.color: ButtonTokens.control-fgColor-disabled;
                }
                pressed when !root.disabled && ta.pressed: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-active-bg;
                }
                hover when !root.disabled && !ta.pressed && ta.has-hover: {
                    row-bg.background: ButtonTokens.color-action-list-item-default-hover-bg;
                }
            ]
        }
    }
}
