// Primer-style SelectPanel body (anchored shell is [`AnchoredOverlay`](../AnchoredOverlay/anchored-overlay.slint)).
// Single mode: [`SelectOption`](../Select/select.slint) + [`ActionListRow`](../ActionList/action-list-row.slint).
// Multi mode: [`SelectPanelItem`] + checkbox row + `multi-selected` (`[bool]`; row `ix` checked when `ix < multi-selected.length && multi-selected[ix]`, same as `ActionList`) + `multi-item-activated(ix)` (parent updates selection).

import { ActionListRow } from "../ActionList/action-list-row.slint";
import { ActionListDescriptionLayout } from "../ActionList/types.slint";
import { Icons } from "../assets/icons.slint";
import { PrimerTextInput } from "../PrimerTextInput/primer-text-input.slint";
import { Spinner } from "../Progress/spinner.slint";
import { SelectOption } from "../Select/select.slint";
import { LayoutTokens, PrimerColors, SelectPanelTokens, Size } from "../tokens.slint";
import { SelectPanelRow } from "./select-panel-row.slint";
import { SelectPanelItem, SelectPanelMode } from "./types.slint";

export component SelectPanel {
    in property <SelectPanelMode> mode: SelectPanelMode.multi;
    in property <string> title: "";
    in property <string> subtitle: "";
    in-out property <string> filter-text: "";
    in property <string> filter-placeholder: "Filter items";
    in property <bool> disabled: false;
    in property <bool> loading: false;
    in property <string> loading-message: "Loading…";
    in property <string> empty-message: "No results";
    /// When non-empty, shown above `empty-message` (Primer **SelectPanelMessage**-style title).
    in property <string> empty-title: "";
    in property <length> list-max-height: SelectPanelTokens.list-max-height-default;
    /// Row with keyboard/list focus (multi mode accent); `-1` hides the accent.
    in property <int> focused-index: -1;
    /// When true, shows a top border and padded slot below the list; place footer actions as **direct children** of `SelectPanel`.
    in property <bool> show-footer: false;

    in property <[SelectOption]> single-items: [];
    in-out property <int> selected-index: -1;

    in property <[SelectPanelItem]> multi-items: [];
    /// `SelectPanelMode.multi`: row `ix` is checked when `ix < multi-selected.length && multi-selected[ix]` (out-of-range / missing entries unchecked).
    in property <[bool]> multi-selected: [];

    in property <int> item-count: -1;

    callback filter-changed(string);
    callback single-selected-changed(int);
    /// Fired when an enabled row is clicked in multi mode; parent toggles `multi-selected` (this component does not mutate it).
    callback multi-item-activated(int);

    horizontal-stretch: 1;

    private property <int> effective-len: item-count >= 0 ? item-count
        : mode == SelectPanelMode.single ? single-items.length : multi-items.length;

    VerticalLayout {
        spacing: SelectPanelTokens.wrapper-stack-gap;
        width: 100%;
        alignment: start;

        if root.title != "": Text {
            text: root.title;
            color: PrimerColors.fgColor-default;
            font-size: LayoutTokens.text-body-size-medium;
            font-weight: LayoutTokens.base-text-weight-semibold;
            wrap: word-wrap;
        }

        if root.subtitle != "": Text {
            text: root.subtitle;
            color: PrimerColors.fgColor-muted;
            font-size: LayoutTokens.text-body-size-small;
            font-weight: LayoutTokens.base-text-weight-medium;
            wrap: word-wrap;
        }

        PrimerTextInput {
            width: 100%;
            block: true;
            placeholder: root.filter-placeholder;
            text <=> root.filter-text;
            disabled: root.disabled;
            has-leading-visual: true;
            leading-visual: Icons.search;
            edited(t) => {
                root.filter-changed(t);
            }
        }

        Rectangle {
            width: 100%;
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Rectangle {
            width: 100%;
            height: root.list-max-height;
            background: PrimerColors.bgColor-canvas-subtle;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;
            clip: true;

            VerticalLayout {
                width: 100%;
                height: 100%;
                alignment: stretch;

                if root.loading: VerticalLayout {
                    padding: LayoutTokens.stack-padding-normal;
                    spacing: SelectPanelTokens.wrapper-stack-gap;
                    alignment: center;

                    HorizontalLayout {
                        spacing: SelectPanelTokens.wrapper-stack-gap;
                        alignment: center;

                        Spinner {
                            size: Size.small;
                        }

                        Text {
                            text: root.loading-message;
                            font-size: LayoutTokens.text-body-size-small;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }
                    }
                }

                if !root.loading && root.effective-len == 0: VerticalLayout {
                    padding: SelectPanelTokens.message-region-padding;
                    spacing: SelectPanelTokens.message-stack-gap;
                    alignment: center;

                    if root.empty-title != "": Text {
                        horizontal-alignment: center;
                        text: root.empty-title;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                        color: PrimerColors.fgColor-default;
                        wrap: word-wrap;
                    }

                    Text {
                        horizontal-alignment: center;
                        text: root.empty-message;
                        font-size: LayoutTokens.text-body-size-small;
                        color: PrimerColors.fgColor-muted;
                        font-weight: root.empty-title != "" ? LayoutTokens.base-text-weight-medium : LayoutTokens.base-text-weight-semibold;
                        wrap: word-wrap;
                    }
                }

                if !root.loading && root.effective-len > 0 && root.mode == SelectPanelMode.single: Flickable {
                    height: parent.height;
                    viewport-width: parent.width;
                    viewport-height: single-vl.preferred-height;

                    single-vl := VerticalLayout {
                        width: parent.width;

                        for ix in root.effective-len: HorizontalLayout {
                            spacing: LayoutTokens.nav-list-sidebar-indicator-gap;
                            alignment: stretch;

                            Rectangle {
                                horizontal-stretch: 0;
                                y: (parent.height - self.height) / 2;
                                width: LayoutTokens.nav-list-sidebar-indicator-width;
                                height: LayoutTokens.nav-list-sidebar-indicator-height;
                                border-radius: LayoutTokens.nav-list-sidebar-indicator-radius;
                                background: ix == root.focused-index && root.focused-index >= 0 ? PrimerColors.bgColor-accent-emphasis : #00000000;
                            }

                            ActionListRow {
                                horizontal-stretch: 1;
                                label-markdown: @markdown("");
                                label: root.single-items[ix].label;
                                has-markdown: false;
                                description: "";
                                description-layout: ActionListDescriptionLayout.none;
                                selected: ix == root.selected-index;
                                disabled: root.disabled || !root.single-items[ix].enabled;
                                clicked => {
                                    if !root.single-items[ix].enabled || root.disabled {
                                        return;
                                    }
                                    root.selected-index = ix;
                                    root.single-selected-changed(ix);
                                }
                            }
                        }
                    }
                }

                if !root.loading && root.effective-len > 0 && root.mode == SelectPanelMode.multi: Flickable {
                    height: parent.height;
                    viewport-width: parent.width;
                    viewport-height: multi-vl.preferred-height;

                    multi-vl := VerticalLayout {
                        width: parent.width;

                        for ix in root.effective-len: SelectPanelRow {
                            label: root.multi-items[ix].label;
                            description: root.multi-items[ix].description;
                            swatch: root.multi-items[ix].swatch;
                            disabled: root.disabled || !root.multi-items[ix].enabled;
                            show-focus-accent: ix == root.focused-index;
                            checked: ix < root.multi-selected.length && root.multi-selected[ix];
                            clicked => {
                                if !root.multi-items[ix].enabled || root.disabled {
                                    return;
                                }
                                root.multi-item-activated(ix);
                            }
                        }
                    }
                }
            }
        }

        // Primer SelectPanel `.Footer` (`show-footer` hides chrome; `@children` cannot live inside `if`).
        VerticalLayout {
            visible: root.show-footer;

            Rectangle {
                height: LayoutTokens.nav-list-divider-height;
                background: PrimerColors.borderColor-default;
            }

            VerticalLayout {
                padding: LayoutTokens.banner-padding-default;
                spacing: LayoutTokens.button-content-gap;
                alignment: start;

                @children
            }
        }
    }
}
