// Primer **SelectPanel2** — **`Button`** anchor + **`AnchoredOverlay`** + heading + **`FilteredActionList2`** (new stack only).
// Upstream: `SelectPanel.tsx` + `AnchoredOverlay` + `FilteredActionList`.

import {
    AnchoredOverlay,
    AnchoredOverlayAlign,
    AnchoredOverlayHeight,
    AnchoredOverlaySide,
    AnchoredOverlayWidth,
    PositionProps,
} from "../AnchoredOverlay/anchored-overlay.slint";
import { Button, ButtonVariant } from "../Buttons/buttons.slint";
import { Icons } from "../assets/icons.slint";
import { FilteredActionList2 } from "../FilteredActionList2/filtered-action-list2.slint";
import { FilteredActionListLoadingKind } from "../FilteredActionList2/types.slint";
import {
    ActionList2Line,
    ActionList2ListRole,
    ActionList2SelectionMode,
    ALVariant,
} from "../ActionList2/types.slint";
import { LayoutTokens, SelectPanelTokens } from "../tokens.slint";
import { SelectPanel2Footer } from "./select-panel2-footer.slint";
import { SelectPanel2Heading } from "./select-panel2-heading.slint";
import { SelectPanel2Notice } from "./select-panel2-notice.slint";
import { SelectPanel2NoticeVariant } from "./types.slint";

export { SelectPanel2NoticeVariant } from "./types.slint";

export component SelectPanel2 {
    in property <string> anchor-label: "Select labels";
    in property <ButtonVariant> button-variant: ButtonVariant.default;
    in property <bool> button-disabled: false;
    /// When false, hide the built-in trigger; host supplies **`anchor-position-props`** (upstream **`renderAnchor={null}`**).
    in property <bool> has-built-in-anchor: true;
    in property <PositionProps> anchor-position-props: {
        absolute-position: { x: 0px, y: 0px },
        source-size: { width: 0px, height: 0px },
    };
    in property <string> title: "Select labels";
    in property <string> subtitle: "";
    in property <string> filter-placeholder: "Filter Labels";
    in property <AnchoredOverlaySide> side: AnchoredOverlaySide.outside_bottom;
    in property <AnchoredOverlayAlign> align: AnchoredOverlayAlign.start;
    in property <AnchoredOverlayWidth> width-preset: AnchoredOverlayWidth.medium;
    in property <AnchoredOverlayHeight> height-preset: AnchoredOverlayHeight.auto;
    in property <bool> prevent-overflow: true;
    in property <bool> show-backdrop: false;
    in property <bool> allow-dismiss: true;
    in property <bool> reduce-motion: false;
    in property <length> margin: LayoutTokens.base-size-4;
    in property <length> anchor-offset: 0px;
    in property <length> alignment-offset: 0px;
    in property <length> panel-padding: LayoutTokens.base-size-8;
    property <length> overlay-panel-width:
        root.width-preset == AnchoredOverlayWidth.small ? 256px
        : root.width-preset == AnchoredOverlayWidth.medium ? 320px
        : root.width-preset == AnchoredOverlayWidth.large ? 480px
        : root.width-preset == AnchoredOverlayWidth.xlarge ? 640px
        : 960px;
    property <length> panel-body-width: root.overlay-panel-width - 2 * root.panel-padding;

    in-out property <bool> open: false;
    property <bool> popup-visible: false;

    in-out property <string> filter-text: "";
    in property <[ActionList2Line]> lines: [];
    in property <ALVariant> list-variant: ALVariant.inset;
    in property <bool> show-dividers: false;
    in property <ActionList2ListRole> list-role: ActionList2ListRole.listbox;
    in property <ActionList2SelectionMode> selection-mode: ActionList2SelectionMode.multiple;
    in-out property <int> selected-index: -1;
    in property <[bool]> multi-selected: [];
    in property <length> body-region-height: SelectPanelTokens.list-max-height-default;
    in property <bool> loading: false;
    in property <FilteredActionListLoadingKind> loading-kind: FilteredActionListLoadingKind.body_spinner;
    in property <string> loading-message: "Loading…";
    in property <bool> show-message: false;
    in property <string> message-title: "";
    in property <string> message-description: "";
    in property <string> empty-title: "";
    in property <string> empty-message: "";
    in property <bool> select-all-visible: false;
    in-out property <bool> select-all-checked: false;
    in-out property <bool> select-all-indeterminate: false;

    in property <bool> show-notice: false;
    in property <SelectPanel2NoticeVariant> notice-variant: SelectPanel2NoticeVariant.info;
    in property <string> notice-text: "";
    in property <bool> show-footer: false;
    in property <bool> close-on-single-select: true;

    callback filter-changed(string);
    callback item-activated(int);
    callback single-selected-changed(int);
    callback select-all-changed(bool);
    callback opened();
    callback closed();
    callback close-requested();

    property <PositionProps> effective-anchor-position:
        root.has-built-in-anchor
        ? {
            absolute-position: trigger.absolute-position,
            source-size: { width: trigger.width, height: trigger.height },
        }
        : root.anchor-position-props;

    changed open => {
        if root.open && !root.popup-visible {
            panel-popup.show();
        } else if !root.open && root.popup-visible {
            panel-popup.close();
        }
    }

    close-after-single-pick := Timer {
        interval: 1ms;
        running: false;
        triggered() => {
            panel-popup.close();
            self.stop();
        }
    }

    VerticalLayout {
        alignment: start;

        trigger := Button {
            visible: root.has-built-in-anchor;
            variant: root.button-variant;
            disabled: root.button-disabled;
            label: root.anchor-label;
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                if root.popup-visible {
                    panel-popup.close();
                } else {
                    panel-popup.show();
                }
            }
        }

        panel-popup := AnchoredOverlay {
            position-props: root.effective-anchor-position;
            side: root.side;
            align: root.align;
            width-preset: root.width-preset;
            height-preset: root.height-preset;
            prevent-overflow: root.prevent-overflow;
            show-backdrop: root.show-backdrop;
            allow-dismiss: root.allow-dismiss;
            reduce-motion: root.reduce-motion;
            margin: root.margin;
            anchor-offset: root.anchor-offset;
            alignment-offset: root.alignment-offset;
            panel-padding: 0px;

            close-requested => {
                root.close-requested();
            }

            opened => {
                root.popup-visible = true;
                root.open = true;
                root.opened();
            }

            closed => {
                root.popup-visible = false;
                root.open = false;
                root.closed();
            }

            panel-body := VerticalLayout {
                width: root.panel-body-width;
                padding: root.panel-padding;
                spacing: SelectPanelTokens.wrapper-stack-gap;
                alignment: start;

                SelectPanel2Heading {
                    title: root.title;
                    subtitle: root.subtitle;
                }

                if root.show-notice: SelectPanel2Notice {
                    variant: root.notice-variant;
                    text: root.notice-text;
                }

                FilteredActionList2 {
                    filter-text <=> root.filter-text;
                    placeholder: root.filter-placeholder;
                    lines: root.lines;
                    list-variant: root.list-variant;
                    show-dividers: root.show-dividers;
                    list-role: root.list-role;
                    selection-mode: root.selection-mode;
                    selected-index: root.selected-index;
                    multi-selected: root.multi-selected;
                    body-region-height: root.body-region-height;
                    loading: root.loading;
                    loading-kind: root.loading-kind;
                    loading-message: root.loading-message;
                    show-message: root.show-message;
                    message-title: root.message-title;
                    message-description: root.message-description;
                    empty-title: root.empty-title;
                    empty-message: root.empty-message;
                    select-all-visible: root.select-all-visible;
                    select-all-checked <=> root.select-all-checked;
                    select-all-indeterminate <=> root.select-all-indeterminate;
                    filter-changed(t) => {
                        root.filter-changed(t);
                    }
                    item-activated(ix) => {
                        root.item-activated(ix);
                        if root.selection-mode == ActionList2SelectionMode.single {
                            root.single-selected-changed(ix);
                            if root.close-on-single-select && !root.show-backdrop {
                                close-after-single-pick.start();
                            }
                        }
                    }
                    select-all-changed(on) => {
                        root.select-all-changed(on);
                    }
                }

                // **`@children`** cannot live inside **`if`** (Slint); use **`visible`** like legacy **SelectPanel**.
                SelectPanel2Footer {
                    visible: root.show-footer;
                    @children
                }
            }
        }
    }
}
