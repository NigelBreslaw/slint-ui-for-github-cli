import { Banner, BannerVariant } from "../Banner/banner.slint";
import { SelectPanelNoticeVariant } from "./types.slint";

/// Thin **Banner** wrapper (upstream **SelectPanel** `notice` above the filter).
export component SelectPanelNotice {
    in property <SelectPanelNoticeVariant> variant: SelectPanelNoticeVariant.info;
    in property <string> text: "";

    property <BannerVariant> banner-variant:
        root.variant == SelectPanelNoticeVariant.error ? BannerVariant.critical
        : root.variant == SelectPanelNoticeVariant.warning ? BannerVariant.warning
        : BannerVariant.info;

    horizontal-stretch: 1;

    Banner {
        width: 100%;
        variant: root.banner-variant;
        description: root.text;
    }
}
