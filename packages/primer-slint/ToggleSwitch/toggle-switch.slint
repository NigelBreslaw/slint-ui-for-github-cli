// Primer ToggleSwitch — PR1–PR5 as before; motion: **`LayoutTokens.duration-80`** + upstream easing on knob, icons, track chrome (**`ToggleSwitch.module.css`**; disabled uses **0ms** like `transition-property: none`).
// Upstream: primer-ui-react ToggleSwitch.tsx + ToggleSwitch.module.css

import { Icons } from "../assets/icons.slint";
import { Spinner } from "../Progress/spinner.slint";
import { LayoutTokens, PrimerColors, Size, ToggleSwitchTokens } from "../tokens.slint";

export enum ToggleSwitchSize {
    small,
    medium,
}

export enum ToggleSwitchStatusLabelPosition {
    start,
    end,
}

export component ToggleSwitch {
    in-out property <bool> checked: false;
    in property <bool> disabled: false;
    in property <bool> loading: false;
    in property <ToggleSwitchSize> size: ToggleSwitchSize.medium;
    in property <ToggleSwitchStatusLabelPosition> status-label-position: ToggleSwitchStatusLabelPosition.start;
    in property <string> button-label-on: "On";
    in property <string> button-label-off: "Off";

    callback changed(bool);
    callback clicked;

    private property <bool> accepts-interaction: !root.disabled && !root.loading;
    private property <length> track-width: root.size == ToggleSwitchSize.small ? 48px : 64px;
    private property <length> track-height: root.size == ToggleSwitchSize.small ? 24px : 32px;
    /// Matches React **`.SwitchButton`** / **`.ToggleKnob`**: thin border on the track; knob **`width: 50%`** and **`top`/`bottom`/`left: 1px`** of the **padding box** (inner area inside the track border).
    private property <length> track-border-w: 1px;
    private property <length> track-inner-w: root.track-width - 2 * root.track-border-w;
    private property <length> track-inner-h: root.track-height - 2 * root.track-border-w;
    private property <length> track-half-w: root.track-inner-w / 2;
    private property <length> icon-diameter: root.size == ToggleSwitchSize.small ? 12px : 16px;
    private property <length> knob-w: root.track-inner-w / 2;
    private property <length> knob-h: root.track-inner-h - 2 * root.track-border-w;
    private property <length> knob-x: root.track-border-w + (root.checked ? root.track-inner-w - root.knob-w - 1px : 1px);
    private property <length> knob-y: root.track-border-w + 1px;
    private property <length> line-icon-x: (root.track-half-w - root.icon-diameter) / 2 + (root.checked ? 0px : -root.track-half-w);
    private property <length> circle-icon-x: (root.track-half-w - root.icon-diameter) / 2 + (root.checked ? root.track-half-w : 0px);
    private property <length> knob-corner-radius: LayoutTokens.borderRadius-medium - 2px;

    private property <duration> motion-duration: root.disabled ? 0ms : LayoutTokens.duration-80;

    private property <length> status-font-size: root.size == ToggleSwitchSize.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;
    private property <length> focus-ring-padding: 5px;
    private property <length> focus-host-width: root.track-width + 2 * root.focus-ring-padding;
    private property <length> focus-host-height: root.track-height + 2 * root.focus-ring-padding;

    private property <color> line-icon-fg: root.disabled ? ToggleSwitchTokens.line-icon-fgColor-disabled : ToggleSwitchTokens.line-icon-fgColor-rest;
    private property <color> circle-icon-fg: root.disabled ? ToggleSwitchTokens.circle-icon-fgColor-disabled : ToggleSwitchTokens.circle-icon-fgColor-rest;
    private property <color> knob-fill: root.disabled ? ToggleSwitchTokens.knob-bgColor-disabled : ToggleSwitchTokens.knob-bgColor-rest;
    private property <color> knob-stroke: root.disabled ? ToggleSwitchTokens.knob-borderColor-disabled : (root.checked ? ToggleSwitchTokens.knob-borderColor-checked : ToggleSwitchTokens.knob-borderColor-rest);

    animate knob-x {
        duration: root.motion-duration;
        easing: cubic-bezier(0.5, 1, 0.89, 1);
    }

    animate line-icon-x {
        duration: root.motion-duration;
        easing: cubic-bezier(0.5, 1, 0.89, 1);
    }

    animate circle-icon-x {
        duration: root.motion-duration;
        easing: cubic-bezier(0.5, 1, 0.89, 1);
    }

    animate knob-stroke {
        duration: root.motion-duration;
        easing: cubic-bezier(0.5, 1, 0.89, 1);
    }

    HorizontalLayout {
        spacing: LayoutTokens.button-content-gap;
        alignment: center;

        if root.status-label-position == ToggleSwitchStatusLabelPosition.start && root.loading: HorizontalLayout {
            padding-left: 0px;
            padding-right: 0px;
            alignment: center;
            align-items: center;

            Spinner {
                size: Size.small;
                segment-color: PrimerColors.fgColor-muted;
                track-color: #f0f6fc40;
            }
        }

        if root.status-label-position == ToggleSwitchStatusLabelPosition.start: status-touch-start := TouchArea {
            enabled: root.accepts-interaction;
            clicked => {
                root.checked = !root.checked;
                root.changed(root.checked);
                root.clicked();
            }

            VerticalLayout {
                alignment: center;
                min-width: 32px;

                Text {
                    text: root.checked ? root.button-label-on : root.button-label-off;
                    color: root.accepts-interaction ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                    font-size: root.status-font-size;
                    horizontal-alignment: right;
                }
            }
        }

        VerticalLayout {
            alignment: center;

            track-focus-host := Rectangle {
                width: root.focus-host-width;
                height: root.focus-host-height;
                background: transparent;
                border-width: track-fs.has-focus && root.accepts-interaction ? 2px : 0px;
                border-color: PrimerColors.fgColor-link;
                border-radius: LayoutTokens.borderRadius-medium + root.focus-ring-padding;

                track-fs := FocusScope {
                    x: root.focus-ring-padding;
                    y: root.focus-ring-padding;
                    width: root.track-width;
                    height: root.track-height;

                    key-pressed(event) => {
                        if !root.accepts-interaction {
                            return reject;
                        }
                        if event.text == Key.Return || event.text == Key.Space {
                            root.checked = !root.checked;
                            root.changed(root.checked);
                            root.clicked();
                            return accept;
                        }
                        return reject;
                    }

                    track-ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        enabled: root.accepts-interaction;
                        clicked => {
                            root.checked = !root.checked;
                            root.changed(root.checked);
                            root.clicked();
                        }

                        track-plate := Rectangle {
                            width: root.track-width;
                            height: root.track-height;
                            border-radius: LayoutTokens.borderRadius-medium;
                            border-width: 1px;
                            clip: true;
                            background: root.disabled ? ToggleSwitchTokens.track-bgColor-disabled : (root.checked ? ToggleSwitchTokens.track-bgColor-checked-rest : ToggleSwitchTokens.track-bgColor-rest);
                            border-color: root.disabled ? ToggleSwitchTokens.track-borderColor-disabled : (root.checked ? ToggleSwitchTokens.track-borderColor-checked : ToggleSwitchTokens.track-borderColor-rest);

                            animate background {
                                duration: root.motion-duration;
                                easing: cubic-bezier(0.5, 1, 0.89, 1);
                            }

                            animate border-color {
                                duration: root.motion-duration;
                                easing: cubic-bezier(0.5, 1, 0.89, 1);
                            }

                            HorizontalLayout {
                                x: root.track-border-w;
                                y: root.track-border-w;
                                width: root.track-inner-w;
                                height: root.track-inner-h;
                                spacing: 0px;

                                Rectangle {
                                    width: root.track-half-w;
                                    height: root.track-inner-h;
                                    background: transparent;
                                    clip: true;

                                    Image {
                                        source: Icons.toggle_switch_line;
                                        width: root.icon-diameter;
                                        height: root.icon-diameter;
                                        x: root.line-icon-x;
                                        y: (parent.height - self.height) / 2;
                                        colorize: root.line-icon-fg;
                                    }
                                }

                                Rectangle {
                                    width: root.track-half-w;
                                    height: root.track-inner-h;
                                    background: transparent;
                                    clip: true;

                                    Image {
                                        source: Icons.toggle_switch_circle;
                                        width: root.icon-diameter;
                                        height: root.icon-diameter;
                                        x: root.circle-icon-x;
                                        y: (parent.height - self.height) / 2;
                                        colorize: root.circle-icon-fg;
                                    }
                                }
                            }

                            Rectangle {
                                x: root.knob-x;
                                y: root.knob-y;
                                width: root.knob-w;
                                height: root.knob-h;
                                border-radius: root.knob-corner-radius;
                                border-width: 1px;
                                border-color: root.knob-stroke;
                                background: root.knob-fill;
                            }

                            states [
                                disabled when root.disabled: {
                                    track-plate.background: ToggleSwitchTokens.track-bgColor-disabled;
                                    track-plate.border-color: ToggleSwitchTokens.track-borderColor-disabled;
                                }
                                checked-pressed when !root.disabled && root.checked && track-ta.pressed: {
                                    track-plate.background: ToggleSwitchTokens.track-bgColor-checked-active;
                                    track-plate.border-color: ToggleSwitchTokens.track-borderColor-checked;
                                }
                                checked-hover when !root.disabled && root.checked && !track-ta.pressed && track-ta.has-hover: {
                                    track-plate.background: ToggleSwitchTokens.track-bgColor-checked-hover;
                                    track-plate.border-color: ToggleSwitchTokens.track-borderColor-checked;
                                }
                                checked-rest when !root.disabled && root.checked && !track-ta.pressed && !track-ta.has-hover: {
                                    track-plate.background: ToggleSwitchTokens.track-bgColor-checked-rest;
                                    track-plate.border-color: ToggleSwitchTokens.track-borderColor-checked;
                                }
                                unchecked-pressed when !root.disabled && !root.checked && track-ta.pressed: {
                                    track-plate.background: ToggleSwitchTokens.track-bgColor-active;
                                    track-plate.border-color: ToggleSwitchTokens.track-borderColor-rest;
                                }
                                unchecked-hover when !root.disabled && !root.checked && !track-ta.pressed && track-ta.has-hover: {
                                    track-plate.background: ToggleSwitchTokens.track-bgColor-hover;
                                    track-plate.border-color: ToggleSwitchTokens.track-borderColor-rest;
                                }
                            ]
                        }
                    }
                }
            }
        }

        if root.status-label-position == ToggleSwitchStatusLabelPosition.end: status-touch-end := TouchArea {
            enabled: root.accepts-interaction;
            clicked => {
                root.checked = !root.checked;
                root.changed(root.checked);
                root.clicked();
            }

            VerticalLayout {
                alignment: center;
                min-width: 32px;

                Text {
                    text: root.checked ? root.button-label-on : root.button-label-off;
                    color: root.accepts-interaction ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                    font-size: root.status-font-size;
                    horizontal-alignment: right;
                }
            }
        }

        if root.status-label-position == ToggleSwitchStatusLabelPosition.end && root.loading: HorizontalLayout {
            padding-left: LayoutTokens.button-content-gap;
            padding-right: 0px;
            alignment: center;
            align-items: center;

            Spinner {
                size: Size.small;
                segment-color: PrimerColors.fgColor-muted;
                track-color: #f0f6fc40;
            }
        }
    }
}
