import { LayoutTokens, PrimerColors } from "../../tokens.slint";

/// Bordered, clipped list viewport (**`bgColor-canvas-subtle`**, **`borderColor-muted`**) — child is usually **`SelectPanelScrollBody`**, **`SelectPanelLoading`**, or **`SelectPanelMessage`**.
export component SelectPanelListChrome {
    in property <length> list-max-height: 240px;

    horizontal-stretch: 1;

    Rectangle {
        width: 100%;
        height: root.list-max-height;
        background: PrimerColors.bgColor-canvas-subtle;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: 1px;
        border-color: PrimerColors.borderColor-muted;
        clip: true;

        VerticalLayout {
            width: 100%;
            height: 100%;
            alignment: stretch;

            @children
        }
    }
}
