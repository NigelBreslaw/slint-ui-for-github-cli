import { DialogTokens, LayoutTokens, PrimerColors } from "../../tokens.slint";

/// Top border + padded action column — same chrome as **`SelectPanel`** **`show-footer`** region (Primer **`.Footer`**).
export component SelectPanelFooter {
    VerticalLayout {
        Rectangle {
            width: 100%;
            height: LayoutTokens.nav-list-divider-height;
            background: PrimerColors.borderColor-default;
        }

        FlexboxLayout {
            flex-direction: row;
            flex-wrap: wrap;
            alignment: end;
            padding: DialogTokens.footer-padding;
            spacing: DialogTokens.footer-actions-gap;

            @children
        }
    }
}
