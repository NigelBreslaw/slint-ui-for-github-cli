// Shared floating **panel** chrome: elevation shadow + rounded fill + border + padded content slot.
// Used by **`AnchoredOverlay`** (anchored menus) and **`ModalOverlay`** (viewport modal shell). Pass token-backed colors, radii, and shadow from **`OverlayTokens`** or overrides.

import {
    DropShadowLayer,
    MultiDropShadow,
} from "../Effects/multi-drop-shadow.slint";

export component OverlayPanelChrome {

    in property <length> border-radius;
    in property <brush> background;
    in property <color> border-color;
    in property <length> border-width;
    in property <[DropShadowLayer]> surface-shadows;
    in property <length> panel-padding;

    out property <length> chrome-preferred-height: inner-slot.preferred-height;

    MultiDropShadow {
        border-radius: root.border-radius;
        shadows: root.surface-shadows;
    }

    overlay := Rectangle {
        border-radius: root.border-radius;
        background: root.background;
        border-color: root.border-color;
        border-width: root.border-width;
        clip: true;

        inner-slot := VerticalLayout {
            padding: root.panel-padding;
            alignment: start;
            @children
        }
    }
}
