import { AnchoredOverlay } from "anchored-overlay.slint";
import { OverlayType } from "anchored-overlay.slint";
import { StandardDialogHeader } from "../Dialog/parts/dialog-header.slint";
import { DialogBody } from "../Dialog/parts/dialog-body.slint";
import { DialogFooter } from "../Dialog/parts/dialog-footer.slint";
import { Button, ButtonVariant } from "../Buttons/buttons.slint";
import { ModalOverlay } from "../Dialog/modal-overlay.slint";
import { SheetOverlay, SheetSide } from "./sheet-overlay.slint";
import { AppWindow, PrimerColors } from "../tokens.slint";


export component TestButton {
    width: btn.preferred-width;
    height: btn.preferred-height;
    in-out property label <=> btn.label;
    in-out property overlay-type <=> ao.overlay-type;
    in property <length> margin: 0px;

    callback clicked();

    btn := Button {
        clicked => {
            // Concerned if this was a binding it would be firing too often
            // when just scrolling a view of buttons and as the AnchoredOverlay
            // isn't showing that is just pointless code running.
            ao.position-props = {
                absolute-position: btn.absolute-position,
                source-size: { width: btn.width, height: btn.height }
            };
            root.clicked();
            ao.show();
        }
    }

    ao := AnchoredOverlay {
        margin: root.margin;
        @children
    }
}

export component AnchoredOverlayTest inherits Window {

    preferred-width: 700px;
    preferred-height: 700px;

    background: white;

    init => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
    }

    changed width => {
        AppWindow.window-width = root.width;
    }

    changed height => {
        AppWindow.window-height = root.height;
    }

    main-scroll := Rectangle {
        Flickable {
            width: main-scroll.width;
            height: main-scroll.height;
            viewport-width: self.width;
            viewport-height: gallery-main.preferred-height;

            gallery-main := VerticalLayout {
                spacing: 40px;

                TestButton {
                    label: "center modal";

                    Rectangle {
                        width: 100px;
                        height: 100px;
                        background: red;
                        border-width: 2px;
                        border-color: blue;
                        Text {
                            text: "center modal";
                        }
                    }
                }

                TestButton {
                    label: "Position under item";
                    overlay-type: anchored;
                    Rectangle {
                        width: 100px;
                        height: 100px;
                        background: red;
                        border-width: 2px;
                        border-color: blue;
                        Text {
                            text: "Position under item";
                        }
                    }
                }

                Button {
                    label: "Open Modal";
                    clicked => {
                        default-outer-dialog.show();
                    }
                }

                VerticalLayout {
                    spacing: 12px;

                    Text {
                        text: "SheetOverlay (AO2)";
                        color: PrimerColors.fgColor-default;
                        font-size: 16px;
                        font-weight: 600;
                    }

                    HorizontalLayout {
                        spacing: 12px;

                        Button {
                            label: "Sheet left";
                            clicked => {
                                sheet-left.show();
                            }
                        }

                        Button {
                            label: "Sheet right";
                            clicked => {
                                sheet-right.show();
                            }
                        }

                        Button {
                            label: "Sheet bottom";
                            clicked => {
                                sheet-bottom.show();
                            }
                        }
                    }
                }
            }
        }
    }

    default-outer-dialog := ModalOverlay {

        VerticalLayout {

            StandardDialogHeader {
                title: "My Dialog";

                close-requested => default-outer-dialog.close();
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                        // root.default-inner-open = true;
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    // clicked => default-outer-dialog.on-close("close-button");
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                        // root.default-inner-open = true;
                    }
                }
            }
        }
    }

    sheet-left := SheetOverlay {
        side: SheetSide.left;
        default-panel-width: 360px;

        VerticalLayout {

            StandardDialogHeader {
                title: "Left sheet";

                close-requested => {
                    sheet-left.close();
                }
            }

            DialogBody {
                Text {
                    text: "Left SheetOverlay — dismiss with backdrop, Escape, or header close.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Done";
                    variant: ButtonVariant.primary;
                    clicked => {
                        sheet-left.close();
                    }
                }
            }
        }
    }

    sheet-right := SheetOverlay {
        side: SheetSide.right;
        default-panel-width: 360px;

        VerticalLayout {

            StandardDialogHeader {
                title: "Right sheet";

                close-requested => {
                    sheet-right.close();
                }
            }

            DialogBody {
                Text {
                    text: "Right SheetOverlay — slide-in from the right edge.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Done";
                    variant: ButtonVariant.primary;
                    clicked => {
                        sheet-right.close();
                    }
                }
            }
        }
    }

    sheet-bottom := SheetOverlay {
        side: SheetSide.bottom;
        default-panel-height: 320px;

        VerticalLayout {

            StandardDialogHeader {
                title: "Bottom sheet";

                close-requested => {
                    sheet-bottom.close();
                }
            }

            DialogBody {
                Text {
                    text: "Bottom SheetOverlay — slides up. Extra copy so the sheet has meaningful height.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Second paragraph to exercise max height and scrolling if content grows.";
                    color: PrimerColors.fgColor-muted;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Done";
                    variant: ButtonVariant.primary;
                    clicked => {
                        sheet-bottom.close();
                    }
                }
            }
        }
    }
}
