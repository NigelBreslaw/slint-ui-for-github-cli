// Filtered **ActionList** host: filter field, header hairline, and scrollable **`ActionList`** body (upstream: Primer **`FilteredActionList`**).

import { Icons } from "../assets/icons.slint";
import { ActionList } from "../ActionList/action-list.slint";
import { ActionListLine, ActionListSelectionMode } from "../ActionList/types.slint";
import { Checkbox } from "../Checkbox/checkbox.slint";
import { PrimerTextInput } from "../PrimerTextInput/primer-text-input.slint";
import { SelectPanelLoading } from "../SelectPanelCompose/parts/select-panel-loading.slint";
import {
    FilteredActionListTokens,
    LayoutTokens,
    PrimerColors,
    SelectPanelTokens,
} from "../tokens.slint";
import { FilteredActionListLoadingKind } from "./types.slint";

export component FilteredActionList {
    in-out property <string> filter-text: "";
    in property <string> placeholder: "Filter Labels";
    in property <bool> disabled: false;
    /// Parent supplies rows already narrowed by filter query (see gallery **`GalleryFilteredActionList*`** wiring).
    in property <[ActionListLine]> lines: [];
    in property <bool> show-dividers: false;
    in property <ActionListSelectionMode> selection-mode: ActionListSelectionMode.none;
    in property <int> selected-index: -1;
    in property <[bool]> multi-selected: [];
    /// Scroll region height (`SelectPanel`-aligned default).
    in property <length> body-region-height: SelectPanelTokens.list-max-height-default;
    /// When true, loading UI follows **`loading-kind`** (upstream **`loading`** + **`FilteredActionListLoadingTypes`**).
    in property <bool> loading: false;
    in property <FilteredActionListLoadingKind> loading-kind: FilteredActionListLoadingKind.body_spinner;
    /// Shown with **`body_spinner`** (same default as **`SelectPanel.loading-message`**).
    in property <string> loading-message: "Loading…";
    /// Optional **Select all** strip (upstream **`onSelectAllChange`**); sits under the header hairline, above the scroll body.
    in property <bool> select-all-visible: false;
    in-out property <bool> select-all-checked: false;
    in-out property <bool> select-all-indeterminate: false;
    in property <string> select-all-label-unchecked: "Select all";
    in property <string> select-all-label-checked: "Deselect all";
    /// After body loading (spinner/skeleton), replaces **`ActionList`** (upstream **`message`** / **`messageText`** — list hidden while true).
    in property <bool> show-message: false;
    in property <string> message-title: "";
    in property <string> message-description: "";
    /// When **`lines`** is empty, body not loading, and **`show-message`** is false: **`SelectPanel`**-style centered copy (filtered empty).
    in property <string> empty-title: "";
    in property <string> empty-message: "";

    callback filter-changed(string);
    callback item-activated(int);
    callback select-all-changed(bool);

    horizontal-stretch: 1;

    private property <bool> loading-on-input:
        root.loading && root.loading-kind == FilteredActionListLoadingKind.input;
    private property <bool> loading-body-spinner:
        root.loading && root.loading-kind == FilteredActionListLoadingKind.body_spinner;
    private property <bool> loading-body-skeleton:
        root.loading && root.loading-kind == FilteredActionListLoadingKind.body_skeleton;
    private property <bool> show-body-message:
        !root.loading-body-spinner && !root.loading-body-skeleton && root.show-message;
    private property <bool> show-body-empty:
        !root.loading-body-spinner && !root.loading-body-skeleton && !root.show-message && root.lines.length == 0
        && (root.empty-title != "" || root.empty-message != "");
    private property <bool> show-action-list-body:
        !root.loading-body-spinner && !root.loading-body-skeleton && !root.show-body-message && !root.show-body-empty;

    VerticalLayout {
        spacing: SelectPanelTokens.wrapper-stack-gap;
        alignment: stretch;

        PrimerTextInput {
            block: true;
            placeholder: root.placeholder;
            text <=> root.filter-text;
            disabled: root.disabled;
            has-leading-visual: true;
            leading-visual: Icons.search;
            loading: root.loading-on-input;
            edited(t) => {
                root.filter-changed(t);
            }
        }

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        if root.select-all-visible: VerticalLayout {
            alignment: stretch;

            Rectangle {
                background: PrimerColors.bgColor-muted;

                TouchArea {
                    enabled: !root.disabled;

                    clicked => {
                        if root.select-all-indeterminate {
                            root.select-all-indeterminate = false;
                            root.select-all-checked = true;
                        } else {
                            root.select-all-checked = !root.select-all-checked;
                        }
                        root.select-all-changed(root.select-all-checked);
                    }

                    HorizontalLayout {
                        padding-top: FilteredActionListTokens.select-all-padding-block;
                        padding-bottom: FilteredActionListTokens.select-all-padding-block;
                        padding-left: FilteredActionListTokens.select-all-padding-inline;
                        padding-right: FilteredActionListTokens.select-all-padding-inline;
                        spacing: FilteredActionListTokens.select-all-control-label-gap;
                        alignment: center;

                        Checkbox {
                            interactive: false;
                            checked <=> root.select-all-checked;
                            indeterminate: root.select-all-indeterminate;
                            disabled: root.disabled;
                            label: "";
                        }

                        Text {
                            text:
                                root.select-all-checked && !root.select-all-indeterminate
                                ? root.select-all-label-checked
                                : root.select-all-label-unchecked;
                            color: PrimerColors.fgColor-muted;
                            font-size: LayoutTokens.text-body-size-medium;
                            font-weight: LayoutTokens.base-text-weight-normal;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle {
                height: LayoutTokens.table-border-width;
                background: PrimerColors.borderColor-default;
            }
        }

        Rectangle {
            height: root.body-region-height;
            background: PrimerColors.bgColor-canvas-subtle;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;
            clip: true;

            VerticalLayout {
                alignment: stretch;

                if root.loading-body-spinner: SelectPanelLoading {
                    vertical-stretch: 1;
                    message: root.loading-message;
                }

                if root.loading-body-skeleton: VerticalLayout {
                    vertical-stretch: 1;
                    padding: FilteredActionListTokens.skeleton-container-padding;
                    spacing: FilteredActionListTokens.skeleton-stack-gap;
                    alignment: start;

                    Rectangle {
                        height: FilteredActionListTokens.skeleton-line-height;
                        background: PrimerColors.bgColor-neutral-muted;
                        border-radius: FilteredActionListTokens.skeleton-bar-border-radius;
                    }

                    Rectangle {
                        width: 88%;
                        height: FilteredActionListTokens.skeleton-line-height;
                        background: PrimerColors.bgColor-neutral-muted;
                        border-radius: FilteredActionListTokens.skeleton-bar-border-radius;
                    }

                    Rectangle {
                        height: FilteredActionListTokens.skeleton-line-height;
                        background: PrimerColors.bgColor-neutral-muted;
                        border-radius: FilteredActionListTokens.skeleton-bar-border-radius;
                    }

                    Rectangle {
                        width: 64%;
                        height: FilteredActionListTokens.skeleton-line-height;
                        background: PrimerColors.bgColor-neutral-muted;
                        border-radius: FilteredActionListTokens.skeleton-bar-border-radius;
                    }

                    Rectangle {
                        width: 72%;
                        height: FilteredActionListTokens.skeleton-line-height;
                        background: PrimerColors.bgColor-neutral-muted;
                        border-radius: FilteredActionListTokens.skeleton-bar-border-radius;
                    }
                }

                if root.show-body-message: VerticalLayout {
                    vertical-stretch: 1;
                    padding: SelectPanelTokens.message-region-padding;
                    spacing: SelectPanelTokens.message-stack-gap;
                    alignment: center;

                    if root.message-title != "": Text {
                        horizontal-alignment: center;
                        text: root.message-title;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                        color: PrimerColors.fgColor-default;
                        wrap: word-wrap;
                    }

                    if root.message-description != "": Text {
                        horizontal-alignment: center;
                        text: root.message-description;
                        font-size: LayoutTokens.text-body-size-small;
                        color: PrimerColors.fgColor-muted;
                        font-weight: root.message-title != "" ? LayoutTokens.base-text-weight-medium : LayoutTokens.base-text-weight-semibold;
                        wrap: word-wrap;
                    }
                }

                if root.show-body-empty: VerticalLayout {
                    vertical-stretch: 1;
                    padding: SelectPanelTokens.message-region-padding;
                    spacing: SelectPanelTokens.message-stack-gap;
                    alignment: center;

                    if root.empty-title != "": Text {
                        horizontal-alignment: center;
                        text: root.empty-title;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                        color: PrimerColors.fgColor-default;
                        wrap: word-wrap;
                    }

                    if root.empty-message != "": Text {
                        horizontal-alignment: center;
                        text: root.empty-message;
                        font-size: LayoutTokens.text-body-size-small;
                        color: PrimerColors.fgColor-muted;
                        font-weight: root.empty-title != "" ? LayoutTokens.base-text-weight-medium : LayoutTokens.base-text-weight-semibold;
                        wrap: word-wrap;
                    }
                }

                if root.show-action-list-body: Flickable {
                    vertical-stretch: 1;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: parent.width;
                    viewport-height: body-vl.preferred-height;

                    body-vl := VerticalLayout {
                        width: parent.width;

                        ActionList {
                            width: 100%;
                            lines: root.lines;
                            show-dividers: root.show-dividers;
                            selection-mode: root.selection-mode;
                            selected-index: root.selected-index;
                            multi-selected: root.multi-selected;
                            item-activated(ix) => {
                                root.item-activated(ix);
                            }
                        }
                    }
                }
            }
        }
    }
}
