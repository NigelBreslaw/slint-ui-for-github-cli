// Filtered **ActionList** host: filter field, header hairline, and a fixed-height body region (list wiring in later PRs).
// Visual shell aligns with [`SelectPanel`](../SelectPanel/select-panel.slint) filter + list chrome, without **`SelectOption`** row models.

import { Icons } from "../assets/icons.slint";
import { PrimerTextInput } from "../PrimerTextInput/primer-text-input.slint";
import { LayoutTokens, PrimerColors, SelectPanelTokens } from "../tokens.slint";

export component FilteredActionList {
    in-out property <string> filter-text: "";
    in property <string> placeholder: "Filter Labels";
    in property <bool> disabled: false;
    /// Reserved list / message region height (scroll + **`ActionList`** added in a follow-up PR).
    in property <length> body-region-height: SelectPanelTokens.list-max-height-default;

    callback filter-changed(string);

    horizontal-stretch: 1;

    VerticalLayout {
        spacing: SelectPanelTokens.wrapper-stack-gap;
        width: 100%;
        alignment: stretch;

        PrimerTextInput {
            width: 100%;
            block: true;
            placeholder: root.placeholder;
            text <=> root.filter-text;
            disabled: root.disabled;
            has-leading-visual: true;
            leading-visual: Icons.search;
            edited(t) => {
                root.filter-changed(t);
            }
        }

        Rectangle {
            width: 100%;
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Rectangle {
            width: 100%;
            height: root.body-region-height;
            background: PrimerColors.bgColor-canvas-subtle;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;
            clip: true;
        }
    }
}
