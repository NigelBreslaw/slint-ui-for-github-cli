// Technical spike for the Skeleton port — **not** exported from **`primer.slint`**.
//
// **Conclusion:** A Primer-like shimmer is **feasible** in Slint without CSS **`mask-image`**:
// base fill + **clipped** translucent band whose **`x`** is driven by **`mod(animation-tick(), period)`**
// (same time-base idiom as **`UnderlineNav`** loading pulse and **`Spinner`** rotation).
// When **`reduce-motion`** is **`true`**, omit the overlay so only the base fill remains (maps from
// **`prefers-reduced-motion`** at the host). PR1 **`SkeletonBox`** should lift this into the real
// component and replace **`PrimerColors.bgColor-neutral-muted`** with **`skeletonLoader`** once
// **`SkeletonTokens`** / **`LayoutTokens.duration-1000`** exist.

import { Palette } from "std-widgets.slint";
import { LayoutTokens, PrimerColors } from "../tokens.slint";

/// Single skeleton bar demonstrating **shimmer** vs **static** ( **`reduce-motion`** ).
export component SkeletonShimmerSpike {
    in property <length> bar-height: 16px;
    /// React **`SkeletonBox.module.css`** uses **`var(--base-duration-1000)`** for one sweep.
    in property <duration> shimmer-period: 1000ms;
    in property <bool> reduce-motion: false;

    width: 100%;
    height: bar-height;

    Rectangle {
        clip: true;
        width: 100%;
        height: 100%;
        border-radius: LayoutTokens.base-size-4;

        Rectangle {
            width: 100%;
            height: 100%;
            background: PrimerColors.bgColor-neutral-muted;
        }

        if !root.reduce-motion: Rectangle {
            width: 100%;
            height: 100%;
            background: transparent;

            property <float> sweep-phase: mod(animation-tick(), root.shimmer-period) / root.shimmer-period;
            property <length> band-w: self.width * 0.42;
            property <length> sweep-x: -band-w + (self.width + 2 * band-w) * sweep-phase;

            Rectangle {
                x: sweep-x;
                y: 0px;
                width: band-w;
                height: 100%;
                background: Palette.color-scheme == ColorScheme.dark ? #ffffff18 : #0000000d;
            }
        }
    }
}
