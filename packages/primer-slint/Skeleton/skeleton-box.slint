
import { Palette } from "std-widgets.slint";
import { LayoutTokens } from "../tokens.slint";


export component SkeletonBox inherits Rectangle {
    in property <bool> enabled: true;

    in property <length> box-height: LayoutTokens.base-size-16;

    property <bool> dark-canvas: Palette.color-scheme == ColorScheme.dark;
    property <duration> pulse-duration: 1s;
    property <bool> pulsing: false;

    height: root.box-height;
    border-radius: 3px;
    background: dark-canvas ? rgb(31, 35, 42) : rgb(242, 243, 245);
    clip: true;

    Timer {
        interval: 1ms;
        running: root.enabled;
        triggered => {
            self.stop();
            if pulsing {
                self.interval = 20ms;
            } else {
                self.interval = pulse-duration;
            }
            pulsing = !pulsing;
            self.start();
        };
    }

    rec := Rectangle {
        x: -self.width * 2;
        transform-scale-x: 200%;
        transform-origin: { x: 0, y: root.height / 2 };
        background: dark-canvas
            ? @linear-gradient(75deg, rgb(31, 35, 42) 30%, rgb(24, 29, 35) 80%)
            : @linear-gradient(75deg, rgb(242, 243, 245) 30%, rgb(247, 247, 248) 80%);
    }

    states [
        pulse when pulsing: {
            rec.x: 0px;
            in {
                animate rec.x {
                    duration: pulse-duration;
                    easing: cubic-bezier(0.25, 0.1, 0.25, 1);
                }
            }
        }
    ]
}
