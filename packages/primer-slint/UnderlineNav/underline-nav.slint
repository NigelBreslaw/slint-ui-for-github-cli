import {
    CounterLabel,
    CounterLabelVariant,
} from "../CounterLabel/counter-label.slint";
import {
    ButtonTokens,
    LayoutTokens,
    PrimerColors,
    UnderlineNavTokens,
} from "../tokens.slint";

export struct UnderlineNavItem {
    label: string,
    enabled: bool,
    counter: string,
    has-leading-icon: bool,
    leading-icon: image,
}

component UnderlineNavItemRow {
    in property <string> label;
    in property <bool> selected;
    in property <bool> enabled: true;
    in property <string> counter: "";
    in property <bool> has-leading-icon: false;
    in property <image> leading-icon;
    in property <bool> loading-counters: false;
    callback clicked;

    private property <bool> show-counter-slot: counter != "";
    private property <bool> show-counter-value: show-counter-slot && !loading-counters;
    private property <bool> show-counter-loading: show-counter-slot && loading-counters;

    private property <color> label-fg: !root.enabled
        ? PrimerColors.fgColor-muted
        : root.selected ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;

    VerticalLayout {
        alignment: start;
        height: self.preferred-height;

        focus-host := Rectangle {
            border-width: tab-fs.has-focus && root.enabled ? 2px : 0px;
            border-color: PrimerColors.fgColor-accent;
            border-radius: LayoutTokens.borderRadius-medium;

            tab-fs := FocusScope {

                key-pressed(event) => {
                    if !root.enabled {
                        return reject;
                    }
                    if event.text == Key.Return || event.text == Key.Space {
                        root.clicked();
                        return accept;
                    }
                    return reject;
                }

                ta := TouchArea {
                    enabled: root.enabled;
                    mouse-cursor: root.enabled ? pointer : default;
                    clicked => {
                        root.clicked();
                    }

                    VerticalLayout {
                        alignment: center;

                        row-bg := Rectangle {
                            background: transparent;
                            border-radius: LayoutTokens.borderRadius-medium;

                            HorizontalLayout {
                                padding-left: LayoutTokens.base-size-8;
                                padding-right: LayoutTokens.base-size-8;
                                padding-top: LayoutTokens.base-size-6;
                                padding-bottom: LayoutTokens.base-size-6;
                                alignment: center;
                                spacing: LayoutTokens.base-size-8;

                                if root.has-leading-icon: Image {
                                    width: LayoutTokens.iconButton-icon-size-medium;
                                    height: LayoutTokens.iconButton-icon-size-medium;
                                    vertical-alignment: center;
                                    source: root.leading-icon;
                                    colorize: root.label-fg;
                                }

                                // Changing the font-weight of a single label would cause the component to layout shift
                                Rectangle {
                                    width: max(label-t.preferred-width, label-t-selected.preferred-width);
                                    height: max(label-t.preferred-height, label-t-selected.preferred-height);
                                    label-t := Text {
                                        visible: !(root.selected && root.enabled);
                                        text: root.label;
                                        color: root.label-fg;
                                        font-size: LayoutTokens.text-body-size-medium;
                                        font-weight: LayoutTokens.base-text-weight-medium;
                                        vertical-alignment: center;
                                    }

                                    label-t-selected := Text {
                                        visible: root.selected && root.enabled;
                                        text: root.label;
                                        color: root.label-fg;
                                        font-size: LayoutTokens.text-body-size-medium;
                                        font-weight: LayoutTokens.base-text-weight-semibold;
                                        vertical-alignment: center;
                                    }
                                }

                                if show-counter-value: Rectangle {
                                    opacity: root.enabled ? 1.0 : 0.45;
                                    CounterLabel {
                                        text: root.counter;
                                        use-primer-scheme: true;
                                        scheme: CounterLabelVariant.secondary;
                                    }
                                }

                                if show-counter-loading: Rectangle {
                                    private property <float> loading-phase: mod(animation-tick(), UnderlineNavTokens.loading-counter-animation-period) / UnderlineNavTokens.loading-counter-animation-period;
                                    private property <float> loading-pulse-opacity: loading-phase < 0.5
                                        ? UnderlineNavTokens.loading-counter-opacity-max - (UnderlineNavTokens.loading-counter-opacity-max - UnderlineNavTokens.loading-counter-opacity-min) * (loading-phase * 2)
                                        : UnderlineNavTokens.loading-counter-opacity-min + (UnderlineNavTokens.loading-counter-opacity-max - UnderlineNavTokens.loading-counter-opacity-min) * ((loading-phase - 0.5) * 2);
                                    opacity: root.enabled ? loading-pulse-opacity : 0.45;
                                    width: UnderlineNavTokens.loading-counter-width;
                                    height: UnderlineNavTokens.loading-counter-height;
                                    border-radius: self.height / 2;
                                    border-width: LayoutTokens.counter-label-border-width;
                                    border-color: PrimerColors.borderColor-default;
                                    background: PrimerColors.bgColor-neutral-muted;
                                }
                            }

                            states [
                                disabled when !root.enabled: {
                                    background: transparent;
                                    label-t.color: PrimerColors.fgColor-muted;
                                    label-t.font-weight: LayoutTokens.base-text-weight-medium;
                                }
                                pressed when root.enabled && ta.pressed: {
                                    background: ButtonTokens.color-action-list-item-default-active-bg;
                                }
                                hover when root.enabled && !ta.pressed && ta.has-hover: {
                                    background: PrimerColors.bgColor-neutral-muted;
                                }
                            ]
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        y: parent.height - self.height;
        height: 2px;
        background: root.selected ? PrimerColors.accent-underline : transparent;
    }
}

export component UnderlineNav {
    in property <[UnderlineNavItem]> items;
    in property <int> selected-index: -1;
    in property <bool> loading-counters: false;
    in property <string> accessible-name: "";
    callback item-activated(index: int);
    min-height: LayoutTokens.control-xlarge-size;

    Rectangle {
        y: parent.height - self.height;
        height: 1px;
        background: PrimerColors.borderColor-muted;
    }

    VerticalLayout {
        accessible-role: AccessibleRole.tab-list;
        accessible-label: accessible-name;

        HorizontalLayout {
            spacing: LayoutTokens.base-size-8;
            alignment: start;

            for item[index] in items: UnderlineNavItemRow {
                label: item.label;
                selected: index == root.selected-index;
                enabled: item.enabled;
                counter: item.counter;
                has-leading-icon: item.has-leading-icon;
                leading-icon: item.leading-icon;
                loading-counters: root.loading-counters;
                clicked => {
                    root.item-activated(index);
                }
            }
        }
    }
}
