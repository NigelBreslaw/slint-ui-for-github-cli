// Primer-style underline navigation: model-driven items, full-width muted rail, accent bar under the selected tab.
// Item body: Button variant invisible + size medium (matches primer-ui-react UnderlineTabbedInterface body-medium text).
import { ButtonAlignContent, ButtonVariant } from "../Buttons/types.slint";
import { Button } from "../Buttons/buttons.slint";
import { LayoutTokens, PrimerColors, Size } from "../tokens.slint";

export enum UnderlineNavVariant {
    inset,
    flush,
}

export struct UnderlineNavItem {
    label: string,
    enabled: bool,
    /// Non-empty shows a counter pill (or a loading placeholder when `UnderlineNav.loading-counters` is true).
    counter: string,
}

component UnderlineNavItemRow {
    in property <string> label;
    in property <bool> selected;
    in property <bool> enabled: true;
    in property <string> counter: "";
    in property <bool> loading-counters: false;
    callback clicked;


    private property <bool> show-counter-slot: counter != "";
    private property <bool> show-counter-value: show-counter-slot && !loading-counters;
    private property <bool> show-counter-loading: show-counter-slot && loading-counters;

    // width: 10px;

    VerticalLayout {
        spacing: 0px;
        // width: self.preferred-width;

        HorizontalLayout {
            spacing: LayoutTokens.button-content-gap;
            alignment: start;

            nav-btn := Button {
                horizontal-stretch: 0;
                variant: ButtonVariant.invisible;
                size: Size.medium;
                align-content: ButtonAlignContent.start;
                label: root.label;
                count: show-counter-value ? counter : "";
                disabled: !root.enabled;
                label-typography-override: true;
                label-font-size-override: LayoutTokens.text-body-size-medium;
                label-font-weight-override: root.selected ? LayoutTokens.base-text-weight-semibold : LayoutTokens.base-text-weight-medium;
                label-color-override: root.selected ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                clicked => {
                    root.clicked();
                }
            }

            if show-counter-loading: Rectangle {
                width: 24px;
                height: 16px;
                border-radius: 20px;
                border-width: 1px;
                border-color: PrimerColors.borderColor-default;
                background: PrimerColors.bgColor-neutral-muted;
            }
        }

        Rectangle {
            height: 2px;
            background: root.selected ? PrimerColors.accent-underline : #00000000;
        }
    }
}

export component UnderlineNav {
    in property <[UnderlineNavItem]> items;
    in property <int> selected-index: -1;
    /// `inset`: horizontal padding (`stack-padding-normal`). `flush`: no inline padding (matches `[data-variant='flush']`).
    in property <UnderlineNavVariant> variant: UnderlineNavVariant.inset;
    /// When true, non-empty item `counter` values render a fixed-size skeleton instead of the numeric pill (UnderlineNav `LoadingCounter`).
    in property <bool> loading-counters: false;
    /// When non-empty, exposes a `tab-list` landmark for assistive tech (React `aria-label` on the list).
    in property <string> accessible-name: "";
    callback item-activated(index: int);

    private property <length> inset-padding-inline: variant == UnderlineNavVariant.inset ? LayoutTokens.stack-padding-normal : 0px;

    VerticalLayout {
        spacing: 0px;
        /// Prefer intrinsic width from tab items; parents can still set `width: 100%` for full-bleed rails.
        horizontal-stretch: 0;
        accessible-role: AccessibleRole.tab-list;
        accessible-label: accessible-name;
        height: self.preferred-height;

        tabs-row := HorizontalLayout {
            spacing: 8px;
            // min-height: LayoutTokens.control-xlarge-size;
            padding-left: inset-padding-inline;
            padding-right: inset-padding-inline;
            alignment: start;



            for item[index] in items: UnderlineNavItemRow {
                label: item.label;
                selected: index == root.selected-index;
                enabled: item.enabled;
                counter: item.counter;
                loading-counters: root.loading-counters;
                clicked => {
                    root.item-activated(index);
                }
            }
        }

        Rectangle {
            height: 1px;
            width: 100%;
            background: PrimerColors.borderColor-muted;
        }
    }
}
