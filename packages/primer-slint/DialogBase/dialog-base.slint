// Shared floating panel host: `PopupWindow` aligned to an anchor (no full-viewport dimmer — matches Primer anchored overlays / upstream AnchoredOverlay).
// Coordinate math matches [`anchored-popupwindow.md`](../../slint-gallery/gallery/anchored-popupwindow.md).
// Place as a 0×0 sibling under the same layout parent as the anchor; bind anchor-*, window-inner-width / height for placement.
// Panel chrome: OverlayTokens. If the popup closes via the platform, sync `open` from the parent if needed.

import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { DialogBaseAlign, DialogBaseSide } from "./types.slint";
import { LayoutTokens, OverlayTokens } from "../tokens.slint";

export component DialogBase {
    in-out property <bool> open: false;
    /// Viewport width for horizontal clamp (root `Window` inner width).
    in property <length> window-inner-width: 800px;
    in property <length> window-inner-height: 800px;
    in property <length> anchor-abs-x: 0px;
    in property <length> anchor-abs-y: 0px;
    in property <length> anchor-width: 0px;
    in property <length> anchor-height: 0px;
    /// Panel content height.
    in property <length> panel-height: 240px;
    /// When `> 0`, panel width; otherwise matches `anchor-width` (dropdown-style default).
    in property <length> panel-width: 0px;
    in property <length> anchor-gap: 5px;
    /// Vertical placement; `auto` flips above when below would overflow (Primer default for anchored menus).
    in property <DialogBaseSide> vertical-side: auto;
    /// Horizontal alignment of the panel relative to the anchor (LTR).
    in property <DialogBaseAlign> align: start;
    callback close-requested();

    width: 0px;
    height: 0px;

    private property <length> effective-panel-width: panel-width > 0px ? panel-width : anchor-width;

    private property <bool> flip-above:
        anchor-abs-y + anchor-height + anchor-gap + panel-height > window-inner-height
        && anchor-abs-y >= anchor-gap + panel-height;

    private property <length> panel-window-y:
        vertical-side == DialogBaseSide.outside_top ? anchor-abs-y - anchor-gap - panel-height
        : vertical-side == DialogBaseSide.outside_bottom ? anchor-abs-y + anchor-height + anchor-gap
        : flip-above ? anchor-abs-y - anchor-gap - panel-height
        : anchor-abs-y + anchor-height + anchor-gap;

    private property <length> panel-window-x-raw:
        align == DialogBaseAlign.start ? anchor-abs-x
        : align == DialogBaseAlign.center ? anchor-abs-x + (anchor-width - effective-panel-width) / 2
        : anchor-abs-x + anchor-width - effective-panel-width;

    private property <length> panel-window-x-max: max(0px, window-inner-width - effective-panel-width);

    private property <length> panel-window-x: max(0px, min(panel-window-x-raw, panel-window-x-max));

    changed open => {
        if root.open {
            popup.show();
        } else {
            popup.close();
        }
    }

    popup := PopupWindow {
        x: panel-window-x - root.absolute-position.x;
        y: panel-window-y - root.absolute-position.y;
        width: effective-panel-width;
        height: panel-height;

        panel-scope := FocusScope {
            width: 100%;
            height: 100%;

            key-pressed(event) => {
                if event.text == Key.Escape {
                    root.open = false;
                    root.close-requested();
                    return accept;
                }
                return reject;
            }

            panel-bg := Rectangle {
                width: 100%;
                height: 100%;

                MultiDropShadow {
                    width: parent.width;
                    height: parent.height;
                    border-radius: OverlayTokens.panel-border-radius;
                    shadows: OverlayTokens.panel-elevation-shadow;
                }

                // Clip only the fill + children so rounded corners hold; do not clip the wrapper or shadow blur is cut off.
                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    clip: true;
                    background: OverlayTokens.panel-background;
                    border-radius: OverlayTokens.panel-border-radius;
                    border-width: OverlayTokens.panel-border-width;
                    border-color: OverlayTokens.panel-border;

                    VerticalLayout {
                        width: 100%;
                        height: 100%;
                        padding: LayoutTokens.stack-padding-normal;
                        alignment: start;

                        @children
                    }
                }
            }
        }
    }
}
