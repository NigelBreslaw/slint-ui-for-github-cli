import {
    ActionList,
    ActionListLine,
    ActionListLineKind,
    ActionListRow,
    Icons,
} from "../../primer-slint/primer.slint";
import { PrimerColors } from "../../primer-slint/tokens.slint";

/// ActionList and ActionListRow gallery demos (Action list sidebar group).
export component GalleryActionListPage inherits VerticalLayout {
    spacing: 28px;
    width: 100%;
    alignment: start;

    private property <string> demo-action-list-shell-last: "";
    private property <[ActionListLine]> demo-action-list-shell-lines: [
        { kind: ActionListLineKind.row, label: "First action", selected: true, disabled: false },
        { kind: ActionListLineKind.divider, label: "", selected: false, disabled: false },
        { kind: ActionListLineKind.row, label: "Second action", selected: false, disabled: false },
        { kind: ActionListLineKind.row, label: "Disabled action", selected: false, disabled: true },
    ];

    Text {
        text: "Action list";
        color: PrimerColors.fgColor-default;
        font-size: 18px;
        font-weight: 600;
    }

    Text {
        text: "Primer ActionList port — PR1 shell and shared row chrome.";
        color: PrimerColors.fgColor-muted;
        font-size: 13px;
        wrap: word-wrap;
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "ActionListRow";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Shared list-row chrome (hover / pressed / selected). NavList and pickers (e.g. SelectPanel single mode) build on this.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 0;
            width: 360px;

            ActionListRow {
                width: 100%;
                label: "Unselected row";
                selected: false;
                disabled: false;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Selected row";
                selected: true;
                disabled: false;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Disabled row";
                selected: false;
                disabled: true;
                has-leading-visual: true;
                leading-icon: Icons.alert;
                description: "With description";
                trailing-text: "·";
                clicked => {
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "ActionList (PR1 shell)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Flat `lines`: default rows plus a divider. Later PRs add section headings and item variants.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: demo-action-list-shell-last == "" ? "Last item-activated index: —" : "Last item-activated index: " + demo-action-list-shell-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 0;
            width: 360px;

            ActionList {
                width: 100%;
                lines: demo-action-list-shell-lines;
                item-activated(idx) => {
                    demo-action-list-shell-last = "\{idx}";
                }
            }
        }
    }
}
