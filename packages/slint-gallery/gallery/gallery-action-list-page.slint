            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: true,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.divider,
            label: "",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Second action",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Disabled action",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: true,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
    ];

    private property <string> demo-action-list-pr3-last: "";
    private property <[ActionListLine]> demo-action-list-pr3-lines: [
        {
            kind: ActionListLineKind.section_heading,
            label: "Workflow",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Default row",
            description: "Block description under the title.",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "12",
            has-leading-visual: true,
            leading-icon: Icons.issue_opened,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Inline copy",
            description: "Secondary on the same line",
            description-layout: ActionListDescriptionLayout.inline,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Large density row",
            description: "Taller row (LayoutTokens large metrics).",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: true,
            leading-icon: Icons.gear_24,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: true,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.divider,
            label: "",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Delete permanently",
            description: "Uses ActionListTokens danger surfaces.",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: true,
            leading-icon: Icons.alert,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.danger,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "Inactive item",
            description: "Not available on your plan.",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "Pro",
            has-leading-visual: true,
            leading-icon: Icons.stop,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.inactive,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
