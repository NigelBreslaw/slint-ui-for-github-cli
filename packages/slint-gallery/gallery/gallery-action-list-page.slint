            label: "Loading item",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.loading,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.section_divider,
            label: "",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.section_heading,
            label: "Team",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: false,
            disabled: false,
            row-variant: ActionListRowVariant.default,
            large: false,
            section-heading-variant: ActionListSectionHeadingVariant.filled,
        },
        {
            kind: ActionListLineKind.row,
            label: "Danger + selected",
            description: "",
            description-layout: ActionListDescriptionLayout.block,
            trailing-text: "",
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            selected: true,
            disabled: false,
            row-variant: ActionListRowVariant.danger,
