    Text {
        text: "Action list";
        color: PrimerColors.fgColor-default;
        font-size: 18px;
        font-weight: 600;
    }

    Text {
        text: "Primer ActionList port — ActionList shell (PR1) + tokens (PR2) + item variants and sections (PR3).";
        color: PrimerColors.fgColor-muted;
        font-size: 13px;
        wrap: word-wrap;
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "ActionListRow";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Shared row chrome; pass `row-variant`, `description-layout`, and `large` for ActionList parity demos.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 0;
            width: 360px;

            ActionListRow {
                width: 100%;
                label: "Unselected row";
                selected: false;
                disabled: false;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Selected row";
                selected: true;
                disabled: false;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Disabled row";
                selected: false;
                disabled: true;
                has-leading-visual: true;
                leading-icon: Icons.alert;
                description: "With description";
                trailing-text: "·";
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Danger row";
                description: "Hover / pressed use danger-muted surfaces.";
                row-variant: ActionListRowVariant.danger;
                has-leading-visual: true;
                leading-icon: Icons.alert;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Inactive row";
                description: "Cannot be activated.";
                trailing-text: "Pro";
                row-variant: ActionListRowVariant.inactive;
                has-leading-visual: true;
                leading-icon: Icons.stop;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Loading row";
                row-variant: ActionListRowVariant.loading;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Large + block description";
                description: "Uses `LayoutTokens.action-list-item-min-height-large` and larger block padding.";
                large: true;
                has-leading-visual: true;
                leading-icon: Icons.gear_24;
                clicked => {
                }
            }

            ActionListRow {
                width: 100%;
                label: "Inline description";
                description: "Secondary on the same line";
                description-layout: ActionListDescriptionLayout.inline;
                clicked => {
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "ActionList (basic shell)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Flat `lines`: default rows and an item divider.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: demo-action-list-shell-last == "" ? "Last item-activated index: —" : "Last item-activated index: " + demo-action-list-shell-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 0;
            width: 360px;

            ActionList {
                width: 100%;
                lines: demo-action-list-shell-lines;
                item-activated(idx) => {
                    demo-action-list-shell-last = "\{idx}";
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "ActionList (PR3 — sections + variants)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Section headings (subtle + filled), item divider, section divider, default / danger / inactive / loading rows, large row, inline description.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: demo-action-list-pr3-last == "" ? "Last item-activated index: —" : "Last item-activated index: " + demo-action-list-pr3-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 0;
            width: 400px;

            ActionList {
                width: 100%;
                lines: demo-action-list-pr3-lines;
                item-activated(idx) => {
                    demo-action-list-pr3-last = "\{idx}";
                }
            }
        }
