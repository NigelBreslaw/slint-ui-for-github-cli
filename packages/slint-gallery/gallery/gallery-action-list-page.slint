    ActionListSectionHeadingVariant,
    Icons,
} from "../../primer-slint/primer.slint";
import { PrimerColors } from "../../primer-slint/tokens.slint";

/// ActionList and ActionListRow gallery demos (Action list sidebar group).
export component GalleryActionListPage inherits VerticalLayout {
    spacing: 28px;
