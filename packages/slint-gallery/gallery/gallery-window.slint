import { PrimerColors } from "../../primer-slint/tokens.slint";
import { GalleryHeader } from "./gallery-header.slint";
import { GallerySidebar } from "./gallery-sidebar.slint";
import { GalleryButtonsPage } from "./gallery-buttons-page.slint";
import { GalleryNavsPage } from "./gallery-navs-page.slint";
import { GalleryFeedbackPage } from "./gallery-feedback-page.slint";
import { GalleryFormsPage } from "./gallery-forms-page.slint";
import { GalleryDataPage } from "./gallery-data-page.slint";
import { GalleryActionListPage } from "./gallery-action-list-page.slint";
import { GalleryActionList2Page } from "./gallery-action-list2-page.slint";
import { AppWindow } from "../../primer-slint/tokens.slint";

import "../../primer-slint/assets/fonts/MonaSans-VariableFont.ttf";
import "../../primer-slint/assets/fonts/MonaSans-Italic-VariableFont.ttf";
import "../../primer-slint/assets/fonts/VeraMono.ttf";

export global GalleryState {
    in-out property <int> selected-group-index: 6;
}

export component GalleryWindow inherits Window {

    changed width => {
        AppWindow.window-width = root.width;
    }
    changed height => {
        AppWindow.window-height = root.height;
    }

    init => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
    }

    preferred-width: 1000px;
    preferred-height: 800px;
    min-width: 640px;
    min-height: 480px;
    title: "Primer gallery";
    default-font-family: "Mona Sans";
    icon: @image-url("../../primer-slint/assets/24px/palette.svg");

    background: PrimerColors.bgColor-default;

    VerticalLayout {
        GalleryHeader {
            height: 64px;
        }

        HorizontalLayout {

            GallerySidebar {
                selected-index: GalleryState.selected-group-index;
                group-selected(idx) => {
                    GalleryState.selected-group-index = idx;
                }
            }

            main-scroll := Rectangle {

                gallery-flick := Flickable {
                    width: main-scroll.width;
                    height: main-scroll.height;

                    viewport-width: self.width;
                    viewport-height: gallery-main.preferred-height;

                    gallery-main := VerticalLayout {
                        width: gallery-flick.width;
                        padding: 24px;
                        spacing: 8px;
                        alignment: start;

                        if GalleryState.selected-group-index == 0: GalleryButtonsPage { }

                        if GalleryState.selected-group-index == 1: GalleryNavsPage { }

                        if GalleryState.selected-group-index == 2: GalleryFeedbackPage { }

                        if GalleryState.selected-group-index == 3: GalleryFormsPage {
                            window-inner-width: root.width;
                            window-inner-height: root.height;
                        }

                        if GalleryState.selected-group-index == 4: GalleryDataPage { }

                        if GalleryState.selected-group-index == 5: GalleryActionListPage { }

                        if GalleryState.selected-group-index == 6: GalleryActionList2Page { }
                    }
                }
            }
        }
    }
}
