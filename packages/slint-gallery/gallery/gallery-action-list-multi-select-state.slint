/// Multi-select demo state for **Action list** — toggled from **Node** (`gallery-action-list-multi-select-bridge-shared.ts`, wired in `gallery-main.ts`).
export global GalleryActionListMultiSelect {
    /// One bool per **`lines`** index (demo: four rows); checked rows are true.
    in-out property <[bool]> row-checked: [true, false, false, false];
    in-out property <string> last-activated-label: "";
    in-out property <string> selection-summary: "";
    callback row-activated(int);
}
