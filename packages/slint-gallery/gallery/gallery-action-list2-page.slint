        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList2 {
                    width: 100%;
                    lines: root.block-description-lines;
                    item-activated(ix) => {
                        root.block-description-last = root.block-description-lines[ix].label;
                    }
                }

                Text {
                    visible: root.block-description-last != "";
                    text: "Last activated: " + root.block-description-last;
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
