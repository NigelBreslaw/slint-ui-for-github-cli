import {
    ActionList2,
    ActionList2Line,
    ActionList2LineKind,
    ActionList2RowVariant,
} from "../../primer-slint/primer.slint";
import { PrimerColors } from "../../primer-slint/tokens.slint";

/// ActionList2 demos — one section per upstream Storybook **Features** story (PR1: Simple List only).
export component GalleryActionList2Page inherits VerticalLayout {
    spacing: 28px;
    width: 100%;
    alignment: start;

    private property <string> simple-list-last: "";

    private property <[ActionList2Line]> simple-list-lines: [
        {
            kind: ActionList2LineKind.row,
            label: "Copy link",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Quote reply",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Edit comment",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
        },
        {
            kind: ActionList2LineKind.item_divider,
            label: "",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Delete file",
            row-variant: ActionList2RowVariant.danger,
            disabled: false,
        },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Simple List";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Matches Storybook Features → Simple List (divider before danger row).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList2 {
                    width: 100%;
                    lines: root.simple-list-lines;
                    item-activated(ix) => {
                        root.simple-list-last = root.simple-list-lines[ix].label;
                    }
                }

                Text {
                    visible: root.simple-list-last != "";
                    text: "Last activated: " + root.simple-list-last;
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
