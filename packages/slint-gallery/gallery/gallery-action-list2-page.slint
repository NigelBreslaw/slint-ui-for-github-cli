    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Block description";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Matches Storybook Features → Block Description (leading Avatar, primary label + block description).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
