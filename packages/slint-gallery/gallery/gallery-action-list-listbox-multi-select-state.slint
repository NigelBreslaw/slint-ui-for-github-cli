/// Listbox **multi-select** demo for **Action list** — same Node pattern as **`GalleryActionListMultiSelect`** (`gallery-action-list-multi-select-bridge-shared.ts`, `gallery-main.ts`). Storybook **Listbox Multi Select**: no row seam dividers, last row **`disabled`**.
export global GalleryActionListListboxMultiSelect {
    /// One bool per **`lines`** index (four rows); checked rows are true.
    in-out property <[bool]> row-checked: [true, false, false, false];
    in-out property <string> last-activated-label: "";
    in-out property <string> selection-summary: "";
    callback row-activated(int);
}
