                    selection-mode: ActionList2SelectionMode.multiple;
                    multi-selected: GalleryActionList2ListboxMultiSelect.row-checked;
                    lines: root.listbox-multi-select-lines;
                    item-activated(ix) => {
                        GalleryActionList2ListboxMultiSelect.row-activated(ix);
                    }
                }

                Text {
                    text: "Last row: \{GalleryActionList2ListboxMultiSelect.last-activated-label} — selected: \{GalleryActionList2ListboxMultiSelect.selection-summary}";
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
