            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.plus_circle,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            has-markdown: false,
            label-markdown: @markdown(""),
            inactive-text: "",
            show-trailing-loading: false,
            has-trailing-visual: false,
            trailing-icon: Icons.dot_fill,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Symbol",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.plus_circle,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            has-markdown: false,
            label-markdown: @markdown(""),
            inactive-text: "",
            show-trailing-loading: false,
            has-trailing-visual: false,
            trailing-icon: Icons.dot_fill,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Exclude archived",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.plus_circle,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            has-markdown: false,
            label-markdown: @markdown(""),
            inactive-text: "",
            show-trailing-loading: false,
            has-trailing-visual: false,
            trailing-icon: Icons.dot_fill,
        },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Inside overlay";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Matches Primer Storybook **Features → Inside overlay** ([primer.style/react/storybook](https://primer.style/react/storybook/?path=/story/components-actionlist-features--inside-overlay)): **`toggle overlay`** opens **`AnchoredOverlay`** with **`shrink-wrap`** so the popup hugs **`ActionList2`**; **`panel-width: 0`** matches the trigger width. Trailing **arrow** icons, an **`item_divider`**, then a **danger** row. Viewport clamp/flip uses **`AppWindow`**. Choosing a row fires **`item-activated`** and closes the overlay; **Escape** closes too.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        btn-inside-overlay := Button {
            width: 100%;
            max-width: 320px;
            align-content: ButtonAlignContent.start;
            label: "toggle overlay";
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                root.inside-overlay-open = true;
            }
        }

        anchored-overlay-action-list := AnchoredOverlay {
            open <=> root.inside-overlay-open;
            window-inner-width: AppWindow.window-width;
            window-inner-height: AppWindow.window-height;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.start;
            shrink-wrap: true;
            panel-width: 0px;
            panel-height: 360px;
            anchor-abs-x: btn-inside-overlay.absolute-position.x;
            anchor-abs-y: btn-inside-overlay.absolute-position.y;
            anchor-width: btn-inside-overlay.width;
            anchor-height: btn-inside-overlay.height;
            close-requested => {
            }

            ActionList2 {
                width: 100%;
                show-dividers: false;
                selection-mode: ActionList2SelectionMode.none;
                lines: root.inside-overlay-lines;
                item-activated(ix) => {
                    root.inside-overlay-last = root.inside-overlay-lines[ix].label;
                    root.inside-overlay-open = false;
                }
            }
        }

        Text {
            visible: root.inside-overlay-last != "";
            text: "Last activated: " + root.inside-overlay-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Loading item";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Matches Primer Storybook **Features → Loading item** ([primer.style/react/storybook](https://primer.style/react/storybook/?path=/story/components-actionlist-features--loading-item)) and **`reference/actionlist-features/loading-item.png`**: four rows, no leading visuals, block descriptions; the second row (**Accessibility**) shows a trailing **`Spinner`** and does not fire **`item-activated`**.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList2 {
                    width: 100%;
                    show-dividers: false;
                    lines: root.loading-item-lines;
                    item-activated(ix) => {
                        root.loading-item-last = root.loading-item-lines[ix].label;
                    }
                }

                Text {
                    visible: root.loading-item-last != "";
                    text: "Last activated: " + root.loading-item-last;
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "With dynamic content";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Same pattern as React: **`ActionList.Item`** **`onSelect={() => setIsTrue(!isTrue)}`** with children **`Activated? {isTrue ? 'Yes' : 'No'}`** — here one row, **`item-activated`** flips **`with-dynamic-is-true`**, label is a bound **`with-dynamic-item-label`**.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList2 {
                    width: 100%;
                    show-dividers: false;
                    selection-mode: ActionList2SelectionMode.none;
                    lines: root.with-dynamic-content-lines;
                    item-activated(ix) => {
                        if ix == 0 {
                            root.with-dynamic-is-true = !root.with-dynamic-is-true;
                        }
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Listbox multi select";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Same as **Multi select** (`selectionVariant=\"multiple\"`, checkbox lead, fourth row **`disabled`**) with the Storybook **Listbox Multi Select** difference: **`show-dividers`** false (no row seam hairlines). Checked rows are **`GalleryActionList2ListboxMultiSelect.row-checked`**, toggled from Node (`gallery-action-list2-multi-select-bridge-shared.ts`).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

