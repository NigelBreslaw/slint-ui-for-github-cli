        }

        Text {
            text: "`listbox-focus-bar-outside` + **single** rows, **multi** selection column (`.MultiSelectCheckbox` style), **label-link-style**, **Avatar** + **IconButton**.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: demo-action-list-pr4-last == "" ? "Last item-activated index: —" : "Last item-activated index: " + demo-action-list-pr4-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: demo-action-list-pr4-trailing == "" ? "Last trailing-action line index: —" : "Last trailing-action line index: " + demo-action-list-pr4-trailing;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 0;
            width: 420px;

            ActionList {
                width: 100%;
                listbox-focus-bar-outside: true;
                lines: demo-action-list-pr4-lines;
                item-activated(idx) => {
                    demo-action-list-pr4-last = "\{idx}";
                }
                trailing-action-clicked(idx) => {
                    demo-action-list-pr4-trailing = "\{idx}";
                }
            }
        }
    }
}
