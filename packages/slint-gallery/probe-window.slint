// Dialog height probe: card column + intrinsic body (Flickable later). Run: `pnpm --filter slint-gallery run probe`

export enum BodyDensity { minimal, short, long, }

/// Debug-bar chip: fewer nested copies in **`ProbeWindow`**.
component ProbePill {
    in property <string> label;
    in property <bool> on;
    callback chosen;

    Rectangle {
        min-width: 40px;
        min-height: 30px;
        background: on ? #0969da1a : #d0d7de80;
        border-radius: 6px;
        border-width: 1px;
        border-color: #d0d7de;

        TouchArea {
            clicked => {
                root.chosen();
            }

            Text {
                text: label;
                color: #1f2328;
                font-size: 12px;
                width: 100%;
                height: 100%;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }
}

export component ProbeWindow inherits Window {
    title: "Dialog height probe";
    preferred-width: 480px;
    preferred-height: 700px;

    in-out property <bool> show-header: true;
    in-out property <bool> show-footer: true;
    in-out property <BodyDensity> body-density: short;

    private property <length> max-dialog-h: max(min(root.height - 40px, 520px), 240px);
    private property <length> header-h: 52px;
    private property <length> footer-h: 56px;

    private property <string> short-text: "Short copy. The panel should hug this text: little empty space below.";
    private property <string> long-text:
        "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed non risus. Suspendisse lectus tortor, dignissim sit amet, adipiscing nec, ultricies sed, dolor.\n\n" + "Cras elementum ultrices diam. Maecenas ligula massa, varius a, semper congue, euismod non, mi. Proin porttitor, orci nec nonummy molestie, enim est eleifend mi, non fermentum diam nisl sit amet erat.\n\n" + "Duis semper. Duis arcu massa, scelerisque vitae, consequat in, pretium a, enim. Pellentesque congue. Ut in risus volutpat libero pharetra tempor.\n\n" + "Cras vestibulum bibendum augue. Praesent egestas leo in pede. Praesent blandit odio eu enim. Pellentesque sed dui ut augue blandit sodales.\n\n" + "Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia Curae; Aliquam nibh. Mauris ac mauris sed pede pellentesque fermentum.\n\n" + "Maecenas adipiscing ante non diam. Ut velit mauris, egestas sed, gravida nec, ornare ut, mi. Aenean ut orci vel massa suscipit pulvinar.\n\n" + "Nulla sollicitudin. Fusce varius, ligula non tempus aliquam, nunc turpis ullamcorper nibh, in tempus sapien eros vitae ligula. Nulla facilisi.\n\n" + "Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. In non velit. Etiam laoreet. Morbi est.\n\n" + "Donec ut dolor. Duis vel nibh at velit dignissim rutrum. Nulla facilisi. Integer lacinia sollicitudin massa. Cras metus.\n\n" + "Curabitur dapibus enim quis is. Aliquam erat volutpat. Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium.\n\n" + "Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.";

    private property <string> body-str:
        root.body-density == BodyDensity.minimal ? "Minimal" : root.body-density == BodyDensity.short ? root.short-text : root.long-text;

    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: start;

        // Debug bar
        Rectangle {
            width: 100%;
            min-height: 48px;
            background: #eaeef2;

            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-top: 6px;
                padding-bottom: 6px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: start;

                Text {
                    font-size: 11px;
                    color: #1f2328;
                    text: "Debug ·";
                    vertical-alignment: center;
                }

                ProbePill {
                    label: "Hdr";
                    on: root.show-header;
                    chosen => {
                        root.show-header = !root.show-header;
                    }
                }

                ProbePill {
                    label: "Ftr";
                    on: root.show-footer;
                    chosen => {
                        root.show-footer = !root.show-footer;
                    }
                }

                ProbePill {
                    label: "·";
                    on: root.body-density == BodyDensity.minimal;
                    chosen => {
                        root.body-density = BodyDensity.minimal;
                    }
                }

                ProbePill {
                    label: "S";
                    on: root.body-density == BodyDensity.short;
                    chosen => {
                        root.body-density = BodyDensity.short;
                    }
                }

                ProbePill {
                    label: "L";
                    on: root.body-density == BodyDensity.long;
                    chosen => {
                        root.body-density = BodyDensity.long;
                    }
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 1px;
            background: #d0d7de;
        }

        VerticalLayout {
            width: 100%;
            height: 100%;
            vertical-stretch: 1;
            alignment: center;

            // Card: **`max-dialog-h`** caps height (long text may draw past until Flickable returns).
            Rectangle {
                width: 400px;
                max-height: max-dialog-h;
                background: #ffffff;
                border-radius: 12px;
                border-width: 1px;
                border-color: #d0d7de;
                clip: true;

                VerticalLayout {
                    width: 100%;
                    spacing: 0px;
                    alignment: start;

                    if root.show-header: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: header-h;
                            background: #f6f8fa;
                            border-top-left-radius: 12px;
                            border-top-right-radius: 12px;

                            HorizontalLayout {
                                width: 100%;
                                height: 100%;
                                padding-left: 16px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: center;

                                Text {
                                    text: "Probe dialog";
                                    color: #1f2328;
                                    font-size: 16px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }

                                TouchArea {
                                    width: 28px;
                                    height: 28px;
                                    clicked => {
                                        root.body-density = BodyDensity.short;
                                    }
                                    Text {
                                        text: "×";
                                        color: #656d76;
                                        font-size: 18px;
                                        width: 100%;
                                        height: 100%;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        Rectangle {
                            width: 100%;
                            height: 1px;
                            background: #d0d7de;
                        }
                    }

                    // Body: intrinsic height (no Flickable wrapper for now)
                    VerticalLayout {
                        width: 100%;
                        padding-top: 16px;
                        padding-bottom: 16px;
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 0px;
                        alignment: start;
                        Text {
                            text: root.body-str;
                            color: #1f2328;
                            font-size: 14px;
                            wrap: word-wrap;
                        }
                    }

                    if root.show-footer: VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            width: 100%;
                            height: 1px;
                            background: #d0d7de;
                        }

                        Rectangle {
                            height: footer-h;
                            background: #f6f8fa;
                            border-bottom-left-radius: 12px;
                            border-bottom-right-radius: 12px;
                            HorizontalLayout {
                                width: 100%;
                                height: 100%;
                                padding-left: 12px;
                                padding-right: 12px;
                                alignment: end;
                                Text {
                                    text: "Footer (probe)";
                                    color: #656d76;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
