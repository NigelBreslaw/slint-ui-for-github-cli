// Dialog height probe: column shell + intrinsic body (no Flickable yet; grow/shrink with text). Run: `pnpm --filter slint-gallery run probe`

export enum BodyDensity {
    minimal,
    short,
    long,
}

export component ProbeWindow inherits Window {
    title: "Dialog height probe";
    preferred-width: 480px;
    preferred-height: 700px;

    in-out property <bool> show-header: true;
    in-out property <bool> show-footer: true;
    in-out property <BodyDensity> body-density: short;

    /// Viewport cap for the card. Floored so the layout is stable before **`Window`** size is known.
    private property <length> max-dialog-h: max(min(root.height - 40px, 520px), 240px);
    private property <length> header-h: 52px;
    private property <length> footer-h: 56px;

    private property <string> short-text:
        "Short copy. The panel should hug this text: little empty space below.";
    private property <string> long-text:
        "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed non risus. Suspendisse lectus tortor, dignissim sit amet, adipiscing nec, ultricies sed, dolor.\n\n"
        + "Cras elementum ultrices diam. Maecenas ligula massa, varius a, semper congue, euismod non, mi. Proin porttitor, orci nec nonummy molestie, enim est eleifend mi, non fermentum diam nisl sit amet erat.\n\n"
        + "Duis semper. Duis arcu massa, scelerisque vitae, consequat in, pretium a, enim. Pellentesque congue. Ut in risus volutpat libero pharetra tempor.\n\n"
        + "Cras vestibulum bibendum augue. Praesent egestas leo in pede. Praesent blandit odio eu enim. Pellentesque sed dui ut augue blandit sodales.\n\n"
        + "Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia Curae; Aliquam nibh. Mauris ac mauris sed pede pellentesque fermentum.\n\n"
        + "Maecenas adipiscing ante non diam. Ut velit mauris, egestas sed, gravida nec, ornare ut, mi. Aenean ut orci vel massa suscipit pulvinar.\n\n"
        + "Nulla sollicitudin. Fusce varius, ligula non tempus aliquam, nunc turpis ullamcorper nibh, in tempus sapien eros vitae ligula. Nulla facilisi.\n\n"
        + "Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. In non velit. Etiam laoreet. Morbi est.\n\n"
        + "Donec ut dolor. Duis vel nibh at velit dignissim rutrum. Nulla facilisi. Integer lacinia sollicitudin massa. Cras metus.\n\n"
        + "Curabitur dapibus enim quis is. Aliquam erat volutpat. Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium.\n\n"
        + "Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.";

    private property <string> body-str:
        root.body-density == BodyDensity.minimal ? "Minimal"
        : root.body-density == BodyDensity.short ? root.short-text
        : root.long-text;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;
        alignment: start;

        // —— Debug bar (not part of the “dialog” card) ——
        Rectangle {
            width: 100%;
            min-height: 48px;
            background: #eaeef2;

            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-top: 6px;
                padding-bottom: 6px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;

                Text {
                    font-size: 11px;
                    color: #1f2328;
                    text: "Debug ·";
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: #d0d7de;
                }

                Rectangle {
                    min-width: 42px;
                    min-height: 30px;
                    background: root.show-header ? #0969da1a : #d0d7de80;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #d0d7de;

                    TouchArea {
                        clicked => {
                            root.show-header = !root.show-header;
                        }

                        Text {
                            text: "Hdr";
                            font-size: 12px;
                            color: #1f2328;
                            width: 100%;
                            height: 100%;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }

                Rectangle {
                    min-width: 42px;
                    min-height: 30px;
                    background: root.show-footer ? #0969da1a : #d0d7de80;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #d0d7de;

                    TouchArea {
                        clicked => {
                            root.show-footer = !root.show-footer;
                        }

                        Text {
                            text: "Ftr";
                            font-size: 12px;
                            color: #1f2328;
                            width: 100%;
                            height: 100%;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }

                Rectangle { width: 1px; height: 24px; background: #d0d7de; }

                // Body density: minimal / short / long
                Rectangle {
                    min-width: 36px;
                    min-height: 30px;
                    background: root.body-density == BodyDensity.minimal ? #0969da2a : #d0d7de80;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #d0d7de;

                    TouchArea {
                        clicked => {
                            root.body-density = BodyDensity.minimal;
                        }

                        Text {
                            text: "·";
                            font-size: 12px;
                            color: #1f2328;
                            width: 100%;
                            height: 100%;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }

                Rectangle {
                    min-width: 36px;
                    min-height: 30px;
                    background: root.body-density == BodyDensity.short ? #0969da2a : #d0d7de80;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #d0d7de;

                    TouchArea {
                        clicked => {
                            root.body-density = BodyDensity.short;
                        }

                        Text {
                            text: "S";
                            font-size: 12px;
                            color: #1f2328;
                            width: 100%;
                            height: 100%;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }

                Rectangle {
                    min-width: 36px;
                    min-height: 30px;
                    background: root.body-density == BodyDensity.long ? #0969da2a : #d0d7de80;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #d0d7de;

                    TouchArea {
                        clicked => {
                            root.body-density = BodyDensity.long;
                        }

                        Text {
                            text: "L";
                            font-size: 12px;
                            color: #1f2328;
                            width: 100%;
                            height: 100%;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 1px;
            background: #d0d7de;
        }

        VerticalLayout {
            width: 100%;
            height: 100%;
            vertical-stretch: 1;
            alignment: center;

            // Card: height follows content. **`max-dialog-h`** caps the flex column (long text may overflow until Flickable is restored).
            panel-rect := Rectangle {
                width: 400px;
                max-height: max-dialog-h;
                background: #ffffff;
                border-radius: 12px;
                border-width: 1px;
                border-color: #d0d7de;
                clip: true;

                col := VerticalLayout {
                    width: 100%;
                    max-height: max-dialog-h;
                    spacing: 0px;
                    padding: 0px;
                    alignment: start;

                    if root.show-header: header-bar := Rectangle {
                        height: header-h;
                        background: #f6f8fa;
                        border-top-left-radius: 12px;
                        border-top-right-radius: 12px;

                        HorizontalLayout {
                            width: 100%;
                            height: 100%;
                            padding-left: 16px;
                            padding-right: 12px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: "Probe dialog";
                                font-size: 16px;
                                font-weight: 600;
                                color: #1f2328;
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                width: 28px;
                                height: 28px;
                                background: #eaeef280;
                                border-radius: 6px;

                                TouchArea {
                                    clicked => {
                                        root.body-density = BodyDensity.short;
                                    }

                                    Text {
                                        text: "×";
                                        color: #656d76;
                                        font-size: 18px;
                                        width: 100%;
                                        height: 100%;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    if root.show-header: Rectangle {
                        height: 1px;
                        background: #d0d7de;
                    }

                    // Shrink-wrapped body (intrinsic height from text; Flickable added later for overflow).
                    body-block := Rectangle {
                        width: 100%;
                        background: #ffffff;

                        VerticalLayout {
                            width: parent.width;
                            padding: 16px;
                            spacing: 8px;
                            alignment: start;

                            Text {
                                text: root.body-str;
                                wrap: word-wrap;
                                color: #1f2328;
                                font-size: 14px;
                            }
                        }
                    }

                    if root.show-footer: Rectangle {
                        height: 1px;
                        background: #d0d7de;
                    }

                    if root.show-footer: footer-bar := Rectangle {
                        height: footer-h;
                        background: #f6f8fa;
                        border-bottom-left-radius: 12px;
                        border-bottom-right-radius: 12px;

                        HorizontalLayout {
                            width: 100%;
                            height: 100%;
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;
                            alignment: end;

                            Text {
                                text: "Footer (probe)";
                                color: #656d76;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
