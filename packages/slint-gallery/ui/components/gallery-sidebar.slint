    leading-is-directory: false,
    has-leading-visual: true,
    trailing: TreeViewTrailingVisual.none,
    has-leading-action: false,
    show-leading-action-icon: false,
    leading-action-icon: Icons.dot_fill,
    leading-file-icon: Icons.file,
    interactive: true,
    is-skeleton: false,
    has-secondary-actions: false,
    secondary-actions-badge: "",
    loading-children-badge: "",
},
    ];

    Rectangle {
        background: PrimerColors.bgColor-inset;

        Rectangle {
            x: parent.width - self.width;
            width: 1px;
            background: PrimerColors.borderColor-default;
        }

        VerticalLayout {
            padding-top: 12px;
            padding-bottom: 12px;
            padding-left: 8px;
            padding-right: 12px;
            spacing: 8px;

            Text {
                text: "Components";
                font-size: 11px;
                font-weight: 600;
                color: PrimerColors.fgColor-muted;
            }

            scroll-host := Rectangle {

                sidebar-flick := Flickable {
                    width: scroll-host.width;
                    height: scroll-host.height;

                    viewport-width: self.width;
                    viewport-height: nav-tree.preferred-height;

                    nav-tree := PrimerTreeView {
                        width: sidebar-flick.width;
                        accessible-name: "Gallery pages";
                        rows: nav-from-host ? GallerySidebarNav.rows : fallback-nav-rows;
                        max-gutter-columns: 2;
                        suppress-current-for-directories: nav-from-host;
                        row-current-requested(id) => {
                            if nav-from-host {
                                GallerySidebarNav.row-current-requested(id);
                            } else if id == "action-list-playground"
                                || id == "action-menu-playground"
                                || id == "anchored-overlay-playground"
                                || id == "avatar-playground"
                                || id == "banner-playground"
                                || id == "buttons-playground"
                                || id == "checkbox-playground"
                                || id == "counter-label-playground"
                                || id == "data-playground"
                                || id == "dialogs-playground"
                                || id == "icon-button-playground"
                                || id == "label-playground"
                                || id == "navs-playground"
                                || id == "radio-playground"
                                || id == "segmented-control-playground"
                                || id == "select-playground"
                                || id == "sheets-playground"
                                || id == "skeleton-box-playground"
                                || id == "spinner-playground"
                                || id == "state-label-playground"
                                || id == "text-input-playground"
                                || id == "toggle-switch-playground"
                                || id == "tree-view-playground"
                                || id == "underline-nav-playground"
                            {
                                GalleryState.selected-page-id = id;
                            }
                        }
                        row-toggle-requested(id) => {
                            if nav-from-host {
                                GallerySidebarNav.row-toggle-requested(id);
                            }
                        }
                        row-secondary-actions-requested(id, ax, ay, aw, ah) => {
                            if nav-from-host {
                                GallerySidebarNav.row-secondary-actions-requested(id, ax, ay, aw, ah);
                            }
                        }
                    }
                }
            }
        }
    }
}
