                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList {
                    width: 100%;
                    show-dividers: false;
                    selection-mode: ActionListSelectionMode.multiple;
                    multi-selected: GalleryActionListListboxMultiSelect.row-checked;
                    lines: root.listbox-multi-select-lines;
                    item-activated(ix) => {
                        GalleryActionListListboxMultiSelect.row-activated(ix);
                    }
                }

                Text {
                    text: "Last row: \{GalleryActionListListboxMultiSelect.last-activated-label} — selected: \{GalleryActionListListboxMultiSelect.selection-summary}";
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }

