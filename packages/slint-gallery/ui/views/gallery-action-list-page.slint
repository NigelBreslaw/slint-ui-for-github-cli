        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "List options";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;
                alignment: start;

                Text {
                    text: "List";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "variant";
                    placeholder: "Choose…";
                    options: root.list-variant-options;
                    selected-index <=> list-variant-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                Checkbox {
                    label: "Leading icon";
                    checked <=> preview-has-leading-icon;
                }

                Checkbox {
                    label: "Disable focus zone";
                    disabled: root.scenario-key != "25";
                    checked <=> preview-disable-focus-zone;
                }

                Checkbox {
                    label: "Trailing action loading";
                    disabled: root.scenario-key != "26";
                    checked <=> preview-trailing-action-loading;
                }
            }
        }
    }
}
