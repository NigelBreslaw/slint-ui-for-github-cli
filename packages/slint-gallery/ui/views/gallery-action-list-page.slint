// **ActionList2** gallery — composed rows + **ActionList2Lines** where needed.
import {
    ActionList2,
    ActionList2CustomHeading,
    ActionList2DescriptionLayout,
    ActionList2ItemDivider,
    ActionList2Line,
    ActionList2LineKind,
    ActionList2Lines,
    ActionList2LinkRow,
    ActionList2ListRole,
    ActionList2ListVisualHeading,
    ALVariant,
    ActionList2Row,
    ActionList2RowSize,
    ActionList2RowVariant,
    ActionList2SectionHeading,
    ActionList2SectionHeadingVariant,
    ActionList2SelectionLead,
    ActionList2SelectionMode,
    Checkbox,
    Icons,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { ActionList2Tokens, LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryDemoOptionsSidebar,
} from "../components/gallery-demo-options-sidebar.slint";
import { GalleryActionList2ListboxMultiSelect } from "../state/gallery-action-list2-listbox-multi-select-state.slint";
import { GalleryActionList2MenuMultiSelect } from "../state/gallery-action-list2-menu-multi-select-state.slint";

export component GalleryActionList2Page {
    property <int> scenario-ix: 0;
    /// **`Select`** binds **option index**; match previews via **`scenario-options[ix].value`** (not the index).
    property <string> scenario-key:
        root.scenario-ix >= 0 && root.scenario-ix < root.scenario-options.length
        ? root.scenario-options[root.scenario-ix].value
        : "0";
    property <int> list-variant-ix: 0;
    property <bool> preview-has-leading-icon: false;
    property <bool> preview-disable-focus-zone: false;
    property <int> keyboard-nav-focused: -1;

    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "SimpleList", enabled: true },
        { value: "2", label: "ItemDividers", enabled: true },
        { value: "3", label: "BlockDescription", enabled: true },
        { value: "4", label: "InlineDescription", enabled: true },
        { value: "6", label: "SingleSelect", enabled: true },
        { value: "7", label: "SingleSelectLines", enabled: true },
        { value: "9", label: "MultiSelectLines", enabled: true },
        { value: "10", label: "ListboxMultiSelect", enabled: true },
        { value: "12", label: "DisabledItem", enabled: true },
        { value: "13", label: "InactiveItem", enabled: true },
        { value: "14", label: "LoadingItem", enabled: true },
        { value: "16", label: "Active", enabled: true },
        { value: "17", label: "WithVisualListHeading", enabled: true },
        { value: "18", label: "WithCustomHeading", enabled: true },
        { value: "19", label: "GroupWithFilledTitle", enabled: true },
        { value: "20", label: "WithAvatars", enabled: true },
        { value: "21", label: "WithIcons", enabled: true },
        { value: "22", label: "LargeItem", enabled: true },
        { value: "24", label: "TextWrapAndTruncation", enabled: true },
        { value: "25", label: "KeyboardNavigation", enabled: true },
        { value: "26", label: "WithTrailingAction", enabled: true },
    ];
    property <bool> preview-trailing-action-loading: false;

    property <[SelectOption]> list-variant-options: [
        { value: "0", label: "inset", enabled: true },
        { value: "1", label: "horizontal-inset", enabled: true },
        { value: "2", label: "full", enabled: true },
    ];

    property <string> last-action: "";
    property <int> single-select-ix: 0;
    property <int> disabled-select-ix: 0;
    property <bool> multi-checked-0: true;
    property <bool> multi-checked-1: false;

    property <ALVariant> preview-list-variant:
    root.list-variant-ix == 1 ? ALVariant.horizontal_inset : root.list-variant-ix == 2 ? ALVariant.full : ALVariant.inset;

    property <ALVariant> effective-list-variant: root.preview-list-variant;

    property <length> effective-item-margin-inline:
        root.effective-list-variant == ALVariant.full ? 0px : ActionList2Tokens.item-margin-inline-inset;

    property <length> preview-chrome-width: root.scenario-key == "24" ? 300px : 240px;

    property <[ActionList2Line]> lines-single-select: [
        {
            kind: ActionList2LineKind.row,
            label: "Primer Backlog",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Accessibility",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Octicons",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Primer React",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <[ActionList2Line]> lines-listbox-multi-select: [
        {
            kind: ActionList2LineKind.row,
            label: "Primer Backlog",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Accessibility",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Octicons",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Primer React",
            row-variant: ActionList2RowVariant.default,
            disabled: true,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <[ActionList2Line]> lines-menu-multi-select: [
        {
            kind: ActionList2LineKind.row,
            label: "Copy link",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Quote reply",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Edit comment",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    /// Upstream **`ActionList.test`** listbox arrow navigation (disabled + inactive rows stay focusable).
    property <[ActionList2Line]> lines-keyboard-nav: [
        {
            kind: ActionList2LineKind.row,
            label: "Option 1",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Option 2",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Option 3",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            disabled: true,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Option 4",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Option 5",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            avatar-source: Icons.dot_fill,
            leading-icon: Icons.dot_fill,
            description-layout: ActionList2DescriptionLayout.none,
            inactive-text: "Unavailable due to an outage",
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <string> scenario-caption:
        root.scenario-key == "1" ? "Upstream: ActionList/Features — SimpleList (composed **ActionList2Row**)"
        : root.scenario-key == "2" ? "Upstream: ItemDividers — **`show-top-seam`** on rows"
        : root.scenario-key == "3" ? "Upstream: BlockDescription (composed rows)"
        : root.scenario-key == "4" ? "Upstream: InlineDescription (composed rows)"
        : root.scenario-key == "6" ? "Single select — **`selection-lead: checkmark`**"
        : root.scenario-key == "7" ? "Single select — **`ActionList2Lines`** (`selection-mode: single` → checkmark)"
        : root.scenario-key == "9" ? "Upstream **MultiSelect** — **`ActionList2Lines`** + **`list-role: menu`** → checkmark"
        : root.scenario-key == "10" ? "True listbox multi — **`list-role: listbox`** → **`selection-lead: checkbox`** (Storybook **ListboxMultiSelect** name is misleading; it uses menu)"
        : root.scenario-key == "12" ? "Upstream **DisabledItem** — middle row **`disabled`** (no hover/activation)"
        : root.scenario-key == "13" ? "Upstream **InactiveItem** — **`inactive-text`** warning under block description"
        : root.scenario-key == "14" ? "Upstream **LoadingItem** — **`show-trailing-loading`** spinner; no activation"
        : root.scenario-key == "16" ? "Upstream **Active** — **`active`** row: left accent bar + selected surface"
        : root.scenario-key == "17" ? "Upstream **WithVisualListHeading** — **`ActionList.Heading`** + **GroupHeading** groups"
        : root.scenario-key == "18" ? "Upstream **WithCustomHeading** — **Details** title + **`ActionList2LinkRow`** (`href` → **`last-action`**)"
        : root.scenario-key == "19" ? "Upstream **GroupWithFilledTitle** — filled **GroupHeading** + multi-select menu rows"
        : root.scenario-key == "20" ? "Upstream **WithAvatars** — **`Avatar`** leading visual (20px)"
        : root.scenario-key == "21" ? "Upstream **WithIcons** — leading octicons incl. **danger** row"
        : root.scenario-key == "22" ? "Upstream **LargeItem** — **`row-size: large`** (plain, inline, block description)"
        : root.scenario-key == "24" ? "Upstream **TextWrapAndTruncation** — 300px panel; **`truncate-inline-description`**"
        : root.scenario-key == "25" ? "Upstream listbox focus zone — Tab then **↑**/**↓**/**Home**/**End**; toggle **Disable focus zone**; disabled/inactive rows focusable"
        : root.scenario-key == "26" ? "Upstream **WithTrailingAction** — icon/text **`ActionList2TrailingAction`**; row click vs trailing click (**not** for menu/listbox)"
        : "Upstream: ActionList — Default (composed rows)";

    // vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "ActionList2";
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            preview-chrome := Rectangle {
                width: root.preview-chrome-width;
                border-width: 1px;
                border-color: PrimerColors.borderColor-muted;
                border-radius: LayoutTokens.borderRadius-medium;
                background: PrimerColors.bgColor-default;

                preview-layout := VerticalLayout {
                    alignment: start;

                    if root.scenario-key == "18": VerticalLayout {
                        padding-left:
                            root.effective-item-margin-inline + LayoutTokens.action-list-item-padding-inline;
                        padding-right:
                            root.effective-item-margin-inline + LayoutTokens.action-list-item-padding-inline;
                        padding-bottom: LayoutTokens.button-content-gap;

                        Text {
                            text: "Details";
                            color: PrimerColors.fgColor-default;
                            font-size: LayoutTokens.text-body-size-large;
                            font-weight: LayoutTokens.base-text-weight-semibold;
                            wrap: word-wrap;
                        }
                    }

                    al := ActionList2 {
                        list-variant: root.effective-list-variant;

                        if root.scenario-key == "0": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Copy link";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.copy_icon;
                                clicked => {
                                    root.last-action = "Activated Copy link";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Quote reply";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.link;
                                clicked => {
                                    root.last-action = "Activated Quote reply";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Edit comment";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.diff_modified;
                                clicked => {
                                    root.last-action = "Activated Edit comment";
                                }
                            }
                        }

                        if root.scenario-key == "1": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Copy link";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.copy_icon;
                                trailing-text: "⌘C";
                                clicked => {
                                    root.last-action = "Activated line 0";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Quote reply";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.link;
                                trailing-text: "⌘Q";
                                clicked => {
                                    root.last-action = "Activated line 1";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Edit comment";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.diff_modified;
                                trailing-text: "⌘E";
                                clicked => {
                                    root.last-action = "Activated line 2";
                                }
                            }
                            ActionList2ItemDivider {
                                margin-inline: root.effective-item-margin-inline;
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Delete file";
                                row-variant: ActionList2RowVariant.danger;
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.x;
                                clicked => {
                                    root.last-action = "Activated line 4";
                                }
                            }
                        }

                        if root.scenario-key == "2": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Copy link";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.copy_icon;
                                clicked => {
                                    root.last-action = "Activated line 0";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Quote reply";
                                show-divider: true;
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.link;
                                clicked => {
                                    root.last-action = "Activated line 1";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Edit comment";
                                show-divider: true;
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.diff_modified;
                                clicked => {
                                    root.last-action = "Activated line 2";
                                }
                            }
                        }

                        if root.scenario-key == "3": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Accessibility";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Accessibility";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Octicons";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Octicons";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Primer React";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Primer React";
                                }
                            }
                        }

                        if root.scenario-key == "4": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Accessibility";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Accessibility";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Octicons";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Octicons";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Primer React";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Primer React";
                                }
                            }
                        }

                        if root.scenario-key == "6": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Inbox";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.single-select-ix == 0;
                                clicked => {
                                    root.single-select-ix = 0;
                                    root.last-action = "Selected Inbox";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Primary";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.single-select-ix == 1;
                                clicked => {
                                    root.single-select-ix = 1;
                                    root.last-action = "Selected Primary";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Calendar";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.single-select-ix == 2;
                                clicked => {
                                    root.single-select-ix = 2;
                                    root.last-action = "Selected Calendar";
                                }
                            }
                        }

                        if root.scenario-key == "7": ActionList2Lines {
                            list-variant: root.effective-list-variant;
                            selection-mode: ActionList2SelectionMode.single;
                            selected-index: root.single-select-ix;
                            lines: root.lines-single-select;
                            item-activated(ix) => {
                                root.single-select-ix = ix;
                                root.last-action = "Selected " + root.lines-single-select[ix].label;
                            }
                        }

                        if root.scenario-key == "9": ActionList2Lines {
                            list-variant: root.effective-list-variant;
                            list-role: ActionList2ListRole.menu;
                            selection-mode: ActionList2SelectionMode.multiple;
                            multi-selected: GalleryActionList2MenuMultiSelect.row-checked;
                            lines: root.lines-menu-multi-select;
                            item-activated(ix) => {
                                GalleryActionList2MenuMultiSelect.row-activated(ix);
                                root.last-action = "Toggled " + root.lines-menu-multi-select[ix].label;
                            }
                        }

                        if root.scenario-key == "10": ActionList2Lines {
                            list-variant: root.effective-list-variant;
                            list-role: ActionList2ListRole.listbox;
                            selection-mode: ActionList2SelectionMode.multiple;
                            multi-selected: GalleryActionList2ListboxMultiSelect.row-checked;
                            lines: root.lines-listbox-multi-select;
                            item-activated(ix) => {
                                GalleryActionList2ListboxMultiSelect.row-activated(ix);
                                root.last-action = "Toggled " + root.lines-listbox-multi-select[ix].label;
                            }
                        }

                        if root.scenario-key == "12": VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.effective-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
