    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "With dynamic content";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList {
                    width: 100%;
                    show-dividers: false;
                    selection-mode: ActionListSelectionMode.none;
                    lines: root.with-dynamic-content-lines;
                    item-activated(ix) => {
                        if ix == 0 {
                            root.with-dynamic-is-true = !root.with-dynamic-is-true;
                        }
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Listbox multi select";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

