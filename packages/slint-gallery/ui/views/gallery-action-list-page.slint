    private property <[ActionListLine]> active-demo-lines: [
        {
            kind: ActionListLineKind.row,
            label: "Active item",
            row-variant: ActionListRowVariant.default,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            has-markdown: false,
            label-markdown: @markdown(""),
            inactive-text: "",
            active: true,
            show-trailing-loading: false,
            has-trailing-visual: false,
            trailing-icon: Icons.dot_fill,
        },
        {
            kind: ActionListLineKind.row,
            label: "Second row",
            row-variant: ActionListRowVariant.default,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            has-markdown: false,
            label-markdown: @markdown(""),
            inactive-text: "",
            active: false,
            show-trailing-loading: false,
            has-trailing-visual: false,
            trailing-icon: Icons.dot_fill,
        },
        {
            kind: ActionListLineKind.row,
            label: "Third row",
            row-variant: ActionListRowVariant.default,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            has-markdown: false,
            label-markdown: @markdown(""),
            inactive-text: "",
            active: false,
            show-trailing-loading: false,
            has-trailing-visual: false,
            trailing-icon: Icons.dot_fill,
        },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Active (Primer data-active)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: 6px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                width: 100%;
                alignment: start;

                ActionList {
                    width: 100%;
                    lines: root.active-demo-lines;
                    item-activated(ix) => {
                        root.active-demo-last = root.active-demo-lines[ix].label;
                    }
                }

                Text {
                    visible: root.active-demo-last != "";
                    text: "Last activated: " + root.active-demo-last;
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "Inside overlay";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        btn-inside-overlay := Button {
            width: 100%;
            max-width: 320px;
            align-content: ButtonAlignContent.start;
            label: "toggle overlay";
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                root.inside-overlay-open = true;
            }
        }

        anchored-overlay-action-list := AnchoredOverlay {
            open <=> root.inside-overlay-open;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.start;
            shrink-wrap: true;
            panel-width: 0px;
            panel-height: 360px;
            anchor-abs-x: btn-inside-overlay.absolute-position.x;
            anchor-abs-y: btn-inside-overlay.absolute-position.y;
            anchor-width: btn-inside-overlay.width;
            anchor-height: btn-inside-overlay.height;
            close-requested => {
            }

            ActionList {
                width: 100%;
                show-dividers: false;
                selection-mode: ActionListSelectionMode.none;
                lines: root.inside-overlay-lines;
                item-activated(ix) => {
                    root.inside-overlay-last = root.inside-overlay-lines[ix].label;
                    root.inside-overlay-open = false;
                }
            }
        }

        Text {
            visible: root.inside-overlay-last != "";
            text: "Last activated: " + root.inside-overlay-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

