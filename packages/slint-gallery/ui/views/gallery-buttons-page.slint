import {
    Button,
    ButtonAlignContent,
    ButtonVariant,
    Checkbox,
    Icons,
    PrimerTextInput,
    Radio,
    RadioGroup,
    Size,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import { GalleryDemoOptionsSidebar } from "../components/gallery-demo-options-sidebar.slint";

/// Interactive **Button** playground. **CounterLabel** has its own sidebar entry; **IconButton** is under **Buttons → IconButton**.
export component GalleryButtonsPage {
    vertical-stretch: 1;

    property <ButtonVariant> preview-variant: ButtonVariant.default;
    property <Size> preview-size: Size.medium;
    property <bool> preview-disabled: false;
    property <bool> preview-loading: false;
    property <string> preview-label: "Button";
    property <ButtonAlignContent> preview-align: ButtonAlignContent.center;
    /// 0 none, 1 emoji, 2 icon
    property <int> leading-kind: 0;
    /// 0 info, 1 circle_check, 2 search (when leading-kind == 2)
    property <int> leading-icon-preset: 0;
    /// 0 none, 1 text, 2 icon, 3 text + icon
    property <int> trailing-kind: 0;
    /// 0 circle_check, 1 arrow_down, 2 link (when trailing shows icon)
    property <int> trailing-icon-preset: 0;
    property <string> preview-count: "";

    property <image> preview-leading-icon:
        leading-icon-preset == 0 ? Icons.info
        : leading-icon-preset == 1 ? Icons.circle_check : Icons.search;

    property <image> preview-trailing-icon:
        trailing-icon-preset == 0 ? Icons.circle_check
        : trailing-icon-preset == 1 ? Icons.arrow_down : Icons.link;

    property <bool> preview-has-leading-icon: leading-kind == 2;
    property <string> preview-leading-text: leading-kind == 1 ? "⭐" : "";
    property <bool> preview-has-trailing-icon: trailing-kind == 2 || trailing-kind == 3;
    property <string> preview-trailing-text: trailing-kind == 1 || trailing-kind == 3 ? "→" : "";

    HorizontalLayout {
        vertical-stretch: 1;
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "Button";
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            Button {
                variant: preview-variant;
                size: preview-size;
                disabled: preview-disabled;
                loading: preview-loading;
                label: preview-label;
                align-content: preview-align;
                count: preview-count;
                has-leading-icon: preview-has-leading-icon;
                leading-icon: preview-leading-icon;
                leading-text: preview-leading-text;
                has-trailing-icon: preview-has-trailing-icon;
                trailing-icon: preview-trailing-icon;
                trailing-text: preview-trailing-text;
                clicked => {
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 4px;

                Text {
                    text: "Variant";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    Radio {
                        value: "def";
                        label: "default";
                        checked: preview-variant == ButtonVariant.default;
                        toggled => {
                            preview-variant = ButtonVariant.default;
                        }
                    }

                    Radio {
                        value: "pri";
                        label: "primary";
                        checked: preview-variant == ButtonVariant.primary;
                        toggled => {
                            preview-variant = ButtonVariant.primary;
                        }
                    }

                    Radio {
                        value: "dan";
                        label: "danger";
                        checked: preview-variant == ButtonVariant.danger;
                        toggled => {
                            preview-variant = ButtonVariant.danger;
                        }
                    }

                    Radio {
                        value: "inv";
                        label: "invisible";
                        checked: preview-variant == ButtonVariant.invisible;
                        toggled => {
                            preview-variant = ButtonVariant.invisible;
                        }
                    }

                    Radio {
                        value: "lnk";
                        label: "link";
                        checked: preview-variant == ButtonVariant.link;
                        toggled => {
                            preview-variant = ButtonVariant.link;
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;

                Text {
                    text: "Size";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    Radio {
                        value: "sm";
                        label: "small";
                        checked: preview-size == Size.small;
                        toggled => {
                            preview-size = Size.small;
                        }
                    }

                    Radio {
                        value: "md";
                        label: "medium";
                        checked: preview-size == Size.medium;
                        toggled => {
                            preview-size = Size.medium;
                        }
                    }

                    Radio {
                        value: "lg";
                        label: "large";
                        checked: preview-size == Size.large;
                        toggled => {
                            preview-size = Size.large;
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "State";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Checkbox {
                    label: "Disabled";
                    checked <=> preview-disabled;
                }

                Checkbox {
                    label: "Loading";
                    checked <=> preview-loading;
                }
            }

            VerticalLayout {
                spacing: 6px;

                Text {
                    text: "Label";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "";
                    placeholder: "Button text";
                    text <=> preview-label;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;

                Text {
                    text: "Align content";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    Radio {
                        value: "c";
                        label: "center";
                        checked: preview-align == ButtonAlignContent.center;
                        toggled => {
                            preview-align = ButtonAlignContent.center;
                        }
                    }

                    Radio {
                        value: "s";
                        label: "start";
                        checked: preview-align == ButtonAlignContent.start;
                        toggled => {
                            preview-align = ButtonAlignContent.start;
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;

                Text {
                    text: "Leading";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    Radio {
                        value: "l0";
                        label: "none";
                        checked: leading-kind == 0;
                        toggled => {
                            leading-kind = 0;
                        }
                    }

                    Radio {
                        value: "l1";
                        label: "emoji";
                        checked: leading-kind == 1;
                        toggled => {
                            leading-kind = 1;
                        }
                    }

                    Radio {
                        value: "l2";
                        label: "icon";
                        checked: leading-kind == 2;
                        toggled => {
                            leading-kind = 2;
                        }
                    }
                }

                if leading-kind == 2: VerticalLayout {
                    spacing: 4px;

                    Text {
                        text: "Leading icon";
                        font-size: LayoutTokens.text-body-size-small;
                        color: PrimerColors.fgColor-muted;
                    }

                    RadioGroup {
                        label: "";

                        Radio {
                            value: "li0";
                            label: "info";
                            checked: leading-icon-preset == 0;
                            toggled => {
                                leading-icon-preset = 0;
                            }
                        }

                        Radio {
                            value: "li1";
                            label: "circle_check";
                            checked: leading-icon-preset == 1;
                            toggled => {
                                leading-icon-preset = 1;
                            }
                        }

                        Radio {
                            value: "li2";
                            label: "search";
                            checked: leading-icon-preset == 2;
                            toggled => {
                                leading-icon-preset = 2;
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;

                Text {
                    text: "Trailing";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    Radio {
                        value: "t0";
                        label: "none";
                        checked: trailing-kind == 0;
                        toggled => {
                            trailing-kind = 0;
                        }
                    }

                    Radio {
                        value: "t1";
                        label: "text";
                        checked: trailing-kind == 1;
                        toggled => {
                            trailing-kind = 1;
                        }
                    }

                    Radio {
                        value: "t2";
                        label: "icon";
                        checked: trailing-kind == 2;
                        toggled => {
                            trailing-kind = 2;
                        }
                    }

                    Radio {
                        value: "t3";
                        label: "text + icon";
                        checked: trailing-kind == 3;
                        toggled => {
                            trailing-kind = 3;
                        }
                    }
                }

                if trailing-kind == 2 || trailing-kind == 3: VerticalLayout {
                    spacing: 4px;

                    Text {
                        text: "Trailing icon";
                        font-size: LayoutTokens.text-body-size-small;
                        color: PrimerColors.fgColor-muted;
                    }

                    RadioGroup {
                        label: "";

                        Radio {
                            value: "ti0";
                            label: "circle_check";
                            checked: trailing-icon-preset == 0;
                            toggled => {
                                trailing-icon-preset = 0;
                            }
                        }

                        Radio {
                            value: "ti1";
                            label: "arrow_down";
                            checked: trailing-icon-preset == 1;
                            toggled => {
                                trailing-icon-preset = 1;
                            }
                        }

                        Radio {
                            value: "ti2";
                            label: "link";
                            checked: trailing-icon-preset == 2;
                            toggled => {
                                trailing-icon-preset = 2;
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 6px;

                Text {
                    text: "Count";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Empty hides the counter; non-empty replaces trailing visuals when rules allow.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "";
                    placeholder: "e.g. 12 or 99+";
                    text <=> preview-count;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }
            }
        }
    }
}
