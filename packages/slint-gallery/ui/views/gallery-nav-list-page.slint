import {
    Checkbox,
    NavList,
    NavListExpandableItem,
    NavListGroup,
    NavListGroupHeading,
    NavListItem,
    NavListSubNav,
    PrimerTextInput,
    Radio,
    RadioGroup,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { Icons } from "../../../primer-slint/assets/icons.slint";
import { ActionListDescriptionLayout } from "../../../primer-slint/ActionList/types.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryDemoOptionsSidebar,
} from "../components/gallery-demo-options-sidebar.slint";

/// **NavList** — upstream feature stories (Default through **WithDescription**).
export component GalleryNavListPage {
    property <int> scenario-ix: 0;
    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "WithSubItems", enabled: true },
        { value: "2", label: "WithNestedSubItems", enabled: true },
        { value: "3", label: "WithGroup", enabled: true },
        { value: "4", label: "WithGroupHeadingLinks", enabled: true },
        { value: "5", label: "WithInactiveItems", enabled: true },
        { value: "6", label: "WithDescription", enabled: true },
    ];

    /// Active leaf id: `"1"`, `"2.1"`, `"1.2.2"`, etc.
    property <string> preview-active-id: "1";
    property <bool> preview-item2-expanded: true;
    property <bool> preview-item12-expanded: true;
    property <bool> preview-default-open: false;

    property <bool> subitem-child-active:
        root.preview-active-id == "2.1" || root.preview-active-id == "2.2";
    property <bool> subitem-expanded: root.preview-item2-expanded || root.subitem-child-active;

    property <bool> nested-child-active:
        root.preview-active-id == "1.2.1" || root.preview-active-id == "1.2.2";
    property <bool> nested-item1-expanded: root.preview-default-open || root.preview-active-id == "1.1";
    property <bool> nested-item12-expanded: root.preview-item12-expanded || root.nested-child-active;

    property <string> preview-group1-title: "Group 1";
    property <string> preview-group2-title: "Group 2";

    property <bool> preview-inactive-item1: true;
    property <bool> preview-inactive-sub2: true;
    property <string> preview-inactive-text: "Unavailable due to an outage";

    property <string> inactive-copy-item1:
        root.preview-inactive-item1 ? root.preview-inactive-text : "";
    property <string> inactive-copy-sub2:
        root.preview-inactive-sub2 ? root.preview-inactive-text : "";

    property <string> scenario-title:
        root.scenario-ix == 0 ? "Default"
        : root.scenario-ix == 1 ? "WithSubItems"
        : root.scenario-ix == 2 ? "WithNestedSubItems"
        : root.scenario-ix == 3 ? "WithGroup"
        : root.scenario-ix == 4 ? "WithGroupHeadingLinks"
        : root.scenario-ix == 5 ? "WithInactiveItems"
        : "WithDescription";

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "NavList — " + root.scenario-title;
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            preview-chrome := Rectangle {
                width: 240px;
                border-width: 1px;
                border-color: PrimerColors.borderColor-muted;
                border-radius: LayoutTokens.borderRadius-medium;
                background: PrimerColors.bgColor-default;

                preview-layout := VerticalLayout {
                    alignment: start;
                    width: parent.width;

                    NavList {
                        width: parent.width;
                        aria-label: "Demo navigation";

                        if root.scenario-ix == 0: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                active: root.preview-active-id == "2";
                                clicked => {
                                    preview-active-id = "2";
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 1: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            item2-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 2";
                                    expanded <=> root.subitem-expanded;
                                    child-active: root.subitem-child-active;
                                    toggled => {
                                    }
                                }

                                if root.subitem-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        active: root.preview-active-id == "2.1";
                                        clicked => {
                                            preview-active-id = "2.1";
                                        }
                                    }

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 2";
                                        active: root.preview-active-id == "2.2";
                                        clicked => {
                                            preview-active-id = "2.2";
                                        }
                                    }
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 2: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            item1-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 1";
                                    expanded <=> root.nested-item1-expanded;
                                    default-open: root.preview-default-open;
                                    child-active: root.nested-child-active;
                                    toggled => {
                                    }
                                }

                                if root.nested-item1-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        active: root.preview-active-id == "1.1";
                                        clicked => {
                                            preview-active-id = "1.1";
                                        }
                                    }

                                    sub12-block := VerticalLayout {
                                        width: parent.width;
                                        alignment: start;

                                        NavListExpandableItem {
                                            subitem-depth: 1;
                                            label: "Sub item 1.2";
                                            expanded <=> root.nested-item12-expanded;
                                            child-active: root.nested-child-active;
                                            toggled => {
                                            }
                                        }

                                        if root.nested-item12-expanded: NavListSubNav {
                                            depth: 2;

                                            NavListItem {
                                                subitem-depth: 2;
                                                label: "Sub item 1.2.1";
                                                active: root.preview-active-id == "1.2.1";
                                                clicked => {
                                                    preview-active-id = "1.2.1";
                                                }
                                            }

                                            NavListItem {
                                                subitem-depth: 2;
                                                label: "Sub item 1.2.2";
                                                active: root.preview-active-id == "1.2.2";
                                                clicked => {
                                                    preview-active-id = "1.2.2";
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                active: root.preview-active-id == "2";
                                clicked => {
                                    preview-active-id = "2";
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 3: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListGroup {
                                title: root.preview-group1-title;

                                NavListItem {
                                    label: "Item 1A";
                                    active: root.preview-active-id == "g1a";
                                    clicked => {
                                        preview-active-id = "g1a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1B";
                                    active: root.preview-active-id == "g1b";
                                    clicked => {
                                        preview-active-id = "g1b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1C";
                                    active: root.preview-active-id == "g1c";
                                    clicked => {
                                        preview-active-id = "g1c";
                                    }
                                }
                            }

                            NavListGroup {
                                title: root.preview-group2-title;

                                NavListItem {
                                    label: "Item 2A";
                                    active: root.preview-active-id == "g2a";
                                    clicked => {
                                        preview-active-id = "g2a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2B";
                                    active: root.preview-active-id == "g2b";
                                    clicked => {
                                        preview-active-id = "g2b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2C";
                                    active: root.preview-active-id == "g2c";
                                    clicked => {
                                        preview-active-id = "g2c";
                                    }
                                }
                            }
                        }

                        if root.scenario-ix == 4: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListGroup {
                                NavListGroupHeading {
                                    title: root.preview-group1-title;
                                    href: "#group-1";
                                    clicked => {
                                    }
                                }

                                NavListItem {
                                    label: "Item 1A";
                                    active: root.preview-active-id == "g1a";
                                    clicked => {
                                        preview-active-id = "g1a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1B";
                                    active: root.preview-active-id == "g1b";
                                    clicked => {
                                        preview-active-id = "g1b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1C";
                                    active: root.preview-active-id == "g1c";
                                    clicked => {
                                        preview-active-id = "g1c";
                                    }
                                }
                            }

                            NavListGroup {
                                NavListGroupHeading {
                                    title: root.preview-group2-title;
                                    href: "#group-2";
                                    clicked => {
                                    }
                                }

                                NavListItem {
                                    label: "Item 2A";
                                    active: root.preview-active-id == "g2a";
                                    clicked => {
                                        preview-active-id = "g2a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2B";
                                    active: root.preview-active-id == "g2b";
                                    clicked => {
                                        preview-active-id = "g2b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2C";
                                    active: root.preview-active-id == "g2c";
                                    clicked => {
                                        preview-active-id = "g2c";
                                    }
                                }
                            }
                        }

                        if root.scenario-ix == 5: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                inactive-text: root.inactive-copy-item1;
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            inactive-item2-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 2";
                                    expanded <=> root.subitem-expanded;
                                    child-active: root.subitem-child-active;
                                    toggled => {
                                    }
                                }

                                if root.subitem-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        active: root.preview-active-id == "2.1";
                                        clicked => {
                                            preview-active-id = "2.1";
                                        }
                                    }

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 2";
                                        inactive-text: root.inactive-copy-sub2;
                                        active: root.preview-active-id == "2.2";
                                        clicked => {
                                            preview-active-id = "2.2";
                                        }
                                    }
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 6: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Main Repository";
                                has-leading-visual: true;
                                leading-icon: Icons.repo;
                                description: "Primary project repository";
                                active: root.preview-active-id == "repo";
                                clicked => {
                                    preview-active-id = "repo";
                                }
                            }

                            NavListItem {
                                label: "Documentation";
                                has-leading-visual: true;
                                leading-icon: Icons.book;
                                description: "User guides and API documentation";
                                active: root.preview-active-id == "docs";
                                clicked => {
                                    preview-active-id = "docs";
                                }
                            }

                            NavListItem {
                                label: "Bug Reports";
                                has-leading-visual: true;
                                leading-icon: Icons.issue_opened;
                                description: "Submit and track bug reports for the project. Include detailed steps to reproduce, expected behavior, and system information.";
                                description-layout: ActionListDescriptionLayout.block;
                                active: root.preview-active-id == "bugs";
                                clicked => {
                                    preview-active-id = "bugs";
                                }
                            }

                            NavListItem {
                                label: "Community";
                                has-leading-visual: true;
                                leading-icon: Icons.people;
                                description: "Connect with other developers, share ideas, and collaborate on features and improvements.";
                                description-layout: ActionListDescriptionLayout.block;
                                active: root.preview-active-id == "community";
                                clicked => {
                                    preview-active-id = "community";
                                }
                            }

                            NavListItem {
                                label: "Recent Changes";
                                has-leading-visual: true;
                                leading-icon: Icons.git_commit;
                                description: "Latest commits and releases";
                                active: root.preview-active-id == "changes";
                                clicked => {
                                    preview-active-id = "changes";
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "Story";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(ix) => {
                        preview-active-id =
                            ix == 3 || ix == 4 ? "g1a"
                            : ix == 5 ? "2.1"
                            : ix == 6 ? "repo"
                            : "1";
                        preview-item2-expanded = true;
                        preview-item12-expanded = true;
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "aria-current";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    if root.scenario-ix == 0: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Item 2";
                            checked: preview-active-id == "2";
                            toggled => {
                                preview-active-id = "2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 1: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "2.1";
                            toggled => {
                                preview-active-id = "2.1";
                            }
                        }

                        Radio {
                            label: "Sub item 2";
                            checked: preview-active-id == "2.2";
                            toggled => {
                                preview-active-id = "2.2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 2: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "1.1";
                            toggled => {
                                preview-active-id = "1.1";
                            }
                        }

                        Radio {
                            label: "Sub item 1.2.1";
                            checked: preview-active-id == "1.2.1";
                            toggled => {
                                preview-active-id = "1.2.1";
                            }
                        }

                        Radio {
                            label: "Sub item 1.2.2";
                            checked: preview-active-id == "1.2.2";
                            toggled => {
                                preview-active-id = "1.2.2";
                            }
                        }

                        Radio {
                            label: "Item 2";
                            checked: preview-active-id == "2";
                            toggled => {
                                preview-active-id = "2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 5: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "2.1";
                            toggled => {
                                preview-active-id = "2.1";
                            }
                        }

                        Radio {
                            label: "Sub item 2";
                            checked: preview-active-id == "2.2";
                            toggled => {
                                preview-active-id = "2.2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 6: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Main Repository";
                            checked: preview-active-id == "repo";
                            toggled => {
                                preview-active-id = "repo";
                            }
                        }

                        Radio {
                            label: "Documentation";
                            checked: preview-active-id == "docs";
                            toggled => {
                                preview-active-id = "docs";
                            }
                        }

                        Radio {
                            label: "Bug Reports";
                            checked: preview-active-id == "bugs";
                            toggled => {
                                preview-active-id = "bugs";
                            }
                        }

                        Radio {
                            label: "Community";
                            checked: preview-active-id == "community";
                            toggled => {
                                preview-active-id = "community";
                            }
                        }

                        Radio {
                            label: "Recent Changes";
                            checked: preview-active-id == "changes";
                            toggled => {
                                preview-active-id = "changes";
                            }
                        }
                    }

                    if root.scenario-ix == 3 || root.scenario-ix == 4: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1A";
                            checked: preview-active-id == "g1a";
                            toggled => {
                                preview-active-id = "g1a";
                            }
                        }

                        Radio {
                            label: "Item 1B";
                            checked: preview-active-id == "g1b";
                            toggled => {
                                preview-active-id = "g1b";
                            }
                        }

                        Radio {
                            label: "Item 1C";
                            checked: preview-active-id == "g1c";
                            toggled => {
                                preview-active-id = "g1c";
                            }
                        }

                        Radio {
                            label: "Item 2A";
                            checked: preview-active-id == "g2a";
                            toggled => {
                                preview-active-id = "g2a";
                            }
                        }

                        Radio {
                            label: "Item 2B";
                            checked: preview-active-id == "g2b";
                            toggled => {
                                preview-active-id = "g2b";
                            }
                        }

                        Radio {
                            label: "Item 2C";
                            checked: preview-active-id == "g2c";
                            toggled => {
                                preview-active-id = "g2c";
                            }
                        }
                    }
                }
            }

            if root.scenario-ix == 1: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "expanded";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Checkbox {
                    label: "Item 2 expanded";
                    checked <=> preview-item2-expanded;
                    toggled => {
                    }
                }
            }

            if root.scenario-ix == 2: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "Expand";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Checkbox {
                    label: "Item 1 defaultOpen";
                    checked <=> preview-default-open;
                    toggled => {
                    }
                }

                Checkbox {
                    label: "Sub item 1.2 expanded";
                    checked <=> preview-item12-expanded;
                    toggled => {
                    }
                }
            }

            if root.scenario-ix == 3: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "title";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "Group 1";
                    text <=> preview-group1-title;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "Group 2";
                    text <=> preview-group2-title;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }
            }

            if root.scenario-ix == 4: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "GroupHeading";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Headings are links (hover for underline). Edit titles via WithGroup scenario.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if root.scenario-ix == 5: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "inactiveText";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Inactive rows are not interactive; attention copy shows below the label.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                Checkbox {
                    label: "Item 1 inactive";
                    checked <=> preview-inactive-item1;
                    toggled => {
                    }
                }

                Checkbox {
                    label: "Sub item 2 inactive";
                    checked <=> preview-inactive-sub2;
                    toggled => {
                    }
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "inactiveText";
                    text <=> preview-inactive-text;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }
            }

            if root.scenario-ix == 6: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "description";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Inline descriptions sit beside the label; block descriptions render below (Bug Reports, Community).";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }
        }
    }
}
