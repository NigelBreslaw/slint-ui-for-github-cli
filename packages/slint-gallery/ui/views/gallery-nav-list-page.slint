                                }
                            }

                            if root.preview-expand-visible-count >= 6: NavListItem {
                                label: "Item 9";
                                active: root.preview-active-id == "9";
                                clicked => {
                                    preview-active-id = "9";
                                }
                            }

                            NavListGroupExpand {
                                label: "Show more";
                                pages: root.preview-expand-pages;
                                item-count: root.preview-expand-item-count;
                                current-page <=> preview-expand-page;
                                page-changed(_page) => {
                                }
                            }
                        }

                        if root.scenario-ix == 10: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListGroup {
                                title: root.preview-group1-title;

                                NavListItem {
                                    label: "Item 1A";
                                    active: root.preview-active-id == "g1a";
                                    clicked => {
                                        preview-active-id = "g1a";
                                    }
                                }

                                NavListItem {
