import {
    Button,
    Checkbox,
    NavList,
    NavListExpandableItem,
    NavListGroup,
    NavListGroupExpand,
    NavListGroupHeading,
    NavListItem,
    NavListSubNav,
    PrimerTextInput,
    Radio,
    RadioGroup,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { Icons } from "../../../primer-slint/assets/icons.slint";
import { ActionListDescriptionLayout } from "../../../primer-slint/ActionList/types.slint";
import { ActionListTokens, LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryDemoOptionsSidebar,
} from "../components/gallery-demo-options-sidebar.slint";

/// **NavList** — upstream feature stories (Default through **WithGroupExpand**).
export component GalleryNavListPage {
    property <int> scenario-ix: 0;
    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "WithSubItems", enabled: true },
        { value: "2", label: "WithNestedSubItems", enabled: true },
        { value: "3", label: "WithGroup", enabled: true },
        { value: "4", label: "WithGroupHeadingLinks", enabled: true },
        { value: "5", label: "WithInactiveItems", enabled: true },
        { value: "6", label: "WithDescription", enabled: true },
        { value: "7", label: "WithTrailingAction", enabled: true },
        { value: "8", label: "WithTrailingActionInSubItem", enabled: true },
        { value: "9", label: "WithExpand", enabled: true },
        { value: "10", label: "WithGroupExpand", enabled: true },
    ];

    property <[SelectOption]> expand-pages-options: [
        { value: "0", label: "pages=0 (all at once)", enabled: true },
        { value: "1", label: "pages=2 (paginated)", enabled: true },
    ];
    property <int> expand-pages-option-ix: 0;

    property <string> preview-last-trailing-action: "";
    /// Sidebar **aria-current** radios (hidden until we want manual active-item control in the gallery).
    property <bool> show-aria-current-sidebar: false;

    /// Active leaf id: `"1"`, `"2.1"`, `"1.2.2"`, etc.
    property <string> preview-active-id: "1";
    property <bool> preview-item2-expanded: true;
    property <bool> preview-item12-expanded: true;
    property <bool> preview-item3-expanded: true;
    property <bool> preview-default-open: false;

    property <bool> subitem-child-active:
        root.preview-active-id == "2.1" || root.preview-active-id == "2.2";
    property <bool> subitem-expanded: root.preview-item2-expanded || root.subitem-child-active;

    property <bool> nested-child-active:
        root.preview-active-id == "1.2.1" || root.preview-active-id == "1.2.2";
    property <bool> nested-item1-expanded: root.preview-default-open || root.preview-active-id == "1.1";
    property <bool> nested-item12-expanded: root.preview-item12-expanded || root.nested-child-active;

    property <string> preview-group1-title: "Group 1";
    property <string> preview-group2-title: "Group 2";

    property <int> preview-expand-pages: root.expand-pages-option-ix == 0 ? 0 : 2;
    property <int> preview-expand-page: 0;
    property <int> preview-expand-item-count: 6;
    property <int> preview-expand-items-per-page:
        root.preview-expand-pages == 0
        ? root.preview-expand-item-count
        : (root.preview-expand-item-count + root.preview-expand-pages - 1) / root.preview-expand-pages;
    property <int> preview-expand-visible-count:
        root.preview-expand-pages == 0
        ? (root.preview-expand-page > 0 ? root.preview-expand-item-count : 0)
        : root.preview-expand-items-per-page * root.preview-expand-page;

    property <int> preview-g1-expand-page: 0;
    property <int> preview-g2-expand-page: 0;
    property <int> preview-g1-expand-visible: root.preview-g1-expand-page > 0 ? 2 : 0;
    property <int> preview-g2-expand-visible: root.preview-g2-expand-page > 0 ? 2 : 0;

    property <bool> preview-inactive-item1: true;
    property <bool> preview-inactive-sub2: true;
    property <string> preview-inactive-text: "Unavailable due to an outage";

    property <string> inactive-copy-item1:
        root.preview-inactive-item1 ? root.preview-inactive-text : "";
    property <string> inactive-copy-sub2:
        root.preview-inactive-sub2 ? root.preview-inactive-text : "";

    property <string> scenario-title:
        root.scenario-ix == 0 ? "Default"
        : root.scenario-ix == 1 ? "WithSubItems"
        : root.scenario-ix == 2 ? "WithNestedSubItems"
        : root.scenario-ix == 3 ? "WithGroup"
        : root.scenario-ix == 4 ? "WithGroupHeadingLinks"
        : root.scenario-ix == 5 ? "WithInactiveItems"
        : root.scenario-ix == 6 ? "WithDescription"
        : root.scenario-ix == 7 ? "WithTrailingAction"
        : root.scenario-ix == 8 ? "WithTrailingActionInSubItem"
        : root.scenario-ix == 9 ? "WithExpand"
        : "WithGroupExpand";

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "NavList — " + root.scenario-title;
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            preview-chrome := Rectangle {
                width: 300px;
                border-width: 1px;
                border-color: PrimerColors.borderColor-muted;
                border-radius: LayoutTokens.borderRadius-medium;
                background: PrimerColors.bgColor-default;

                preview-layout := VerticalLayout {
                    alignment: start;
                    padding-left: ActionListTokens.list-padding-block-inset;

                    NavList {
                        width: parent.width - parent.padding-left;
                        aria-label: "Demo navigation";

                        if root.scenario-ix == 0: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                active: root.preview-active-id == "2";
                                clicked => {
                                    preview-active-id = "2";
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 1: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            item2-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 2";
                                    expanded <=> root.subitem-expanded;
                                    child-active: root.subitem-child-active;
                                    toggled => {
                                    }
                                }

                                if root.subitem-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        active: root.preview-active-id == "2.1";
                                        clicked => {
                                            preview-active-id = "2.1";
                                        }
                                    }

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 2";
                                        active: root.preview-active-id == "2.2";
                                        clicked => {
                                            preview-active-id = "2.2";
                                        }
                                    }
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 2: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            item1-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 1";
                                    expanded <=> root.nested-item1-expanded;
                                    default-open: root.preview-default-open;
                                    child-active: root.nested-child-active;
                                    toggled => {
                                    }
                                }

                                if root.nested-item1-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        active: root.preview-active-id == "1.1";
                                        clicked => {
                                            preview-active-id = "1.1";
                                        }
                                    }

                                    sub12-block := VerticalLayout {
                                        width: parent.width;
                                        alignment: start;

                                        NavListExpandableItem {
                                            subitem-depth: 1;
                                            label: "Sub item 1.2";
                                            expanded <=> root.nested-item12-expanded;
                                            child-active: root.nested-child-active;
                                            toggled => {
                                            }
                                        }

                                        if root.nested-item12-expanded: NavListSubNav {
                                            depth: 2;

                                            NavListItem {
                                                subitem-depth: 2;
                                                label: "Sub item 1.2.1";
                                                active: root.preview-active-id == "1.2.1";
                                                clicked => {
                                                    preview-active-id = "1.2.1";
                                                }
                                            }

                                            NavListItem {
                                                subitem-depth: 2;
                                                label: "Sub item 1.2.2";
                                                active: root.preview-active-id == "1.2.2";
                                                clicked => {
                                                    preview-active-id = "1.2.2";
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                active: root.preview-active-id == "2";
                                clicked => {
                                    preview-active-id = "2";
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 3: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListGroup {
                                title: root.preview-group1-title;

                                NavListItem {
                                    label: "Item 1A";
                                    active: root.preview-active-id == "g1a";
                                    clicked => {
                                        preview-active-id = "g1a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1B";
                                    active: root.preview-active-id == "g1b";
                                    clicked => {
                                        preview-active-id = "g1b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1C";
                                    active: root.preview-active-id == "g1c";
                                    clicked => {
                                        preview-active-id = "g1c";
                                    }
                                }
                            }

                            NavListGroup {
                                title: root.preview-group2-title;

                                NavListItem {
                                    label: "Item 2A";
                                    active: root.preview-active-id == "g2a";
                                    clicked => {
                                        preview-active-id = "g2a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2B";
                                    active: root.preview-active-id == "g2b";
                                    clicked => {
                                        preview-active-id = "g2b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2C";
                                    active: root.preview-active-id == "g2c";
                                    clicked => {
                                        preview-active-id = "g2c";
                                    }
                                }
                            }
                        }

                        if root.scenario-ix == 4: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListGroup {
                                NavListGroupHeading {
                                    title: root.preview-group1-title;
                                    href: "#group-1";
                                    clicked => {
                                    }
                                }

                                NavListItem {
                                    label: "Item 1A";
                                    active: root.preview-active-id == "g1a";
                                    clicked => {
                                        preview-active-id = "g1a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1B";
                                    active: root.preview-active-id == "g1b";
                                    clicked => {
                                        preview-active-id = "g1b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 1C";
                                    active: root.preview-active-id == "g1c";
                                    clicked => {
                                        preview-active-id = "g1c";
                                    }
                                }
                            }

                            NavListGroup {
                                NavListGroupHeading {
                                    title: root.preview-group2-title;
                                    href: "#group-2";
                                    clicked => {
                                    }
                                }

                                NavListItem {
                                    label: "Item 2A";
                                    active: root.preview-active-id == "g2a";
                                    clicked => {
                                        preview-active-id = "g2a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2B";
                                    active: root.preview-active-id == "g2b";
                                    clicked => {
                                        preview-active-id = "g2b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2C";
                                    active: root.preview-active-id == "g2c";
                                    clicked => {
                                        preview-active-id = "g2c";
                                    }
                                }
                            }
                        }

                        if root.scenario-ix == 5: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                inactive-text: root.inactive-copy-item1;
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            inactive-item2-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 2";
                                    expanded <=> root.subitem-expanded;
                                    child-active: root.subitem-child-active;
                                    toggled => {
                                    }
                                }

                                if root.subitem-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        active: root.preview-active-id == "2.1";
                                        clicked => {
                                            preview-active-id = "2.1";
                                        }
                                    }

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 2";
                                        inactive-text: root.inactive-copy-sub2;
                                        active: root.preview-active-id == "2.2";
                                        clicked => {
                                            preview-active-id = "2.2";
                                        }
                                    }
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }
                        }

                        if root.scenario-ix == 6: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Main Repository";
                                has-leading-visual: true;
                                leading-icon: Icons.repo;
                                description: "Primary project repository";
                                active: root.preview-active-id == "repo";
                                clicked => {
                                    preview-active-id = "repo";
                                }
                            }

                            NavListItem {
                                label: "Documentation";
                                has-leading-visual: true;
                                leading-icon: Icons.book;
                                description: "User guides and API documentation";
                                active: root.preview-active-id == "docs";
                                clicked => {
                                    preview-active-id = "docs";
                                }
                            }

                            NavListItem {
                                label: "Bug Reports";
                                has-leading-visual: true;
                                leading-icon: Icons.issue_opened;
                                description: "Submit and track bug reports for the project. Include detailed steps to reproduce, expected behavior, and system information.";
                                description-layout: ActionListDescriptionLayout.block;
                                active: root.preview-active-id == "bugs";
                                clicked => {
                                    preview-active-id = "bugs";
                                }
                            }

                            NavListItem {
                                label: "Community";
                                has-leading-visual: true;
                                leading-icon: Icons.people;
                                description: "Connect with other developers, share ideas, and collaborate on features and improvements.";
                                description-layout: ActionListDescriptionLayout.block;
                                active: root.preview-active-id == "community";
                                clicked => {
                                    preview-active-id = "community";
                                }
                            }

                            NavListItem {
                                label: "Recent Changes";
                                has-leading-visual: true;
                                leading-icon: Icons.git_commit;
                                description: "Latest commits and releases";
                                active: root.preview-active-id == "changes";
                                clicked => {
                                    preview-active-id = "changes";
                                }
                            }
                        }

                        if root.scenario-ix == 7: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                has-leading-visual: true;
                                leading-icon: Icons.file_directory_fill;
                                has-trailing-action: true;
                                trailing-action-has-icon: true;
                                trailing-action-icon: Icons.chevron_left;
                                trailing-action-label: "Expand sidebar";
                                active: root.preview-active-id == "ta1";
                                clicked => {
                                    preview-active-id = "ta1";
                                }
                                trailing-action-clicked => {
                                    preview-last-trailing-action = "Expand sidebar";
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                has-trailing-action: true;
                                trailing-action-has-icon: true;
                                trailing-action-icon: Icons.chevron_right;
                                trailing-action-label: "Some action";
                                active: root.preview-active-id == "ta2";
                                clicked => {
                                    preview-active-id = "ta2";
                                }
                                trailing-action-clicked => {
                                    preview-last-trailing-action = "Some action";
                                }
                            }
                        }

                        if root.scenario-ix == 8: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                has-leading-visual: true;
                                leading-icon: Icons.file_directory_fill;
                                has-trailing-action: true;
                                trailing-action-has-icon: true;
                                trailing-action-icon: Icons.chevron_left;
                                trailing-action-label: "Expand sidebar";
                                active: root.preview-active-id == "ta1";
                                clicked => {
                                    preview-active-id = "ta1";
                                }
                                trailing-action-clicked => {
                                    preview-last-trailing-action = "Expand sidebar";
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                has-trailing-action: true;
                                trailing-action-has-icon: true;
                                trailing-action-icon: Icons.chevron_right;
                                trailing-action-label: "Some action";
                                active: root.preview-active-id == "ta2";
                                clicked => {
                                    preview-active-id = "ta2";
                                }
                                trailing-action-clicked => {
                                    preview-last-trailing-action = "Some action";
                                }
                            }

                            trailing-sub-block := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                NavListExpandableItem {
                                    label: "Item 3";
                                    expanded <=> root.preview-item3-expanded;
                                    toggled => {
                                    }
                                }

                                if root.preview-item3-expanded: NavListSubNav {
                                    depth: 1;

                                    NavListItem {
                                        subitem-depth: 1;
                                        label: "Sub item 1";
                                        has-trailing-action: true;
                                        trailing-action-has-icon: true;
                                        trailing-action-icon: Icons.book;
                                        trailing-action-label: "Another action";
                                        active: root.preview-active-id == "ta-sub1";
                                        clicked => {
                                            preview-active-id = "ta-sub1";
                                        }
                                        trailing-action-clicked => {
                                            preview-last-trailing-action = "Another action";
                                        }
                                    }
                                }
                            }
                        }

                        if root.scenario-ix == 9: VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            NavListItem {
                                label: "Item 1";
                                active: root.preview-active-id == "1";
                                clicked => {
                                    preview-active-id = "1";
                                }
                            }

                            NavListItem {
                                label: "Item 2";
                                active: root.preview-active-id == "2";
                                clicked => {
                                    preview-active-id = "2";
                                }
                            }

                            NavListItem {
                                label: "Item 3";
                                active: root.preview-active-id == "3";
                                clicked => {
                                    preview-active-id = "3";
                                }
                            }

                            if root.preview-expand-visible-count >= 1: NavListItem {
                                label: "Item 4";
                                active: root.preview-active-id == "4";
                                clicked => {
                                    preview-active-id = "4";
                                }
                            }

                            if root.preview-expand-visible-count >= 2: NavListItem {
                                label: "Item 5";
                                active: root.preview-active-id == "5";
                                clicked => {
                                    preview-active-id = "5";
                                }
                            }

                            if root.preview-expand-visible-count >= 3: NavListItem {
                                label: "Item 6";
                                active: root.preview-active-id == "6";
                                clicked => {
                                    preview-active-id = "6";
                                }
                            }

                            if root.preview-expand-visible-count >= 4: NavListItem {
                                label: "Item 7";
                                active: root.preview-active-id == "7";
                                clicked => {
