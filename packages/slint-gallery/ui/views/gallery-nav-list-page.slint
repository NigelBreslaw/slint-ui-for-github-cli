                                        preview-active-id = "g1c";
                                    }
                                }

                                if root.preview-g1-expand-visible >= 1: NavListItem {
                                    label: "Item 1D";
                                    active: root.preview-active-id == "g1d";
                                    clicked => {
                                        preview-active-id = "g1d";
                                    }
                                }

                                if root.preview-g1-expand-visible >= 2: NavListItem {
                                    label: "Item 1E";
                                    has-trailing-action: true;
                                    trailing-action-has-icon: true;
                                    trailing-action-icon: Icons.chevron_right;
                                    trailing-action-label: "Some action";
                                    active: root.preview-active-id == "g1e";
                                    clicked => {
                                        preview-active-id = "g1e";
                                    }
                                    trailing-action-clicked => {
                                        preview-last-trailing-action = "Some action (1E)";
                                    }
                                }

                                NavListGroupExpand {
                                    label: "More";
                                    item-count: 2;
                                    current-page <=> preview-g1-expand-page;
                                    page-changed(_page) => {
                                    }
                                }
                            }

                            NavListGroup {
                                title: root.preview-group2-title;

                                NavListItem {
                                    label: "Item 2A";
                                    active: root.preview-active-id == "g2a";
                                    clicked => {
                                        preview-active-id = "g2a";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2B";
                                    active: root.preview-active-id == "g2b";
                                    clicked => {
                                        preview-active-id = "g2b";
                                    }
                                }

                                NavListItem {
                                    label: "Item 2C";
                                    active: root.preview-active-id == "g2c";
                                    clicked => {
                                        preview-active-id = "g2c";
                                    }
                                }

                                if root.preview-g2-expand-visible >= 1: NavListItem {
                                    label: "Item 2D";
                                    has-trailing-visual: true;
                                    trailing-icon: Icons.book;
                                    active: root.preview-active-id == "g2d";
                                    clicked => {
                                        preview-active-id = "g2d";
                                    }
                                }

                                if root.preview-g2-expand-visible >= 2: NavListItem {
                                    label: "Item 2E";
                                    has-trailing-visual: true;
                                    trailing-icon: Icons.file_directory_fill;
                                    active: root.preview-active-id == "g2e";
                                    clicked => {
                                        preview-active-id = "g2e";
                                    }
                                }

                                NavListGroupExpand {
                                    label: "Show";
                                    item-count: 2;
                                    current-page <=> preview-g2-expand-page;
                                    page-changed(_page) => {
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "Story";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(ix) => {
                        preview-active-id =
                            ix == 3 || ix == 4 ? "g1a"
                            : ix == 5 ? "2.1"
                            : ix == 6 ? "repo"
                            : ix == 7 || ix == 8 ? "ta1"
                            : ix == 9 ? "1"
                            : "g1a";
                        preview-item2-expanded = true;
                        preview-item12-expanded = true;
                        preview-item3-expanded = true;
                        preview-last-trailing-action = "";
                        preview-expand-page = 0;
                        preview-g1-expand-page = 0;
                        preview-g2-expand-page = 0;
                    }
                }

                if root.scenario-ix == 9 || root.scenario-ix == 10: Button {
                    label: "Collapse expanded groups";
                    clicked => {
                        preview-expand-page = 0;
                        preview-g1-expand-page = 0;
                        preview-g2-expand-page = 0;
                    }
                }
            }

            if root.show-aria-current-sidebar: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "aria-current";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                RadioGroup {
                    label: "";

                    if root.scenario-ix == 0: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Item 2";
                            checked: preview-active-id == "2";
                            toggled => {
                                preview-active-id = "2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 1: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "2.1";
                            toggled => {
                                preview-active-id = "2.1";
                            }
                        }

                        Radio {
                            label: "Sub item 2";
                            checked: preview-active-id == "2.2";
                            toggled => {
                                preview-active-id = "2.2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 2: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "1.1";
                            toggled => {
                                preview-active-id = "1.1";
                            }
                        }

                        Radio {
                            label: "Sub item 1.2.1";
                            checked: preview-active-id == "1.2.1";
                            toggled => {
                                preview-active-id = "1.2.1";
                            }
                        }

                        Radio {
                            label: "Sub item 1.2.2";
                            checked: preview-active-id == "1.2.2";
                            toggled => {
                                preview-active-id = "1.2.2";
                            }
                        }

                        Radio {
                            label: "Item 2";
                            checked: preview-active-id == "2";
                            toggled => {
                                preview-active-id = "2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 5: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "2.1";
                            toggled => {
                                preview-active-id = "2.1";
                            }
                        }

                        Radio {
                            label: "Sub item 2";
                            checked: preview-active-id == "2.2";
                            toggled => {
                                preview-active-id = "2.2";
                            }
                        }

                        Radio {
                            label: "Item 3";
                            checked: preview-active-id == "3";
                            toggled => {
                                preview-active-id = "3";
                            }
                        }
                    }

                    if root.scenario-ix == 9: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "1";
                            toggled => {
                                preview-active-id = "1";
                            }
                        }

                        Radio {
                            label: "Item 4";
                            checked: preview-active-id == "4";
                            toggled => {
                                preview-active-id = "4";
                            }
                        }

                        Radio {
                            label: "Item 9";
                            checked: preview-active-id == "9";
                            toggled => {
                                preview-active-id = "9";
                            }
                        }
                    }

                    if root.scenario-ix == 10: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1A";
                            checked: preview-active-id == "g1a";
                            toggled => {
                                preview-active-id = "g1a";
                            }
                        }

                        Radio {
                            label: "Item 1E";
                            checked: preview-active-id == "g1e";
                            toggled => {
                                preview-active-id = "g1e";
                            }
                        }

                        Radio {
                            label: "Item 2D";
                            checked: preview-active-id == "g2d";
                            toggled => {
                                preview-active-id = "g2d";
                            }
                        }
                    }

                    if root.scenario-ix == 7 || root.scenario-ix == 8: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1";
                            checked: preview-active-id == "ta1";
                            toggled => {
                                preview-active-id = "ta1";
                            }
                        }

                        Radio {
                            label: "Item 2";
                            checked: preview-active-id == "ta2";
                            toggled => {
                                preview-active-id = "ta2";
                            }
                        }

                        if root.scenario-ix == 8: Radio {
                            label: "Sub item 1";
                            checked: preview-active-id == "ta-sub1";
                            toggled => {
                                preview-active-id = "ta-sub1";
                            }
                        }
                    }

                    if root.scenario-ix == 6: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Main Repository";
                            checked: preview-active-id == "repo";
                            toggled => {
                                preview-active-id = "repo";
                            }
                        }

                        Radio {
                            label: "Documentation";
                            checked: preview-active-id == "docs";
                            toggled => {
                                preview-active-id = "docs";
                            }
                        }

                        Radio {
                            label: "Bug Reports";
                            checked: preview-active-id == "bugs";
                            toggled => {
                                preview-active-id = "bugs";
                            }
                        }

                        Radio {
                            label: "Community";
                            checked: preview-active-id == "community";
                            toggled => {
                                preview-active-id = "community";
                            }
                        }

                        Radio {
                            label: "Recent Changes";
                            checked: preview-active-id == "changes";
                            toggled => {
                                preview-active-id = "changes";
                            }
                        }
                    }

                    if root.scenario-ix == 3 || root.scenario-ix == 4: VerticalLayout {
                        spacing: 4px;

                        Radio {
                            label: "Item 1A";
                            checked: preview-active-id == "g1a";
                            toggled => {
                                preview-active-id = "g1a";
                            }
                        }

                        Radio {
                            label: "Item 1B";
                            checked: preview-active-id == "g1b";
                            toggled => {
                                preview-active-id = "g1b";
                            }
                        }

                        Radio {
                            label: "Item 1C";
                            checked: preview-active-id == "g1c";
                            toggled => {
                                preview-active-id = "g1c";
                            }
                        }

                        Radio {
                            label: "Item 2A";
                            checked: preview-active-id == "g2a";
                            toggled => {
                                preview-active-id = "g2a";
                            }
                        }

                        Radio {
                            label: "Item 2B";
                            checked: preview-active-id == "g2b";
                            toggled => {
                                preview-active-id = "g2b";
                            }
                        }

                        Radio {
                            label: "Item 2C";
                            checked: preview-active-id == "g2c";
                            toggled => {
                                preview-active-id = "g2c";
                            }
                        }
                    }
                }
            }

            if root.scenario-ix == 1: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "expanded";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Checkbox {
                    label: "Item 2 expanded";
                    checked <=> preview-item2-expanded;
                    toggled => {
                    }
                }
            }

            if root.scenario-ix == 2: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "Expand";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Checkbox {
                    label: "Item 1 defaultOpen";
                    checked <=> preview-default-open;
                    toggled => {
                    }
                }

                Checkbox {
                    label: "Sub item 1.2 expanded";
                    checked <=> preview-item12-expanded;
                    toggled => {
                    }
                }
            }

            if root.scenario-ix == 3: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "title";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "Group 1";
                    text <=> preview-group1-title;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "Group 2";
                    text <=> preview-group2-title;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }
            }

            if root.scenario-ix == 4: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "GroupHeading";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Headings are links (hover for underline). Edit titles via WithGroup scenario.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if root.scenario-ix == 5: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "inactiveText";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Inactive rows are not interactive; attention copy shows below the label.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                Checkbox {
                    label: "Item 1 inactive";
                    checked <=> preview-inactive-item1;
                    toggled => {
                    }
                }

                Checkbox {
                    label: "Sub item 2 inactive";
                    checked <=> preview-inactive-sub2;
                    toggled => {
                    }
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "inactiveText";
                    text <=> preview-inactive-text;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }
            }

            if root.scenario-ix == 6: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "description";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Inline descriptions sit beside the label; block descriptions render below (Bug Reports, Community).";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if root.scenario-ix == 7 || root.scenario-ix == 8: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "TrailingAction";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Trailing actions are separate controls at the row end; they do not activate the nav item.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                if root.scenario-ix == 8: Checkbox {
                    label: "Item 3 expanded";
                    checked <=> preview-item3-expanded;
                    toggled => {
                    }
                }

                Text {
                    text: root.preview-last-trailing-action == "" ? "Click a trailing action…" : "Last trailing: " + root.preview-last-trailing-action;
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if root.scenario-ix == 9: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "pages";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "GroupExpand pages";
                    options: root.expand-pages-options;
                    selected-index <=> expand-pages-option-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_ix) => {
                        preview-expand-page = 0;
                    }
                }

                Text {
                    text: "Visible hidden items: " + root.preview-expand-visible-count + " / " + root.preview-expand-item-count + " (currentPage=" + root.preview-expand-page + ")";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if root.scenario-ix == 10: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "GroupExpand";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Text {
                    text: "Each group has its own “More” / “Show” control (pages=0). Expand to reveal trailing visuals and actions.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }
        }
    }
