import {
    Icons,
    NavList,
    NavListGroup,
    NavListGroupHeadingVariant,
    NavListItem,
    UnderlineNav,
    UnderlineNavItem,
    UnderlineNavVariant,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";

export component GalleryNavsPage inherits VerticalLayout {
    spacing: 28px;
    width: 100%;
    alignment: start;

    private property <int> demo-nav-flat-selected: 0;
    private property <[NavListItem]> demo-nav-flat-items: [
        {
            data: {
                label: "Dashboard",
                current: demo-nav-flat-selected == 0,
                inactive: false,
                inactive-text: "",
                description: "Overview and activity",
                has-leading-visual: true,
                leading-icon: Icons.layout_grid,
                trailing-text: "New",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Settings",
                current: demo-nav-flat-selected == 1,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: true,
                leading-icon: Icons.gear_24,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Billing (inactive)",
                current: false,
                inactive: true,
                inactive-text: "Not available on your plan.",
                description: "Payment method",
                has-leading-visual: true,
                leading-icon: Icons.stop,
                trailing-text: "Pro",
            },
            children: [],
            subnav-default-open: false,
        },
    ];
    private property <[NavListGroup]> demo-nav-groups: [
        {
            title: "Repository",
            heading-variant: NavListGroupHeadingVariant.filled,
            items: [
                {
                    data: {
                        label: "Code",
                        current: true,
                        inactive: false,
                        inactive-text: "",
                        description: "Browse files and folders",
                        has-leading-visual: true,
                        leading-icon: Icons.layout_grid,
                        trailing-text: "",
                    },
                    children: [],
                    subnav-default-open: false,
                },
                {
                    data: {
                        label: "Issues",
                        current: false,
                        inactive: false,
                        inactive-text: "",
                        description: "",
                        has-leading-visual: true,
                        leading-icon: Icons.issue_opened,
                        trailing-text: "24",
                    },
                    children: [],
                    subnav-default-open: false,
                },
            ],
        },
        {
            title: "Organization",
            heading-variant: NavListGroupHeadingVariant.subtle,
            items: [
                {
                    data: {
                        label: "People",
                        current: false,
                        inactive: false,
                        inactive-text: "",
                        description: "Members and roles",
                        has-leading-visual: true,
                        leading-icon: Icons.inbox,
                        trailing-text: "8",
                    },
                    children: [],
                    subnav-default-open: false,
                },
                {
                    data: {
                        label: "Teams",
                        current: false,
                        inactive: false,
                        inactive-text: "",
                        description: "",
                        has-leading-visual: true,
                        leading-icon: Icons.pull_request,
                        trailing-text: "",
                    },
                    children: [],
                    subnav-default-open: false,
                },
            ],
        },
    ];
    private property <[NavListItem]> demo-nav-subnav-items: [
        {
            data: {
                label: "Overview",
                current: false,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: true,
                leading-icon: Icons.layout_grid,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Pull requests",
                current: false,
                inactive: false,
                inactive-text: "",
                description: "Nested items; parent toggles open.",
                has-leading-visual: true,
                leading-icon: Icons.pull_request,
                trailing-text: "",
            },
            children: [
                {
                    data: {
                        label: "Open",
                        current: true,
                        inactive: false,
                        inactive-text: "",
                        description: "",
                        has-leading-visual: false,
                        leading-icon: Icons.dot_fill,
                        trailing-text: "12",
                    },
                    children: [],
                    subnav-default-open: false,
                },
                {
                    data: {
                        label: "Closed",
                        current: false,
                        inactive: false,
                        inactive-text: "",
                        description: "",
                        has-leading-visual: false,
                        leading-icon: Icons.dot_fill,
                        trailing-text: "240",
                    },
                    children: [],
                    subnav-default-open: false,
                },
            ],
            subnav-default-open: true,
        },
    ];
    private property <int> demo-nav-sidebar-selected: 0;
    // Minimal labels — common Primer sidebar: blue accent bar + muted row for `current`.
    private property <[NavListItem]> demo-nav-sidebar-items: [
        {
            data: {
                label: "Item 1",
                current: demo-nav-sidebar-selected == 0,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Item 2",
                current: demo-nav-sidebar-selected == 1,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Item 3",
                current: demo-nav-sidebar-selected == 2,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
    ];
    private property <string> demo-nav-last: "";

    private property <int> demo-underline-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-items: [
        { label: "Code", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Issues", enabled: true, counter: "12", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Pull requests", enabled: true, counter: "3", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-flush-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-flush-items: [
        { label: "Actions", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Projects", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-loading-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-loading-items: [
        { label: "Open", enabled: true, counter: "8", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Closed", enabled: true, counter: "24", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Draft", enabled: true, counter: "3", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-scroll-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-scroll-items: [
        { label: "Overview", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Repositories", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Projects", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Packages", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Stars", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Sponsors", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-disabled-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-disabled-items: [
        { label: "Code", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Issues", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Pull requests", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Security", enabled: false, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-loading-icons-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-loading-icons-items: [
        { label: "Open", enabled: true, counter: "128", has-leading-icon: true, leading-icon: Icons.issue_opened },
        { label: "Closed", enabled: true, counter: "2.4k", has-leading-icon: true, leading-icon: Icons.issue_draft },
        { label: "Drafts", enabled: true, counter: "4", has-leading-icon: true, leading-icon: Icons.git_pull_request_draft },
    ];
    private property <int> demo-underline-loading-flush-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-loading-flush-items: [
        { label: "Queued", enabled: true, counter: "6", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "In progress", enabled: true, counter: "2", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Done", enabled: true, counter: "14", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-loading-mixed-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-loading-mixed-items: [
        { label: "Summary", enabled: true, counter: "", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Checks", enabled: true, counter: "7", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Files", enabled: true, counter: "12", has-leading-icon: false, leading-icon: Icons.dot_fill },
        { label: "Logs (disabled)", enabled: false, counter: "99", has-leading-icon: false, leading-icon: Icons.dot_fill },
    ];
    private property <int> demo-underline-with-icons-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-with-icons-items: [
        { label: "Code", enabled: true, counter: "", has-leading-icon: true, leading-icon: Icons.layout_grid },
        { label: "Issues", enabled: true, counter: "", has-leading-icon: true, leading-icon: Icons.issue_opened },
        { label: "Pull requests", enabled: true, counter: "", has-leading-icon: true, leading-icon: Icons.pull_request },
    ];
    private property <int> demo-underline-with-icons-counters-selected: 0;
    private property <[UnderlineNavItem]> demo-underline-with-icons-counters-items: [
        { label: "Code", enabled: true, counter: "", has-leading-icon: true, leading-icon: Icons.layout_grid },
        { label: "Issues", enabled: true, counter: "12", has-leading-icon: true, leading-icon: Icons.issue_opened },
        { label: "Pull requests", enabled: true, counter: "3", has-leading-icon: true, leading-icon: Icons.pull_request },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "UnderlineNav";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Primer-style tabs (TouchArea + CounterLabel / loading skeleton). The matrix below maps each public API surface to a subsection on this page.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 4px;
            width: 100%;
            alignment: start;

            Text {
                text: "API → demo";
                color: PrimerColors.fgColor-default;
                font-size: 12px;
                font-weight: 600;
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "Surface";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    font-weight: 600;
                    width: 168px;
                }

                Text {
                    text: "Where exercised";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    font-weight: 600;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "items, selected-index, item-activated";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Every demo below.";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "variant (inset default)";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Most rows use inset; flush only where labeled.";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "CounterLabel (static)";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Inset with counters; Leading icons + counters.";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "loading-counters";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Skeleton pills only when counter ≠ \"\". Opacity animates via loading-pulse-opacity (UnderlineNavItemRow) + UnderlineNavTokens period.";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "has-leading-icon, leading-icon";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Leading icons; Leading icons + counters; Loading + leading icons.";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "enabled: false";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Disabled tab; Loading mixed (disabled row still reserves a skeleton slot).";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                spacing: 12px;
                width: 100%;
                alignment: start;

                Text {
                    text: "accessible-name";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    width: 168px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Set on each UnderlineNav (tab-list landmark).";
                    horizontal-stretch: 1;
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }

        Text {
            text: "Inset with counters (static CounterLabel).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            items: demo-underline-items;
            selected-index: demo-underline-selected;
            accessible-name: "Demo repository tabs";
            item-activated(idx) => {
                demo-underline-selected = idx;
            }
        }

        Text {
            text: "Inset with a disabled tab (no hover; muted label).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            items: demo-underline-disabled-items;
            selected-index: demo-underline-disabled-selected;
            accessible-name: "Demo tabs with disabled item";
            item-activated(idx) => {
                demo-underline-disabled-selected = idx;
            }
        }

        Text {
            text: "Flush variant (no horizontal padding on the tab row).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            variant: UnderlineNavVariant.flush;
            items: demo-underline-flush-items;
            selected-index: demo-underline-flush-selected;
            accessible-name: "Demo flush tabs";
            item-activated(idx) => {
                demo-underline-flush-selected = idx;
            }
        }

        Text {
            text: "loading-counters — skeleton pills with animated opacity (loading-pulse-opacity). Three tabs keep the motion visible.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            loading-counters: true;
            items: demo-underline-loading-items;
            selected-index: demo-underline-loading-selected;
            accessible-name: "Demo loading counters";
            item-activated(idx) => {
                demo-underline-loading-selected = idx;
            }
        }

        Text {
            text: "loading-counters + leading icons (pulse next to icons).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            loading-counters: true;
            items: demo-underline-loading-icons-items;
            selected-index: demo-underline-loading-icons-selected;
            accessible-name: "Demo loading counters with icons";
            item-activated(idx) => {
                demo-underline-loading-icons-selected = idx;
            }
        }

        Text {
            text: "loading-counters + flush (same pulse, edge-to-edge row).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            variant: UnderlineNavVariant.flush;
            loading-counters: true;
            items: demo-underline-loading-flush-items;
            selected-index: demo-underline-loading-flush-selected;
            accessible-name: "Demo flush loading counters";
            item-activated(idx) => {
                demo-underline-loading-flush-selected = idx;
            }
        }

        Text {
            text: "loading-counters + mixed counters + disabled: Summary has no pill; Checks/Files pulse; disabled row still shows a dimmed skeleton.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            loading-counters: true;
            items: demo-underline-loading-mixed-items;
            selected-index: demo-underline-loading-mixed-selected;
            accessible-name: "Demo mixed loading counters";
            item-activated(idx) => {
                demo-underline-loading-mixed-selected = idx;
            }
        }

        Text {
            text: "Leading icons only (Storybook WithIcons).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            items: demo-underline-with-icons-items;
            selected-index: demo-underline-with-icons-selected;
            accessible-name: "Demo tabs with icons";
            item-activated(idx) => {
                demo-underline-with-icons-selected = idx;
            }
        }

        Text {
            text: "Leading icons + CounterLabel (Storybook WithCounterLabels).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        UnderlineNav {
            items: demo-underline-with-icons-counters-items;
            selected-index: demo-underline-with-icons-counters-selected;
            accessible-name: "Demo tabs with icons and counters";
            item-activated(idx) => {
                demo-underline-with-icons-counters-selected = idx;
            }
        }

        Text {
            text: "Narrow width (clip — no horizontal scroll).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        Rectangle {
            width: 260px;
            clip: true;

            UnderlineNav {
                items: demo-underline-scroll-items;
                selected-index: demo-underline-scroll-selected;
                accessible-name: "Demo overflow tabs";
                item-activated(idx) => {
                    demo-underline-scroll-selected = idx;
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "NavList (flat)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Leading icons, optional description line, trailing text; current row, inactive row with explanation. Clicks report (group-index, path) — flat list uses group 0; path is dot-separated indices for SubNav.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: demo-nav-last == "" ? "Last activation: —" : "Last activation: " + demo-nav-last;
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 360px;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-default;
            background: PrimerColors.bgColor-canvas-subtle;

            VerticalLayout {
                padding: 8px;
                width: 100%;

                NavList {
                    width: 100%;
                    items: demo-nav-flat-items;
                    groups: [];
                    item-activated(gi, path) => {
                        demo-nav-last = "flat (" + gi + ", " + path + ")";
                        demo-nav-flat-selected = path == "0"
                            ? 0
                            : path == "1" ? 1 : demo-nav-flat-selected;
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "NavList (sidebar accent)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Typical repo sidebar: sidebar-current-indicator adds a blue vertical bar on the current row, neutral muted background, and semibold label; other rows stay plain.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 360px;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-default;
            background: PrimerColors.bgColor-canvas-subtle;

            VerticalLayout {
                padding: 8px;
                width: 100%;
                alignment: start;

                NavList {
                    items: demo-nav-sidebar-items;
                    groups: [];
                    sidebar-current-indicator: true;
                    item-activated(gi, path) => {
                        demo-nav-last = "sidebar (" + gi + ", " + path + ")";
                        demo-nav-sidebar-selected = path == "0"
                            ? 0
                            : path == "1" ? 1 : path == "2" ? 2 : demo-nav-sidebar-selected;
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "NavList (grouped)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Filled and subtle group headings, divider between groups; items may show leading icon, description, and trailing count.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 360px;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-default;
            background: PrimerColors.bgColor-canvas-subtle;

            VerticalLayout {
                padding: 8px;
                width: 100%;

                NavList {
                    width: 100%;
                    items: [];
                    groups: demo-nav-groups;
                    item-activated(gi, path) => {
                        demo-nav-last = "grouped (" + gi + ", " + path + ")";
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;
        alignment: start;

        Text {
            text: "NavList (SubNav)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Parent rows with children show a chevron and expand/collapse; activation reports a dot-separated path (e.g. 1.0 for first nested item under the second top-level row). Nesting is capped at four levels.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            horizontal-stretch: 0;
            width: 360px;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-default;
            background: PrimerColors.bgColor-canvas-subtle;

            VerticalLayout {
                padding: 8px;
                width: 100%;

                NavList {
                    width: 100%;
                    items: demo-nav-subnav-items;
                    groups: [];
                    item-activated(gi, path) => {
                        demo-nav-last = "subnav (" + gi + ", " + path + ")";
                    }
                }
            }
        }
    }
}
