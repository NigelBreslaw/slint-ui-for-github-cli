    property <[NavListItem]> items-inactive: [
        {
            data: {
                label: "Item 1",
                current: false,
                inactive: true,
                inactive-text: "Unavailable due to an outage",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
