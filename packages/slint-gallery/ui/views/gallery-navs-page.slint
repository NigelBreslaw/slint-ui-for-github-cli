// **NavList** gallery — scenarios aligned with Primer Storybook `Components/NavList` + `Features` (see sidebar footer for non-goals).
import {
    Icons,
    NavList,
    NavListGroup,
    NavListGroupHeadingVariant,
    NavListItem,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import { GalleryDemoOptionsSidebar } from "../components/gallery-demo-options-sidebar.slint";

export component GalleryNavsPage {
    property <int> scenario-ix: 0;
    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "WithSubItems", enabled: true },
        { value: "2", label: "WithNestedSubItems", enabled: true },
        { value: "3", label: "WithInactiveItems", enabled: true },
        { value: "4", label: "WithGroup", enabled: true },
        { value: "5", label: "WithDescription", enabled: true },
        { value: "6", label: "SidebarCurrentIndicator", enabled: true },
    ];

    property <int> demo-default-selected: 0;
    property <int> demo-nav-sidebar-selected: 0;
    property <string> demo-nav-last: "";

    changed scenario-ix => {
        root.demo-nav-last = "";
        root.demo-default-selected = 0;
        root.demo-nav-sidebar-selected = 0;
    }

    property <string> scenario-title:
        root.scenario-ix == 0 ? "Default"
        : root.scenario-ix == 1 ? "WithSubItems"
        : root.scenario-ix == 2 ? "WithNestedSubItems"
        : root.scenario-ix == 3 ? "WithInactiveItems"
        : root.scenario-ix == 4 ? "WithGroup"
        : root.scenario-ix == 5 ? "WithDescription"
        : "SidebarCurrentIndicator";

    property <string> scenario-description:
        root.scenario-ix == 0
        ? "Three top-level items; first row is current (upstream `aria-current` → active styling)."
        : root.scenario-ix == 1
        ? "Parent with SubNav: two nested rows, first nested row is current; parent starts expanded."
        : root.scenario-ix == 2
        ? "SubNav nesting and chevron expand/collapse; activation path is dot-separated indices (depth capped at four levels in Slint)."
        : root.scenario-ix == 3
        ? "Inactive top-level row plus inactive nested row with `inactiveText` (upstream `WithInactiveItems`)."
        : root.scenario-ix == 4
        ? "Two groups with filled and subtle headings and a divider between groups."
        : root.scenario-ix == 5
        ? "Leading icons with inline and block descriptions (upstream `WithDescription`)."
        : "Product sidebar pattern: `sidebar-current-indicator` adds the blue vertical bar; current uses selected row chrome without double accent.";

    property <[NavListItem]> items-default: [
        {
            data: {
                label: "Item 1",
                current: demo-default-selected == 0,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Item 2",
                current: demo-default-selected == 1,
                inactive: false,
                inactive-text: "",
