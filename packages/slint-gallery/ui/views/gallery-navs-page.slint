    property <[NavListItem]> items-sidebar: [
        {
            data: {
                label: "Item 1",
                current: demo-nav-sidebar-selected == 0,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Item 2",
                current: demo-nav-sidebar-selected == 1,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
        {
            data: {
                label: "Item 3",
                current: demo-nav-sidebar-selected == 2,
                inactive: false,
                inactive-text: "",
                description: "",
                has-leading-visual: false,
                leading-icon: Icons.dot_fill,
                trailing-text: "",
            },
            children: [],
            subnav-default-open: false,
        },
    ];

    property <[NavListItem]> preview-items:
        root.scenario-ix == 0 ? root.items-default
        : root.scenario-ix == 1 ? root.items-with-sub-items
        : root.scenario-ix == 2 ? root.items-nested-subnav
        : root.scenario-ix == 3 ? root.items-inactive
        : root.scenario-ix == 4 ? [] : root.scenario-ix == 5 ? root.items-with-description : root.items-sidebar;

    property <[NavListGroup]> preview-groups: root.scenario-ix == 4 ? root.demo-nav-groups : [];

    property <bool> preview-sidebar-indicator: root.scenario-ix == 6;

    HorizontalLayout {

        VerticalLayout {
            horizontal-stretch: 1;
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "NavList — " + root.scenario-title;
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            Text {
                text: root.scenario-description;
                color: PrimerColors.fgColor-muted;
                font-size: 12px;
                wrap: word-wrap;
            }

            Text {
                text: root.demo-nav-last == "" ? "Last activation: —" : "Last activation: " + root.demo-nav-last;
                color: PrimerColors.fgColor-muted;
                font-size: 12px;
                wrap: word-wrap;
            }

            Rectangle {
                horizontal-stretch: 0;
                width: 360px;
                border-radius: LayoutTokens.borderRadius-medium;
                border-width: 1px;
                border-color: PrimerColors.borderColor-default;
                background: PrimerColors.bgColor-canvas-subtle;

                VerticalLayout {
                    padding: 8px;
                    width: 100%;

                    NavList {
                        width: 100%;
                        items: root.preview-items;
                        groups: root.preview-groups;
                        sidebar-current-indicator: root.preview-sidebar-indicator;
                        item-activated(gi, path) => {
                            root.demo-nav-last = "(" + gi + ", " + path + ")";
                            if root.scenario-ix == 0 {
                                root.demo-default-selected = path == "0"
                                    ? 0
                                    : path == "1" ? 1 : path == "2" ? 2 : root.demo-default-selected;
                            }
                            if root.scenario-ix == 6 {
                                root.demo-nav-sidebar-selected = path == "0"
                                    ? 0
                                    : path == "1" ? 1 : path == "2" ? 2 : root.demo-nav-sidebar-selected;
                            }
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "Storybook-aligned";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                Text {
                    text: "Not in this gallery: WithReactRouterLink, WithNextJsLink, WithReloads, WithTrailingAction, WithGroupExpand / Expand stories, WithGroupHeadingLinks.";
                    color: PrimerColors.fgColor-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
