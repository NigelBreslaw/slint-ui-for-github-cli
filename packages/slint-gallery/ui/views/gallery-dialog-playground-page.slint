import {
    Button,
    ButtonAlignContent,
    ButtonVariant,
    Checkbox,
    DialogBody,
    Dialog2,
    DialogFooter,
    DialogHeader,
    OverlayAlign,
    OverlayWidth,
    OverlayHeight,
    PrimerTextInput,
    Radio,
    RadioGroup,
    Select,
    SelectOption,
    StandardDialogHeader,
    ToggleSwitchSize,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryDemoOptionsSidebar,
} from "../components/gallery-demo-options-sidebar.slint";

/// **Dialogs → Playground**: one **Show dialog** button; sidebar picks **Default**, configurable **Playground**, or **Align** (top/bottom).
export component GalleryDialogsPlaygroundPage {

    property <[SelectOption]> playground-width-options: [
        { value: "small", label: "small (296px)", enabled: true },
        { value: "medium", label: "medium (320px)", enabled: true },
        { value: "large", label: "large (480px)", enabled: true },
        { value: "xlarge", label: "xlarge (640px)", enabled: true },
    ];

    property <[SelectOption]> playground-height-options: [
        { value: "auto", label: "auto (viewport cap)", enabled: true },
        { value: "small", label: "small (480px max)", enabled: true },
        { value: "large", label: "large (640px max)", enabled: true },
    ];

    property <int> playground-width-index: 1;
    property <int> playground-height-index: 0;

    property <bool> playground-show-header: true;
    property <bool> playground-show-footer: true;
    property <string> playground-title-text: "Playground";
    property <string> playground-subtitle-text: "";

    property <OverlayWidth> playground-width-enum:
        playground-width-index == 0 ? OverlayWidth.small : playground-width-index == 1 ? OverlayWidth.medium : playground-width-index == 2 ? OverlayWidth.large : OverlayWidth.xlarge;

    property <OverlayHeight> playground-height-enum:
        playground-height-index == 0 ? OverlayHeight.auto : playground-height-index == 1 ? OverlayHeight.small : OverlayHeight.large;

    property <[SelectOption]> align-vertical-options: [
        { value: "center", label: "center", enabled: true },
        { value: "top", label: "top", enabled: true },
        { value: "bottom", label: "bottom", enabled: true },
    ];

    property <int> align-vertical-index: 0;

    property <OverlayAlign> align-vertical-preset:
        align-vertical-index == 0 ? OverlayAlign.center : align-vertical-index == 1 ? OverlayAlign.top : OverlayAlign.bottom;

    vertical-stretch: 1;

    HorizontalLayout {

        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "Dialog";
                color: PrimerColors.fgColor-default;
                font-size: 22px;
                font-weight: 600;
            }

            Button {
                align-content: ButtonAlignContent.start;
                label: "Show dialog";
                clicked => {
                    playground-dialog.show();
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Demo";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                VerticalLayout {
                    spacing: 12px;
                    alignment: start;

                    Select {
                        horizontal-stretch: 1;
                        label-text: "Width";
                        placeholder: "Choose width…";
                        options: root.playground-width-options;
                        selected-index <=> playground-width-index;
                        validation-status: ValidationStatus.none;
                        selected-changed(_idx) => {
                        }
                    }

                    Select {
                        horizontal-stretch: 1;
                        label-text: "Height";
                        placeholder: "Choose height…";
                        options: root.playground-height-options;
                        selected-index <=> playground-height-index;
                        validation-status: ValidationStatus.none;
                        selected-changed(_idx) => {
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Checkbox {
                            label: "Show header";
                            checked <=> playground-show-header;
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Checkbox {
                            label: "Show footer";
                            checked <=> playground-show-footer;
                        }
                    }

                    PrimerTextInput {
                        horizontal-stretch: 1;
                        label-text: "Title";
                        placeholder: "Dialog title…";
                        text <=> playground-title-text;
                        validation-status: ValidationStatus.none;
                        edited(_) => {
                        }
                    }

                    PrimerTextInput {
                        horizontal-stretch: 1;
                        label-text: "Subtitle";
                        placeholder: "Optional subtitle…";
                        text <=> playground-subtitle-text;
                        validation-status: ValidationStatus.none;
                        edited(_) => {
                        }
                    }

                    Select {
                        label-text: "Vertical align";
                        placeholder: "Choose top or bottom…";
                        options: root.align-vertical-options;
                        selected-index <=> align-vertical-index;
                        validation-status: ValidationStatus.none;
                        selected-changed(_idx) => {
                        }
                    }
                }
            }
        }
    }

    playground-dialog := Dialog2 {
        width-preset: root.playground-width-enum;
        height-preset: root.playground-height-enum;
        align-preset: root.align-vertical-preset;

        VerticalLayout {

            if root.playground-show-header: StandardDialogHeader {
                title: root.playground-title-text;
                subtitle: root.playground-subtitle-text;
                close-requested => {
                    playground-dialog.close();
                }
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            if root.playground-show-footer: DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => {
                        playground-dialog.close();
                    }
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                    }
                }
            }
        }
    }
}
