            leading-file-icon: Icons.file,
            interactive: true,
            is-skeleton: false,
            has-secondary-actions: false,
            secondary-actions-badge: "",
            loading-children-badge: "",
        },
    ];

    property <[TreeViewRow]> async-error-rows:
        !async-e-expanded ? async-e-collapsed
        : async-e-step == 4 ? async-e-done
        : async-e-loading;

    property <[TreeViewRow]> empty-dir-rows: [
        {
            id: "ed",
            label: "empty-folder",
            level: 1,
            has-children: true,
            expanded: true,
            current: false,
            leading-is-directory: true,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
            is-skeleton: false,
            has-secondary-actions: false,
            secondary-actions-badge: "",
            loading-children-badge: "",
        },
        {
            id: "ed-h",
            label: "No files in this directory.",
            level: 2,
            has-children: false,
            expanded: false,
            current: false,
            leading-is-directory: false,
            has-leading-visual: false,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
            is-skeleton: false,
            has-secondary-actions: false,
            secondary-actions-badge: "",
            loading-children-badge: "",
        },
    ];

    Timer {
        interval: 750ms;
        running: async-s-timer-arm;
        triggered => {
            async-s-timer-arm = false;
            async-s-children-ready = true;
        }
    }

    Timer {
        interval: 750ms;
        running: async-w-timer-arm;
        triggered => {
            async-w-timer-arm = false;
            async-w-children-ready = true;
        }
    }

    Timer {
        interval: 650ms;
        running: async-e-timer-arm;
        triggered => {
            async-e-timer-arm = false;
            if async-e-step == 1 {
                async-e-step = 2;
                async-e-dialog-open = true;
            } else if async-e-step == 3 {
                async-e-step = 4;
            }
        }
    }

    VerticalLayout {
        spacing: 8px;
        alignment: start;

        Text {
            text: "Tree view";
            font-size: 20px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        Text {
            text: "Flat **[TreeViewRow]** model: **SubTree**-style loading (skeleton + count badge), **AsyncError** + retry **Dialog**, **AnchoredOverlay** + **ActionList** for kebab menus, leading-action column, multiline labels (**truncate = false**).";
            wrap: word-wrap;
            width: 100%;
            font-size: 13px;
            color: PrimerColors.fgColor-muted;
        }
    }

    // --- Default (Components/TreeView)
    TreeViewSectionHeading { title: "Default"; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            accessible-name: "Source files";
            rows: default-rows;
            row-toggle-requested(id) => {
                if id == "src" {
                    def-src = !def-src;
                } else if id == "components" {
                    def-components = !def-components;
                } else if id == "folder" {
                    def-folder = !def-folder;
                }
            }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- TrailingActions (Examples)
    TreeViewSectionHeading {
        title: "TrailingActions";
        note: "Kebab opens **AnchoredOverlay** + **ActionList**; count badge on the first row. **Open sample dialog** exercises a nested **Dialog**.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            horizontal-stretch: 1;
            rows: trailing-demo-rows;
            flat: true;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, ax, ay, aw, ah) => {
                tv-trailing-menu-ax = ax;
                tv-trailing-menu-ay = ay;
                tv-trailing-menu-aw = aw;
                tv-trailing-menu-ah = ah;
                tv-trailing-menu-open = true;
            }
        }

        tv-trailing-overlay := AnchoredOverlay {
            open <=> tv-trailing-menu-open;
            anchor-abs-x: tv-trailing-menu-ax;
            anchor-abs-y: tv-trailing-menu-ay;
            anchor-width: tv-trailing-menu-aw;
            anchor-height: tv-trailing-menu-ah;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.end;
            shrink-wrap: true;
            panel-width: 220px;
            close-requested => {
                tv-trailing-menu-open = false;
            }

            ActionList {
                lines: tv-trailing-menu-lines;
                item-activated(ix) => {
                    tv-trailing-menu-open = false;
                    if ix == 0 {
                        tv-trailing-sample-dialog-open = true;
                    }
                }
            }
        }

        tv-trailing-sample-dialog := Dialog {
            open <=> tv-trailing-sample-dialog-open;
            width-preset: DialogWidthPreset.small;
            on-close(_gesture) => {
                tv-trailing-sample-dialog-open = false;
            }

            VerticalLayout {
                alignment: stretch;

                StandardDialogHeader {
                    title: "Tree item action";
                    close-requested => tv-trailing-sample-dialog.on-close("close-button");
                }

                DialogBody {
                    Text {
                        text: "This dialog was opened from the tree row overflow menu (Storybook **TrailingActions** echo).";
                        wrap: word-wrap;
                        color: PrimerColors.fgColor-default;
                        font-size: 14px;
                    }
                }

                DialogFooter {
                    Button {
                        label: "Close";
                        clicked => tv-trailing-sample-dialog.on-close("close-button");
                    }
                }
            }
        }

    }

    // --- Files
    TreeViewSectionHeading { title: "Files"; note: "truncate = false (long paths wrap)."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            truncate: false;
            rows: files-rows;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- FilesChanged
    TreeViewSectionHeading { title: "FilesChanged"; note: "Diff trailing visuals."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            truncate: false;
            rows: files-changed-rows;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- Controlled
    TreeViewSectionHeading { title: "Controlled"; note: "Discrete expand-all / partial / collapse snapshots."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            HorizontalLayout {
                spacing: 8px;
                Button {
                    label: "Collapse all";
                    clicked => {
                        controlled-mode = 0;
                    }
                }
                Button {
                    label: "Partial";
                    clicked => {
                        controlled-mode = 1;
                    }
                }
                Button {
                    label: "Expand all";
                    variant: ButtonVariant.primary;
                    clicked => {
                        controlled-mode = 2;
                    }
                }
            }

            PrimerTreeView {
                rows: controlled-rows;
                row-toggle-requested(_) => { }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }
    }

    // --- AsyncSuccess, AsyncWithCount, AsyncError, EmptyDirectories, NestedTrees
    TreeViewSectionHeading {
        title: "AsyncSuccess · AsyncWithCount · AsyncError · EmptyDirectories · NestedTrees";
        note: "Host rebuilds **`rows`**; **Timer** drives loading → done (or error + **Dialog** + retry).";
    }

    VerticalLayout {
        spacing: 20px;
        alignment: start;
        width: 100%;

        Text {
            text: "AsyncSuccess";
            font-size: 12px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 280px;
            max-width: 420px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            PrimerTreeView {
                accessible-name: "Async success";
                rows: async-success-rows;
                row-toggle-requested(id) => {
                    if id == "as-root" {
                        if !async-s-expanded {
                            async-s-expanded = true;
                            async-s-children-ready = false;
                            async-s-timer-arm = true;
                        } else {
                            async-s-expanded = false;
                            async-s-children-ready = false;
                            async-s-timer-arm = false;
                        }
                    }
                }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }

        Text {
            text: "AsyncWithCount (skeleton nodes + count badge)";
            font-size: 12px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 280px;
            max-width: 420px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            PrimerTreeView {
                accessible-name: "Async with count";
                rows: async-with-count-rows;
                row-toggle-requested(id) => {
                    if id == "aw-root" {
                        if !async-w-expanded {
                            async-w-expanded = true;
                            async-w-children-ready = false;
                            async-w-timer-arm = true;
                        } else {
                            async-w-expanded = false;
                            async-w-children-ready = false;
                            async-w-timer-arm = false;
                        }
                    }
                }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }

        Text {
            text: "AsyncError (retry)";
            font-size: 12px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 280px;
            max-width: 420px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            PrimerTreeView {
                accessible-name: "Async error";
                rows: async-error-rows;
                row-toggle-requested(id) => {
                    if id == "ae-root" {
                        if !async-e-expanded {
                            async-e-expanded = true;
                            async-e-step = 1;
                            async-e-dialog-open = false;
                            async-e-timer-arm = true;
                        } else {
                            async-e-expanded = false;
                            async-e-step = 0;
                            async-e-dialog-open = false;
                            async-e-timer-arm = false;
                        }
                    }
                }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }

        Text {
            text: "EmptyDirectories";
            font-size: 12px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 280px;
            max-width: 420px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            PrimerTreeView {
                rows: empty-dir-rows;
                row-toggle-requested(_) => { }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }

        Text {
            text: "NestedTrees";
            font-size: 12px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            Rectangle {
                width: 260px;
                background: PrimerColors.bgColor-default;
                border-radius: LayoutTokens.borderRadius-medium;
                border-width: LayoutTokens.table-border-width;
                border-color: PrimerColors.borderColor-default;

                VerticalLayout {
                    padding: 4px;
                    Text {
                        text: "Inner tree";
                        font-size: 11px;
                        font-weight: 600;
                        color: PrimerColors.fgColor-muted;
                    }
                    PrimerTreeView {
                        rows: flat-rows;
                        flat: true;
                        row-toggle-requested(_) => { }
                        row-secondary-actions-requested(_, _, _, _, _) => { }
                    }
                }
            }

            Rectangle {
                width: 260px;
                background: PrimerColors.bgColor-default;
                border-radius: LayoutTokens.borderRadius-medium;
                border-width: LayoutTokens.table-border-width;
                border-color: PrimerColors.borderColor-default;

                VerticalLayout {
                    padding: 4px;
                    Text {
                        text: "Outer tree";
                        font-size: 11px;
                        font-weight: 600;
                        color: PrimerColors.fgColor-muted;
                    }
                    PrimerTreeView {
                        rows: default-rows;
                        row-toggle-requested(id) => {
                            if id == "src" {
                                def-src = !def-src;
                            } else if id == "components" {
                                def-components = !def-components;
                            } else if id == "folder" {
                                def-folder = !def-folder;
                            }
                        }
                        row-secondary-actions-requested(_, _, _, _, _) => { }
                    }
                }
            }
        }
    }

    // --- NestedScrollContainer (scaled)
    TreeViewSectionHeading {
        title: "NestedScrollContainer";
        note: "Scaled: 8 children in a fixed-height flickable (Storybook: 100×10).";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        height: 200px;
        background: PrimerColors.bgColor-inset;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;
        clip: true;

        flick := Flickable {
            width: parent.width;
            height: parent.height;
            viewport-width: parent.width;
            viewport-height: tree-ns.preferred-height;

            tree-ns := PrimerTreeView {
                width: flick.width;
                rows: nested-scroll-rows;
                row-toggle-requested(_) => { }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }
    }

    // --- StressTest (scaled)
    TreeViewSectionHeading {
        title: "StressTest";
        note: "Scaled: 12 visible rows (Storybook: 1000×100). Prefer ListView virtualization for real workloads.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            rows: stress-rows;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- ContainIntrinsicSize (scaled + note)
    TreeViewSectionHeading {
        title: "ContainIntrinsicSize";
        note: "Web content-visibility has no Slint equivalent; fixed row height + bounded scroll approximate large subtrees.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            rows: intrinsic-rows;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- InitialFocus
    TreeViewSectionHeading {
        title: "InitialFocus";
        note: "Focus order before/after the tree; default-focus wiring is host-specific.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            Button {
                label: "Before tree";
            }
            PrimerTreeView {
                truncate: false;
                rows: files-rows;
                row-toggle-requested(_) => { }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
            Button {
                label: "After tree";
            }
        }
    }

    // --- FocusManagement
    TreeViewSectionHeading {
        title: "FocusManagement";
        note: "Kebab in-row (**TrailingActions** pattern); separate **AnchoredOverlay** for this demo.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        fm-focus-overlay := AnchoredOverlay {
            open <=> fm-focus-menu-open;
            anchor-abs-x: fm-focus-menu-ax;
            anchor-abs-y: fm-focus-menu-ay;
            anchor-width: fm-focus-menu-aw;
            anchor-height: fm-focus-menu-ah;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.end;
            shrink-wrap: true;
            panel-width: 200px;
            close-requested => {
                fm-focus-menu-open = false;
            }

            ActionList {
                lines: tv-trailing-menu-lines;
                item-activated(_ix) => {
                    fm-focus-menu-open = false;
                }
            }
        }

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Adjacent standalone kebab (story chrome) vs in-tree kebab:";
                    vertical-alignment: center;
                    color: PrimerColors.fgColor-default;
                }
                IconButton {
                    icon-source: Icons.kebab_horizontal;
                }
            }
            PrimerTreeView {
                rows: trailing-demo-rows;
                flat: true;
                row-toggle-requested(_) => { }
                row-secondary-actions-requested(_, ax, ay, aw, ah) => {
                    fm-focus-menu-ax = ax;
                    fm-focus-menu-ay = ay;
                    fm-focus-menu-aw = aw;
                    fm-focus-menu-ah = ah;
                    fm-focus-menu-open = true;
                }
            }
        }
    }

    // --- WithoutIndentation (flat)
    TreeViewSectionHeading { title: "WithoutIndentation"; note: "Root flat — no indent or chevron column."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            flat: true;
            rows: flat-rows;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- MultilineItems
    TreeViewSectionHeading { title: "MultilineItems"; note: "truncate = false; second row adds leading-action column + wrap."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            truncate: false;
            rows: multiline-rows;
            row-toggle-requested(_) => { }
            row-secondary-actions-requested(_, _, _, _, _) => { }
        }
    }

    // --- LeadingAction (Private story)
    TreeViewSectionHeading {
        title: "LeadingAction";
        note: "Leading-action column + issue icons (grabber is non-interactive here).";
    }
    VerticalLayout {
        spacing: 12px;
        alignment: start;
        width: 100%;
        max-width: 560px;

        Banner {
            variant: BannerVariant.warning;
            title: "Do not grab items";
            description: "Slint port echoes the upstream warning banner; drag-and-drop is out of scope.";
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            PrimerTreeView {
                rows: leading-action-rows;
                row-toggle-requested(_) => { }
                row-secondary-actions-requested(_, _, _, _, _) => { }
            }
        }
    }

    async-e-dialog := Dialog {
        open <=> async-e-dialog-open;
        width-preset: DialogWidthPreset.small;
        on-close(_gesture) => {
            async-e-dialog-open = false;
            async-e-expanded = false;
            async-e-step = 0;
            async-e-timer-arm = false;
        }

        VerticalLayout {
            alignment: stretch;

            StandardDialogHeader {
                title: "Could not load folder";
                close-requested => async-e-dialog.on-close("close-button");
            }

            DialogBody {
                Text {
                    text: "A simulated network error occurred while loading children (Storybook **AsyncError**).";
                    wrap: word-wrap;
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                }
            }

            DialogFooter {
                Button {
                    label: "Retry";
                    variant: ButtonVariant.primary;
                    clicked => {
                        async-e-dialog-open = false;
                        async-e-step = 3;
                        async-e-timer-arm = true;
                    }
                }
                Button {
                    label: "Close";
                    clicked => async-e-dialog.on-close("close-button");
                }
            }
        }
    }
}
