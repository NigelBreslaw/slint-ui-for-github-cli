            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
            is-skeleton: false,
            has-secondary-actions: false,
            secondary-actions-badge: "",
            loading-children-badge: "",
        },
    ];

    property <[TreeViewRow]> async-with-count-rows:
        !async-w-expanded ? async-w-collapsed : !async-w-children-ready ? async-w-loading : async-w-done;

    in-out property <bool> async-e-expanded: false;
    in-out property <int> async-e-step: 0;
    property <bool> async-e-timer-arm: false;
    in-out property <bool> async-e-dialog-open: false;

    property <[TreeViewRow]> async-e-collapsed: [
        {
            id: "ae-root",
            label: "failing-fetch",
            level: 1,
            has-children: true,
            expanded: false,
            current: false,
            leading-is-directory: true,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
            is-skeleton: false,
            has-secondary-actions: false,
            secondary-actions-badge: "",
            loading-children-badge: "",
        },
    ];

    property <[TreeViewRow]> async-e-loading: [
        {
