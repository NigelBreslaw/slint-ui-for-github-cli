// One scroll — sections mirror Storybook **Components/TreeView** (see `TreeView/UPSTREAM_INVENTORY.md`). Heavy stories are scaled.

import {
    ActionList,
    ActionListDescriptionLayout,
    ActionListLine,
    ActionListLineKind,
    ActionListRowVariant,
    AnchoredOverlay,
    AnchoredOverlayAlign,
    AnchoredOverlaySide,
    Banner,
    BannerVariant,
    Button,
    ButtonVariant,
    Dialog,
    DialogBody,
    DialogFooter,
    DialogWidthPreset,
    IconButton,
    Icons,
    PrimerTreeView,
    StandardDialogHeader,
    TreeViewRow,
    TreeViewTrailingVisual,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";

component TreeViewSectionHeading {
    in property <string> title;
    in property <string> note: "";

    VerticalLayout {
        spacing: 4px;
        alignment: start;

        Text {
            text: root.title;
            font-size: 14px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        if root.note != "": Text {
            text: root.note;
            wrap: word-wrap;
            width: 100%;
            font-size: 12px;
            color: PrimerColors.fgColor-muted;
        }
    }
}

export component GalleryTreeViewPage inherits VerticalLayout {
    spacing: 28px;
    alignment: start;
    padding: 24px;

    /// **Controlled** — three discrete expansion snapshots (host would rebuild a flat model).
    in-out property <int> controlled-mode: 2;

