    property <[TreeViewRow]> intrinsic-rows: [
        {
            id: "i0",
            label: "root-a",
            level: 1,
            has-children: true,
            expanded: true,
            current: false,
            leading-is-directory: true,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
        },
        {
            id: "i1",
            label: "leaf-1",
            level: 2,
            has-children: false,
            expanded: false,
            current: false,
            leading-is-directory: false,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
        },
        {
            id: "i2",
            label: "leaf-2",
            level: 2,
            has-children: false,
            expanded: false,
            current: false,
            leading-is-directory: false,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
        },
        {
            id: "i3",
            label: "leaf-3",
            level: 2,
            has-children: false,
            expanded: false,
            current: false,
            leading-is-directory: false,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.none,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
        },
    ];

    property <[TreeViewRow]> multiline-rows: [
        {
            id: "m1",
            label: "Short row",
            level: 1,
            has-children: false,
            expanded: false,
            current: false,
            leading-is-directory: false,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.diff-added,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
        },
        {
            id: "m2",
            label: "Very long label that should wrap across multiple lines when truncate is false in the tree view root",
            level: 1,
            has-children: false,
            expanded: false,
            current: false,
            leading-is-directory: false,
            has-leading-visual: true,
            trailing: TreeViewTrailingVisual.diff-modified,
            has-leading-action: false,
            show-leading-action-icon: false,
            leading-action-icon: Icons.dot_fill,
            leading-file-icon: Icons.file,
            interactive: true,
        },
    ];

    VerticalLayout {
        spacing: 8px;
        alignment: start;

        Text {
            text: "Tree view";
            font-size: 20px;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
        }

        Text {
            text: "Flat row model + Primer tokens. Async, error dialogs, and secondary-actions overlays are follow-up PRs.";
            wrap: word-wrap;
            width: 100%;
            font-size: 13px;
            color: PrimerColors.fgColor-muted;
        }
    }

    // --- Default (Components/TreeView)
    TreeViewSectionHeading { title: "Default"; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            accessible-name: "Source files";
            rows: default-rows;
            row-toggle-requested(id) => {
                if id == "src" {
                    def-src = !def-src;
                } else if id == "components" {
                    def-components = !def-components;
                } else if id == "folder" {
                    def-folder = !def-folder;
                }
            }
        }
    }

    // --- TrailingActions (Examples)
    TreeViewSectionHeading {
        title: "TrailingActions";
        note: "Storybook: secondary actions, dialogs, and count buttons — ActionList / Dialog wiring in a later PR.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            HorizontalLayout {
                spacing: 8px;
                IconButton {
                    icon-source: Icons.gear_24;
                }
                IconButton {
                    icon-source: Icons.issue_opened;
                }
                Text {
                    text: "Placeholder actions row (mirrors story chrome).";
                    vertical-alignment: center;
                    color: PrimerColors.fgColor-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            PrimerTreeView {
                rows: flat-rows;
                flat: true;
                row-toggle-requested(_) => { }
            }
        }
    }

    // --- Files
    TreeViewSectionHeading { title: "Files"; note: "truncate = false (long paths wrap)."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            truncate: false;
            rows: files-rows;
            row-toggle-requested(_) => { }
        }
    }

    // --- FilesChanged
    TreeViewSectionHeading { title: "FilesChanged"; note: "Diff trailing visuals."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            truncate: false;
            rows: files-changed-rows;
            row-toggle-requested(_) => { }
        }
    }

    // --- Controlled
    TreeViewSectionHeading { title: "Controlled"; note: "Discrete expand-all / partial / collapse snapshots."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            HorizontalLayout {
                spacing: 8px;
                Button {
                    label: "Collapse all";
                    clicked => {
                        controlled-mode = 0;
                    }
                }
                Button {
                    label: "Partial";
                    clicked => {
                        controlled-mode = 1;
                    }
                }
                Button {
                    label: "Expand all";
                    variant: ButtonVariant.primary;
                    clicked => {
                        controlled-mode = 2;
                    }
                }
            }

            PrimerTreeView {
                rows: controlled-rows;
                row-toggle-requested(_) => { }
            }
        }
    }

    // --- AsyncSuccess, AsyncWithCount, AsyncError, EmptyDirectories, NestedTrees
    TreeViewSectionHeading {
        title: "AsyncSuccess · AsyncWithCount · AsyncError · EmptyDirectories · NestedTrees";
        note: "SubTree loading / skeleton count / error dialog / empty leaf / nested inner tree — host-driven row rebuild + dialogs in follow-up PRs.";
    }
    Text {
        text: "Use timers and flat row insertion in the gallery host to mirror Storybook; the row chrome above is shared.";
        wrap: word-wrap;
        width: 100%;
        font-size: 13px;
        color: PrimerColors.fgColor-muted;
    }

    HorizontalLayout {
        spacing: 16px;
        alignment: start;

        Rectangle {
            width: 260px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            VerticalLayout {
                padding: 4px;
                Text {
                    text: "Inner tree (NestedTrees echo)";
                    font-size: 11px;
                    font-weight: 600;
                    color: PrimerColors.fgColor-muted;
                }
                PrimerTreeView {
                    rows: flat-rows;
                    flat: true;
                    row-toggle-requested(_) => { }
                }
            }
        }

        Rectangle {
            width: 260px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            VerticalLayout {
                padding: 4px;
                Text {
                    text: "Outer tree";
                    font-size: 11px;
                    font-weight: 600;
                    color: PrimerColors.fgColor-muted;
                }
                PrimerTreeView {
                    rows: default-rows;
                    row-toggle-requested(id) => {
                        if id == "src" {
                            def-src = !def-src;
                        } else if id == "components" {
                            def-components = !def-components;
                        } else if id == "folder" {
                            def-folder = !def-folder;
                        }
                    }
                }
            }
        }
    }

    // --- NestedScrollContainer (scaled)
    TreeViewSectionHeading {
        title: "NestedScrollContainer";
        note: "Scaled: 8 children in a fixed-height flickable (Storybook: 100×10).";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        height: 200px;
        background: PrimerColors.bgColor-inset;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;
        clip: true;

        flick := Flickable {
            width: parent.width;
            height: parent.height;
            viewport-width: parent.width;
            viewport-height: tree-ns.preferred-height;

            tree-ns := PrimerTreeView {
                width: flick.width;
                rows: nested-scroll-rows;
                row-toggle-requested(_) => { }
            }
        }
    }

    // --- StressTest (scaled)
    TreeViewSectionHeading {
        title: "StressTest";
        note: "Scaled: 12 visible rows (Storybook: 1000×100). Prefer ListView virtualization for real workloads.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            rows: stress-rows;
            row-toggle-requested(_) => { }
        }
    }

    // --- ContainIntrinsicSize (scaled + note)
    TreeViewSectionHeading {
        title: "ContainIntrinsicSize";
        note: "Web content-visibility has no Slint equivalent; fixed row height + bounded scroll approximate large subtrees.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            rows: intrinsic-rows;
            row-toggle-requested(_) => { }
        }
    }

    // --- InitialFocus
    TreeViewSectionHeading {
        title: "InitialFocus";
        note: "Focus order before/after the tree; default-focus wiring is host-specific.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            Button {
                label: "Before tree";
            }
            PrimerTreeView {
                truncate: false;
                rows: files-rows;
                row-toggle-requested(_) => { }
            }
            Button {
                label: "After tree";
            }
        }
    }

    // --- FocusManagement
    TreeViewSectionHeading {
        title: "FocusManagement";
        note: "Kebab beside labels: full parity uses tabIndex -1 on trailing controls in the host.";
    }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Row with adjacent menu:";
                    vertical-alignment: center;
                    color: PrimerColors.fgColor-default;
                }
                IconButton {
                    icon-source: Icons.kebab_horizontal;
                }
            }
            PrimerTreeView {
                rows: flat-rows;
                flat: true;
                row-toggle-requested(_) => { }
            }
        }
    }

    // --- WithoutIndentation (flat)
    TreeViewSectionHeading { title: "WithoutIndentation"; note: "Root flat — no indent or chevron column."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            flat: true;
            rows: flat-rows;
            row-toggle-requested(_) => { }
        }
    }

    // --- MultilineItems
    TreeViewSectionHeading { title: "MultilineItems"; note: "truncate = false."; }
    Rectangle {
        horizontal-stretch: 1;
        min-width: 320px;
        max-width: 560px;
        background: PrimerColors.bgColor-default;
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;

        PrimerTreeView {
            truncate: false;
            rows: multiline-rows;
            row-toggle-requested(_) => { }
        }
    }

    // --- LeadingAction (Private story)
    TreeViewSectionHeading {
        title: "LeadingAction";
        note: "Leading-action column + issue icons (grabber is non-interactive here).";
    }
    VerticalLayout {
        spacing: 12px;
        alignment: start;
        width: 100%;
        max-width: 560px;

        Banner {
            variant: BannerVariant.warning;
            title: "Do not grab items";
            description: "Slint port echoes the upstream warning banner; drag-and-drop is out of scope.";
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 320px;
            background: PrimerColors.bgColor-default;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: LayoutTokens.table-border-width;
            border-color: PrimerColors.borderColor-default;

            PrimerTreeView {
                rows: leading-action-rows;
                row-toggle-requested(_) => { }
            }
        }
    }
}
