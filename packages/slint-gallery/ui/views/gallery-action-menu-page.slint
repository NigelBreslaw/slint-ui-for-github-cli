        { kind: ActionList2LineKind.row, label: "Cut", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
        { kind: ActionList2LineKind.row, label: "Copy", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
        { kind: ActionList2LineKind.row, label: "Paste", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
    ];

    property <[ActionList2Line]> lines-submenu-paste: [
        { kind: ActionList2LineKind.row, label: "Paste plain text", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
        { kind: ActionList2LineKind.row, label: "Paste formulas", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
        { kind: ActionList2LineKind.row, label: "Paste with formatting", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
    ];

    property <[ActionList2Line]> lines-submenu-from: [
        { kind: ActionList2LineKind.row, label: "Current clipboard", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
        { kind: ActionList2LineKind.row, label: "History", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
        { kind: ActionList2LineKind.row, label: "Another device", row-variant: ActionList2RowVariant.default, row-size: ActionList2RowSize.medium, disabled: false, has-leading-avatar: false, avatar-source: Icons.dot_fill, has-leading-visual: false, leading-icon: Icons.dot_fill, description: "", description-layout: ActionList2DescriptionLayout.none, truncate-inline-description: false, trailing-text: "", inactive-text: "", show-trailing-loading: false, active: false, section-heading-variant: ActionList2SectionHeadingVariant.subtle },
    ];

    property <[ActionList2Line]> delayed-lines-view: root.delayed-copy-done ? root.lines-delayed-after : root.lines-delayed-before;
    delayed-close-timer := Timer {
        interval: 700ms;
        running: false;
        triggered() => {
            root.delayed-copy-done = false;
            root.delayed-menu-open = false;
            self.stop();
        }
    }

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: "ActionMenu";
                color: PrimerColors.fgColor-default;
                font-size: 22px;
                font-weight: 600;
            }

            if root.scenario-ix == 9: VerticalLayout {
                spacing: 12px;
                alignment: start;

                Text {
                    text: "ShortcutMenu: global Shift+C is not wired in Slint; use the button. Clicks outside dismiss the overlay (no ignoreClickRefs).";
                    color: PrimerColors.fgColor-attention;
                    font-size: LayoutTokens.text-body-size-small;
                    wrap: word-wrap;
                }

                PrimerTextInput {
                    horizontal-stretch: 1;
                    label-text: "Sample field";
                    placeholder: "Type here…";
                    text <=> shortcut-field;
                    validation-status: ValidationStatus.none;
                    edited(_t) => {
                    }
                }

                Button {
                    label: "Open menu (simulated shortcut)";
                    clicked => {
                        root.shortcut-menu-open = true;
                    }
                }

                shortcut-am := ActionMenu {
                    button-label: "Anchor";
                    open <=> shortcut-menu-open;
                    width-preset: root.overlay-width;
                    ActionList2 {
                        list-variant: ALVariant.inset;
                        ActionList2Lines {
                            list-role: ActionList2ListRole.menu;
                            lines: root.lines-default;
                            selection-mode: ActionList2SelectionMode.none;
                            item-activated(ix) => {
                                root.last-action = "Shortcut row " + ix;
                                root.shortcut-menu-open = false;
                            }
                        }
                    }
                }
            }

            if root.scenario-ix == 6: VerticalLayout {
                spacing: 12px;
                alignment: start;

                sub-root := ActionMenu {
                    button-label: "Edit";
                    width-preset: root.overlay-width;
                    VerticalLayout {
                        spacing: 0px;
                        alignment: start;
                        ActionList2 {
                            list-variant: ALVariant.inset;
                            ActionList2Lines {
                                list-role: ActionList2ListRole.menu;
                                lines: root.lines-submenu-root;
                                selection-mode: ActionList2SelectionMode.none;
                                item-activated(ix) => {
                                    root.last-action = "Submenu root " + ix;
                                }
                            }
                        }

                        sub-paste := ActionMenu {
                            button-variant: ButtonVariant.invisible;
                            button-label: "Paste special";
                            button-has-trailing-icon: true;
                            button-trailing-icon: Icons.chevron_right;
                            side: AnchoredOverlaySide.outside_right;
                            width-preset: AnchoredOverlayWidth.auto;
                            VerticalLayout {
                                width: submenu-paste-list.preferred-width;
                                submenu-paste-list := ActionList2 {
                                    list-variant: ALVariant.inset;
                                    ActionList2Lines {
                                        list-role: ActionList2ListRole.menu;
                                        lines: root.lines-submenu-paste;
                                        selection-mode: ActionList2SelectionMode.none;
                                        item-activated(ix) => {
                                            root.last-action = "Paste special " + ix;
                                        }
                                    }
                                }

                                sub-from := ActionMenu {
                                    button-variant: ButtonVariant.invisible;
                                    button-label: "Paste from";
                                    button-has-trailing-icon: true;
                                    button-trailing-icon: Icons.chevron_right;
                                    side: AnchoredOverlaySide.outside_right;
                                    width-preset: AnchoredOverlayWidth.auto;
                                    VerticalLayout {
                                        width: submenu-from-list.preferred-width;
                                        submenu-from-list := ActionList2 {
                                            list-variant: ALVariant.inset;
                                            ActionList2Lines {
                                                list-role: ActionList2ListRole.menu;
                                                lines: root.lines-submenu-from;
                                                selection-mode: ActionList2SelectionMode.none;
                                                item-activated(ix) => {
                                                    root.last-action = "Paste from " + ix;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if root.scenario-ix == 10: ActionMenu {
                button-label: "Group items by";
                width-preset: root.overlay-width;
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    ActionList2 {
                        list-variant: ALVariant.inset;
                        ActionList2Lines {
                            list-role: ActionList2ListRole.menu;
                            lines: root.lines-mix-single;
                            selection-mode: ActionList2SelectionMode.single;
                            selected-index <=> mix-single-ix;
                            show-dividers: true;
                            item-activated(ix) => {
                                root.mix-single-ix = ix;
                                root.last-action = "Mixed single ix " + ix;
                            }
                        }
                    }

                    ActionList2 {
                        list-variant: ALVariant.inset;
                        ActionList2Lines {
                            list-role: ActionList2ListRole.menu;
                            lines: root.lines-mix-multi;
                            selection-mode: ActionList2SelectionMode.multiple;
                            multi-selected: [root.mx0, root.mx1, root.mx2];
                            item-activated(ix) => {
                                if ix == 0 {
                                    root.mx0 = !root.mx0;
                                }
                                if ix == 1 {
                                    root.mx1 = !root.mx1;
                                }
                                if ix == 2 {
                                    root.mx2 = !root.mx2;
                                }
                                root.last-action = "Mixed multi toggled " + ix;
                            }
                        }
                    }
                }
            }

            if root.scenario-ix == 11: ActionMenu {
                button-label: "Anchor";
                open <=> delayed-menu-open;
                width-preset: root.overlay-width;
                ActionList2 {
                    list-variant: ALVariant.inset;
                    ActionList2Lines {
                        list-role: ActionList2ListRole.menu;
                        lines: root.delayed-lines-view;
                        selection-mode: ActionList2SelectionMode.none;
                        item-activated(ix) => {
                            if ix == 0 {
                                root.delayed-copy-done = true;
                                delayed-close-timer.start();
                            }
                            root.last-action = "Delayed activate " + ix;
                        }
                    }
                }
            }

            if root.scenario-ix != 6 && root.scenario-ix != 9 && root.scenario-ix != 10 && root.scenario-ix != 11: demo-am := ActionMenu {
                button-label: root.scenario-ix == 2 || root.scenario-ix == 8 ? "Milestone: pick one" : root.scenario-ix == 3 ? "Display" : "Open menu";
                side: root.overlay-side;
                width-preset: root.overlay-width;
                ActionList2 {
                    list-variant: ALVariant.inset;
                    ActionList2Lines {
                        list-role: ActionList2ListRole.menu;
                        lines: root.overlay-lines;
                        selection-mode: root.overlay-sel-mode;
                        selected-index <=> demo-sel-ix;
                        multi-selected: [root.m0, root.m1, root.m2];
                        show-dividers: root.scenario-ix == 8;
                        item-activated(ix) => {
                            root.last-action = "Activated line " + ix;
                            if root.scenario-ix == 2 || root.scenario-ix == 8 {
                                root.demo-sel-ix = ix;
                            }
                            if root.scenario-ix == 3 {
                                if ix == 0 {
                                    root.m0 = !root.m0;
                                }
                                if ix == 1 {
                                    root.m1 = !root.m1;
                                }
                                if ix == 2 {
                                    root.m2 = !root.m2;
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "Menu options";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }
            }
        }
    }
}
