// **ActionMenu** gallery — 13 upstream Storybook scenarios (see plan). Out-of-scope stories are listed in the sidebar footer.
import {
    ActionList2,
    ActionList2DescriptionLayout,
    ActionList2Line,
    ActionList2LineKind,
    ActionList2Lines,
    ActionList2ListRole,
    ActionList2RowSize,
    ActionList2RowVariant,
    ActionList2SectionHeadingVariant,
    ActionList2SelectionMode,
    ALVariant,
    ActionMenu,
    AnchoredOverlaySide,
    AnchoredOverlayWidth,
    Button,
    ButtonVariant,
    Icons,
    PrimerTextInput,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import { GalleryDemoOptionsSidebar } from "../components/gallery-demo-options-sidebar.slint";

export component GalleryActionMenuPage {
    property <int> scenario-ix: 0;

    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "LinksAndActions", enabled: true },
        { value: "2", label: "SingleSelect", enabled: true },
        { value: "3", label: "MultiSelect", enabled: true },
        { value: "4", label: "InactiveItems", enabled: true },
        { value: "5", label: "LoadingItems", enabled: true },
        { value: "6", label: "Submenus", enabled: true },
        { value: "7", label: "DisabledItems", enabled: true },
        { value: "8", label: "GroupsAndDescriptions", enabled: true },
        { value: "9", label: "ShortcutMenu", enabled: true },
        { value: "10", label: "MixedSelection", enabled: true },
        { value: "11", label: "DelayedMenuClose", enabled: true },
        { value: "12", label: "OnRightSide", enabled: true },
    ];

    property <string> last-action: "";
    property <int> demo-sel-ix: 0;
    property <bool> m0: false;
    property <bool> m1: true;
    property <bool> m2: false;

    property <int> mix-single-ix: 1;
    property <bool> mx0: true;
    property <bool> mx1: false;
    property <bool> mx2: false;

    property <bool> shortcut-menu-open: false;
    property <string> shortcut-field: "";

    property <bool> delayed-copy-done: false;
    property <bool> delayed-menu-open: false;

    changed scenario-ix => {
        root.demo-sel-ix = 0;
        root.m0 = false;
        root.m1 = true;
        root.m2 = false;
        root.mix-single-ix = 1;
        root.mx0 = true;
        root.mx1 = false;
        root.mx2 = false;
        root.shortcut-menu-open = false;
        root.delayed-copy-done = false;
        root.delayed-menu-open = false;
        root.last-action = "";
        if root.scenario-ix == 8 {
            root.demo-sel-ix = 1;
        }
    }

