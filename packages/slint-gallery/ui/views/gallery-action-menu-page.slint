        : AnchoredOverlayWidth.auto;
    property <ActionList2SelectionMode> overlay-sel-mode:
        root.scenario-ix == 2 || root.scenario-ix == 8 ? ActionList2SelectionMode.single
        : root.scenario-ix == 3 ? ActionList2SelectionMode.multiple
        : ActionList2SelectionMode.none;

