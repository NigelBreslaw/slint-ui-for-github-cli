import {
    Avatar,
    Label,
    LabelGroup,
    LabelGroupItem,
    LabelSize,
    LabelVariant,
    Size,
    SkeletonBox,
    Spinner,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import { GalleryFeedbackDemoAssets } from "../state/gallery-feedback-demo-assets.slint";
import { Palette } from "std-widgets.slint";

/// Spinner, Avatar, Label, and LabelGroup gallery demos. (Banner: see **Banner → Playground**.)
export component GalleryFeedbackPage inherits VerticalLayout {
    spacing: 28px;
    padding: 24px;

    property <[LabelGroupItem]> demo-label-group-items: [
        { text: "bug", variant: LabelVariant.danger, size: LabelSize.small },
        { text: "enhancement", variant: LabelVariant.accent, size: LabelSize.small },
        { text: "good first issue", variant: LabelVariant.success, size: LabelSize.small },
        { text: "documentation", variant: LabelVariant.secondary, size: LabelSize.small },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Spinner";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;
                Text {
                    text: "Small";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Spinner {
                    size: Size.small;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;
                Text {
                    text: "Medium";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Spinner {
                    size: Size.medium;
                 }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;
                Text {
                    text: "Large";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Spinner {
                    size: Size.large;
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "SkeletonBox";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Rectangle {
            background: Palette.color-scheme == ColorScheme.dark ? #0d1117 : #ffffff;
            border-radius: 6px;
            width: 272px;
            height: 16px;

            SkeletonBox { }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Avatar";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Primer Avatar — default size 20px, token ring + placeholder fill; sizes / square per Storybook features.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: "Placeholder (no image)";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        Avatar {
            alt-text: "Demo placeholder avatar";
        }

        Text {
            text: "Default 20px + image";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        Avatar {
            source: GalleryFeedbackDemoAssets.hubot;
            alt-text: "Hubot";
        }

        Text {
            text: "Header profile size (LayoutTokens.avatar-size-header)";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        Avatar {
            size: LayoutTokens.avatar-size-header;
            source: GalleryFeedbackDemoAssets.hubot;
            alt-text: "Profile";
        }

        Text {
            text: "Size ladder (4–64px)";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: center;
            Avatar { size: 4px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 8px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 12px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 16px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 20px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 24px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 28px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 32px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 40px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 48px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 56px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { size: 64px; source: GalleryFeedbackDemoAssets.hubot; }
        }

        Text {
            text: "Square";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: center;
            Avatar { square: true; size: 24px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { square: true; size: 40px; source: GalleryFeedbackDemoAssets.hubot; }
            Avatar { square: true; size: 48px; source: GalleryFeedbackDemoAssets.hubot; }
        }
    }

    VerticalLayout {
        spacing: 16px;
        width: 100%;

        Text {
            text: "Label";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Product metadata chips — see Primer Label at primer.style. Not the same as CounterLabel (numeric pills on buttons).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 8px;
            width: 100%;

            Text {
                text: "Style variants (small)";
                color: PrimerColors.fgColor-muted;
                font-size: 12px;
            }

            HorizontalLayout {
                spacing: 8px;

                Label { text: "Default"; variant: LabelVariant.default; size: LabelSize.small; }
                Label { text: "Primary"; variant: LabelVariant.primary; size: LabelSize.small; }
                Label { text: "Secondary"; variant: LabelVariant.secondary; size: LabelSize.small; }
                Label { text: "Accent"; variant: LabelVariant.accent; size: LabelSize.small; }
                Label { text: "Success"; variant: LabelVariant.success; size: LabelSize.small; }
            }

            HorizontalLayout {
                spacing: 8px;

                Label { text: "Attention"; variant: LabelVariant.attention; size: LabelSize.small; }
                Label { text: "Severe"; variant: LabelVariant.severe; size: LabelSize.small; }
                Label { text: "Danger"; variant: LabelVariant.danger; size: LabelSize.small; }
                Label { text: "Done"; variant: LabelVariant.done; size: LabelSize.small; }
                Label { text: "Sponsors"; variant: LabelVariant.sponsors; size: LabelSize.small; }
            }
        }

        VerticalLayout {
            spacing: 8px;
            width: 100%;

            Text {
                text: "Size variants (default + primary)";
                color: PrimerColors.fgColor-muted;
                font-size: 12px;
            }

            HorizontalLayout {
                spacing: 16px;
                alignment: start;

                VerticalLayout {
                    spacing: 4px;
                    alignment: start;

                    Text {
                        text: "Small";
                        font-size: 12px;
                        color: PrimerColors.fgColor-muted;
                    }

                    Label { text: "Default"; variant: LabelVariant.default; size: LabelSize.small; }
                }

                VerticalLayout {
                    spacing: 4px;
                    alignment: start;

                    Text {
                        text: "Large";
                        font-size: 12px;
                        color: PrimerColors.fgColor-muted;
                    }

                    Label { text: "Default"; variant: LabelVariant.default; size: LabelSize.large; }
                }

                VerticalLayout {
                    spacing: 4px;
                    alignment: start;

                    Text {
                        text: "Large primary";
                        font-size: 12px;
                        color: PrimerColors.fgColor-muted;
                    }

                    Label { text: "Primary"; variant: LabelVariant.primary; size: LabelSize.large; }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "LabelGroup";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Row of Label chips (MVP: no truncation or +N more).";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        LabelGroup {
            width: 100%;
            items: demo-label-group-items;
        }
    }
}
