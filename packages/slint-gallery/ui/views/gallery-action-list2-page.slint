// **ActionList2** gallery — PR5 inline + block descriptions.
import {
    ActionList2,
    ActionList2DescriptionLayout,
    ActionList2Line,
    ActionList2LineKind,
    ActionList2ListVariant,
    ActionList2RowVariant,
    Checkbox,
    Icons,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryDemoOptionsSidebar,
} from "../components/gallery-demo-options-sidebar.slint";

export component GalleryActionList2Page {
    property <int> scenario-ix: 0;
    property <int> list-variant-ix: 0;
    property <bool> preview-has-leading-icon: false;

    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "SimpleList", enabled: true },
        { value: "2", label: "ItemDividers", enabled: true },
        { value: "3", label: "BlockDescription", enabled: true },
        { value: "4", label: "InlineDescription", enabled: true },
    ];

    property <[SelectOption]> list-variant-options: [
        { value: "0", label: "inset", enabled: true },
        { value: "1", label: "horizontal-inset", enabled: true },
        { value: "2", label: "full", enabled: true },
    ];

    property <string> last-action: "";

    property <ActionList2ListVariant> preview-list-variant:
    root.list-variant-ix == 1 ? ActionList2ListVariant.horizontal_inset : root.list-variant-ix == 2 ? ActionList2ListVariant.full : ActionList2ListVariant.inset;

    property <[ActionList2Line]> lines-default: [
        {
            kind: ActionList2LineKind.row,
            label: "Copy link",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.copy_icon,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Quote reply",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.link,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Edit comment",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.diff_modified,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
        },
    ];

    property <[ActionList2Line]> lines-simple-list: [
        {
            kind: ActionList2LineKind.row,
            label: "Copy link",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.copy_icon,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "⌘C",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Quote reply",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.link,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "⌘Q",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Edit comment",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.diff_modified,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "⌘E",
        },
        {
            kind: ActionList2LineKind.item_divider,
            label: "",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Delete file",
            row-variant: ActionList2RowVariant.danger,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.x,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
        },
    ];

    property <[ActionList2Line]> lines-block-description: [
        {
            kind: ActionList2LineKind.row,
            label: "Primer Backlog",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Accessibility",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Octicons",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Primer React",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
        },
    ];

    property <[ActionList2Line]> lines-inline-description: [
        {
            kind: ActionList2LineKind.row,
            label: "Primer Backlog",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.inline,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Accessibility",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.inline,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Octicons",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.inline,
            trailing-text: "",
        },
        {
            kind: ActionList2LineKind.row,
            label: "Primer React",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.inline,
            trailing-text: "",
        },
    ];

    property <[ActionList2Line]> preview-lines:
        root.scenario-ix == 1 ? root.lines-simple-list
        : root.scenario-ix == 3 ? root.lines-block-description
        : root.scenario-ix == 4 ? root.lines-inline-description
        : root.lines-default;

    property <bool> preview-show-dividers: root.scenario-ix == 2;

    property <string> scenario-caption:
        root.scenario-ix == 1 ? "Upstream: ActionList/Features — SimpleList"
        : root.scenario-ix == 2 ? "Upstream: ActionList/Features — ItemDividers (`showDividers`)"
        : root.scenario-ix == 3 ? "Upstream: ActionList/Features — BlockDescription"
        : root.scenario-ix == 4 ? "Upstream: ActionList/Features — InlineDescription"
        : "Upstream: ActionList — Default";

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "ActionList2";
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            Text {
                text: root.scenario-caption;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                wrap: word-wrap;
            }

            preview-chrome := Rectangle {
                width: 240px;
                border-width: 1px;
                border-color: PrimerColors.borderColor-muted;
                border-radius: LayoutTokens.borderRadius-medium;
                background: PrimerColors.bgColor-default;

                preview-layout := VerticalLayout {
                    width: parent.width;
                    alignment: start;

                    ActionList2 {
                        list-variant: root.preview-list-variant;
                        show-dividers: root.preview-show-dividers;
                        lines: root.preview-lines;
                        item-activated(ix) => {
                            root.last-action = "Activated line " + ix;
                        }
                    }
                }
            }

            if root.last-action != "": Text {
                text: "Last activated: " + root.last-action;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                wrap: word-wrap;
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "List options";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;
                alignment: start;

                Text {
                    text: "List";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "variant";
                    placeholder: "Choose…";
                    options: root.list-variant-options;
                    selected-index <=> list-variant-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                Checkbox {
                    label: "Leading icon";
                    checked <=> preview-has-leading-icon;
                }

                Text {
                    text: "Tab to a row for focus ring. Hover and press for row background.";
                    font-size: LayoutTokens.text-body-size-small;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }
        }
    }
}
