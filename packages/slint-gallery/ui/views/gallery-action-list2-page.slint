// **ActionList2** gallery — PR10 headings + prior scenarios.
import {
    ActionList2,
    ActionList2CustomHeading,
    ActionList2DescriptionLayout,
    ActionList2ItemDivider,
    ActionList2Line,
    ActionList2LineKind,
    ActionList2Lines,
    ActionList2ListRole,
    ActionList2ListVisualHeading,
    ALVariant,
    ActionList2Row,
    ActionList2RowVariant,
    ActionList2SectionHeading,
    ActionList2SectionHeadingVariant,
    ActionList2SelectionLead,
    ActionList2SelectionMode,
    Checkbox,
    Icons,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { ActionList2Tokens, LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryDemoOptionsSidebar,
} from "../components/gallery-demo-options-sidebar.slint";

export component GalleryActionList2Page {
    property <int> scenario-ix: 0;
    property <int> list-variant-ix: 0;
    property <bool> preview-has-leading-icon: false;

    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "SimpleList", enabled: true },
        { value: "2", label: "ItemDividers", enabled: true },
        { value: "3", label: "BlockDescription", enabled: true },
        { value: "4", label: "InlineDescription", enabled: true },
        { value: "11", label: "LinesAdapter", enabled: true },
        { value: "6", label: "SingleSelect", enabled: true },
        { value: "7", label: "SingleSelectLines", enabled: true },
        { value: "8", label: "MultiSelect", enabled: true },
        { value: "9", label: "MultiSelectLines", enabled: true },
        { value: "10", label: "ListboxMultiSelect", enabled: true },
        { value: "12", label: "DisabledItem", enabled: true },
        { value: "13", label: "InactiveItem", enabled: true },
        { value: "14", label: "LoadingItem", enabled: true },
        { value: "15", label: "InactiveSingleSelect", enabled: true },
        { value: "16", label: "Active", enabled: true },
        { value: "17", label: "WithVisualListHeading", enabled: true },
        { value: "18", label: "WithCustomHeading", enabled: true },
        { value: "19", label: "GroupFilled", enabled: true },
    ];

    property <[SelectOption]> list-variant-options: [
        { value: "0", label: "inset", enabled: true },
        { value: "1", label: "horizontal-inset", enabled: true },
        { value: "2", label: "full", enabled: true },
    ];

    property <string> last-action: "";
    property <int> single-select-ix: 0;
    property <int> disabled-select-ix: 0;
    property <int> inactive-single-select-ix: 1;
    property <bool> multi-checked-0: true;
    property <bool> multi-checked-1: false;
    property <bool> multi-checked-2: false;
    property <bool> multi-checked-3: false;

    property <[bool]> multi-selected-state:
        [root.multi-checked-0, root.multi-checked-1, root.multi-checked-2, root.multi-checked-3];

    property <ALVariant> preview-list-variant:
    root.list-variant-ix == 1 ? ALVariant.horizontal_inset : root.list-variant-ix == 2 ? ALVariant.full : ALVariant.inset;

    property <length> preview-item-margin-inline:
        root.preview-list-variant == ALVariant.full ? 0px : ActionList2Tokens.item-margin-inline-inset;

    property <[ActionList2Line]> lines-adapter-demo: [
        {
            kind: ActionList2LineKind.row,
            label: "Copy link",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.copy_icon,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Quote reply",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.link,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Edit comment",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: root.preview-has-leading-icon,
            leading-icon: Icons.diff_modified,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <[ActionList2Line]> lines-single-select: [
        {
            kind: ActionList2LineKind.row,
            label: "Primer Backlog",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Accessibility",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Octicons",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Primer React",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <[ActionList2Line]> lines-listbox-multi-select: [
        {
            kind: ActionList2LineKind.row,
            label: "Primer Backlog",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Accessibility",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "GitHub",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Octicons",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Primer React",
            row-variant: ActionList2RowVariant.default,
            disabled: true,
            has-leading-visual: true,
            leading-icon: Icons.table,
            description: "github/primer",
            description-layout: ActionList2DescriptionLayout.block,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <[ActionList2Line]> lines-menu-multi-select: [
        {
            kind: ActionList2LineKind.row,
            label: "Copy link",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Quote reply",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "Edit comment",
            row-variant: ActionList2RowVariant.default,
            disabled: false,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    property <string> scenario-caption:
        root.scenario-ix == 1 ? "Upstream: ActionList/Features — SimpleList (composed **ActionList2Row**)"
        : root.scenario-ix == 2 ? "Upstream: ItemDividers — **`show-top-seam`** on rows"
        : root.scenario-ix == 3 ? "Upstream: BlockDescription (composed rows)"
        : root.scenario-ix == 4 ? "Upstream: InlineDescription (composed rows)"
        : root.scenario-ix == 11 ? "**ActionList2Lines** — plain rows (no **`item_divider`**)"
        : root.scenario-ix == 6 ? "Single select — **`selection-lead: checkmark`**"
        : root.scenario-ix == 7 ? "Single select — **`ActionList2Lines`** (`selection-mode: single` → checkmark)"
        : root.scenario-ix == 8 ? "Upstream **MultiSelect** — `role=menu`, **`selection-lead: checkmark`**"
        : root.scenario-ix == 9 ? "Upstream **MultiSelect** — **`ActionList2Lines`** + **`list-role: menu`** → checkmark"
        : root.scenario-ix == 10 ? "True listbox multi — **`list-role: listbox`** → **`selection-lead: checkbox`** (Storybook **ListboxMultiSelect** name is misleading; it uses menu)"
        : root.scenario-ix == 12 ? "Upstream **DisabledItem** — middle row **`disabled`** (no hover/activation)"
        : root.scenario-ix == 13 ? "Upstream **InactiveItem** — **`inactive-text`** warning under block description"
        : root.scenario-ix == 14 ? "Upstream **LoadingItem** — **`show-trailing-loading`** spinner; no activation"
        : root.scenario-ix == 15 ? "Upstream **InactiveSingleSelect** — inactive row in single-select menu"
        : root.scenario-ix == 16 ? "Upstream **Active** — **`active`** row: left accent bar + selected surface"
        : root.scenario-ix == 17 ? "Upstream **WithVisualListHeading** — list title + subtle **section** groups"
        : root.scenario-ix == 18 ? "Upstream **WithCustomHeading** — medium custom title + rows"
        : root.scenario-ix == 19 ? "Upstream **GroupWithFilledTitle** — **`section-heading-variant: filled`**"
        : "Upstream: ActionList — Default (composed rows)";

    // vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: start;

            Text {
                text: "ActionList2";
                color: PrimerColors.fgColor-default;
                font-size: 15px;
                font-weight: 600;
            }

            preview-chrome := Rectangle {
                width: 240px;
                border-width: 1px;
                border-color: PrimerColors.borderColor-muted;
                border-radius: LayoutTokens.borderRadius-medium;
                background: PrimerColors.bgColor-default;

                preview-layout := VerticalLayout {
                    alignment: start;

                    al := ActionList2 {
                        list-variant: root.preview-list-variant;

                        if root.scenario-ix == 0: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Copy link";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.copy_icon;
                                clicked => {
                                    root.last-action = "Activated Copy link";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Quote reply";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.link;
                                clicked => {
                                    root.last-action = "Activated Quote reply";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Edit comment";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.diff_modified;
                                clicked => {
                                    root.last-action = "Activated Edit comment";
                                }
                            }
                        }

                        if root.scenario-ix == 1: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Copy link";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.copy_icon;
                                trailing-text: "⌘C";
                                clicked => {
                                    root.last-action = "Activated line 0";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Quote reply";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.link;
                                trailing-text: "⌘Q";
                                clicked => {
                                    root.last-action = "Activated line 1";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Edit comment";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.diff_modified;
                                trailing-text: "⌘E";
                                clicked => {
                                    root.last-action = "Activated line 2";
                                }
                            }
                            ActionList2ItemDivider {
                                margin-inline: root.preview-item-margin-inline;
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Delete file";
                                row-variant: ActionList2RowVariant.danger;
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.x;
                                clicked => {
                                    root.last-action = "Activated line 4";
                                }
                            }
                        }

                        if root.scenario-ix == 2: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Copy link";
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.copy_icon;
                                clicked => {
                                    root.last-action = "Activated line 0";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Quote reply";
                                show-divider: true;
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.link;
                                clicked => {
                                    root.last-action = "Activated line 1";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Edit comment";
                                show-divider: true;
                                has-leading-visual: root.preview-has-leading-icon;
                                leading-icon: Icons.diff_modified;
                                clicked => {
                                    root.last-action = "Activated line 2";
                                }
                            }
                        }

                        if root.scenario-ix == 3: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Accessibility";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Accessibility";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Octicons";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Octicons";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer React";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Primer React";
                                }
                            }
                        }

                        if root.scenario-ix == 4: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Accessibility";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Accessibility";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Octicons";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Octicons";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer React";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.inline;
                                clicked => {
                                    root.last-action = "Activated Primer React";
                                }
                            }
                        }

                        if root.scenario-ix == 11: ActionList2Lines {
                            list-variant: root.preview-list-variant;
                            lines: root.lines-adapter-demo;
                            item-activated(ix) => {
                                root.last-action = "Activated line " + ix;
                            }
                        }

                        if root.scenario-ix == 6: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Inbox";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.single-select-ix == 0;
                                clicked => {
                                    root.single-select-ix = 0;
                                    root.last-action = "Selected Inbox";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primary";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.single-select-ix == 1;
                                clicked => {
                                    root.single-select-ix = 1;
                                    root.last-action = "Selected Primary";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Calendar";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.single-select-ix == 2;
                                clicked => {
                                    root.single-select-ix = 2;
                                    root.last-action = "Selected Calendar";
                                }
                            }
                        }

                        if root.scenario-ix == 7: ActionList2Lines {
                            list-variant: root.preview-list-variant;
                            selection-mode: ActionList2SelectionMode.single;
                            selected-index: root.single-select-ix;
                            lines: root.lines-single-select;
                            item-activated(ix) => {
                                root.single-select-ix = ix;
                                root.last-action = "Selected " + root.lines-single-select[ix].label;
                            }
                        }

                        if root.scenario-ix == 8: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Build";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.multi-checked-0;
                                clicked => {
                                    root.multi-checked-0 = !root.multi-checked-0;
                                    root.last-action = "Toggled Build";
                                }
                            }
                            ActionList2ItemDivider {
                                margin-inline: root.preview-item-margin-inline;
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Test";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.multi-checked-1;
                                clicked => {
                                    root.multi-checked-1 = !root.multi-checked-1;
                                    root.last-action = "Toggled Test";
                                }
                            }
                            ActionList2ItemDivider {
                                margin-inline: root.preview-item-margin-inline;
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Release";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.multi-checked-2;
                                clicked => {
                                    root.multi-checked-2 = !root.multi-checked-2;
                                    root.last-action = "Toggled Release";
                                }
                            }
                        }

                        if root.scenario-ix == 9: ActionList2Lines {
                            list-variant: root.preview-list-variant;
                            list-role: ActionList2ListRole.menu;
                            selection-mode: ActionList2SelectionMode.multiple;
                            multi-selected: root.multi-selected-state;
                            lines: root.lines-menu-multi-select;
                            item-activated(ix) => {
                                if ix == 0 {
                                    root.multi-checked-0 = !root.multi-checked-0;
                                } else if ix == 1 {
                                    root.multi-checked-1 = !root.multi-checked-1;
                                } else if ix == 2 {
                                    root.multi-checked-2 = !root.multi-checked-2;
                                }
                                root.last-action = "Toggled " + root.lines-menu-multi-select[ix].label;
                            }
                        }

                        if root.scenario-ix == 10: ActionList2Lines {
                            list-variant: root.preview-list-variant;
                            list-role: ActionList2ListRole.listbox;
                            selection-mode: ActionList2SelectionMode.multiple;
                            multi-selected: root.multi-selected-state;
                            lines: root.lines-listbox-multi-select;
                            item-activated(ix) => {
                                if ix == 0 {
                                    root.multi-checked-0 = !root.multi-checked-0;
                                } else if ix == 1 {
                                    root.multi-checked-1 = !root.multi-checked-1;
                                } else if ix == 2 {
                                    root.multi-checked-2 = !root.multi-checked-2;
                                } else if ix == 3 {
                                    root.multi-checked-3 = !root.multi-checked-3;
                                }
                                root.last-action = "Toggled " + root.lines-listbox-multi-select[ix].label;
                            }
                        }

                        if root.scenario-ix == 12: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.disabled-select-ix == 0;
                                clicked => {
                                    root.disabled-select-ix = 0;
                                    root.last-action = "Selected Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Accessibility";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                disabled: true;
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.disabled-select-ix == 1;
                                show-divider: true;
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Octicons";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.disabled-select-ix == 2;
                                show-divider: true;
                                clicked => {
                                    root.disabled-select-ix = 2;
                                    root.last-action = "Selected Octicons";
                                }
                            }
                        }

                        if root.scenario-ix == 13: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer Backlog";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Accessibility";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                inactive-text: "Unavailable due to an outage";
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Octicons";
                                has-leading-visual: true;
                                leading-icon: Icons.table;
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Octicons";
                                }
                            }
                        }

                        if root.scenario-ix == 14: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Primer Backlog";
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Primer Backlog";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Accessibility";
                                description: "GitHub";
                                description-layout: ActionList2DescriptionLayout.block;
                                show-trailing-loading: true;
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Octicons";
                                description: "github/primer";
                                description-layout: ActionList2DescriptionLayout.block;
                                clicked => {
                                    root.last-action = "Activated Octicons";
                                }
                            }
                        }

                        if root.scenario-ix == 15: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Inactive item";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: false;
                                inactive-text: "Unavailable due to an outage";
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Item 2";
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.inactive-single-select-ix == 1;
                                clicked => {
                                    root.inactive-single-select-ix = 1;
                                    root.last-action = "Selected Item 2";
                                }
                            }
                        }

                        if root.scenario-ix == 16: VerticalLayout {
                            alignment: start;
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Active item";
                                active: true;
                                clicked => {
                                    root.last-action = "Activated Active item";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Second row";
                                clicked => {
                                    root.last-action = "Activated Second row";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Third row";
                                clicked => {
                                    root.last-action = "Activated Third row";
                                }
                            }
                        }

                        if root.scenario-ix == 17: VerticalLayout {
                            alignment: start;
                            ActionList2ListVisualHeading {
                                margin-inline: root.preview-item-margin-inline;
                                title: "Filter by";
                            }
                            ActionList2SectionHeading {
                                margin-inline: root.preview-item-margin-inline;
                                title: "Repositories";
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "app/assets/modules";
                                has-leading-visual: true;
                                leading-icon: Icons.file_directory_fill;
                                clicked => {
                                    root.last-action = "Activated app/assets/modules";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "src/react/components";
                                has-leading-visual: true;
                                leading-icon: Icons.file_directory_fill;
                                clicked => {
                                    root.last-action = "Activated src/react/components";
                                }
                            }
                            ActionList2SectionHeading {
                                margin-inline: root.preview-item-margin-inline;
                                title: "Advanced";
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Owner";
                                has-leading-visual: true;
                                leading-icon: Icons.plus_circle;
                                clicked => {
                                    root.last-action = "Activated Owner";
                                }
                            }
                        }

                        if root.scenario-ix == 18: VerticalLayout {
                            alignment: start;
                            ActionList2CustomHeading {
                                margin-inline: root.preview-item-margin-inline;
                                title: "Details";
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "Readme";
                                has-leading-visual: true;
                                leading-icon: Icons.book;
                                clicked => {
                                    root.last-action = "Activated Readme";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "License";
                                has-leading-visual: true;
                                leading-icon: Icons.law;
                                clicked => {
                                    root.last-action = "Activated License";
                                }
                            }
                        }

                        if root.scenario-ix == 19: VerticalLayout {
                            alignment: start;
                            ActionList2SectionHeading {
                                margin-inline: root.preview-item-margin-inline;
                                title: "Everyone";
                                variant: ActionList2SectionHeadingVariant.filled;
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "octocat";
                                description: "Mona Lisa";
                                description-layout: ActionList2DescriptionLayout.block;
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.multi-checked-0;
                                clicked => {
                                    root.multi-checked-0 = !root.multi-checked-0;
                                    root.last-action = "Toggled octocat";
                                }
                            }
                            ActionList2Row {
                                margin-inline: root.preview-item-margin-inline;
                                label: "hubot";
                                description: "Hubot";
                                description-layout: ActionList2DescriptionLayout.block;
                                selection-lead: ActionList2SelectionLead.checkmark;
                                selected: root.multi-checked-1;
                                clicked => {
                                    root.multi-checked-1 = !root.multi-checked-1;
                                    root.last-action = "Toggled hubot";
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "List options";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;
                alignment: start;

                Text {
                    text: "List";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "variant";
                    placeholder: "Choose…";
                    options: root.list-variant-options;
                    selected-index <=> list-variant-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                Checkbox {
                    label: "Leading icon";
                    checked <=> preview-has-leading-icon;
                }
            }
        }
    }
}
