import {
    AnchoredOverlay,
    AnchoredOverlayAlign,
    AnchoredOverlaySide,
    Button,
    ButtonAlignContent,
    ButtonVariant,
    Checkbox,
    CheckboxGroup,
    Icons,
    LayoutTokens,
    Radio,
    RadioGroup,
    Select,
    SelectOption,
    SelectPanel,
    SelectPanelItem,
    SelectPanelMode,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { GallerySelectPanelMulti } from "../state/gallery-select-panel-multi-state.slint";
import { AppWindow, PrimerColors } from "../../../primer-slint/tokens.slint";

export component GalleryFormsPage inherits VerticalLayout {
    spacing: 28px;
    padding: 24px;

    property <[SelectOption]> demo-select-options: [
        { value: "one", label: "First option", enabled: true },
        { value: "two", label: "Second option", enabled: true },
        { value: "three", label: "Third option", enabled: false },
    ];
    property <int> demo-select-index: 0;

    property <bool> demo-cb-off: false;
    property <bool> demo-cb-on: true;
    property <bool> demo-cb-label: false;
    property <bool> demo-cb-indet: true;
    property <bool> demo-cg-opt1: false;
    property <bool> demo-cg-opt2: true;

    property <string> demo-radio-mutex: "beta";
    property <string> demo-rg-plan: "";
    property <string> demo-rg-disabled-pick: "b";
    property <string> demo-rg-hidden-axis: "x";

    property <bool> demo-select-panel-open: false;
    property <string> demo-sp-filter: "";
    property <int> demo-sp-focused: 0;
    property <[SelectPanelItem]> demo-sp-items: [
        { value: "enhancement", label: "enhancement", description: "New feature or request", swatch: #84b6eb, enabled: true },
        { value: "bug", label: "bug", description: "Something isn't working", swatch: #d73a4a, enabled: true },
        { value: "good-first-issue", label: "good first issue", description: "Good for newcomers", swatch: #3fb950, enabled: true },
        { value: "documentation", label: "documentation", description: "Improvements or additions to documentation", swatch: #0075ca, enabled: true },
        { value: "duplicate", label: "duplicate", description: "This issue or pull request already exists", swatch: #cfd3d7, enabled: true },
    ];

    VerticalLayout {
        spacing: 12px;

        Text {
            text: "Select";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "Demo select";
            placeholder: "Choose an option…";
            options: demo-select-options;
            selected-index <=> demo-select-index;
            validation-status: ValidationStatus.success;
            validation-message: "Static gallery model.";
            selected-changed(_idx) => {
            }
        }
    }

    anchored-overlay-demo-column := VerticalLayout {
        spacing: 12px;

        Text {
            text: "AnchoredOverlay + SelectPanel (anchored)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "AnchoredOverlay: vertical-side auto (flip), align start; SelectPanel multi mode (`multi-selected` + `multi-item-activated`, `show-footer` + children, `focused-index` accent). Escape closes the popup. See anchored-popupwindow.md in this folder.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: "Labels";
            color: PrimerColors.fgColor-default;
            font-size: 12px;
            font-weight: 600;
            wrap: word-wrap;
        }

        btn-select-panel := Button {
            max-width: 420px;
            align-content: ButtonAlignContent.start;
            label: "bug, good first issue";
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                demo-select-panel-open = true;
            }
        }

        anchored-overlay-select-panel := AnchoredOverlay {
            open <=> demo-select-panel-open;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.start;
            panel-width: 360px;
            panel-height: 480px;
            anchor-abs-x: btn-select-panel.absolute-position.x;
            anchor-abs-y: btn-select-panel.absolute-position.y;
            anchor-width: btn-select-panel.width;
            anchor-height: btn-select-panel.height;
            close-requested => {
            }

            SelectPanel {
                mode: SelectPanelMode.multi;
                title: "Select labels";
                subtitle: "Use labels to organize issues and pull requests";
                filter-placeholder: "Filter items";
                filter-text <=> demo-sp-filter;
                multi-items: demo-sp-items;
                multi-selected: GallerySelectPanelMulti.row-checked;
                focused-index: demo-sp-focused;
                list-max-height: 200px;
                show-footer: true;
                filter-changed(_t) => {
                }
                single-selected-changed(_i) => {
                }
                multi-item-activated(ix) => {
                    GallerySelectPanelMulti.row-activated(ix);
                }

                HorizontalLayout {
                    spacing: LayoutTokens.button-content-gap;
                    alignment: end;

                    Button {
                        label: "Cancel";
                        clicked => {
                            demo-select-panel-open = false;
                        }
                    }

                    Button {
                        label: "Apply";
                        variant: ButtonVariant.primary;
                        clicked => {
                            demo-select-panel-open = false;
                        }
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        align-items: start;
        padding-left: 12px;

        Text {
            text: "Checkbox";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Unchecked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Checkbox {
                    checked <=> demo-cb-off;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Checked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Checkbox {
                    checked <=> demo-cb-on;
                }
            }
        }

        Checkbox {
            label: "Send email notifications";
            checked <=> demo-cb-label;
        }

        Checkbox {
            label: "Indeterminate (first click checks)";
            checked: false;
            indeterminate <=> demo-cb-indet;
        }

        Checkbox {
            label: "Leading icon + label";
            checked: true;
        }

        Text {
            text: "Radio";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Mutex selection is page state (checked: selected == value; toggled updates selection). RadioGroup only provides the fieldset shell — bind each Radio from the same state. When the group is disabled, set disabled on every Radio too.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Unchecked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Radio {
                    checked: false;
                    interactive: false;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Checked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Radio {
                    checked: true;
                    interactive: false;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Disabled · off";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Radio {
                    disabled: true;
                    checked: false;
                    interactive: false;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Disabled · on";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Radio {
                    disabled: true;
                    checked: true;
                    interactive: false;
                }
            }
        }

        RadioGroup {
            label: "Mutex (one selected value)";
            caption: "Legend + caption on the group; radios bind to page state.";

            Radio {
                value: "alpha";
                label: "Alpha";
                checked: demo-radio-mutex == "alpha";
                toggled => {
                    demo-radio-mutex = "alpha";
                }
            }

            Radio {
                value: "beta";
                label: "Beta";
                checked: demo-radio-mutex == "beta";
                toggled => {
                    demo-radio-mutex = "beta";
                }
            }

            Radio {
                value: "gamma";
                label: "Gamma";
                checked: demo-radio-mutex == "gamma";
                toggled => {
                    demo-radio-mutex = "gamma";
                }
            }
        }

        Text {
            text: "RadioGroup";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Validation row, disabled stack (mirror disabled on each Radio), and visually hidden legend — same shell as CheckboxGroup.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        RadioGroup {
            label: "Shipping speed";
            caption: "Gallery starts with no plan selected — validation shows until you pick one.";
            required: true;
            validation-status: demo-rg-plan == "" ? ValidationStatus.error : ValidationStatus.success;
            validation-message: demo-rg-plan == "" ? "Select a shipping option." : "Looks good.";

            Radio {
                value: "standard";
                label: "Standard";
                checked: demo-rg-plan == "standard";
                toggled => {
                    demo-rg-plan = "standard";
                }
            }

            Radio {
                value: "express";
                label: "Express";
                checked: demo-rg-plan == "express";
                toggled => {
                    demo-rg-plan = "express";
                }
            }

            Radio {
                value: "overnight";
                label: "Overnight";
                checked: demo-rg-plan == "overnight";
                toggled => {
                    demo-rg-plan = "overnight";
                }
            }
        }

        RadioGroup {
            label: "Disabled group";
            disabled: true;

            Radio {
                value: "a";
                label: "Option A";
                disabled: true;
                checked: demo-rg-disabled-pick == "a";
                toggled => {
                    demo-rg-disabled-pick = "a";
                }
            }

            Radio {
                value: "b";
                label: "Option B";
                disabled: true;
                checked: demo-rg-disabled-pick == "b";
                toggled => {
                    demo-rg-disabled-pick = "b";
                }
            }
        }

        RadioGroup {
            label: "External legend";
            label-visually-hidden: true;
            caption: "Legend text is not shown; caption remains visible.";

            Radio {
                value: "x";
                label: "North";
                checked: demo-rg-hidden-axis == "x";
                toggled => {
                    demo-rg-hidden-axis = "x";
                }
            }

            Radio {
                value: "y";
                label: "South";
                checked: demo-rg-hidden-axis == "y";
                toggled => {
                    demo-rg-hidden-axis = "y";
                }
            }
        }

        Text {
            text: "CheckboxGroup";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Legend, caption, required asterisk, validation, disabled dimming (mirror disabled on each Checkbox), and visually hidden legend.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        CheckboxGroup {
            label: "Features";
            caption: "Choose one or more options.";
            required: true;
            validation-status: !demo-cg-opt1 && !demo-cg-opt2 ? ValidationStatus.error : ValidationStatus.success;
            validation-message: !demo-cg-opt1 && !demo-cg-opt2 ? "Pick at least one." : "Looks good.";

            Checkbox {
                label: "Option A";
                checked <=> demo-cg-opt1;
            }

            Checkbox {
                label: "Option B";
                checked <=> demo-cg-opt2;
            }
        }

        CheckboxGroup {
            label: "Disabled group";
            disabled: true;

            Checkbox {
                label: "Cannot toggle";
                disabled: true;
                checked: false;
            }

            Checkbox {
                label: "Also off";
                disabled: true;
                checked: true;
            }
        }

        CheckboxGroup {
            label: "Screen-reader legend (hidden in UI)";
            label-visually-hidden: true;
            caption: "Legend text is not shown; caption remains.";

            Checkbox {
                label: "Alpha";
            }

            Checkbox {
                label: "Beta";
            }
        }
    }
}
