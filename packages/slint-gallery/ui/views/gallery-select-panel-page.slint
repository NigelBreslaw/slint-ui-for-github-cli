import {
    ActionListDescriptionLayout,
    ActionListLine,
    ActionListLineKind,
    ActionListListRole,
    ActionListRowSize,
    ActionListRowVariant,
    ActionListSectionHeadingVariant,
    ActionListSelectionMode,
    ActionListVariant,
    Button,
    ButtonVariant,
    Checkbox,
    FilteredActionListLoadingKind,
    Icons,
    Select,
    SelectOption,
    AnchoredOverlayWidth,
    SelectPanel,
    SelectPanelNoticeVariant,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors, SelectPanelTokens } from "../../../primer-slint/tokens.slint";
import { GalleryFilteredActionListSelectAll } from "../state/gallery-filtered-action-list-select-all-state.slint";
import { GalleryFilteredActionListLong } from "../state/gallery-filtered-action-list-state.slint";
import {
    GallerySelectPanelCancel,
    GallerySelectPanelDefault,
    GallerySelectPanelDisabled,
    GallerySelectPanelFetch,
    GallerySelectPanelModalMulti,
    GallerySelectPanelSingle,
} from "../state/gallery-select-panel-state.slint";
import { GalleryDemoOptionsSidebar } from "../components/gallery-demo-options-sidebar.slint";

export component GallerySelectPanelPage {
    property <int> scenario-ix: 0;

    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "SingleSelect", enabled: true },
        { value: "2", label: "MultiSelect", enabled: true },
        { value: "3", label: "FilterPlaceholder", enabled: true },
        { value: "4", label: "ItemDividers", enabled: true },
        { value: "5", label: "DisabledItem", enabled: true },
        { value: "6", label: "InactiveItems", enabled: true },
        { value: "7", label: "Notice", enabled: true },
        { value: "8", label: "FooterSecondary", enabled: true },
        { value: "9", label: "Groups", enabled: true },
        { value: "10", label: "Message", enabled: true },
        { value: "11", label: "NoResults", enabled: true },
        { value: "12", label: "NoInitialItems", enabled: true },
        { value: "13", label: "LoadingFetch", enabled: true },
        { value: "14", label: "SelectAll", enabled: true },
        { value: "15", label: "CancelFooter", enabled: true },
        { value: "16", label: "SingleModal", enabled: true },
        { value: "17", label: "MultiModal", enabled: true },
        { value: "18", label: "ExternalAnchor", enabled: true },
        { value: "19", label: "OverflowScroll", enabled: true },
        { value: "20", label: "LongItems", enabled: true },
    ];

    property <string> sp-filter: "";
    property <int> sp-single-selected-index: 0;
    property <bool> sp-open: false;
    property <int> sp-notice-variant-ix: 0;
    property <int> sp-message-variant-ix: 0;
    property <bool> sp-fetch-loading: true;
    property <bool> sp-ext-open: false;

    property <[ActionListLine]> sp-inactive-lines: [
        {
            kind: ActionListLineKind.row,
            label: "enhancement",
            row-variant: ActionListRowVariant.default,
            row-size: ActionListRowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.dot_fill,
            description: "New feature or request",
            description-layout: ActionListDescriptionLayout.block,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.row,
            label: "request",
            row-variant: ActionListRowVariant.default,
            row-size: ActionListRowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: true,
            leading-icon: Icons.dot_fill,
            description: "New feature or request",
            description-layout: ActionListDescriptionLayout.block,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "Currently inactive due to an outage",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
    ];

    property <[ActionListLine]> sp-groups-lines: [
        {
            kind: ActionListLineKind.section_heading,
            label: "Repos",
            row-variant: ActionListRowVariant.default,
            row-size: ActionListRowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionListSectionHeadingVariant.filled,
        },
        {
            kind: ActionListLineKind.row,
            label: "View settings",
            row-variant: ActionListRowVariant.default,
            row-size: ActionListRowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
        {
            kind: ActionListLineKind.section_heading,
            label: "Live query",
            row-variant: ActionListRowVariant.default,
            row-size: ActionListRowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionListSectionHeadingVariant.filled,
        },
        {
            kind: ActionListLineKind.row,
            label: "item 1",
            row-variant: ActionListRowVariant.default,
            row-size: ActionListRowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionListDescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionListSectionHeadingVariant.subtle,
        },
    ];

    property <bool> sp-is-single: root.scenario-ix == 1 || root.scenario-ix == 16;
    property <bool> sp-is-modal: root.scenario-ix == 16 || root.scenario-ix == 17;
    property <bool> sp-is-external: root.scenario-ix == 18;
    /// Scenarios that use **`GallerySelectPanelDefault`** lines + multi-select.
    property <bool> sp-use-default-bridge:
        root.scenario-ix == 0 || root.scenario-ix == 2 || root.scenario-ix == 3
        || root.scenario-ix == 4 || root.scenario-ix == 7 || root.scenario-ix == 8
        || root.scenario-ix == 10 || root.scenario-ix == 11 || root.scenario-ix == 19;
    property <bool> sp-no-results: root.scenario-ix == 11 && root.sp-filter == "none";

    property <string> sp-title:
        root.scenario-ix == 9 ? "Attach files and symbols"
        : root.scenario-ix == 12 ? "Set projects"
        : root.scenario-ix == 1 || root.scenario-ix == 16 ? ""
        : "Select labels";

    property <string> sp-subtitle:
        root.scenario-ix == 9
        ? "Choose which files and symbols you want to chat about. Use fewer references for more accurate responses."
        : root.scenario-ix == 1 || root.scenario-ix == 16 ? ""
        : "Use labels to organize issues and pull requests";

    property <string> sp-filter-placeholder:
        root.scenario-ix == 3 ? "Filter labels" : "Filter Labels";

    property <SelectPanelNoticeVariant> sp-notice-variant:
        root.sp-notice-variant-ix == 1 ? SelectPanelNoticeVariant.warning
        : root.sp-notice-variant-ix == 2 ? SelectPanelNoticeVariant.error
        : SelectPanelNoticeVariant.info;

    property <string> sp-notice-text:
        root.sp-notice-variant-ix == 1
        ? "You have reached the limit of assignees on your free account. Upgrade your account."
        : root.sp-notice-variant-ix == 2
        ? "We couldn't load all collaborators. Try again or contact support."
        : "Try a different search term.";

    property <bool> sp-show-message:
        root.scenario-ix == 10 && root.sp-message-variant-ix != 0;

    property <string> sp-message-title:
        root.sp-message-variant-ix == 2 ? "Failed to load labels"
        : root.sp-message-variant-ix == 3 ? "Some labels may be outdated"
        : "No labels found";

    property <string> sp-message-description:
        root.sp-message-variant-ix == 2
        ? "Check your network connection and try again or contact support."
        : root.sp-message-variant-ix == 3
        ? "Consider refreshing to get the latest data."
        : "Try adjusting your search or create a new label.";

    property <length> sp-body-height:
        root.scenario-ix == 20 ? 320px : SelectPanelTokens.list-max-height-default;

    property <AnchoredOverlayWidth> sp-width-preset:
        root.scenario-ix == 19 ? AnchoredOverlayWidth.small
        : root.scenario-ix == 7 ? AnchoredOverlayWidth.large
        : AnchoredOverlayWidth.medium;

    changed scenario-ix => {
        root.sp-filter = "";
        GallerySelectPanelDefault.filter-changed("");
        GallerySelectPanelSingle.filter-changed("");
        GallerySelectPanelDisabled.filter-changed("");
        GallerySelectPanelFetch.filter-changed("");
        GallerySelectPanelCancel.filter-changed("");
        GallerySelectPanelModalMulti.filter-changed("");
        GalleryFilteredActionListSelectAll.filter-changed("");
        GalleryFilteredActionListLong.filter-changed("");
        root.sp-single-selected-index = 0;
        root.sp-notice-variant-ix = 0;
        root.sp-message-variant-ix = 0;
        root.sp-fetch-loading = root.scenario-ix == 13;
        root.sp-open = false;
        root.sp-ext-open = false;
    }

    changed sp-filter => {
        if root.scenario-ix == 1 {
            root.sp-single-selected-index = 0;
        }
    }

    fetch-timer := Timer {
        interval: 2000ms;
        running: false;
        triggered() => {
            root.sp-fetch-loading = false;
            self.stop();
        }
    }

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 1;
            padding: 24px;
            spacing: 16px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: "SelectPanel";
                color: PrimerColors.fgColor-default;
                font-size: 22px;
                font-weight: 600;
            }

            if !root.sp-is-external: SelectPanel {
                open <=> root.sp-open;
                width-preset: root.sp-width-preset;
                anchor-label: "Select labels";
                title: root.sp-title;
                subtitle: root.sp-subtitle;
                filter-placeholder: root.sp-filter-placeholder;
                filter-text <=> root.sp-filter;
                list-role: ActionListListRole.listbox;
                selection-mode: root.sp-is-single ? ActionListSelectionMode.single : ActionListSelectionMode.multiple;
                selected-index <=> root.sp-single-selected-index;
                list-variant: root.scenario-ix == 9 ? ActionListVariant.horizontal_inset : ActionListVariant.inset;
                show-dividers: root.scenario-ix == 4 || root.scenario-ix == 20;
                show-notice: root.scenario-ix == 7;
                notice-variant: root.sp-notice-variant;
                notice-text: root.sp-notice-text;
                show-footer: root.scenario-ix == 8 || root.scenario-ix == 15 || root.sp-is-modal;
                show-backdrop: root.sp-is-modal;
                close-on-single-select: !root.sp-is-modal;
                loading: root.scenario-ix == 13 && root.sp-fetch-loading;
                loading-kind: FilteredActionListLoadingKind.body_spinner;
                loading-message: "Loading labels…";
                show-message: root.sp-show-message;
                message-title: root.sp-message-title;
                message-description: root.sp-message-description;
                empty-title: root.scenario-ix == 12 ? "We couldn't find any projects" : "";
                empty-message:
                    root.scenario-ix == 12
                    ? "Try searching for a different project or create a new one."
                    : root.sp-no-results ? "No labels match your filter." : "";
                select-all-visible: root.scenario-ix == 14;
                select-all-checked <=> GalleryFilteredActionListSelectAll.select-all-checked;
                select-all-indeterminate <=> GalleryFilteredActionListSelectAll.select-all-indeterminate;
                body-region-height: root.sp-body-height;
                lines:
                    root.scenario-ix == 6 ? root.sp-inactive-lines
                    : root.scenario-ix == 9 ? root.sp-groups-lines
                    : root.scenario-ix == 12 ? []
                    : root.scenario-ix == 5 ? GallerySelectPanelDisabled.lines
                    : root.scenario-ix == 14 ? GalleryFilteredActionListSelectAll.lines
                    : root.scenario-ix == 15 ? GallerySelectPanelCancel.lines
                    : root.scenario-ix == 17 ? GallerySelectPanelModalMulti.lines
                    : root.scenario-ix == 13 ? GallerySelectPanelFetch.lines
                    : root.scenario-ix == 1 || root.scenario-ix == 16 ? GallerySelectPanelSingle.lines
                    : root.scenario-ix == 20 ? GalleryFilteredActionListLong.lines
                    : root.scenario-ix == 10 && root.sp-message-variant-ix != 0 ? []
                    : root.sp-no-results ? [] : GallerySelectPanelDefault.lines;
                multi-selected:
                    root.scenario-ix == 5 ? GallerySelectPanelDisabled.multi-selected
                    : root.scenario-ix == 14 ? GalleryFilteredActionListSelectAll.multi-selected
                    : root.scenario-ix == 15 ? GallerySelectPanelCancel.multi-selected
                    : root.scenario-ix == 17 ? GallerySelectPanelModalMulti.multi-selected
                    : GallerySelectPanelDefault.multi-selected;
                filter-changed(t) => {
                    if root.scenario-ix == 1 || root.scenario-ix == 16 {
                        GallerySelectPanelSingle.filter-changed(t);
                    } else if root.scenario-ix == 5 {
                        GallerySelectPanelDisabled.filter-changed(t);
                    } else if root.scenario-ix == 13 {
                        GallerySelectPanelFetch.filter-changed(t);
                    } else if root.scenario-ix == 14 {
                        GalleryFilteredActionListSelectAll.filter-changed(t);
                    } else if root.scenario-ix == 15 {
                        GallerySelectPanelCancel.filter-changed(t);
                    } else if root.scenario-ix == 17 {
                        GallerySelectPanelModalMulti.filter-changed(t);
                    } else if root.scenario-ix == 20 {
                        GalleryFilteredActionListLong.filter-changed(t);
                    } else if root.sp-use-default-bridge {
                        GallerySelectPanelDefault.filter-changed(t);
                    }
                }
                item-activated(ix) => {
                    if root.sp-is-single {
                        root.sp-single-selected-index = ix;
                    } else if root.scenario-ix == 5 {
                        GallerySelectPanelDisabled.item-activated(ix);
                    } else if root.scenario-ix == 14 {
                        GalleryFilteredActionListSelectAll.item-activated(ix);
                    } else if root.scenario-ix == 15 {
                        GallerySelectPanelCancel.item-activated(ix);
                    } else if root.scenario-ix == 17 {
                        GallerySelectPanelModalMulti.item-activated(ix);
                    } else if root.sp-use-default-bridge || root.scenario-ix == 6 || root.scenario-ix == 9 {
                        GallerySelectPanelDefault.item-activated(ix);
                    }
                }
                single-selected-changed(ix) => {
                    root.sp-single-selected-index = ix;
                }
                select-all-changed(on) => {
                    GalleryFilteredActionListSelectAll.select-all-changed(on);
                }
                if root.scenario-ix == 8: Button {
                    label: "Edit labels";
                    variant: ButtonVariant.link;
                    clicked => {
                        root.sp-open = false;
                    }
                }
                if root.scenario-ix == 8: Button {
                    label: "Add label";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.sp-open = false;
                    }
                }
                if root.scenario-ix == 15: Button {
                    label: "Cancel";
                    clicked => {
                        GallerySelectPanelCancel.reset();
                        root.sp-open = false;
                    }
                }
                if root.sp-is-modal: Button {
                    label: "Cancel";
                    clicked => {
                        if root.scenario-ix == 17 {
                            GallerySelectPanelModalMulti.reset();
                        }
                        root.sp-open = false;
                    }
                }
                if root.sp-is-modal: Button {
                    label: "Save";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.sp-open = false;
                    }
                }
            }

            if root.sp-is-external: VerticalLayout {
                spacing: 12px;
                alignment: start;

                ext-trigger := Button {
                    label: "bug, good first issue";
                    has-trailing-icon: true;
                    trailing-icon: Icons.triangle_down;
                    clicked => {
                        root.sp-ext-open = !root.sp-ext-open;
                    }
                }

                SelectPanel {
                    has-built-in-anchor: false;
                    open <=> root.sp-ext-open;
                    anchor-position-props: {
                        absolute-position: ext-trigger.absolute-position,
                        source-size: { width: ext-trigger.width, height: ext-trigger.height },
                    };
                    title: "Select labels";
                    subtitle: "Use labels to organize issues and pull requests";
                    filter-text <=> root.sp-filter;
                    lines: GallerySelectPanelDefault.lines;
                    list-role: ActionListListRole.listbox;
                    selection-mode: ActionListSelectionMode.multiple;
                    multi-selected: GallerySelectPanelDefault.multi-selected;
                    filter-changed(t) => {
                        GallerySelectPanelDefault.filter-changed(t);
                    }
                    item-activated(ix) => {
                        GallerySelectPanelDefault.item-activated(ix);
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "SelectPanel options";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> root.scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                if root.scenario-ix == 7: Select {
                    horizontal-stretch: 1;
                    label-text: "Notice variant";
                    options: [
                        { value: "0", label: "Info", enabled: true },
                        { value: "1", label: "Warning", enabled: true },
                        { value: "2", label: "Error", enabled: true },
                    ];
                    selected-index <=> root.sp-notice-variant-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                if root.scenario-ix == 10: Select {
                    horizontal-stretch: 1;
                    label-text: "Message variant";
                    options: [
                        { value: "0", label: "List (default)", enabled: true },
                        { value: "1", label: "Empty message", enabled: true },
                        { value: "2", label: "Error message", enabled: true },
                        { value: "3", label: "Warning message", enabled: true },
                    ];
                    selected-index <=> root.sp-message-variant-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }

                if root.scenario-ix == 11: Text {
                    text: "Filter hint: type the literal `none` to show no-results empty copy.";
                    color: PrimerColors.fgColor-muted;
                    font-size: LayoutTokens.text-body-size-small;
                    wrap: word-wrap;
                }

                if root.scenario-ix == 13: Button {
                    label: "Simulate fetch";
                    clicked => {
                        root.sp-fetch-loading = true;
                        fetch-timer.start();
                    }
                }

                if root.sp-is-modal: Checkbox {
                    label: "Open modal panel";
                    checked <=> root.sp-open;
                }

                if root.scenario-ix == 1: Text {
                    text: "Selected index: " + root.sp-single-selected-index;
                    color: PrimerColors.fgColor-muted;
                    font-size: LayoutTokens.text-body-size-small;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 1px;
                    background: PrimerColors.borderColor-muted;
                }
            }
        }
    }
}
