// **FilteredActionList2** gallery — **FilteredActionList** + **SelectPanel** list-body scenarios.
import {
    ActionList2DescriptionLayout,
    ActionList2Line,
    ActionList2LineKind,
    ActionList2ListRole,
    ActionList2RowSize,
    ActionList2RowVariant,
    ActionList2SectionHeadingVariant,
    ActionList2SelectionMode,
    Button,
    FilteredActionList2,
    FilteredActionListLoadingKind,
    Icons,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../../primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../primer-slint/tokens.slint";
import {
    GalleryFilteredActionList2Default,
    GalleryFilteredActionList2Long,
} from "../state/gallery-filtered-action-list2-state.slint";
import { GalleryFilteredActionList2Multi } from "../state/gallery-filtered-action-list2-multi-state.slint";
import { GalleryFilteredActionList2SelectAll } from "../state/gallery-filtered-action-list2-select-all-state.slint";
import { GalleryDemoOptionsSidebar } from "../components/gallery-demo-options-sidebar.slint";

export component GalleryFilteredActionList2Page {
    property <int> scenario-ix: 0;

    property <[SelectOption]> scenario-options: [
        { value: "0", label: "Default", enabled: true },
        { value: "1", label: "WithLongItems", enabled: true },
        { value: "2", label: "SingleSelect", enabled: true },
        { value: "3", label: "MultiSelect", enabled: true },
        { value: "4", label: "LoadingInput", enabled: true },
        { value: "5", label: "LoadingBodySpinner", enabled: true },
        { value: "6", label: "LoadingBodySkeleton", enabled: true },
        { value: "7", label: "MessageVsList", enabled: true },
        { value: "8", label: "EmptyBody", enabled: true },
        { value: "9", label: "SelectAll", enabled: true },
    ];

    property <string> scenario-caption:
        root.scenario-ix == 0
        ? "Upstream FilteredActionList Default — prefix filter; colored leading circles."
        : root.scenario-ix == 1
        ? "Upstream FilteredActionList WithLongItems — `body-region-height` 320px."
        : root.scenario-ix == 2
        ? "Upstream SelectPanel SingleSelect — `listbox` + `single` checkmark; initial **enhancement**."
        : root.scenario-ix == 3
        ? "Upstream SelectPanel MultiSelect — `listbox` + `multiple` checkboxes; initial **bug**, **good first issue**."
        : root.scenario-ix == 4
        ? "Upstream FilteredActionList loading **input** — spinner in filter field; list rows remain."
        : root.scenario-ix == 5
        ? "Upstream FilteredActionList **body_spinner** / SelectPanel AsyncFetch — list body replaced."
        : root.scenario-ix == 6
        ? "Upstream FilteredActionList **body_skeleton** — skeleton placeholders only."
        : root.scenario-ix == 7
        ? "Upstream message body — toggle **`show-message`** vs list (permission denied copy)."
        : root.scenario-ix == 8
        ? "Upstream filtered empty — `lines: []` with **`empty-message`** (no rows)."
        : "Upstream SelectPanel **WithSelectAll** — select-all strip + **listbox** multi-select (tri-state).";

    property <bool> show-storybook-page-chrome:
        root.scenario-ix == 0 || root.scenario-ix == 1 || root.scenario-ix == 9;

    property <string> fal2-default-filter: "";
    property <string> fal2-long-filter: "";
    property <string> fal2-single-filter: "";
    property <string> fal2-multi-filter: "";
    property <string> fal2-loading-input-filter: "";
    property <string> fal2-loading-spinner-filter: "";
    property <string> fal2-loading-skeleton-filter: "";
    property <string> fal2-message-vs-list-filter: "";
    property <bool> fal2-message-vs-list-show-message: false;
    property <string> fal2-empty-body-filter: "";
    property <string> fal2-select-all-filter: "";
    property <int> fal2-single-selected-index: 0;

    property <[ActionList2Line]> fal2-loading-demo-lines: [
        {
            kind: ActionList2LineKind.row,
            label: "enhancement",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "bug",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
        {
            kind: ActionList2LineKind.row,
            label: "design",
            row-variant: ActionList2RowVariant.default,
            row-size: ActionList2RowSize.medium,
            disabled: false,
            has-leading-avatar: false,
            avatar-source: Icons.dot_fill,
            has-leading-visual: false,
            leading-icon: Icons.dot_fill,
            description: "",
            description-layout: ActionList2DescriptionLayout.none,
            truncate-inline-description: false,
            trailing-text: "",
            inactive-text: "",
            show-trailing-loading: false,
            active: false,
            section-heading-variant: ActionList2SectionHeadingVariant.subtle,
        },
    ];

    changed scenario-ix => {
        root.fal2-single-selected-index = 0;
        root.fal2-message-vs-list-show-message = false;
    }

    changed fal2-single-filter => {
        root.fal2-single-selected-index = 0;
    }

    vertical-stretch: 1;

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 1;
            padding: 24px;
            spacing: 16px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: "FilteredActionList2";
                color: PrimerColors.fgColor-default;
                font-size: 22px;
                font-weight: 600;
            }

            Text {
                text: root.scenario-caption;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                wrap: word-wrap;
            }

            if root.scenario-ix == 7: Button {
                label: root.fal2-message-vs-list-show-message ? "Show list body" : "Show message body";
                clicked => {
                    root.fal2-message-vs-list-show-message = !root.fal2-message-vs-list-show-message;
                }
            }

            Rectangle {
                horizontal-stretch: 0;
                width: 320px;
                background: PrimerColors.bgColor-default;
                border-radius: 6px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    alignment: start;

                    if root.show-storybook-page-chrome || root.scenario-ix == 2 || root.scenario-ix == 3: Text {
                        text:
                            root.scenario-ix == 1
                            ? "Filtered Action List with Long Items"
                            : root.scenario-ix == 9
                            ? "Filtered Action List"
                            : root.scenario-ix == 2
                            ? "Single select labels"
                            : root.scenario-ix == 3
                            ? "Select labels"
                            : "Filtered Action List";
                        color: PrimerColors.fgColor-default;
                        font-size: 18px;
                        font-weight: 700;
                        wrap: word-wrap;
                    }

                    if root.show-storybook-page-chrome || root.scenario-ix == 2 || root.scenario-ix == 3: Text {
                        text:
                            root.scenario-ix == 3
                            ? "Use labels to organize issues and pull requests"
                            : root.scenario-ix == 9
                            ? "Multi-select rows; use the strip to toggle all visible labels."
                            : "Please select labels that describe your issue:";
                        color: PrimerColors.fgColor-default;
                        font-size: 14px;
                        font-weight: 400;
                        wrap: word-wrap;
                    }

                    if root.scenario-ix == 0: FilteredActionList2 {
                        filter-text <=> root.fal2-default-filter;
                        placeholder: "Filter Labels";
                        lines: GalleryFilteredActionList2Default.lines;
                        filter-changed(t) => {
                            GalleryFilteredActionList2Default.filter-changed(t);
                        }
                    }

                    if root.scenario-ix == 1: FilteredActionList2 {
                        filter-text <=> root.fal2-long-filter;
                        placeholder: "Filter Labels";
                        body-region-height: 320px;
                        lines: GalleryFilteredActionList2Long.lines;
                        filter-changed(t) => {
                            GalleryFilteredActionList2Long.filter-changed(t);
                        }
                    }

                    if root.scenario-ix == 2: FilteredActionList2 {
                        filter-text <=> root.fal2-single-filter;
                        placeholder: "Filter Labels";
                        lines: GalleryFilteredActionList2Default.lines;
                        list-role: ActionList2ListRole.listbox;
                        selection-mode: ActionList2SelectionMode.single;
                        selected-index: root.fal2-single-selected-index;
                        filter-changed(t) => {
                            GalleryFilteredActionList2Default.filter-changed(t);
                        }
                        item-activated(ix) => {
                            root.fal2-single-selected-index = ix;
                        }
                    }

                    if root.scenario-ix == 3: FilteredActionList2 {
                        filter-text <=> root.fal2-multi-filter;
                        placeholder: "Filter Labels";
                        lines: GalleryFilteredActionList2Multi.lines;
                        list-role: ActionList2ListRole.listbox;
                        selection-mode: ActionList2SelectionMode.multiple;
                        multi-selected: GalleryFilteredActionList2Multi.multi-selected;
                        filter-changed(t) => {
                            GalleryFilteredActionList2Multi.filter-changed(t);
                        }
                        item-activated(ix) => {
                            GalleryFilteredActionList2Multi.item-activated(ix);
                        }
                    }

                    if root.scenario-ix == 4: FilteredActionList2 {
                        loading: true;
                        loading-kind: FilteredActionListLoadingKind.input;
                        filter-text <=> root.fal2-loading-input-filter;
                        placeholder: "Filter Labels";
                        lines: root.fal2-loading-demo-lines;
                        filter-changed(_) => {
                        }
                    }

                    if root.scenario-ix == 5: FilteredActionList2 {
                        loading: true;
                        loading-kind: FilteredActionListLoadingKind.body_spinner;
                        loading-message: "Loading labels…";
                        filter-text <=> root.fal2-loading-spinner-filter;
                        placeholder: "Filter Labels";
                        lines: root.fal2-loading-demo-lines;
                        filter-changed(_) => {
                        }
                    }

                    if root.scenario-ix == 6: FilteredActionList2 {
                        loading: true;
                        loading-kind: FilteredActionListLoadingKind.body_skeleton;
                        filter-text <=> root.fal2-loading-skeleton-filter;
                        placeholder: "Filter Labels";
                        lines: [];
                        filter-changed(_) => {
                        }
                    }

                    if root.scenario-ix == 7: FilteredActionList2 {
                        filter-text <=> root.fal2-message-vs-list-filter;
                        placeholder: "Filter Labels";
                        lines: root.fal2-message-vs-list-show-message ? [] : root.fal2-loading-demo-lines;
                        show-message: root.fal2-message-vs-list-show-message;
                        message-title: "No access";
                        message-description: "You do not have permission to view these labels.";
                        filter-changed(_) => {
                        }
                    }

                    if root.scenario-ix == 8: FilteredActionList2 {
                        filter-text <=> root.fal2-empty-body-filter;
                        placeholder: "Filter Labels";
                        lines: [];
                        empty-message: "No labels match your filter.";
                        filter-changed(_) => {
                        }
                    }

                    if root.scenario-ix == 9: FilteredActionList2 {
                        select-all-visible: true;
                        list-role: ActionList2ListRole.listbox;
                        selection-mode: ActionList2SelectionMode.multiple;
                        filter-text <=> root.fal2-select-all-filter;
                        placeholder: "Filter Labels";
                        lines: GalleryFilteredActionList2SelectAll.lines;
                        multi-selected: GalleryFilteredActionList2SelectAll.multi-selected;
                        select-all-checked <=> GalleryFilteredActionList2SelectAll.select-all-checked;
                        select-all-indeterminate <=> GalleryFilteredActionList2SelectAll.select-all-indeterminate;
                        filter-changed(t) => {
                            GalleryFilteredActionList2SelectAll.filter-changed(t);
                        }
                        item-activated(ix) => {
                            GalleryFilteredActionList2SelectAll.item-activated(ix);
                        }
                        select-all-changed(on) => {
                            GalleryFilteredActionList2SelectAll.select-all-changed(on);
                        }
                    }
                }
            }
        }

        Rectangle { }

        GalleryDemoOptionsSidebar {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                Text {
                    text: "Scenario";
                    font-size: LayoutTokens.text-body-size-medium;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                }

                Select {
                    horizontal-stretch: 1;
                    label-text: "Filtered list options";
                    placeholder: "Choose…";
                    options: root.scenario-options;
                    selected-index <=> root.scenario-ix;
                    validation-status: ValidationStatus.none;
                    selected-changed(_i) => {
                    }
                }
            }
        }
    }
}
