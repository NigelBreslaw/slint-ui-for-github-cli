/// **SelectPanel2** gallery globals — **Node** / **Rust** bridges.

import { ActionList2Line } from "../../../primer-slint/primer.slint";

export global GallerySelectPanel2Default {
    in-out property <[ActionList2Line]> lines: [];
    in-out property <[bool]> multi-selected: [];
    callback filter-changed(string);
    callback item-activated(int);
}

export global GallerySelectPanel2Single {
    in-out property <[ActionList2Line]> lines: [];
    callback filter-changed(string);
}

export global GallerySelectPanel2Disabled {
    in-out property <[ActionList2Line]> lines: [];
    in-out property <[bool]> multi-selected: [];
    callback filter-changed(string);
