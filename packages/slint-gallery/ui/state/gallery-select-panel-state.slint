/// **SelectPanel** gallery globals — **Node** / **Rust** bridges.

import { ActionListLine } from "../../../primer-slint/primer.slint";

export global GallerySelectPanelDefault {
    in-out property <[ActionListLine]> lines: [];
    in-out property <[bool]> multi-selected: [];
    callback filter-changed(string);
    callback item-activated(int);
}

export global GallerySelectPanelSingle {
    in-out property <[ActionListLine]> lines: [];
    callback filter-changed(string);
}

export global GallerySelectPanelDisabled {
    in-out property <[ActionListLine]> lines: [];
    in-out property <[bool]> multi-selected: [];
    callback filter-changed(string);
    callback item-activated(int);
}

export global GallerySelectPanelCancel {
    in-out property <[ActionListLine]> lines: [];
    in-out property <[bool]> multi-selected: [];
    callback filter-changed(string);
    callback item-activated(int);
    callback reset();
}

export global GallerySelectPanelFetch {
    in-out property <[ActionListLine]> lines: [];
    callback filter-changed(string);
}

/// **MultiSelectModal** — working selection; **Cancel** restores via **`reset()`**.
export global GallerySelectPanelModalMulti {
    in-out property <[ActionListLine]> lines: [];
    in-out property <[bool]> multi-selected: [];
    callback filter-changed(string);
    callback item-activated(int);
    callback reset();
}
