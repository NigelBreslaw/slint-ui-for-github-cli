/// Second **index multi-select** global for **Action list** listbox scenario (separate selection state from **`GalleryActionListMultiSelect`**). Wired in **`gallery-main.ts`**.
export global GalleryActionListListboxMultiSelect {
    in-out property <[bool]> row-checked: [true, false, false, false];
    in-out property <string> last-activated-label: "";
    in-out property <string> selection-summary: "";
    callback row-activated(int);
}
