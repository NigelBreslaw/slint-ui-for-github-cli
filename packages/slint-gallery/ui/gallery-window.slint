import { PrimerColors } from "../../primer-slint/tokens.slint";
import { GalleryHeader } from "./components/gallery-header.slint";
import { GallerySidebar } from "./components/gallery-sidebar.slint";
import { GalleryButtonsPage } from "./views/gallery-buttons-page.slint";
import { GalleryIconButtonPage } from "./views/gallery-icon-button-page.slint";
import { GalleryCounterLabelPage } from "./views/gallery-counter-label-page.slint";
import { GalleryAvatarPage } from "./views/gallery-avatar-page.slint";
import { GalleryLabelPage } from "./views/gallery-label-page.slint";
import { GallerySkeletonBoxPage } from "./views/gallery-skeleton-box-page.slint";
import { GallerySpinnerPage } from "./views/gallery-spinner-page.slint";
import { GalleryBannerPage } from "./views/gallery-banner-page.slint";
import { GalleryCheckboxPage } from "./views/gallery-checkbox-page.slint";
import { GalleryRadioPage } from "./views/gallery-radio-page.slint";
import { GalleryDataTablePage } from "./views/gallery-data-table-page.slint";
import { GalleryPaginationPage } from "./views/gallery-pagination-page.slint";
import { GalleryAnchoredOverlayPage } from "./views/gallery-anchored-overlay-page.slint";
import { GalleryActionListPage } from "./views/gallery-action-list-page.slint";
import { GalleryFilteredActionListPage } from "./views/gallery-filtered-action-list-page.slint";
import { GallerySelectPanelPage } from "./views/gallery-select-panel-page.slint";
import { GalleryActionMenuPage } from "./views/gallery-action-menu-page.slint";
import { GalleryDialogsPlaygroundPage } from "./views/gallery-dialog-playground-page.slint";
import { GallerySheetsPage } from "./views/gallery-sheets-page.slint";
import { GalleryStateLabelPage } from "./views/gallery-state-label-page.slint";
import { GalleryToggleSwitchPage } from "./views/gallery-toggle-switch-page.slint";
import { GalleryPrimerTextInputPage } from "./views/gallery-primer-text-input-page.slint";
import { GallerySegmentedControlPage } from "./views/gallery-segmented-control-page.slint";
import { GallerySelectPage } from "./views/gallery-select-page.slint";
import { GalleryTreeViewPage } from "./views/gallery-tree-view-page.slint";
import { GalleryUnderlineNavPage } from "./views/gallery-underline-nav-page.slint";
import { AppWindow } from "../../primer-slint/tokens.slint";
import { Icons } from "../../primer-slint/primer.slint";
import { GalleryState } from "./state/gallery-state.slint";

import "../../primer-slint/assets/fonts/MonaSans-VariableFont.ttf";
import "../../primer-slint/assets/fonts/MonaSans-Italic-VariableFont.ttf";
import "../../primer-slint/assets/fonts/VeraMono.ttf";

/// Re-export items for use in Rust, Node, etc.
export { Icons }
export { GalleryActionListMenuMultiSelect } from "./state/gallery-action-list-menu-multi-select-state.slint";
export { GalleryActionListListboxMultiSelect } from "./state/gallery-action-list-listbox-multi-select-state.slint";
export {
    GalleryFilteredActionListDefault,
    GalleryFilteredActionListLong,
} from "./state/gallery-filtered-action-list-state.slint";
export { GalleryFilteredActionListMulti } from "./state/gallery-filtered-action-list-multi-state.slint";
export { GalleryFilteredActionListSelectAll } from "./state/gallery-filtered-action-list-select-all-state.slint";
export {
    GallerySelectPanelCancel,
    GallerySelectPanelDefault,
    GallerySelectPanelDisabled,
    GallerySelectPanelFetch,
    GallerySelectPanelModalMulti,
    GallerySelectPanelSingle,
} from "./state/gallery-select-panel-state.slint";
export { GalleryTreeViewListModels } from "./state/gallery-tree-view-list-models.slint";
export { GallerySidebarNav } from "./state/gallery-sidebar-nav.slint";
export { GalleryState } from "./state/gallery-state.slint";

export component GalleryWindow inherits Window {

    changed width => {
        AppWindow.window-width = root.width;
    }
    changed height => {
        AppWindow.window-height = root.height;
    }

    init => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
    }

    preferred-width: 1000px;
    preferred-height: 800px;
    min-width: 360px;
    min-height: 360px;
    title: "Primer gallery";
    default-font-family: "Mona Sans";
    icon: Icons.palette;

    background: PrimerColors.bgColor-default;

    VerticalLayout {
        GalleryHeader {
            height: 64px;
        }

        HorizontalLayout {
            vertical-stretch: 1;

            GallerySidebar { }

            main-scroll := Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;

                gallery-flick := Flickable {
                    width: main-scroll.width;
                    height: main-scroll.height;

                    viewport-width: self.width;
                    viewport-height: gallery-main.preferred-height;

                    gallery-main := VerticalLayout {
                        width: gallery-flick.width;
                        min-height: gallery-flick.height;
                        alignment: start;

                        if GalleryState.selected-page-id == "action-list-playground": GalleryActionListPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "filtered-action-list-playground": GalleryFilteredActionListPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "select-panel-playground": GallerySelectPanelPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "action-menu-playground": GalleryActionMenuPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "anchored-overlay-playground": GalleryAnchoredOverlayPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "avatar-playground": GalleryAvatarPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "banner-playground": GalleryBannerPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "buttons-playground": GalleryButtonsPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "icon-button-playground": GalleryIconButtonPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "counter-label-playground": GalleryCounterLabelPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "data-table-playground": GalleryDataTablePage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "pagination-playground": GalleryPaginationPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "dialogs-playground": GalleryDialogsPlaygroundPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "sheets-playground": GallerySheetsPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "checkbox-playground": GalleryCheckboxPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "radio-playground": GalleryRadioPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "label-playground": GalleryLabelPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "select-playground": GallerySelectPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "segmented-control-playground": GallerySegmentedControlPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "skeleton-box-playground": GallerySkeletonBoxPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "spinner-playground": GallerySpinnerPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "state-label-playground": GalleryStateLabelPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "text-input-playground": GalleryPrimerTextInputPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "toggle-switch-playground": GalleryToggleSwitchPage {
                            height: main-scroll.height;
                        }

                        if GalleryState.selected-page-id == "tree-view-playground": GalleryTreeViewPage {
                            width: gallery-flick.width;
                            horizontal-stretch: 1;
                        }

                        if GalleryState.selected-page-id == "underline-nav-playground": GalleryUnderlineNavPage {
                            height: main-scroll.height;
                        }
                    }
                }
            }
        }
    }
}
