import { PrimerColors } from "../../primer-slint/tokens.slint";
import { GalleryHeader } from "./components/gallery-header.slint";
import { GallerySidebar } from "./components/gallery-sidebar.slint";
import { GalleryButtonsPage } from "./views/gallery-buttons-page.slint";
import { GalleryNavsPage } from "./views/gallery-navs-page.slint";
import { GalleryFeedbackPage } from "./views/gallery-feedback-page.slint";
import { GalleryFormsPage } from "./views/gallery-forms-page.slint";
import { GalleryDataPage } from "./views/gallery-data-page.slint";
import { GalleryActionListPage } from "./views/gallery-action-list-page.slint";
import { GalleryDialogsPage } from "./views/gallery-dialogs-page.slint";
import { GallerySelectPanelPage } from "./views/gallery-select-panel-page.slint";
import { GalleryStateLabelPage } from "./views/gallery-state-label-page.slint";
import { GalleryToggleSwitchPage } from "./views/gallery-toggle-switch-page.slint";
import { AppWindow } from "../../primer-slint/tokens.slint";
import { Icons } from "../../primer-slint/primer.slint";

import "../../primer-slint/assets/fonts/MonaSans-VariableFont.ttf";
import "../../primer-slint/assets/fonts/MonaSans-Italic-VariableFont.ttf";
import "../../primer-slint/assets/fonts/VeraMono.ttf";

/// Re-export items for use in Rust, Node, etc.
export { Icons }
export { GalleryActionListMultiSelect } from "./state/gallery-action-list-multi-select-state.slint";
export { GalleryActionListListboxMultiSelect } from "./state/gallery-action-list-listbox-multi-select-state.slint";
export { GallerySelectPanelMulti } from "./state/gallery-select-panel-multi-state.slint";
export {
    GalleryFilteredActionListDefault,
    GalleryFilteredActionListLong,
} from "./state/gallery-filtered-action-list-state.slint";
export { GalleryFilteredActionListSelectAll } from "./state/gallery-filtered-action-list-select-all-state.slint";


export global GalleryState {
    in-out property <int> selected-group-index: 4;
}

export component GalleryWindow inherits Window {

    changed width => {
        AppWindow.window-width = root.width;
    }
    changed height => {
        AppWindow.window-height = root.height;
    }

    init => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
    }

    preferred-width: 1000px;
    preferred-height: 800px;
    min-width: 360px;
    min-height: 360px;
    title: "Primer gallery";
    default-font-family: "Mona Sans";
    icon: Icons.palette;

    background: PrimerColors.bgColor-default;

    VerticalLayout {
        GalleryHeader {
            height: 64px;
        }

        HorizontalLayout {

            GallerySidebar {
                selected-index: GalleryState.selected-group-index;
                group-selected(idx) => {
                    GalleryState.selected-group-index = idx;
                }
            }

            main-scroll := Rectangle {

                gallery-flick := Flickable {
                    width: main-scroll.width;
                    height: main-scroll.height;

                    viewport-width: self.width;
                    viewport-height: gallery-main.preferred-height;

                    gallery-main := VerticalLayout {
                        width: gallery-flick.width;
                        min-height: gallery-flick.height;
                        alignment: start;

                        if GalleryState.selected-group-index == 0: GalleryButtonsPage { }

                        if GalleryState.selected-group-index == 1: GalleryNavsPage { }

                        if GalleryState.selected-group-index == 2: GalleryFeedbackPage { }

                        if GalleryState.selected-group-index == 3: GalleryFormsPage { }

                        if GalleryState.selected-group-index == 4: GalleryDataPage { }

                        if GalleryState.selected-group-index == 5: GalleryActionListPage { }

                        if GalleryState.selected-group-index == 6: GalleryDialogsPage { }

                        if GalleryState.selected-group-index == 7: GallerySelectPanelPage { }

                        if GalleryState.selected-group-index == 8: GalleryStateLabelPage {
                            height: main-scroll.height;

                        }

                        if GalleryState.selected-group-index == 9: GalleryToggleSwitchPage {
                            height: main-scroll.height;
                        }
                    }
                }
            }
        }
    }
}
