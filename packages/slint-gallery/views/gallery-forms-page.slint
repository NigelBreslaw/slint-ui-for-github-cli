import {
    AnchoredOverlay,
    AnchoredOverlayAlign,
    AnchoredOverlaySide,
    Button,
    ButtonAlignContent,
    ButtonVariant,
    Checkbox,
    CheckboxGroup,
    Icons,
    LayoutTokens,
    PrimerTextInput,
    TextInputLoaderPosition,
    Select,
    SelectOption,
    SelectPanel,
    SelectPanelItem,
    SelectPanelMode,
    Size,
    ToggleSwitch,
    ToggleSwitchSize,
    ToggleSwitchStatusLabelPosition,
    ValidationStatus,
} from "../../primer-slint/primer.slint";
import { GallerySelectPanelMulti } from "../state/gallery-select-panel-multi-state.slint";
import { AppWindow, PrimerColors } from "../../primer-slint/tokens.slint";

export component GalleryFormsPage inherits VerticalLayout {
    spacing: 28px;
    width: 100%;

    private property <[SelectOption]> demo-select-options: [
        { value: "one", label: "First option", enabled: true },
        { value: "two", label: "Second option", enabled: true },
        { value: "three", label: "Third option", enabled: false },
    ];
    private property <int> demo-select-index: 0;

    private property <bool> demo-cb-off: false;
    private property <bool> demo-cb-on: true;
    private property <bool> demo-cb-label: false;
    private property <bool> demo-cb-indet: true;
    private property <bool> demo-cg-opt1: false;
    private property <bool> demo-cg-opt2: true;

    private property <bool> demo-ts-spike: false;
    private property <bool> demo-ts-end: false;
    private property <bool> demo-ts-custom: false;

    private property <string> demo-p1-block: "";
    private property <string> demo-p1-small: "";
    private property <string> demo-p1-large: "";
    private property <string> demo-p1-disabled: "Cannot edit";
    private property <string> demo-p1-caption: "";
    private property <string> demo-p1-error: "";
    private property <string> demo-p1-success: "";
    private property <string> demo-p1-required: "";
    private property <string> demo-p3-lead: "";
    private property <string> demo-p3-trail: "value";
    private property <string> demo-p3-mono: "repo/pkg@v1";
    private property <string> demo-p3-default-fill: "";
    private property <string> demo-p3-contrast-fill: "";
    private property <string> demo-p4-plain: "";
    private property <string> demo-p4-lead-auto: "";
    private property <string> demo-p4-trail-auto: "";
    private property <string> demo-p4-both-auto: "";
    private property <string> demo-p4-force-lead: "";
    private property <string> demo-p4-force-trail: "";
    private property <string> demo-p4-both-force-lead: "";
    private property <string> demo-p4-both-force-trail: "";
    private property <string> demo-p5-limit-only: "Hello";
    private property <string> demo-p5-limit-caption: "Notes";
    private property <string> demo-p5-exceed: "This text exceeds the twelve-character limit.";
    private property <string> demo-p5-hidden-label: "";
    private property <string> demo-p6-trailing-clear: "Clear me";

    private property <bool> demo-select-panel-open: false;
    private property <string> demo-sp-filter: "";
    private property <int> demo-sp-focused: 0;
    private property <[SelectPanelItem]> demo-sp-items: [
        { value: "enhancement", label: "enhancement", description: "New feature or request", swatch: #84b6eb, enabled: true },
        { value: "bug", label: "bug", description: "Something isn't working", swatch: #d73a4a, enabled: true },
        { value: "good-first-issue", label: "good first issue", description: "Good for newcomers", swatch: #3fb950, enabled: true },
        { value: "documentation", label: "documentation", description: "Improvements or additions to documentation", swatch: #0075ca, enabled: true },
        { value: "duplicate", label: "duplicate", description: "This issue or pull request already exists", swatch: #cfd3d7, enabled: true },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Select";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            width: 100%;
            label-text: "Demo select";
            placeholder: "Choose an option…";
            options: demo-select-options;
            selected-index <=> demo-select-index;
            validation-status: ValidationStatus.success;
            validation-message: "Static gallery model.";
            selected-changed(_idx) => {
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "PrimerTextInput";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "PR1–2: layout + tokens/states; PR3: leading/trailing visuals, monospace, contrast.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 150px;
                block: true;
                label-text: "Block";
                placeholder: "Placeholder…";
                text <=> demo-p1-block;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 150px;
                block: true;
                size: Size.small;
                label-text: "Small";
                placeholder: "Small height";
                text <=> demo-p1-small;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 150px;
                block: true;
                size: Size.large;
                label-text: "Large";
                placeholder: "Large height";
                text <=> demo-p1-large;
                edited(_) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 150px;
                block: true;
                label-text: "Disabled";
                text <=> demo-p1-disabled;
                disabled: true;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 150px;
                block: true;
                label-text: "With caption";
                caption: "Helper text sits below the field.";
                placeholder: "Type…";
                text <=> demo-p1-caption;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 150px;
                block: true;
                label-text: "Required label";
                required: true;
                placeholder: "Required field";
                text <=> demo-p1-required;
                edited(_) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 150px;
                block: true;
                label-text: "Validation error";
                validation-status: ValidationStatus.error;
                validation-message: "Something went wrong";
                text <=> demo-p1-error;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 150px;
                block: true;
                label-text: "Validation success";
                validation-status: ValidationStatus.success;
                validation-message: "Looks good.";
                text <=> demo-p1-success;
                edited(_) => {
                }
            }
        }

        Text {
            text: "PrimerTextInput — PR3 (visuals / monospace / contrast)";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Leading visual";
                placeholder: "Search…";
                has-leading-visual: true;
                leading-visual: Icons.check_circle;
                text <=> demo-p3-lead;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Trailing visual";
                placeholder: "Enter monies";
                has-trailing-visual: true;
                trailing-visual: Icons.info;
                text <=> demo-p3-trail;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Monospace";
                monospace: true;
                placeholder: "package/name";
                text <=> demo-p3-mono;
                edited(_) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Default fill";
                caption: "canvas default (PR2 rest token).";
                text <=> demo-p3-default-fill;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Contrast fill";
                caption: "data-contrast / bgColor-inset.";
                contrast: true;
                text <=> demo-p3-contrast-fill;
                edited(_) => {
                }
            }
        }

        Text {
            text: "PrimerTextInput — PR4 (loading / loader-position)";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            font-weight: 600;
        }

        Text {
            text: "`auto`: spinner in leading slot when `has-leading-visual`; otherwise trailing slot (reserved width, no jump). Explicit `leading` / `trailing` force that column.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · no visuals · auto";
                caption: "Spinner trailing (no icons).";
                loading: true;
                loader-position: TextInputLoaderPosition.auto;
                placeholder: "Loading…";
                text <=> demo-p4-plain;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · leading visual · auto";
                caption: "Spinner replaces leading.";
                loading: true;
                loader-position: TextInputLoaderPosition.auto;
                has-leading-visual: true;
                leading-visual: Icons.check_circle;
                placeholder: "Search…";
                text <=> demo-p4-lead-auto;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · trailing visual · auto";
                caption: "Spinner replaces trailing.";
                loading: true;
                loader-position: TextInputLoaderPosition.auto;
                has-trailing-visual: true;
                trailing-visual: Icons.info;
                placeholder: "Amount…";
                text <=> demo-p4-trail-auto;
                edited(_) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · both visuals · auto";
                caption: "Spinner replaces leading; trailing icon stays.";
                loading: true;
                loader-position: TextInputLoaderPosition.auto;
                has-leading-visual: true;
                leading-visual: Icons.check_circle;
                has-trailing-visual: true;
                trailing-visual: Icons.info;
                text <=> demo-p4-both-auto;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · no visuals · loader leading";
                caption: "Explicit leading column.";
                loading: true;
                loader-position: TextInputLoaderPosition.leading;
                placeholder: "Forced leading…";
                text <=> demo-p4-force-lead;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · no visuals · loader trailing";
                caption: "Explicit trailing column.";
                loading: true;
                loader-position: TextInputLoaderPosition.trailing;
                placeholder: "Forced trailing…";
                text <=> demo-p4-force-trail;
                edited(_) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · both visuals · loader leading";
                caption: "Spinner leading; trailing icon unchanged.";
                loading: true;
                loader-position: TextInputLoaderPosition.leading;
                has-leading-visual: true;
                leading-visual: Icons.check_circle;
                has-trailing-visual: true;
                trailing-visual: Icons.info;
                text <=> demo-p4-both-force-lead;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 220px;
                block: true;
                label-text: "Loading · both visuals · loader trailing";
                caption: "Leading icon unchanged; spinner trailing.";
                loading: true;
                loader-position: TextInputLoaderPosition.trailing;
                has-leading-visual: true;
                leading-visual: Icons.check_circle;
                has-trailing-visual: true;
                trailing-visual: Icons.info;
                text <=> demo-p4-both-force-trail;
                edited(_) => {
                }
            }
        }

        Text {
            text: "(character limit / visually hidden label)";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            font-weight: 600;
        }

        Text {
            text: "Counter uses `string.character-count` / `character-limit`; over-limit chrome matches validation danger. `label-visually-hidden` hides the label row like CheckboxGroup.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            PrimerTextInput {
                width: 320px;
                block: true;
                label-text: "WithCharacterLimit";
                character-limit: 20;
                placeholder: "Up to 20 characters…";
                text <=> demo-p5-limit-only;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 320px;
                block: true;
                label-text: "WithCharacterLimitAndCaption";
                caption: "Caption stacks above the counter row (same as other fields).";
                character-limit: 24;
                placeholder: "Type…";
                text <=> demo-p5-limit-caption;
                edited(_) => {
                }
            }

            PrimerTextInput {
                width: 320px;
                block: true;
                label-text: "WithCharacterLimitExceeded";
                caption: "Border + counter turn danger when over limit; feedback uses editable `text` only (caption/placeholder are separate).";
                character-limit: 12;
                character-limit-exceeded-message: "Reduce length to continue.";
                text <=> demo-p5-exceed;
                edited(_) => {
                }
            }
        }

        PrimerTextInput {
            width: 320px;
            block: true;
            label-text: "Given name";
            label-visually-hidden: true;
            caption: "VisuallyHiddenLabel: legend text is suppressed; caption remains visible for sighted users.";
            placeholder: "Given name…";
            text <=> demo-p5-hidden-label;
            edited(_) => {
            }
        }

        Text {
            text: "(trailing action / clear)";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            font-weight: 600;
        }

        Text {
            text: "WithTrailingAction: invisible IconButton + Icons.x clears `text` and fires `edited`. WithTooltipDirection: no Slint tooltip-direction prop — parity note only.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        PrimerTextInput {
            width: 320px;
            block: true;
            label-text: "WithTrailingAction";
            caption: "Tap × to clear; slot stays reserved when empty (no layout jump).";
            has-trailing-action: true;
            placeholder: "Type or clear…";
            text <=> demo-p6-trailing-clear;
            edited(_) => {
            }
        }
    }

    anchored-overlay-demo-column := VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "AnchoredOverlay + SelectPanel (anchored)";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "AnchoredOverlay: vertical-side auto (flip), align start; SelectPanel multi mode (`multi-selected` + `multi-item-activated`, `show-footer` + children, `focused-index` accent). Escape closes the popup. See anchored-popupwindow.md in this folder.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: "Labels";
            color: PrimerColors.fgColor-default;
            font-size: 12px;
            font-weight: 600;
            wrap: word-wrap;
        }

        btn-select-panel := Button {
            width: 100%;
            max-width: 420px;
            align-content: ButtonAlignContent.start;
            label: "bug, good first issue";
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                demo-select-panel-open = true;
            }
        }

        anchored-overlay-select-panel := AnchoredOverlay {
            open <=> demo-select-panel-open;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.start;
            panel-width: 360px;
            panel-height: 480px;
            anchor-abs-x: btn-select-panel.absolute-position.x;
            anchor-abs-y: btn-select-panel.absolute-position.y;
            anchor-width: btn-select-panel.width;
            anchor-height: btn-select-panel.height;
            close-requested => {
            }

            SelectPanel {
                width: 100%;
                mode: SelectPanelMode.multi;
                title: "Select labels";
                subtitle: "Use labels to organize issues and pull requests";
                filter-placeholder: "Filter items";
                filter-text <=> demo-sp-filter;
                multi-items: demo-sp-items;
                multi-selected: GallerySelectPanelMulti.row-checked;
                focused-index: demo-sp-focused;
                list-max-height: 200px;
                show-footer: true;
                filter-changed(_t) => {
                }
                single-selected-changed(_i) => {
                }
                multi-item-activated(ix) => {
                    GallerySelectPanelMulti.row-activated(ix);
                }

                HorizontalLayout {
                    spacing: LayoutTokens.button-content-gap;
                    width: 100%;
                    alignment: end;

                    Button {
                        label: "Cancel";
                        clicked => {
                            demo-select-panel-open = false;
                        }
                    }

                    Button {
                        label: "Apply";
                        variant: ButtonVariant.primary;
                        clicked => {
                            demo-select-panel-open = false;
                        }
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "ToggleSwitch";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Default";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Text {
                        text: "Toggle label";
                        color: PrimerColors.fgColor-default;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                    }

                    ToggleSwitch {
                        checked <=> demo-ts-spike;
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Loading";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    checked: false;
                    loading: true;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Label end";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    size: ToggleSwitchSize.small;
                    status-label-position: ToggleSwitchStatusLabelPosition.end;
                    checked <=> demo-ts-end;
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Checked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    checked: true;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Disabled (off)";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    disabled: true;
                    checked: false;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Checked + disabled";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    disabled: true;
                    checked: true;
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Custom labels";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    button-label-on: "Active";
                    button-label-off: "Inactive";
                    checked <=> demo-ts-custom;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Loading, label end";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                ToggleSwitch {
                    loading: true;
                    status-label-position: ToggleSwitchStatusLabelPosition.end;
                    checked: false;
                }
            }
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Checkbox";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 16px;
            alignment: start;

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Unchecked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Checkbox {
                    checked <=> demo-cb-off;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: start;

                Text {
                    text: "Checked";
                    font-size: 12px;
                    color: PrimerColors.fgColor-muted;
                }

                Checkbox {
                    checked <=> demo-cb-on;
                }
            }
        }

        Checkbox {
            width: 100%;
            label: "Send email notifications";
            checked <=> demo-cb-label;
        }

        Checkbox {
            width: 100%;
            label: "Indeterminate (first click checks)";
            checked: false;
            indeterminate <=> demo-cb-indet;
        }

        Checkbox {
            width: 100%;
            label: "Leading icon + label";
            checked: true;
        }

        Text {
            text: "CheckboxGroup";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Legend, caption, required asterisk, validation, disabled dimming (mirror disabled on each Checkbox), and visually hidden legend.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        CheckboxGroup {
            width: 100%;
            label: "Features";
            caption: "Choose one or more options.";
            required: true;
            validation-status: !demo-cg-opt1 && !demo-cg-opt2 ? ValidationStatus.error : ValidationStatus.success;
            validation-message: !demo-cg-opt1 && !demo-cg-opt2 ? "Pick at least one." : "Looks good.";

            Checkbox {
                width: 100%;
                label: "Option A";
                checked <=> demo-cg-opt1;
            }

            Checkbox {
                width: 100%;
                label: "Option B";
                checked <=> demo-cg-opt2;
            }
        }

        CheckboxGroup {
            width: 100%;
            label: "Disabled group";
            disabled: true;

            Checkbox {
                width: 100%;
                label: "Cannot toggle";
                disabled: true;
                checked: false;
            }

            Checkbox {
                width: 100%;
                label: "Also off";
                disabled: true;
                checked: true;
            }
        }

        CheckboxGroup {
            width: 100%;
            label: "Screen-reader legend (hidden in UI)";
            label-visually-hidden: true;
            caption: "Legend text is not shown; caption remains.";

            Checkbox {
                width: 100%;
                label: "Alpha";
            }

            Checkbox {
                width: 100%;
                label: "Beta";
            }
        }
    }
}
