import {
    AnchoredOverlay,
    AnchoredOverlayAlign,
    AnchoredOverlaySide,
    Button,
    ButtonAlignContent,
    ButtonVariant,
    Icons,
    LayoutTokens,
    SelectPanel,
    SelectPanelItem,
    SelectPanelMode,
} from "../../primer-slint/primer.slint";
import { PrimerColors } from "../../primer-slint/tokens.slint";
import { GallerySelectPanelMulti } from "../gallery-select-panel-multi-state.slint";

/// Primer **SelectPanel** gallery: Storybook-aligned demo regions will be filled in as **SelectPanelCompose** lands.
/// **AnchoredOverlay** + trigger patterns stay in the gallery (same as Forms); this page owns the panel interior demos only.
export component GallerySelectPanelPage inherits VerticalLayout {
    spacing: 28px;
    width: 100%;
    alignment: start;

    private property <bool> baseline-select-panel-open: false;
    private property <string> baseline-sp-filter: "";
    private property <int> baseline-sp-focused: 0;
    private property <[SelectPanelItem]> baseline-sp-items: [
        { value: "enhancement", label: "enhancement", description: "New feature or request", swatch: #84b6eb, enabled: true },
        { value: "bug", label: "bug", description: "Something isn't working", swatch: #d73a4a, enabled: true },
        { value: "good-first-issue", label: "good first issue", description: "Good for newcomers", swatch: #3fb950, enabled: true },
        { value: "documentation", label: "documentation", description: "Improvements or additions to documentation", swatch: #0075ca, enabled: true },
        { value: "duplicate", label: "duplicate", description: "This issue or pull request already exists", swatch: #cfd3d7, enabled: true },
    ];

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "Select panel";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Composable **SelectPanelCompose** parts and monolithic **SelectPanel** examples mirror Primer React SelectPanel stories. Each block below reserves space for one gallery demo; implementations follow in later PRs.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 12px;
        width: 100%;

        Text {
            text: "A0 — Baseline (monolithic)";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Same pattern as Forms: AnchoredOverlay (vertical-side auto, align start), monolithic SelectPanel in multi mode with `multi-selected` / `multi-item-activated` via `GallerySelectPanelMulti`, footer Cancel/Apply. Escape closes the overlay.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Text {
            text: "Labels";
            color: PrimerColors.fgColor-default;
            font-size: 12px;
            font-weight: 600;
            wrap: word-wrap;
        }

        btn-baseline-select-panel := Button {
            width: 100%;
            max-width: 420px;
            align-content: ButtonAlignContent.start;
            label: "bug, good first issue";
            has-trailing-icon: true;
            trailing-icon: Icons.triangle_down;
            clicked => {
                baseline-select-panel-open = true;
            }
        }

        AnchoredOverlay {
            open <=> baseline-select-panel-open;
            vertical-side: AnchoredOverlaySide.auto;
            align: AnchoredOverlayAlign.start;
            panel-width: 360px;
            panel-height: 480px;
            anchor-abs-x: btn-baseline-select-panel.absolute-position.x;
            anchor-abs-y: btn-baseline-select-panel.absolute-position.y;
            anchor-width: btn-baseline-select-panel.width;
            anchor-height: btn-baseline-select-panel.height;
            close-requested => {
            }

            SelectPanel {
                width: 100%;
                mode: SelectPanelMode.multi;
                title: "Select labels";
                subtitle: "Use labels to organize issues and pull requests";
                filter-placeholder: "Filter items";
                filter-text <=> baseline-sp-filter;
                multi-items: baseline-sp-items;
                multi-selected: GallerySelectPanelMulti.row-checked;
                focused-index: baseline-sp-focused;
                list-max-height: 200px;
                show-footer: true;
                filter-changed(_t) => {
                }
                single-selected-changed(_i) => {
                }
                multi-item-activated(ix) => {
                    GallerySelectPanelMulti.row-activated(ix);
                }

                HorizontalLayout {
                    spacing: LayoutTokens.button-content-gap;
                    width: 100%;
                    alignment: end;

                    Button {
                        label: "Cancel";
                        clicked => {
                            baseline-select-panel-open = false;
                        }
                    }

                    Button {
                        label: "Apply";
                        variant: ButtonVariant.primary;
                        clicked => {
                            baseline-select-panel-open = false;
                        }
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "1 — Default multi-select labels";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: full compose stack with filter and multi-select rows.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "2 — Custom filter placeholder";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: SelectPanelFilter with non-default placeholder.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "3 — Item dividers";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: scroll body with ActionListItemDivider between rows.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "4 — Notice under header";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: Banner between heading and filter.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "5 — Footer secondary actions";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: footer with Button / text actions.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "6 — Single selection list";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: ActionListRow single-select semantics.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "7 — Disabled / inactive rows";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: disabled and inactive row styling.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "8 — Loading in list region";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: list chrome with loading until items appear.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "9 — No results (empty message)";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: empty message when filter matches nothing.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "10 — Error / warning message";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: message part error and warning variants.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "11 — Overflowing list / max height";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: list max height with scroll inside the panel.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Text {
            text: "12 — Rich empty body (optional)";
            color: PrimerColors.fgColor-default;
            font-size: 13px;
            font-weight: 600;
        }

        Text {
            text: "Placeholder: custom body / children under empty state title.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}
