import {
    Button,
    ButtonVariant,
    DialogAlignPreset,
    DialogBody,
    DialogCompose,
    DialogFooter,
    DialogFillMode,
    DialogHeader,
    DialogHeightPreset,
    StandardDialogHeader,
    DialogNarrowPositionPreset,
    DialogPositionPreset,
    DialogWidthPreset,
} from "../../primer-slint/primer.slint";
import {
    DialogTokens,
    PrimerColors,
} from "../../primer-slint/tokens.slint";

// Gallery dialog modals (`DialogCompose`), timers, and dialog-only state; the page drives fields via `in` / `in-out` bindings.
export component GalleryDialogInstances inherits VerticalLayout {
    spacing: 0px;

    in-out property <bool> default-outer-open: false;
    in-out property <bool> default-inner-open: false;
    in-out property <bool> playground-open: false;
    in-out property <bool> align-demo-open: false;
    in-out property <bool> side-sheet-open: false;
    in-out property <bool> narrow-demo-open: false;
    in-out property <bool> custom-renderers-open: false;
    in-out property <bool> direct-sub-open: false;
    in-out property <bool> stress-test-open: false;
    in-out property <bool> stress-test-inner-open: false;
    in-out property <bool> multistep-footer-open: false;
    in-out property <int> multistep-footer-step: 0;
    in-out property <bool> dynamic-footer-open: false;
    in-out property <int> dynamic-footer-variant: 0;
    in-out property <bool> loading-footer-open: false;
    in-out property <bool> loading-footer-submitting: false;
    in-out property <bool> loading-footer-deleting: false;
    in-out property <bool> loading-custom-footer-open: false;
    in-out property <bool> loading-custom-saving: false;
    in-out property <bool> loading-custom-processing: false;

    in property <DialogWidthPreset> playground-width-enum: DialogWidthPreset.medium;
    in property <DialogHeightPreset> playground-height-enum: DialogHeightPreset.auto;
    in property <bool> playground-show-header: true;
    in property <bool> playground-show-footer: true;
    in property <string> playground-title-text: "Playground";
    in property <string> playground-subtitle-text: "";
    in property <DialogAlignPreset> align-vertical-preset: DialogAlignPreset.center;
    in property <int> align-vertical-index: 0;
    in property <DialogPositionPreset> side-sheet-position-preset: DialogPositionPreset.right;
    in property <int> side-sheet-edge-index: 1;
    in property <DialogNarrowPositionPreset> narrow-viewport-position: DialogNarrowPositionPreset.bottom;
    in property <int> narrow-viewport-index: 0;

    default-outer-dialog := DialogCompose {
        open <=> root.default-outer-open;
        width-preset: DialogWidthPreset.xlarge;
        on-close(_gesture) => {
            root.default-outer-open = false;
            root.default-inner-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "My Dialog";

                close-requested => default-outer-dialog.on-close("close-button");
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.default-inner-open = true;
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => default-outer-dialog.on-close("close-button");
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.default-inner-open = true;
                    }
                }
            }
        }
    }

    default-inner-dialog := DialogCompose {
        open <=> root.default-inner-open;
        width-preset: DialogWidthPreset.small;
        on-close(_gesture) => {
            root.default-inner-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.default-inner-open = false;
                }

                StandardDialogHeader {
                    title: "Inner dialog!";
                    subtitle: "";
                }
            }

            DialogBody {
                Text {
                    text: "Hello world";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }
        }
    }

    playground-dialog := DialogCompose {
        open <=> root.playground-open;
        width-preset: root.playground-width-enum;
        height-preset: root.playground-height-enum;
        on-close(_gesture) => {
            root.playground-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            if root.playground-show-header: StandardDialogHeader {
                title: root.playground-title-text;
                subtitle: root.playground-subtitle-text;
                close-requested => {
                    playground-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            if root.playground-show-footer: DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => {
                        playground-dialog.on-close("close-button");
                    }
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                    }
                }
            }
        }
    }

    align-demo-dialog := DialogCompose {
        open <=> root.align-demo-open;
        align-preset: root.align-vertical-preset;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.align-demo-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: align-vertical-index == 0 ? "Align top" : "Align bottom";

                close-requested => {
                    align-demo-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => {
                        align-demo-dialog.on-close("close-button");
                    }
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                    }
                }
            }
        }
    }

    side-sheet-dialog := DialogCompose {
        open <=> root.side-sheet-open;
        position-preset: root.side-sheet-position-preset;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        fill-mode: DialogFillMode.screen-height;
        on-close(_gesture) => {
            root.side-sheet-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: side-sheet-edge-index == 0 ? "Side sheet (left)" : "Side sheet (right)";

                close-requested => {
                    side-sheet-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }
        }
    }

    narrow-viewport-dialog := DialogCompose {
        open <=> root.narrow-demo-open;
        narrow-layout: true;
        narrow-position-preset: root.narrow-viewport-position;
        position-preset: DialogPositionPreset.center;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.narrow-demo-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: narrow-viewport-index == 0 ? "Bottom sheet (narrow)" : narrow-viewport-index == 1 ? "Fullscreen (narrow)" : "Narrow — center";
                subtitle: "Sheet Subtitle";

                close-requested => {
                    narrow-viewport-dialog.on-close("close-button");
                }
            }

            DialogBody {
            }

            DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.narrow-demo-open = false;
                    }
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                    }
                }
            }
        }
    }

    custom-renderers-dialog := DialogCompose {
        open <=> root.custom-renderers-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.custom-renderers-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.custom-renderers-open = false;
                }

                Text {
                    text: "Custom header title";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }

                Text {
                    text: "renderHeader-style subtitle";
                    color: PrimerColors.fgColor-muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "Uses **`DialogHeader`**, **`DialogBody`**, and **`DialogFooter`** inside **`DialogCompose`**. The body scrolls between header and footer.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Pretend this block is **`renderBody`** output.";
                    color: PrimerColors.fgColor-muted;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Open Second Dialog";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }
                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.custom-renderers-open = false;
                    }
                }
                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                    }
                }
            }
        }
    }

    direct-sub-dialog := DialogCompose {
        open <=> root.direct-sub-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.direct-sub-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.direct-sub-open = false;
                }

                Text {
                    text: "Direct subcomponents";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "**`DialogFooter`** **`use-default-actions: false`** supplies a custom button row below **`DialogBody`**.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {

                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.direct-sub-open = false;
                    }
                }

                Button {
                    label: "Save";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.direct-sub-open = false;
                    }
                }
            }
        }
    }

    stress-test-dialog := DialogCompose {
        open <=> root.stress-test-open;
        position-preset: DialogPositionPreset.center;
        narrow-position-preset: DialogNarrowPositionPreset.fullscreen;
        width-preset: DialogWidthPreset.small;
        on-close(_gesture) => {
            root.stress-test-open = false;
            root.stress-test-inner-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "This dialog has a really long title. So long, in fact, that it should cause wrapping, going to multiple lines!.";
                subtitle: "It's not a common scenario, sure, but what if the subtitle is generated from a really long value? Do we just break the dialog? Or do we handle it because we are pros?";

                close-requested => {
                    stress-test-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis, urna nec lobortis posuere, eros urna venenatis eros, vel accumsan turpis nunc vitae enim.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis, urna nec lobortis posuere, eros urna venenatis eros, vel accumsan turpis nunc vitae enim.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis, urna nec lobortis posuere, eros urna venenatis eros, vel accumsan turpis nunc vitae enim.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Button 0";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Button 1";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Button 2";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Button 3";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Button 4";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Button 5";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Button 6";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                Button {
                    label: "Delete the universe";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.stress-test-open = false;
                        root.stress-test-inner-open = false;
                    }
                }

                Button {
                    label: "Proceed";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.stress-test-inner-open = true;
                    }
                }
            }
        }
    }

    stress-test-inner-dialog := DialogCompose {
        open <=> root.stress-test-inner-open;
        width-preset: DialogWidthPreset.small;
        on-close(_gesture) => {
            root.stress-test-inner-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Inner dialog!";

                close-requested => {
                    stress-test-inner-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Hello world";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }
        }
    }

    multistep-footer-dialog := DialogCompose {
        open <=> root.multistep-footer-open;
        width-preset: DialogWidthPreset.xlarge;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.multistep-footer-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Multistep";
                subtitle: root.multistep-footer-step == 0 ? "Step 1 — default action only" : root.multistep-footer-step == 1 ? "Step 2 — danger appears" : "Step 3 — full footer";

                close-requested => {
                    multistep-footer-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Use **Next** to reveal danger, then primary. **Done** closes. Slint focus management for the close control on step change is not wired in this gallery.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: root.multistep-footer-step < 2 ? "Next" : "Done";
                    variant: ButtonVariant.default;
                    clicked => {
                        if root.multistep-footer-step < 2 {
                            root.multistep-footer-step = root.multistep-footer-step + 1;
                        } else {
                            root.multistep-footer-open = false;
                        }
                    }
                }

                if root.multistep-footer-step >= 1: Button {
                    label: "Remove";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.multistep-footer-open = false;
                    }
                }

                if root.multistep-footer-step >= 2: Button {
                    label: "Confirm";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.multistep-footer-open = false;
                    }
                }
            }
        }
    }

    dynamic-footer-dialog := DialogCompose {
        open <=> root.dynamic-footer-open;
        width-preset: DialogWidthPreset.xlarge;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.dynamic-footer-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Dynamic content";
                subtitle: root.dynamic-footer-variant == 1 ? "Subtitle on — press **Cycle** to change footer membership." : "";

                close-requested => {
                    dynamic-footer-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Each **Cycle layout** advances: full three-button row → danger+default+extra → default-only + subtitle. **`show-footer`** stays true; visibility is per-button.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cycle layout";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.dynamic-footer-variant = root.dynamic-footer-variant == 0 ? 1 : root.dynamic-footer-variant == 1 ? 2 : 0;
                    }
                }

                if root.dynamic-footer-variant == 2: Button {
                    label: "Extra";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                if root.dynamic-footer-variant == 0 || root.dynamic-footer-variant == 2: Button {
                    label: "Close";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.dynamic-footer-open = false;
                    }
                }

                if root.dynamic-footer-variant == 0: Button {
                    label: "Save";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.dynamic-footer-open = false;
                    }
                }
            }
        }
    }

    loading-footer-dialog := DialogCompose {
        open <=> root.loading-footer-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.loading-footer-open = false;
            root.loading-footer-submitting = false;
            root.loading-footer-deleting = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Dialog title";

                close-requested => {
                    loading-footer-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "This is some text";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.loading-footer-open = false;
                        root.loading-footer-submitting = false;
                        root.loading-footer-deleting = false;
                    }
                }

                Button {
                    label: "Delete Repository";
                    variant: ButtonVariant.danger;
                    loading: root.loading-footer-deleting;
                    clicked => {
                        if !root.loading-footer-deleting && !root.loading-footer-submitting {
                            root.loading-footer-deleting = true;
                            lf-delete-done.running = true;
                        }
                    }
                }

                Button {
                    label: "Save & Delete";
                    variant: ButtonVariant.primary;
                    loading: root.loading-footer-submitting;
                    clicked => {
                        if !root.loading-footer-submitting && !root.loading-footer-deleting {
                            root.loading-footer-submitting = true;
                            lf-submit-done.running = true;
                        }
                    }
                }
            }
        }
    }

    lf-submit-done := Timer {
        interval: 2000ms;
        running: false;
        triggered() => {
            root.loading-footer-submitting = false;
            root.loading-footer-open = false;
            self.running = false;
        }
    }

    lf-delete-done := Timer {
        interval: 3000ms;
        running: false;
        triggered() => {
            root.loading-footer-deleting = false;
            root.loading-footer-open = false;
            self.running = false;
        }
    }

    loading-custom-footer-dialog := DialogCompose {
        open <=> root.loading-custom-footer-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.loading-custom-footer-open = false;
            root.loading-custom-saving = false;
            root.loading-custom-processing = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.loading-custom-footer-open = false;
                    root.loading-custom-saving = false;
                    root.loading-custom-processing = false;
                }

                Text {
                    text: "Process Data";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }

                Text {
                    text: "Custom footer with loading states";
                    color: PrimerColors.fgColor-muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "This is some text";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.loading-custom-footer-open = false;
                        root.loading-custom-saving = false;
                        root.loading-custom-processing = false;
                    }
                }
                Button {
                    label: "Save Draft";
                    variant: ButtonVariant.default;
                    loading: root.loading-custom-saving;
                    clicked => {
                    }
                }
                Button {
                    label: "Process & Continue";
                    variant: ButtonVariant.primary;
                    loading: root.loading-custom-processing;
                    clicked => {
                        root.loading-custom-processing = true;
                    }
                }
            }
        }
    }

    lc-save-done := Timer {
        interval: 1500ms;
        running: false;
        triggered() => {
            root.loading-custom-saving = false;
            root.loading-custom-footer-open = false;
            self.running = false;
        }
    }

    lc-process-done := Timer {
        interval: 2500ms;
        running: false;
        triggered() => {
            root.loading-custom-processing = false;
            root.loading-custom-footer-open = false;
            self.running = false;
        }
    }
}
