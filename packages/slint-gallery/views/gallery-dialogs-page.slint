import {
    Button,
    ButtonAlignContent,
    ButtonVariant,
    Checkbox,
    Dialog,
    DialogAlignPreset,
    DialogBody,
    DialogCompose,
    DialogFooter,
    DialogHeader,
    DialogHeightPreset,
    DialogNarrowPositionPreset,
    DialogPositionPreset,
    DialogWidthPreset,
    PrimerTextInput,
    Select,
    SelectOption,
    ValidationStatus,
} from "../../primer-slint/primer.slint";
import { AppWindow, DialogTokens, PrimerColors } from "../../primer-slint/tokens.slint";

/// One Storybook-aligned block (title + meta + stub open control).
component DialogStoryStub inherits VerticalLayout {
    in property <string> story-title;
    in property <string> story-path;
    in property <string> story-note;

    spacing: 10px;
    width: 100%;
    padding-top: 16px;

    Rectangle {
        height: 1px;
        background: PrimerColors.borderColor-default;
    }

    Text {
        text: root.story-title;
        color: PrimerColors.fgColor-default;
        font-size: 15px;
        font-weight: 600;
    }

    Text {
        text: root.story-path;
        color: PrimerColors.fgColor-muted;
        font-size: 11px;
        wrap: word-wrap;
    }

    Text {
        text: root.story-note;
        color: PrimerColors.fgColor-muted;
        font-size: 12px;
        wrap: word-wrap;
    }

    Button {
        max-width: 200px;
        align-content: ButtonAlignContent.start;
        label: "Open dialog (soon)";
        clicked => {
        }
    }
}

/// Primer **Dialog** gallery (Storybook parity sections). **Default**, **Playground**, **Align**, **Side sheet**, **Narrow viewport**, **WithCustomRenderers** / **WithDirectSubcomponents** (**PR9** **`DialogCompose`** + **`DialogHeader`** / **`DialogBody`** / **`DialogFooter`**) are live; other stories are stubs.
export component GalleryDialogsPage inherits VerticalLayout {

    private property <bool> default-outer-open: false;
    private property <bool> default-inner-open: false;

    private property <bool> playground-open: false;
    private property <bool> align-demo-open: false;
    private property <bool> side-sheet-open: false;
    private property <bool> narrow-demo-open: false;
    private property <bool> custom-renderers-open: false;
    private property <bool> direct-sub-open: false;

    private property <[SelectOption]> narrow-viewport-options: [
        { value: "bottom", label: "bottom — slideUp (narrow)", enabled: true },
        { value: "fullscreen", label: "fullscreen — scaleFade", enabled: true },
        { value: "center", label: "center — scaleFade", enabled: true },
    ];

    private property <int> narrow-viewport-index: 0;

    private property <DialogNarrowPositionPreset> narrow-viewport-position:
        narrow-viewport-index == 0 ? DialogNarrowPositionPreset.bottom : narrow-viewport-index == 1 ? DialogNarrowPositionPreset.fullscreen : DialogNarrowPositionPreset.center;

    private property <[SelectOption]> playground-width-options: [
        { value: "small", label: "small (296px)", enabled: true },
        { value: "medium", label: "medium (320px)", enabled: true },
        { value: "large", label: "large (480px)", enabled: true },
        { value: "xlarge", label: "xlarge (640px)", enabled: true },
    ];

    private property <[SelectOption]> playground-height-options: [
        { value: "auto", label: "auto (viewport cap)", enabled: true },
        { value: "small", label: "small (480px max)", enabled: true },
        { value: "large", label: "large (640px max)", enabled: true },
    ];

    private property <int> playground-width-index: 1;
    private property <int> playground-height-index: 0;

    private property <bool> playground-show-header: true;
    private property <bool> playground-show-footer: true;
    private property <string> playground-title-text: "Playground";
    private property <string> playground-subtitle-text: "";

    private property <DialogWidthPreset> playground-width-enum:
        playground-width-index == 0 ? DialogWidthPreset.small : playground-width-index == 1 ? DialogWidthPreset.medium : playground-width-index == 2 ? DialogWidthPreset.large : DialogWidthPreset.xlarge;

    private property <DialogHeightPreset> playground-height-enum:
        playground-height-index == 0 ? DialogHeightPreset.auto : playground-height-index == 1 ? DialogHeightPreset.small : DialogHeightPreset.large;

    private property <[SelectOption]> align-vertical-options: [
        { value: "top", label: "top", enabled: true },
        { value: "bottom", label: "bottom", enabled: true },
    ];

    private property <int> align-vertical-index: 0;

    private property <DialogAlignPreset> align-vertical-preset:
        align-vertical-index == 0 ? DialogAlignPreset.top : DialogAlignPreset.bottom;

    private property <[SelectOption]> side-sheet-edge-options: [
        { value: "left", label: "left (slide from left)", enabled: true },
        { value: "right", label: "right (slide from right)", enabled: true },
    ];

    private property <int> side-sheet-edge-index: 1;

    private property <DialogPositionPreset> side-sheet-position-preset:
        side-sheet-edge-index == 0 ? DialogPositionPreset.left : DialogPositionPreset.right;


    Text {
        text: "Dialog";
        color: PrimerColors.fgColor-default;
        font-size: 22px;
        font-weight: 600;
    }

    VerticalLayout {
        spacing: 10px;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Default";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.default-outer-open = true;
            }
        }
    }
    

    default-outer-dialog := Dialog {
        open <=> root.default-outer-open;
        title: "My Dialog";
        width-preset: DialogWidthPreset.xlarge;
        footer-default-clicked => {
            root.default-inner-open = true;
        }
        footer-danger-clicked => {
            root.default-outer-open = false;
            root.default-inner-open = false;
        }
        footer-primary-clicked => {
            root.default-inner-open = true;
        }
        on-close(_gesture) => {
            root.default-outer-open = false;
            root.default-inner-open = false;
        }

        Text {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    default-inner-dialog := Dialog {
        open <=> root.default-inner-open;
        title: "Inner dialog!";
        width-preset: DialogWidthPreset.small;
        show-footer: false;
        footer-default-clicked => {
        }
        footer-danger-clicked => {
        }
        footer-primary-clicked => {
        }
        on-close(_gesture) => {
            root.default-inner-open = false;
        }

        Text {
            text: "Hello world";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Playground";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 16px;

            Select {
                horizontal-stretch: 1;
                label-text: "Width";
                placeholder: "Choose width…";
                options: playground-width-options;
                selected-index <=> playground-width-index;
                validation-status: ValidationStatus.none;
                selected-changed(_idx) => {
                }
            }

            Select {
                horizontal-stretch: 1;
                label-text: "Height";
                placeholder: "Choose height…";
                options: playground-height-options;
                selected-index <=> playground-height-index;
                validation-status: ValidationStatus.none;
                selected-changed(_idx) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 24px;
            alignment: start;

            Checkbox {
                label: "Show header";
                checked <=> playground-show-header;
            }

            Checkbox {
                label: "Show footer";
                checked <=> playground-show-footer;
            }
        }

        PrimerTextInput {
            width: 100%;
            block: true;
            label-text: "Title";
            placeholder: "Dialog title…";
            text <=> playground-title-text;
            validation-status: ValidationStatus.none;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 100%;
            block: true;
            label-text: "Subtitle";
            placeholder: "Optional subtitle…";
            text <=> playground-subtitle-text;
            validation-status: ValidationStatus.none;
            edited(_) => {
            }
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.playground-open = true;
            }
        }
    }

    playground-dialog := Dialog {
        open <=> root.playground-open;
        title: root.playground-title-text;
        subtitle: root.playground-subtitle-text;
        show-header: root.playground-show-header;
        show-footer: root.playground-show-footer;
        width-preset: root.playground-width-enum;
        height-preset: root.playground-height-enum;
        footer-default-clicked => {
        }
        footer-danger-clicked => {
            root.playground-open = false;
        }
        footer-primary-clicked => {
        }
        on-close(_gesture) => {
            root.playground-open = false;
        }

        Text {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Align top / bottom";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "Vertical align";
            placeholder: "Choose top or bottom…";
            options: align-vertical-options;
            selected-index <=> align-vertical-index;
            validation-status: ValidationStatus.none;
            selected-changed(_idx) => {
            }
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.align-demo-open = true;
            }
        }
    }

    align-demo-dialog := Dialog {
        open <=> root.align-demo-open;
        title: align-vertical-index == 0 ? "Align top" : "Align bottom";
        align-preset: root.align-vertical-preset;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        footer-default-clicked => {
        }
        footer-danger-clicked => {
            root.align-demo-open = false;
        }
        footer-primary-clicked => {
        }
        on-close(_gesture) => {
            root.align-demo-open = false;
        }

        Text {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Side sheet";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "Edge";
            placeholder: "Choose left or right…";
            options: side-sheet-edge-options;
            selected-index <=> side-sheet-edge-index;
            validation-status: ValidationStatus.none;
            selected-changed(_idx) => {
            }
        }

        Button {
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.side-sheet-open = true;
            }
        }
    }

    side-sheet-dialog := Dialog {
        open <=> root.side-sheet-open;
        title: side-sheet-edge-index == 0 ? "Side sheet (left)" : "Side sheet (right)";
        position-preset: root.side-sheet-position-preset;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.side-sheet-open = false;
        }

        Text {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Narrow viewport — bottom · fullscreen · center";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "position.narrow";
            placeholder: "Pick narrow position…";
            options: narrow-viewport-options;
            selected-index <=> narrow-viewport-index;
            validation-status: ValidationStatus.none;
            selected-changed(_idx) => {
            }
        }

        Button {
            max-width: 220px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.narrow-demo-open = true;
            }
        }
    }

    narrow-story-dialog := Dialog {
        open <=> root.narrow-demo-open;
        narrow-layout: true;
        narrow-position-preset: root.narrow-viewport-position;
        position-preset: DialogPositionPreset.center;
        title: narrow-viewport-index == 0 ? "Bottom sheet (narrow)" : narrow-viewport-index == 1 ? "Fullscreen (narrow)" : "Narrow — center";
        subtitle: "Sheet Subtitle";
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        footer-danger-clicked => {
            root.narrow-demo-open = false;
        }
        on-close(_gesture) => {
            root.narrow-demo-open = false;
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "WithCustomRenderers";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Components/Dialog/Features — WithCustomRenderers";
            color: PrimerColors.fgColor-muted;
            font-size: 11px;
            wrap: word-wrap;
        }

        Button {
            max-width: 240px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.custom-renderers-open = true;
            }
        }
    }

    custom-renderers-dialog := DialogCompose {
        open <=> root.custom-renderers-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.custom-renderers-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.custom-renderers-open = false;
                }

                Text {
                    text: "Custom header title";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }

                Text {
                    text: "renderHeader-style subtitle";
                    color: PrimerColors.fgColor-muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "**`DialogCompose`** + **`DialogHeader`** / **`DialogBody`** / **`DialogFooter`** (`PR9`). Body is scrollable between header and footer.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Pretend this block is **`renderBody`** output.";
                    color: PrimerColors.fgColor-muted;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                use-default-actions: true;
                danger-clicked => {
                    root.custom-renderers-open = false;
                }
                default-clicked => {
                }
                primary-clicked => {
                }
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "WithDirectSubcomponents";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Components/Dialog/Features — WithDirectSubcomponents";
            color: PrimerColors.fgColor-muted;
            font-size: 11px;
            wrap: word-wrap;
        }

        Button {
            max-width: 240px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.direct-sub-open = true;
            }
        }
    }

    direct-sub-dialog := DialogCompose {
        open <=> root.direct-sub-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.direct-sub-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.direct-sub-open = false;
                }

                Text {
                    text: "Direct subcomponents";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "**`DialogFooter`** **`use-default-actions: false`** supplies a custom button row below **`DialogBody`**.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                use-default-actions: false;
                default-clicked => {
                }
                danger-clicked => {
                }
                primary-clicked => {
                }

                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.direct-sub-open = false;
                    }
                }

                Button {
                    label: "Save";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.direct-sub-open = false;
                    }
                }
            }
        }
    }

    DialogStoryStub {
        story-title: "StressTest";
        story-path: "Components/Dialog/Features — StressTest";
        story-note: "Long title and subtitle; many footer buttons; narrow fullscreen + inner dialog.";
    }

    DialogStoryStub {
        story-title: "ReproMultistepDialogWithConditionalFooter";
        story-path: "Components/Dialog/Features — ReproMultistepDialogWithConditionalFooter";
        story-note: "Conditional footer by step; focus close button on step change.";
    }

    DialogStoryStub {
        story-title: "ReturnFocusRef";
        story-path: "Components/Dialog/Features — ReturnFocusRef";
        story-note: "Return focus to trigger on close (Slint parity may be partial).";
    }

    DialogStoryStub {
        story-title: "NewIssues";
        story-path: "Components/Dialog/Features — NewIssues";
        story-note: "ActionList in body; initialFocusRef.";
    }

    DialogStoryStub {
        story-title: "RetainsFocusTrapWithDynamicContent";
        story-path: "Components/Dialog/Features — RetainsFocusTrapWithDynamicContent";
        story-note: "Dynamic body/footer and stacked inner dialog.";
    }

    DialogStoryStub {
        story-title: "LoadingFooterButtons";
        story-path: "Components/Dialog/Features — LoadingFooterButtons";
        story-note: "Footer buttons with loading and autoFocus.";
    }

    DialogStoryStub {
        story-title: "LoadingCustomFooterButtonsCould";
        story-path: "Components/Dialog/Features — LoadingCustomFooterButtonsCould";
        story-note: "renderFooter + loading on secondary actions.";
    }
}
