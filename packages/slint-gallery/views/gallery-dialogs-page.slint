        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.default-inner-open = false;
                }

                StandardDialogHeader {
                    title: "Inner dialog!";
                    subtitle: "";
