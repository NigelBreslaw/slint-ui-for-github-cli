    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "ReproMultistepDialogWithConditionalFooter";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            Button {
                max-width: 240px;
                align-content: ButtonAlignContent.start;
                label: "Open multistep dialog";
                clicked => {
                    root.multistep-footer-step = 0;
                    root.multistep-footer-open = true;
                }
            }

            Button {
                max-width: 280px;
                align-content: ButtonAlignContent.start;
                label: "Show dialog (compose)";
                variant: ButtonVariant.primary;
                clicked => {
                    root.multistep-footer-step = 0;
                    root.multistep-footer-compose-open = true;
                }
            }
        }
    }

    multistep-footer-dialog := Dialog {
        open <=> root.multistep-footer-open;
        title: "Multistep";
        subtitle: root.multistep-footer-step == 0 ? "Step 1 — default action only" : root.multistep-footer-step == 1 ? "Step 2 — danger appears" : "Step 3 — full footer";
        footer-has-danger-button: root.multistep-footer-step >= 1;
        footer-has-primary-button: root.multistep-footer-step >= 2;
        footer-default-label: root.multistep-footer-step < 2 ? "Next" : "Done";
        footer-danger-label: "Remove";
        footer-primary-label: "Confirm";
        footer-default-clicked => {
            if root.multistep-footer-step < 2 {
                root.multistep-footer-step = root.multistep-footer-step + 1;
            } else {
                root.multistep-footer-open = false;
            }
        }
        footer-danger-clicked => {
            root.multistep-footer-open = false;
        }
        footer-primary-clicked => {
            root.multistep-footer-open = false;
        }
        on-close(_gesture) => {
            root.multistep-footer-open = false;
        }

        Text {
            text: "Use **Next** to reveal danger, then primary. **Done** closes. Slint focus management for the close control on step change is not wired in this gallery.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    multistep-footer-compose-dialog := DialogCompose {
        open <=> root.multistep-footer-compose-open;
        width-preset: DialogWidthPreset.xlarge;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.multistep-footer-compose-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Multistep";
                subtitle: root.multistep-footer-step == 0 ? "Step 1 — default action only" : root.multistep-footer-step == 1 ? "Step 2 — danger appears" : "Step 3 — full footer";

                close-requested => {
                    multistep-footer-compose-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Use **Next** to reveal danger, then primary. **Done** closes. Slint focus management for the close control on step change is not wired in this gallery.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: root.multistep-footer-step < 2 ? "Next" : "Done";
                    variant: ButtonVariant.default;
                    clicked => {
                        if root.multistep-footer-step < 2 {
                            root.multistep-footer-step = root.multistep-footer-step + 1;
                        } else {
                            root.multistep-footer-compose-open = false;
                        }
                    }
                }

                if root.multistep-footer-step >= 1: Button {
                    label: "Remove";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.multistep-footer-compose-open = false;
                    }
                }

                if root.multistep-footer-step >= 2: Button {
                    label: "Confirm";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.multistep-footer-compose-open = false;
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "RetainsFocusTrapWithDynamicContent";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            Button {
                max-width: 260px;
                align-content: ButtonAlignContent.start;
                label: "Open dynamic footer dialog";
                clicked => {
                    root.dynamic-footer-variant = 0;
                    root.dynamic-footer-open = true;
                }
            }

            Button {
                max-width: 280px;
                align-content: ButtonAlignContent.start;
                label: "Show dialog (compose)";
                variant: ButtonVariant.primary;
                clicked => {
                    root.dynamic-footer-variant = 0;
                    root.dynamic-footer-compose-open = true;
                }
            }
        }
    }

    dynamic-footer-dialog := Dialog {
        open <=> root.dynamic-footer-open;
        title: "Dynamic content";
        subtitle: root.dynamic-footer-variant == 1 ? "Subtitle on — press **Cycle** to change footer membership." : "";
        footer-has-danger-button: root.dynamic-footer-variant == 0 || root.dynamic-footer-variant == 2;
        footer-has-primary-button: root.dynamic-footer-variant == 0;
        footer-extra-1-label: root.dynamic-footer-variant == 2 ? "Extra" : "";
        footer-default-label: "Cycle layout";
        footer-danger-label: "Close";
        footer-primary-label: "Save";
        footer-default-clicked => {
            root.dynamic-footer-variant = root.dynamic-footer-variant == 0 ? 1 : root.dynamic-footer-variant == 1 ? 2 : 0;
        }
        footer-extra-1-clicked => {
        }
        footer-danger-clicked => {
            root.dynamic-footer-open = false;
        }
        footer-primary-clicked => {
            root.dynamic-footer-open = false;
        }
        on-close(_gesture) => {
            root.dynamic-footer-open = false;
        }

        Text {
            text: "Each **Cycle layout** advances: full three-button row → danger+default+extra → default-only + subtitle. **`show-footer`** stays true; visibility is per-button.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    dynamic-footer-compose-dialog := DialogCompose {
        open <=> root.dynamic-footer-compose-open;
        width-preset: DialogWidthPreset.xlarge;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.dynamic-footer-compose-open = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Dynamic content";
                subtitle: root.dynamic-footer-variant == 1 ? "Subtitle on — press **Cycle** to change footer membership." : "";

                close-requested => {
                    dynamic-footer-compose-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "Each **Cycle layout** advances: full three-button row → danger+default+extra → default-only + subtitle. **`show-footer`** stays true; visibility is per-button.";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cycle layout";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.dynamic-footer-variant = root.dynamic-footer-variant == 0 ? 1 : root.dynamic-footer-variant == 1 ? 2 : 0;
                    }
                }

                if root.dynamic-footer-variant == 2: Button {
                    label: "Extra";
                    variant: ButtonVariant.default;
                    clicked => {
                    }
                }

                if root.dynamic-footer-variant == 0 || root.dynamic-footer-variant == 2: Button {
                    label: "Close";
                    variant: ButtonVariant.danger;
                    clicked => {
                        root.dynamic-footer-compose-open = false;
                    }
                }

                if root.dynamic-footer-variant == 0: Button {
                    label: "Save";
                    variant: ButtonVariant.primary;
                    clicked => {
                        root.dynamic-footer-compose-open = false;
                    }
                }
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "LoadingFooterButtons";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            Button {
                max-width: 260px;
                align-content: ButtonAlignContent.start;
                label: "Open loading-footer dialog";
                clicked => {
                    root.loading-footer-submitting = false;
                    root.loading-footer-deleting = false;
                    root.loading-footer-demo-open = true;
                }
            }

            Button {
                max-width: 280px;
                align-content: ButtonAlignContent.start;
                label: "Show dialog (compose)";
                variant: ButtonVariant.primary;
                clicked => {
                    root.loading-footer-compose-submitting = false;
                    root.loading-footer-compose-deleting = false;
                    root.loading-footer-compose-open = true;
                }
            }
        }
    }

    loading-footer-demo-dialog := Dialog {
        open <=> root.loading-footer-demo-open;
        title: "Dialog title";
        footer-default-label: "Cancel";
        footer-danger-label: "Delete Repository";
        footer-primary-label: "Save & Delete";
        footer-danger-loading: root.loading-footer-deleting;
        footer-primary-loading: root.loading-footer-submitting;
        footer-auto-focus: DialogFooterAutoFocus.primary-action;
        footer-default-clicked => {
            root.loading-footer-demo-open = false;
            root.loading-footer-submitting = false;
            root.loading-footer-deleting = false;
        }
        footer-danger-clicked => {
            if !root.loading-footer-deleting && !root.loading-footer-submitting {
                root.loading-footer-deleting = true;
                lf-delete-done.running = true;
            }
        }
        footer-primary-clicked => {
            if !root.loading-footer-submitting && !root.loading-footer-deleting {
                root.loading-footer-submitting = true;
                lf-submit-done.running = true;
            }
        }
        on-close(_gesture) => {
            root.loading-footer-demo-open = false;
            root.loading-footer-submitting = false;
            root.loading-footer-deleting = false;
        }

        Text {
            text: "This is some text";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    loading-footer-compose-dialog := DialogCompose {
        open <=> root.loading-footer-compose-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.loading-footer-compose-open = false;
            root.loading-footer-compose-submitting = false;
            root.loading-footer-compose-deleting = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            StandardDialogHeader {
                title: "Dialog title";

                close-requested => {
                    loading-footer-compose-dialog.on-close("close-button");
                }
            }

            DialogBody {
                Text {
                    text: "This is some text";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.loading-footer-compose-open = false;
                        root.loading-footer-compose-submitting = false;
                        root.loading-footer-compose-deleting = false;
                    }
                }

                Button {
                    label: "Delete Repository";
                    variant: ButtonVariant.danger;
                    loading: root.loading-footer-compose-deleting;
                    clicked => {
                        if !root.loading-footer-compose-deleting && !root.loading-footer-compose-submitting {
                            root.loading-footer-compose-deleting = true;
                            lf-compose-delete-done.running = true;
                        }
                    }
                }

                Button {
                    label: "Save & Delete";
                    variant: ButtonVariant.primary;
                    loading: root.loading-footer-compose-submitting;
                    clicked => {
                        if !root.loading-footer-compose-submitting && !root.loading-footer-compose-deleting {
                            root.loading-footer-compose-submitting = true;
                            lf-compose-submit-done.running = true;
                        }
                    }
                }
            }
        }
    }

    lf-submit-done := Timer {
        interval: 2000ms;
        running: false;
        triggered() => {
            root.loading-footer-submitting = false;
            root.loading-footer-demo-open = false;
            self.running = false;
        }
    }

    lf-delete-done := Timer {
        interval: 3000ms;
        running: false;
        triggered() => {
            root.loading-footer-deleting = false;
            root.loading-footer-demo-open = false;
            self.running = false;
        }
    }

    lf-compose-submit-done := Timer {
        interval: 2000ms;
        running: false;
        triggered() => {
            root.loading-footer-compose-submitting = false;
            root.loading-footer-compose-open = false;
            self.running = false;
        }
    }

    lf-compose-delete-done := Timer {
        interval: 3000ms;
        running: false;
        triggered() => {
            root.loading-footer-compose-deleting = false;
            root.loading-footer-compose-open = false;
            self.running = false;
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "LoadingCustomFooterButtonsCould";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            Button {
                max-width: 280px;
                align-content: ButtonAlignContent.start;
                label: "Open custom-footer loading dialog";
                clicked => {
                    root.loading-custom-saving = false;
                    root.loading-custom-processing = false;
                    root.loading-custom-footer-open = true;
                }
            }

            Button {
                max-width: 300px;
                align-content: ButtonAlignContent.start;
                label: "Show dialog (compose)";
                variant: ButtonVariant.primary;
                clicked => {
                    root.loading-custom-compose-saving = false;
                    root.loading-custom-compose-processing = false;
                    root.loading-custom-footer-compose-open = true;
                }
            }
        }
    }

    loading-custom-footer-demo := DialogCompose {
        open <=> root.loading-custom-footer-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.loading-custom-footer-open = false;
            root.loading-custom-saving = false;
            root.loading-custom-processing = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.loading-custom-footer-open = false;
                    root.loading-custom-saving = false;
                    root.loading-custom-processing = false;
                }

                Text {
                    text: "Process Data";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }

                Text {
                    text: "Custom footer with loading states";
                    color: PrimerColors.fgColor-muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "This is some text";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.loading-custom-footer-open = false;
                        root.loading-custom-saving = false;
                        root.loading-custom-processing = false;
                    }
                }
                Button {
                    label: "Save Draft";
                    variant: ButtonVariant.default;
                    loading: root.loading-custom-saving;
                    clicked => {
                    }
                }
                Button {
                    label: "Process & Continue";
                    variant: ButtonVariant.primary;
                    loading: root.loading-custom-processing;
                    clicked => {
                        root.loading-custom-processing = true;
                    }
                }
            }
        }
    }

    lc-save-done := Timer {
        interval: 1500ms;
        running: false;
        triggered() => {
            root.loading-custom-saving = false;
            root.loading-custom-footer-open = false;
            self.running = false;
        }
    }

    lc-process-done := Timer {
        interval: 2500ms;
        running: false;
        triggered() => {
            root.loading-custom-processing = false;
            root.loading-custom-footer-open = false;
            self.running = false;
        }
    }

    loading-custom-footer-compose-demo := DialogCompose {
        open <=> root.loading-custom-footer-compose-open;
        width-preset: DialogWidthPreset.medium;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            root.loading-custom-footer-compose-open = false;
            root.loading-custom-compose-saving = false;
            root.loading-custom-compose-processing = false;
        }

        VerticalLayout {
            spacing: 0px;
            alignment: stretch;

            DialogHeader {
                close-requested => {
                    root.loading-custom-footer-compose-open = false;
                    root.loading-custom-compose-saving = false;
                    root.loading-custom-compose-processing = false;
                }

                Text {
                    text: "Process Data";
                    color: PrimerColors.fgColor-default;
                    font-size: DialogTokens.title-font-size;
                    font-weight: 600;
                    wrap: word-wrap;
                }

                Text {
                    text: "Custom footer with loading states";
                    color: PrimerColors.fgColor-muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }

            DialogBody {
                Text {
                    text: "This is some text";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    wrap: word-wrap;
                }
            }

            DialogFooter {
                Button {
                    label: "Cancel";
                    variant: ButtonVariant.default;
                    clicked => {
                        root.loading-custom-footer-compose-open = false;
                        root.loading-custom-compose-saving = false;
                        root.loading-custom-compose-processing = false;
                    }
                }
                Button {
                    label: "Save Draft";
                    variant: ButtonVariant.default;
                    loading: root.loading-custom-compose-saving;
                    clicked => {
                    }
                }
                Button {
                    label: "Process & Continue";
                    variant: ButtonVariant.primary;
                    loading: root.loading-custom-compose-processing;
                    clicked => {
                        root.loading-custom-compose-processing = true;
                    }
                }
            }
        }
    }
}
