import {
    Button,
    ButtonAlignContent,
    DialogAlignPreset,
    DialogHeightPreset,
    DialogNarrowPositionPreset,
    DialogPositionPreset,
    DialogWidthPreset,
    PrimerTextInput,
    Select,
    SelectOption,
    ToggleSwitch,
    ToggleSwitchSize,
    ValidationStatus,
} from "../../primer-slint/primer.slint";
import {
    PrimerColors,
} from "../../primer-slint/tokens.slint";
import {
    GalleryDialogInstances,
} from "./gallery-dialog-instances.slint";
export component GalleryDialogsPage inherits VerticalLayout {

    private property <bool> default-outer-open: false;
    private property <bool> default-inner-open: false;

    private property <bool> playground-open: false;
    private property <bool> align-demo-open: false;
    private property <bool> side-sheet-open: false;
    private property <bool> narrow-demo-open: false;
    private property <bool> custom-renderers-open: false;
    private property <bool> direct-sub-open: false;

    private property <bool> stress-test-open: false;
    private property <bool> stress-test-inner-open: false;
    private property <bool> multistep-footer-open: false;
    private property <int> multistep-footer-step: 0;
    private property <bool> dynamic-footer-open: false;
    private property <int> dynamic-footer-variant: 0;

    private property <bool> loading-footer-open: false;
    private property <bool> loading-footer-submitting: false;
    private property <bool> loading-footer-deleting: false;
    private property <bool> loading-custom-footer-open: false;
    private property <bool> loading-custom-saving: false;
    private property <bool> loading-custom-processing: false;

    private property <[SelectOption]> narrow-viewport-options: [
        { value: "bottom", label: "bottom — slideUp (narrow)", enabled: true },
        { value: "fullscreen", label: "fullscreen — scaleFade", enabled: true },
        { value: "center", label: "center — scaleFade", enabled: true },
    ];

    private property <int> narrow-viewport-index: 0;

    private property <DialogNarrowPositionPreset> narrow-viewport-position:
        narrow-viewport-index == 0 ? DialogNarrowPositionPreset.bottom : narrow-viewport-index == 1 ? DialogNarrowPositionPreset.fullscreen : DialogNarrowPositionPreset.center;

    private property <[SelectOption]> playground-width-options: [
        { value: "small", label: "small (296px)", enabled: true },
        { value: "medium", label: "medium (320px)", enabled: true },
        { value: "large", label: "large (480px)", enabled: true },
        { value: "xlarge", label: "xlarge (640px)", enabled: true },
    ];

    private property <[SelectOption]> playground-height-options: [
        { value: "auto", label: "auto (viewport cap)", enabled: true },
        { value: "small", label: "small (480px max)", enabled: true },
        { value: "large", label: "large (640px max)", enabled: true },
    ];

    private property <int> playground-width-index: 1;
    private property <int> playground-height-index: 0;

    private property <bool> playground-show-header: true;
    private property <bool> playground-show-footer: true;
    private property <string> playground-title-text: "Playground";
    private property <string> playground-subtitle-text: "";

    private property <DialogWidthPreset> playground-width-enum:
        playground-width-index == 0
        ? DialogWidthPreset.small : playground-width-index == 1
        ? DialogWidthPreset.medium : playground-width-index == 2
        ? DialogWidthPreset.large : DialogWidthPreset.xlarge;

    private property <DialogHeightPreset> playground-height-enum:
        playground-height-index == 0
        ? DialogHeightPreset.auto : playground-height-index == 1
        ? DialogHeightPreset.small : DialogHeightPreset.large;

    private property <[SelectOption]> align-vertical-options: [
        { value: "top", label: "top", enabled: true },
        { value: "bottom", label: "bottom", enabled: true },
    ];

    private property <int> align-vertical-index: 0;

    private property <DialogAlignPreset> align-vertical-preset:
        align-vertical-index == 0 ? DialogAlignPreset.top : DialogAlignPreset.bottom;

    private property <[SelectOption]> side-sheet-edge-options: [
        { value: "left", label: "left (slide from left)", enabled: true },
        { value: "right", label: "right (slide from right)", enabled: true },
    ];

    private property <int> side-sheet-edge-index: 1;

    private property <DialogPositionPreset> side-sheet-position-preset:
        side-sheet-edge-index == 0 ? DialogPositionPreset.left : DialogPositionPreset.right;

    dialog-instances := GalleryDialogInstances {
        default-outer-open <=> root.default-outer-open;
        default-inner-open <=> root.default-inner-open;
        playground-open <=> root.playground-open;
        align-demo-open <=> root.align-demo-open;
        side-sheet-open <=> root.side-sheet-open;
        narrow-demo-open <=> root.narrow-demo-open;
        custom-renderers-open <=> root.custom-renderers-open;
        direct-sub-open <=> root.direct-sub-open;
        stress-test-open <=> root.stress-test-open;
        stress-test-inner-open <=> root.stress-test-inner-open;
        multistep-footer-open <=> root.multistep-footer-open;
        multistep-footer-step <=> root.multistep-footer-step;
        dynamic-footer-open <=> root.dynamic-footer-open;
        dynamic-footer-variant <=> root.dynamic-footer-variant;
        loading-footer-open <=> root.loading-footer-open;
        loading-footer-submitting <=> root.loading-footer-submitting;
        loading-footer-deleting <=> root.loading-footer-deleting;
        loading-custom-footer-open <=> root.loading-custom-footer-open;
        loading-custom-saving <=> root.loading-custom-saving;
        loading-custom-processing <=> root.loading-custom-processing;

        playground-width-enum: root.playground-width-enum;
        playground-height-enum: root.playground-height-enum;
        playground-show-header: root.playground-show-header;
        playground-show-footer: root.playground-show-footer;
        playground-title-text: root.playground-title-text;
        playground-subtitle-text: root.playground-subtitle-text;
        align-vertical-preset: root.align-vertical-preset;
        align-vertical-index: root.align-vertical-index;
        side-sheet-position-preset: root.side-sheet-position-preset;
        side-sheet-edge-index: root.side-sheet-edge-index;
        narrow-viewport-position: root.narrow-viewport-position;
        narrow-viewport-index: root.narrow-viewport-index;
    }

    Text {
        text: "Dialog";
        color: PrimerColors.fgColor-default;
        font-size: 22px;
        font-weight: 600;
    }

    VerticalLayout {
        spacing: 10px;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Default";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.default-outer-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Playground";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 16px;

            Select {
                horizontal-stretch: 1;
                label-text: "Width";
                placeholder: "Choose width…";
                options: playground-width-options;
                selected-index <=> playground-width-index;
                validation-status: ValidationStatus.none;
                selected-changed(_idx) => {
                }
            }

            Select {
                horizontal-stretch: 1;
                label-text: "Height";
                placeholder: "Choose height…";
                options: playground-height-options;
                selected-index <=> playground-height-index;
                validation-status: ValidationStatus.none;
                selected-changed(_idx) => {
                }
            }
        }

        HorizontalLayout {
            spacing: 24px;
            alignment: start;

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                Text {
                    text: "Show header";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    vertical-alignment: center;
                }

                ToggleSwitch {
                    size: ToggleSwitchSize.small;
                    checked <=> playground-show-header;
                }
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                Text {
                    text: "Show footer";
                    color: PrimerColors.fgColor-default;
                    font-size: 14px;
                    vertical-alignment: center;
                }

                ToggleSwitch {
                    size: ToggleSwitchSize.small;
                    checked <=> playground-show-footer;
                }
            }
        }

        PrimerTextInput {
            width: 100%;
            block: true;
            label-text: "Title";
            placeholder: "Dialog title…";
            text <=> playground-title-text;
            validation-status: ValidationStatus.none;
            edited(_) => {
            }
        }

        PrimerTextInput {
            width: 100%;
            block: true;
            label-text: "Subtitle";
            placeholder: "Optional subtitle…";
            text <=> playground-subtitle-text;
            validation-status: ValidationStatus.none;
            edited(_) => {
            }
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.playground-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Align top / bottom";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "Vertical align";
            placeholder: "Choose top or bottom…";
            options: align-vertical-options;
            selected-index <=> align-vertical-index;
            validation-status: ValidationStatus.none;
            selected-changed(_idx) => {
            }
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.align-demo-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Side sheet";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "Edge";
            placeholder: "Choose left or right…";
            options: side-sheet-edge-options;
            selected-index <=> side-sheet-edge-index;
            validation-status: ValidationStatus.none;
            selected-changed(_idx) => {
            }
        }

        Button {
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.side-sheet-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Narrow viewport — bottom · fullscreen · center";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Select {
            label-text: "position.narrow";
            placeholder: "Pick narrow position…";
            options: narrow-viewport-options;
            selected-index <=> narrow-viewport-index;
            validation-status: ValidationStatus.none;
            selected-changed(_idx) => {
            }
        }

        Button {
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.narrow-demo-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "WithCustomRenderers";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 240px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.custom-renderers-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "WithDirectSubcomponents";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 240px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.direct-sub-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "StressTest";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }



        Button {
            max-width: 220px;
            align-content: ButtonAlignContent.start;
            label: "Open stress dialog";
            clicked => {
                root.stress-test-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "ReproMultistepDialogWithConditionalFooter";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 240px;
            align-content: ButtonAlignContent.start;
            label: "Open multistep dialog";
            clicked => {
                root.multistep-footer-step = 0;
                root.multistep-footer-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "RetainsFocusTrapWithDynamicContent";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 260px;
            align-content: ButtonAlignContent.start;
            label: "Open dynamic footer dialog";
            clicked => {
                root.dynamic-footer-variant = 0;
                root.dynamic-footer-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "LoadingFooterButtons";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 260px;
            align-content: ButtonAlignContent.start;
            label: "Open loading-footer dialog";
            clicked => {
                root.loading-footer-submitting = false;
                root.loading-footer-deleting = false;
                root.loading-footer-open = true;
            }
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding-top: 16px;
        alignment: start;
        width: self.preferred-width;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "LoadingCustomFooterButtonsCould";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Button {
            max-width: 280px;
            align-content: ButtonAlignContent.start;
            label: "Open custom-footer loading dialog";
            clicked => {
                root.loading-custom-saving = false;
                root.loading-custom-processing = false;
                root.loading-custom-footer-open = true;
            }
        }
    }

}
