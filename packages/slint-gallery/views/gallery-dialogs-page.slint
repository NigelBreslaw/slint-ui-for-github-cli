    // Matches primer-ui-react `Dialog.features` **`StressTest`**: **`position: { narrow: fullscreen, regular: center }`**
    // (CSS **`Dialog.module.css`**) — do **not** set **`narrow-layout: true`** here or the shell stays fullscreen at
    // every width; React only uses fullscreen when the real viewport is **≤767px**.
    stress-test-dialog := Dialog {
        open <=> root.stress-test-open;
        position-preset: DialogPositionPreset.center;
        narrow-position-preset: DialogNarrowPositionPreset.fullscreen;
        width-preset: DialogWidthPreset.small;
        title: "This dialog has a really long title. So long, in fact, that it should cause wrapping, going to multiple lines!.";
        subtitle: "It's not a common scenario, sure, but what if the subtitle is generated from a really long value? Do we just break the dialog? Or do we handle it because we are pros?";
        footer-default-label: "Button 0";
        footer-extra-1-label: "Button 1";
        footer-extra-2-label: "Button 2";
        footer-danger-label: "Delete the universe";
        footer-primary-label: "Proceed";
        footer-default-clicked => {
        }
        footer-extra-1-clicked => {
        }
        footer-extra-2-clicked => {
        }
        footer-danger-clicked => {
            root.stress-test-open = false;
        }
        footer-primary-clicked => {
            root.stress-test-inner-legacy-open = true;
        }
        on-close(_gesture) => {
            root.stress-test-open = false;
            root.stress-test-inner-legacy-open = false;
        }

        Text {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis, urna nec lobortis posuere, eros urna venenatis eros, vel accumsan turpis nunc vitae enim.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

