import {
    Button,
    ButtonAlignContent,
    Dialog,
    DialogWidthPreset,
} from "../../primer-slint/primer.slint";
import { AppWindow, PrimerColors } from "../../primer-slint/tokens.slint";

/// One Storybook-aligned block (title + meta + stub open control).
component DialogStoryStub inherits VerticalLayout {
    in property <string> story-title;
    in property <string> story-path;
    in property <string> story-note;

    spacing: 10px;
    width: 100%;
    padding-top: 16px;

    Rectangle {
        height: 1px;
        background: PrimerColors.borderColor-default;
    }

    Text {
        text: root.story-title;
        color: PrimerColors.fgColor-default;
        font-size: 15px;
        font-weight: 600;
    }

    Text {
        text: root.story-path;
        color: PrimerColors.fgColor-muted;
        font-size: 11px;
        wrap: word-wrap;
    }

    Text {
        text: root.story-note;
        color: PrimerColors.fgColor-muted;
        font-size: 12px;
        wrap: word-wrap;
    }

    Button {
        max-width: 200px;
        align-content: ButtonAlignContent.start;
        label: "Open dialog (soon)";
        clicked => {
        }
    }
}

/// Primer **Dialog** gallery (Storybook parity sections). **Default** is live (PR2); other stories are stubs.
export component GalleryDialogsPage inherits VerticalLayout {
    spacing: 32px;
    width: 100%;

    private property <bool> default-outer-open: false;
    private property <bool> default-inner-open: false;

    Text {
        text: "Dialog";
        color: PrimerColors.fgColor-default;
        font-size: 22px;
        font-weight: 600;
    }

    Text {
        text: "Upstream: primer-ui-react `Dialog/` stories. Sections below map 1:1 to Storybook. **PR2** delivers the modal spike (backdrop fade + scaleFade enter motion, centered shell) and a live **Default** demo; other rows stay stubs until later PRs.";
        color: PrimerColors.fgColor-muted;
        font-size: 12px;
        wrap: word-wrap;
    }

    // --- Components/Dialog — Default (PR2 live demo) ---
    VerticalLayout {
        spacing: 10px;
        width: 100%;
        padding-top: 16px;

        Rectangle {
            height: 1px;
            background: PrimerColors.borderColor-default;
        }

        Text {
            text: "Default";
            color: PrimerColors.fgColor-default;
            font-size: 15px;
            font-weight: 600;
        }

        Text {
            text: "Components/Dialog — Default";
            color: PrimerColors.fgColor-muted;
            font-size: 11px;
            wrap: word-wrap;
        }

        Text {
            text: "Outer dialog with scroll body and mixed footer buttons; inner small dialog (no footer), opened from default + primary.";
            color: PrimerColors.fgColor-muted;
            font-size: 12px;
            wrap: word-wrap;
        }

        Button {
            max-width: 200px;
            align-content: ButtonAlignContent.start;
            label: "Show dialog";
            clicked => {
                root.default-outer-open = true;
            }
        }
    }

    default-outer-dialog := Dialog {
        open <=> root.default-outer-open;
        title: "My Dialog";
        width-preset: DialogWidthPreset.xlarge;
        footer-default-clicked => {
            root.default-inner-open = true;
        }
        footer-danger-clicked => {
            root.default-outer-open = false;
            root.default-inner-open = false;
        }
        footer-primary-clicked => {
            root.default-inner-open = true;
        }
        on-close(_gesture) => {
            root.default-outer-open = false;
            root.default-inner-open = false;
        }

        Text {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque sollicitudin mauris maximus elit sagittis, nec lobortis ligula elementum. Nam iaculis urna nec lobortis posuere.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Curabitur scelerisque bibendum faucibus. Duis rhoncus nunc est, at pharetra eros tristique a. Nam sodales turpis lectus, quis faucibus felis fermentum in.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Sed fringilla est ac urna aliquet, eget condimentum felis vulputate. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }

        Text {
            text: "Nunc sodales quis ante quis porttitor. Donec fringilla erat vitae viverra feugiat. Pellentesque vitae rutrum orci.";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    default-inner-dialog := Dialog {
        open <=> root.default-inner-open;
        title: "Inner dialog!";
        width-preset: DialogWidthPreset.small;
        show-footer: false;
        footer-default-clicked => {
        }
        footer-danger-clicked => {
        }
        footer-primary-clicked => {
        }
        on-close(_gesture) => {
            root.default-inner-open = false;
        }

        Text {
            text: "Hello world";
            color: PrimerColors.fgColor-default;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    DialogStoryStub {
        story-title: "Playground";
        story-path: "Components/Dialog — Playground";
        story-note: "Storybook controls matrix only; width/height/position props exercised in other sections.";
    }

    DialogStoryStub {
        story-title: "WithCustomRenderers";
        story-path: "Components/Dialog/Features — WithCustomRenderers";
        story-note: "Custom renderHeader / renderBody / renderFooter.";
    }

    DialogStoryStub {
        story-title: "WithDirectSubcomponents";
        story-path: "Components/Dialog/Features — WithDirectSubcomponents";
        story-note: "Dialog.Header / Body / Footer / Dialog.Buttons.";
    }

    DialogStoryStub {
        story-title: "StressTest";
        story-path: "Components/Dialog/Features — StressTest";
        story-note: "Long title and subtitle; many footer buttons; narrow fullscreen + inner dialog.";
    }

    DialogStoryStub {
        story-title: "ReproMultistepDialogWithConditionalFooter";
        story-path: "Components/Dialog/Features — ReproMultistepDialogWithConditionalFooter";
        story-note: "Conditional footer by step; focus close button on step change.";
    }

    DialogStoryStub {
        story-title: "BottomSheetNarrow";
        story-path: "Components/Dialog/Features — [Position] Bottom sheet (narrow)";
        story-note: "position.narrow bottom, regular center.";
    }

    DialogStoryStub {
        story-title: "FullScreenNarrow";
        story-path: "Components/Dialog/Features — [Position] Fullscreen (narrow)";
        story-note: "position.narrow fullscreen, regular center.";
    }

    DialogStoryStub {
        story-title: "SideSheet";
        story-path: "Components/Dialog/Features — [Position] Side sheet";
        story-note: "position right; full viewport height.";
    }

    DialogStoryStub {
        story-title: "ReturnFocusRef";
        story-path: "Components/Dialog/Features — ReturnFocusRef";
        story-note: "Return focus to trigger on close (Slint parity may be partial).";
    }

    DialogStoryStub {
        story-title: "NewIssues";
        story-path: "Components/Dialog/Features — NewIssues";
        story-note: "ActionList in body; initialFocusRef.";
    }

    DialogStoryStub {
        story-title: "RetainsFocusTrapWithDynamicContent";
        story-path: "Components/Dialog/Features — RetainsFocusTrapWithDynamicContent";
        story-note: "Dynamic body/footer and stacked inner dialog.";
    }

    DialogStoryStub {
        story-title: "LoadingFooterButtons";
        story-path: "Components/Dialog/Features — LoadingFooterButtons";
        story-note: "Footer buttons with loading and autoFocus.";
    }

    DialogStoryStub {
        story-title: "LoadingCustomFooterButtonsCould";
        story-path: "Components/Dialog/Features — LoadingCustomFooterButtonsCould";
        story-note: "renderFooter + loading on secondary actions.";
    }

    DialogStoryStub {
        story-title: "AlignTop";
        story-path: "Components/Dialog/Features — [Align] Top";
        story-note: "align top with centered regular position.";
    }

    DialogStoryStub {
        story-title: "AlignBottom";
        story-path: "Components/Dialog/Features — [Align] Bottom";
        story-note: "align bottom with centered regular position.";
    }
}
