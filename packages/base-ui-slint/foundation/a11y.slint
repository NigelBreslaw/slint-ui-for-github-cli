import { BaseUiLayoutTokens } from "../tokens.slint";
import { BaseUiColors } from "../tokens.slint";

/// Role label strings for gallery/debug when `accessible-role` is set.
export global BaseUiA11y {
    public pure function role-name(role: AccessibleRole) -> string {
        role == AccessibleRole.button ? "button"
        : role == AccessibleRole.checkbox ? "checkbox"
        : role == AccessibleRole.text ? "text"
        : role == AccessibleRole.none ? "none"
        : "other"
    }
}

component BaseUiCheckboxChromeBody {
    in property <bool> checked: false;
    in property <bool> enabled: true;
    in property <string> role-badge-text: "none";
    in property <bool> show-role-badge: false;
    callback toggled();

    width: root.show-role-badge ? 140px : 32px;
    height: 32px;

    fs := FocusScope {
        width: 100%;
        height: 100%;
        enabled: root.enabled;
        focus-on-click: false;
        focus-on-tab-navigation: root.enabled;

        key-pressed(event) => {
            if !root.enabled {
                return reject;
            }
            if event.text == Key.Return || event.text == Key.Space {
                root.toggled();
                return accept;
            }
            return reject;
        }

        ta := TouchArea {
            width: 100%;
            height: 100%;
            enabled: root.enabled;
            clicked => {
                root.toggled();
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                Rectangle {
                    width: 18px;
                    height: 18px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: BaseUiColors.border-strong;
                    background: root.checked ? BaseUiColors.bg-muted : BaseUiColors.surface-elevated;

                    if root.checked: Rectangle {
                        width: 10px;
                        height: 10px;
                        x: 3px;
                        y: 3px;
                        border-radius: 2px;
                        background: BaseUiColors.fg-default;
                    }
                }

                if root.show-role-badge: Text {
                    text: root.role-badge-text;
                    color: BaseUiColors.fg-muted;
                    font-size: BaseUiLayoutTokens.text-body-size-small;
                    font-family: "monospace";
                }
            }
        }
    }
}

/// Checkbox without accessibility metadata.
export component BaseUiCheckboxChrome inherits BaseUiCheckboxChromeBody {
    accessible-role: AccessibleRole.none;

    role-badge-text: "none";
}

/// Checkbox with `accessible-role: checkbox`, label, and checked state.
export component BaseUiCheckboxChromeA11y inherits BaseUiCheckboxChromeBody {
    in property <string> a11y-label: "";

    accessible-role: AccessibleRole.checkbox;
    accessible-label: root.a11y-label;
    accessible-checked: root.checked;
    role-badge-text: "checkbox";
}
