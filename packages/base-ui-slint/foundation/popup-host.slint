import {
    BaseUiAppWindow,
    BaseUiMotionTokens,
    BaseUiOverlayTokens,
} from "../tokens.slint";
import { BaseUiOpenChangeReasons } from "./dismiss.slint";
import {
    BaseUiAnchorAlign,
    BaseUiAnchorSide,
    BaseUiPositionProps,
    BaseUiPositioner,
} from "./positioner.slint";
import { BaseUiPopupPanelChrome } from "./popup-panel-chrome.slint";
import { BaseUiPopupFocusScope } from "./modality.slint";
import { BaseUiFloatingTree } from "./floating-tree.slint";

export { BaseUiPositionProps, BaseUiAnchorSide, BaseUiAnchorAlign } from "./positioner.slint";

/// Headless anchored popup — `PopupWindow` host + neutral panel chrome + dismiss (PR5).
export component BaseUiAnchoredPopup {
    width: 0px;
    height: 0px;

    property <bool> open: false;
    in property <BaseUiPositionProps> position-props;
    in property <BaseUiAnchorSide> side: BaseUiAnchorSide.outside_bottom;
    in property <BaseUiAnchorAlign> align: BaseUiAnchorAlign.start;
    in property <length> margin: 8px;
    in property <length> anchor-offset: 0px;
    in property <length> alignment-offset: 0px;
    in property <bool> prevent-overflow: true;
    in property <length> panel-width: 280px;
    in property <length> panel-height: 120px;
    in property <bool> reduce-motion: false;
    /// When true, Escape and outside-press dismiss (if `allow-dismiss`).
    in property <bool> allow-dismiss: true;
    /// Dimmed fullscreen scrim behind the panel (modal presentation).
    in property <bool> show-backdrop: false;
    /// Modal: enables backdrop when `show-backdrop` is false; focuses panel on open for tab trap.
    in property <bool> modal: false;
    /// Center panel in the host viewport (modal dialog) instead of anchoring to `position-props`.
    in property <bool> viewport-centered: false;
    /// Registers this popup in [`BaseUiFloatingTree`] on show (nested floating demo / widgets).
    in property <string> floating-layer-id: "";
    /// Restored as `top-layer-id` when this layer closes while topmost.
    in property <string> floating-parent-layer-id: "";

    property <bool> effective-backdrop: root.show-backdrop || root.modal;
    property <bool> is-floating-top: root.floating-layer-id == ""
        || root.floating-layer-id == BaseUiFloatingTree.top-layer-id;

    in-out property <string> last-close-reason: BaseUiOpenChangeReasons.none;

    callback show();
    callback close();
    /// Fired before `close()` with the upstream reason string.
    callback close-requested(string);
    callback opened();
    callback closed();

    property <length> ax: root.position-props.absolute-position.x;
    property <length> ay: root.position-props.absolute-position.y;
    property <length> aw: root.position-props.source-size.width;
    property <length> ah: root.position-props.source-size.height;
    property <length> vw: BaseUiAppWindow.window-width;
    property <length> vh: BaseUiAppWindow.window-height;

    property <length> pane-width: root.panel-width;
    property <length> pane-height: root.panel-height;

    out property <BaseUiAnchorSide> effective-side: BaseUiPositioner.flip-side(
        root.side,
        root.prevent-overflow,
        root.ax,
        root.ay,
        root.aw,
        root.ah,
        root.margin,
        root.anchor-offset,
        root.pane-width,
        root.pane-height,
        root.vw,
        root.vh,
    );

    property <length> raw-x: BaseUiPositioner.raw-x(
        root.effective-side,
        root.align,
        root.ax,
        root.ay,
        root.aw,
        root.ah,
        root.margin,
        root.anchor-offset,
        root.alignment-offset,
        root.pane-width,
    );

    property <length> raw-y: BaseUiPositioner.raw-y(
        root.effective-side,
        root.align,
        root.ax,
        root.ay,
        root.aw,
        root.ah,
        root.margin,
        root.anchor-offset,
        root.alignment-offset,
        root.pane-height,
    );

    property <length> final-x: BaseUiPositioner.clamp-x(root.raw-x, root.pane-width, root.prevent-overflow, root.vw);
    property <length> final-y: BaseUiPositioner.clamp-y(root.raw-y, root.pane-height, root.prevent-overflow, root.vh);

    property <length> positioned-x: root.viewport-centered
        ? max(0px, (root.vw - root.pane-width) / 2)
        : root.final-x;
    property <length> positioned-y: root.viewport-centered
        ? max(0px, (root.vh - root.pane-height) / 2)
        : root.final-y;

    function dismiss-with-reason(reason: string) {
        root.last-close-reason = reason;
        root.close();
    }

    open-enter-delay := Timer {
        interval: 1ms;
        running: false;
        triggered() => {
            root.open = true;
            root.opened();
            self.stop();
        }
    }

    show => {
        root.last-close-reason = BaseUiOpenChangeReasons.none;
        if root.floating-layer-id != "" {
            BaseUiFloatingTree.claim(root.floating-layer-id);
        }
        popup.show();
        if root.reduce-motion {
            root.open = true;
            root.opened();
        } else {
            open-enter-delay.start();
        }
    }

    close => {
        if root.last-close-reason != BaseUiOpenChangeReasons.none {
            root.close-requested(root.last-close-reason);
        }
        if root.floating-layer-id != "" {
            BaseUiFloatingTree.release(root.floating-layer-id, root.floating-parent-layer-id);
        }
        root.open = false;
        popup.close();
        root.closed();
    }

    popup := PopupWindow {
        x: 0px - root.position-props.absolute-position.x;
        y: 0px - root.position-props.absolute-position.y;
        width: BaseUiAppWindow.window-width;
        height: BaseUiAppWindow.window-height;

        close-policy: no-auto-close;
        forward-focus: panel-focus;

        overlay-scope := FocusScope {
            key-pressed(event) => {
                if root.allow-dismiss && root.is-floating-top && event.text == Key.Escape {
                    root.dismiss-with-reason(BaseUiOpenChangeReasons.escape-key);
                    return accept;
                }
                return reject;
            }

            dismiss-layer := Rectangle {
                width: BaseUiAppWindow.window-width;
                height: BaseUiAppWindow.window-height;
                background: root.effective-backdrop ? BaseUiOverlayTokens.backdrop-scrim : #00000000;

                dismiss-ta := TouchArea {
                    enabled: root.allow-dismiss && root.is-floating-top;
                    clicked => {
                        root.dismiss-with-reason(BaseUiOpenChangeReasons.outside-press);
                    }
                }
            }

            pane := Rectangle {
                width: root.pane-width;
                height: root.pane-height;

                states [
                    pane-open when root.open: {
                        x: root.positioned-x;
                        y: root.positioned-y;
                        opacity: 1.0;
                        in {
                            animate opacity {
                                duration: BaseUiMotionTokens.overlay-enter-duration;
                                easing: ease-out;
                            }
                        }
                    }
                    pane-idle when !root.open: {
                        x: root.positioned-x;
                        y: root.positioned-y;
                        opacity: 0.0;
                    }
                ]

                touch-blocker := TouchArea { }

                panel-chrome := BaseUiPopupPanelChrome {
                    width: parent.width;
                    height: parent.height;

                    panel-focus := BaseUiPopupFocusScope {
                        width: 100%;
                        height: 100%;
                        modal: root.modal;
                        active: root.open;

                        @children
                    }
                }
            }
        }
    }
}
