/// Open-change reason strings aligned with Base UI [`reason-parts.ts`](https://github.com/mui/base-ui/blob/master/packages/react/src/internals/reason-parts.ts).
export global BaseUiOpenChangeReasons {
    out property <string> none: "none";
    out property <string> escape-key: "escape-key";
    out property <string> outside-press: "outside-press";
    out property <string> close-press: "close-press";
    out property <string> trigger-press: "trigger-press";
}
