{
  "name": "slint-bridge-kit",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Small helpers for wiring slint-ui Node handles (exhaustive callbacks, batched assigns).",
  "keywords": ["slint", "slint-ui", "typescript", "callbacks"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src/assign-properties.ts",
    "src/slint-enum-literals.ts",
    "src/index.ts",
    "src/types.ts",
    "src/version.ts",
    "src/wire-functions.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "typescript": ">=5.4.0"
  },
  "scripts": {
    "autofix": "pnpm lint:fix && pnpm format && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "license": "MIT"
}
