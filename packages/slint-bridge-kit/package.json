{
  "name": "slint-bridge-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Small helpers for wiring slint-ui Node handles (exhaustive callbacks, batched assigns).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "autofix": "pnpm lint:fix && pnpm format && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "license": "MIT"
}
