{
  "name": "github-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "autofix": "pnpm dedupe --prefer-offline && pnpm lint:fix && pnpm format && pnpm knip && pnpm typecheck",
    "start": "node src/main.ts",
    "dev:debug": "cross-env GH_DEBUG_JSON=1 node src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "knip": "knip"
  },
  "dependencies": {
    "arktype": "2.2.0",
    "better-sqlite3": "12.8.0",
    "sharp": "0.34.5",
    "slint-ui": "1.15.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0",
    "cross-env": "10.1.0",
    "knip": "6.1.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "typescript": "6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "slint-ui"
    ]
  }
}
