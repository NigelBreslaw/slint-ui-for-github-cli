{
  "name": "github-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/main.ts",
    "dev:debug": "cross-env GH_DEBUG_JSON=1 node src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "slint-ui": "1.15.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "cross-env": "10.1.0",
    "typescript": "6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "slint-ui"
    ]
  }
}
