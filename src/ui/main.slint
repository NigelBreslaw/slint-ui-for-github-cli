import {
    Spinner,
    Palette,
    StyleMetrics,
} from "std-widgets.slint";
import {
    Authed,
    AppState,
    ProjectRow,
    ReviewRequestRow,
    View,
} from "app-state.slint";
import { SettingsState } from "settings-state.slint";
import { Header } from "components/header.slint";
import { Settings } from "settings.slint";
import { Dashboard } from "dashboard.slint";
import { Button } from "components/button.slint";
import { SideBar } from "components/sideBar.slint";

// Export so backend can access the enums and global state.
export { Authed, AppState, ProjectRow, ReviewRequestRow, SettingsState }

export component MainWindow inherits Window {
    callback close-auth-window;
    callback show_auth_window;
    callback open-github-device-clicked;
    callback show_no_gh_cli_installed;
    callback open_cli_install_page;

    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    close-auth-window => {
        auth_window.close();
    }

    show_auth_window => {
        auth_window.show();
    }

    show_no_gh_cli_installed => {
        no_gh_cli_installed_window.show();
    }

    in property <string> status_message: "";
    in property <string> auth-device-code: "";
    in property <string> auth-device-url: "";

    min-width: 600px;
    min-height: 400px;
    title: "GitHub CLI";
    background: #0d1116;

    HorizontalLayout {
        alignment: center;
        width: 100%;
        height: 100%;

        VerticalLayout {
            alignment: center;
            spacing: 12px;
            width: 100%;
            height: 100%;

            Text {
                text: status_message;
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }

    side-bar := SideBar {
        x: 0;
        y: header.header-height;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;
    }

    content := Rectangle {
        x: side-bar.width;
        y: header.header-height;
        width: root.width - self.x;
        height: root.height - self.y;

        if AppState.view == View.dashboard: Dashboard { }

        if AppState.view == View.settings: Settings { }
    }

    header := Header { }

    no_gh_cli_installed_window := PopupWindow {
        width: root.width;
        height: root.height;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black;
        }

        VerticalLayout {
            x: (root.width - self.preferred-width) / 2;
            y: (root.height - self.preferred-height) / 2;
            width: self.preferred-width;
            height: self.preferred-height;
            spacing: 20px;
            Text {
                text: "GitHub CLI is not installed";
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Button {
                label: "Open CLI install page";
                clicked => {
                    root.open_cli_install_page();
                }
            }
        }

        close-policy: no-auto-close;
    }

    auth_window := PopupWindow {
        width: root.width;
        height: root.height;
        x: 0;
        y: 0;

        close-policy: no-auto-close;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black.with-alpha(0.9);

            TouchArea {
                width: 100%;
                height: 100%;
            }

            vl := VerticalLayout {
                alignment: center;
                spacing: 16px;
                width: self.preferred-width;
                height: 100%;

                Text {
                    text: "Finish in the terminal (browser or device flow)";
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Text {
                    visible: root.auth-device-code != "";
                    text: "Your code: ";
                    font-size: 18px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                TextInput {
                    visible: root.auth-device-code != "";
                    text: root.auth-device-code;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    read-only: true;
                    changed has-focus => {
                        if (self.has-focus) {
                            self.select-all();
                        }
                    }
                }

                Button {
                    visible: root.auth-device-code != "";
                    label: "Copy code to clipboard and open web login";
                    clicked => {
                        root.open-github-device-clicked();
                    }
                }

                Spinner {
                    indeterminate: true;
                }
            }
        }
    }
}
