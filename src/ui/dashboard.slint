import { ListView, VerticalBox } from "std-widgets.slint";
import { AppState } from "app-state.slint";

export component Dashboard {
    width: 100%;
    height: 100%;
    callback open-pr-url(string);

    Rectangle {
        width: 100%;
        height: 100%;
        background: #020408;

        VerticalBox {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            Text {
                text: "Dashboard";
                font-size: 20px;
                font-weight: 700;
                color: #f0f6fc;
            }

            Text {
                text: "Review requests";
                font-size: 14px;
                font-weight: 600;
                color: #c9d1d9;
            }

            Text {
                visible: AppState.review-requests-data-ready;
                text: AppState.review-requests-total + " open (directly requested of you)";
                font-size: 16px;
                font-weight: 600;
                color: #f0f6fc;
            }

            if AppState.review-requests-load-status != "": Text {
                text: AppState.review-requests-load-status;
                color: #8b949e;
                wrap: word-wrap;
            }

            ListView {
                width: 100%;
                for row[index] in AppState.review-requests-model: Rectangle {
                    height: 56px;
                    background: mod(index, 2) == 0 ? #0d1116 : #161b22;

                    TouchArea {
                        clicked => {
                            root.open-pr-url(row.url);
                        }

                        VerticalBox {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: row.title;
                                color: #f0f6fc;
                                overflow: elide;
                            }

                            Text {
                                text: row.repo_label;
                                font-size: 12px;
                                color: #8b949e;
                            }
                        }
                    }
                }
            }
        }
    }
}
