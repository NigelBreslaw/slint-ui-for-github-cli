// Scrollable option list for PrimerSelect (dark, Primer-style). Used inside PopupWindow.

import { SelectOption } from "primer-select-common.slint";

export component PrimerSelectMenu {
    in property <[SelectOption]> options;
    in property <length> row-height;
    in property <length> font-size;
    in property <color> fill-hover;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> fill-selected;
    in property <int> highlighted-index: -1;
    in property <length> viewport-height;

    callback pick(int);

    private property <length> scroll-content-height: options.length * root.row-height;

    min-height: viewport-height;
    max-height: viewport-height;
    horizontal-stretch: 1;

    Rectangle {
        width: 100%;
        height: 100%;
        clip: true;

        Flickable {
            width: 100%;
            height: root.viewport-height;
            viewport-width: parent.width;
            viewport-height: max(root.scroll-content-height, 1px);

            list-col := VerticalLayout {
                spacing: 0;
                width: parent.width;

                for opt[index] in options: Rectangle {
                    height: root.row-height;
                    background:
                        index == root.highlighted-index ? root.fill-selected :
                        row-ta.has-hover ? root.fill-hover : #00000000;
                    opacity: opt.enabled ? 1.0 : 0.45;

                    row-ta := TouchArea {
                        enabled: opt.enabled;

                        clicked => {
                            if opt.enabled {
                                root.pick(index);
                            }
                        }

                        Text {
                            x: 10px;
                            y: 0;
                            width: parent.width - 20px;
                            height: parent.height;
                            text: opt.label;
                            font-size: root.font-size;
                            color: opt.enabled ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }
}
