// Primer-style Select (dark only). Reference: https://primer.style/product/components/select/
// Layered drop-shadow: same pattern as ButtonGreen in buttons.slint.
// Popup + scroll patterns informed by Slint Material DropDownMenu (reimplemented, not copied).
// When `selected-value` or `options` change from TypeScript, keep `selected-label` in sync there
// (Slint cannot scan the options model in a `changed` handler in this toolchain).

import { SelectOption } from "primer-select-common.slint";
import { PrimerSelectMenu } from "primer-select-menu.slint";

export enum SelectSize {
    small,
    medium,
    large,
}

export enum ValidationStatus {
    none,
    error,
    success,
}

export component PrimerSelect {
    in property <string> label-text: "";
    in-out property <string> selected-value: "";
    in-out property <string> selected-label: "";
    in-out property <int> selected-index: -1;
    in property <string> placeholder: "Select…";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <SelectSize> size: medium;
    in property <[SelectOption]> options;
    in property <int> max-visible-rows: 7;
    callback selected-changed(string);

    private property <int> highlighted-index: -1;
    private property <bool> menu-open: false;

    horizontal-stretch: block ? 1 : 0;
    min-width: 200px;

    private property <length> trigger-height: size == SelectSize.small ? 28px : size == SelectSize.large ? 40px : 32px;
    private property <length> trigger-font: size == SelectSize.small ? 12px : size == SelectSize.large ? 15px : 14px;
    private property <color> border-default: #30363d;
    private property <color> border-error: #f85149;
    private property <color> border-success: #238636;
    private property <color> fill-bg: #0d1117;
    private property <color> fill-hover: #161b22;
    private property <color> fill-selected: #21262d;
    private property <color> text-primary: #f0f6fc;
    private property <color> text-muted: #8b949e;
    private property <color> text-error: #f85149;
    private property <color> text-success: #3fb950;

    private property <color> trigger-border-color:
        validation-status == ValidationStatus.error ? border-error : validation-status == ValidationStatus.success ? border-success : border-default;

    private property <length> menu-list-viewport-height: max(min(options.length * trigger-height, max-visible-rows * trigger-height), options.length == 0 ? trigger-height : 0px);

    private property <length> popup-panel-height: trigger-height + 1px + menu-list-viewport-height;

    function apply-pick-at(ix: int) {

        if ix < 0 || ix >= options.length {
            return;
        }
        if !options[ix].enabled {
            return;
        }
        root.selected-value = options[ix].value;
        root.selected-label = options[ix].label;
        root.selected-index = ix;
        root.menu-open = false;
        root.selected-changed(options[ix].value);

        // menu.close();
        test.start();
    }

    test := Timer {
        interval: 20ms;
        running: false;
        triggered => {
            self.stop();
            menu.close();
        }
    }

    function step-highlight(delta: int) {
        if options.length <= 0 {
            return;
        }
        root.highlighted-index = Math.mod(root.highlighted-index + delta + options.length, options.length);
    }

    VerticalLayout {
        spacing: 6px;
        horizontal-stretch: block ? 1 : 0;

        if label-text != "": Text {
            text: label-text;
            font-size: 14px;
            font-weight: 600;
            color: text-primary;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0;
            horizontal-stretch: block ? 1 : 0;

            trigger-wrap := Rectangle {
                horizontal-stretch: block ? 1 : 0;
                height: trigger-height;

                root-focus := FocusScope {
                    width: 100%;
                    height: 100%;

                    key-pressed(event) => {
                        if root.disabled || root.options.length == 0 {
                            return reject;
                        }
                        if event.text == Key.DownArrow {
                            if root.menu-open {
                                root.step-highlight(1);
                            } else {
                                root.highlighted-index = root.selected-index >= 0 ? root.selected-index : 0;
                                root.menu-open = true;
                                menu.show();
                            }
                            return accept;
                        }
                        if event.text == Key.UpArrow {
                            if root.menu-open {
                                root.step-highlight(-1);
                            } else {
                                root.highlighted-index = root.selected-index >= 0 ? root.selected-index : 0;
                                root.menu-open = true;
                                menu.show();
                            }
                            return accept;
                        }
                        if event.text == Key.Return {
                            if root.menu-open {
                                root.apply-pick-at(root.highlighted-index);
                            } else {
                                root.highlighted-index = root.selected-index >= 0 ? root.selected-index : 0;
                                root.menu-open = true;
                                menu.show();
                            }
                            return accept;
                        }
                        reject
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        border-radius: 6px;
                        drop-shadow-offset-x: 0px;
                        drop-shadow-offset-y: 1px;
                        drop-shadow-blur: 2px;
                        drop-shadow-color: #01040966;
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        border-radius: 6px;
                        drop-shadow-offset-x: 0px;
                        drop-shadow-offset-y: 1px;
                        drop-shadow-blur: 1px;
                        drop-shadow-color: #01040999;
                    }

                    trigger-bg := Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: disabled ? fill-bg : ta.has-hover ? fill-hover : fill-bg;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: trigger-border-color;
                        clip: false;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 8px;
                            spacing: 8px;
                            width: 100%;
                            height: 100%;

                            Text {
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                                text: selected-label != "" ? selected-label : placeholder;
                                font-size: trigger-font;
                                color: selected-label != "" ? text-primary : text-muted;
                                overflow: elide;
                            }

                            Image {
                                width: 16px;
                                height: 16px;
                                vertical-alignment: center;
                                source: @image-url("../../assets/16px/chevron-down.svg");
                                colorize: text-muted;
                            }
                        }
                    }

                    ta := TouchArea {
                        clicked => {
                            if !disabled && options.length > 0 {
                                if root.menu-open {
                                    root.menu-open = false;
                                    menu.close();
                                } else {
                                    root.highlighted-index = root.selected-index >= 0 ? root.selected-index : 0;
                                    root.menu-open = true;
                                    menu.show();
                                }
                            }
                        }
                    }

                    menu := PopupWindow {
                        close-policy: close-on-click-outside;
                        x: 0;
                        y: parent.height + 4px;
                        width: parent.width;

                        // sync-timer := Timer {
                        //     interval: 32ms;
                        //     running: true;
                        //     triggered => {
                        //         root.menu-open = parent.visible;
                        //     }
                        // }

                        Rectangle {
                            width: 100%;
                            height: root.popup-panel-height;
                            background: fill-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: border-default;
                            clip: true;

                            VerticalLayout {
                                spacing: 0;
                                width: 100%;
                                height: 100%;

                                VerticalLayout {
                                    spacing: 0;
                                    width: 100%;

                                    Rectangle {
                                        height: root.trigger-height;
                                        background: fill-hover;

                                        TouchArea {
                                            clicked => {
                                            // root.menu-open = false;
                                            // menu.close();
                                        }

                                            HorizontalLayout {
                                                padding-left: 10px;
                                                padding-right: 8px;
                                                spacing: 8px;
                                                width: 100%;
                                                height: 100%;

                                                Text {
                                                    horizontal-stretch: 1;
                                                    vertical-alignment: center;
                                                    text: selected-label != "" ? selected-label : placeholder;
                                                    font-size: root.trigger-font;
                                                    color: selected-label != "" ? text-primary : text-muted;
                                                    overflow: elide;
                                                }

                                                Image {
                                                    width: 16px;
                                                    height: 16px;
                                                    vertical-alignment: center;
                                                    source: @image-url("../../assets/16px/chevron-up.svg");
                                                    colorize: text-muted;
                                                }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: border-default;
                                    }
                                }

                                menu-keys := Rectangle {
                                    horizontal-stretch: 1;
                                    height: root.menu-list-viewport-height;

                                    

                                    if options.length > 0: PrimerSelectMenu {
                                        width: 100%;
                                        height: 100%;
                                        options: root.options;
                                        row-height: root.trigger-height;
                                        font-size: root.trigger-font;
                                        fill-hover: root.fill-hover;
                                        text-primary: root.text-primary;
                                        text-muted: root.text-muted;
                                        fill-selected: root.fill-selected;
                                        highlighted-index: root.highlighted-index;
                                        viewport-height: root.menu-list-viewport-height;
                                        pick(ix) => {
                                            root.apply-pick-at(ix);
                                        }
                                    }

                                    if options.length == 0: Rectangle {
                                        height: 100%;
                                        background: fill-bg;

                                        Text {
                                            x: 10px;
                                            y: 0;
                                            width: parent.width - 20px;
                                            height: parent.height;
                                            text: "No options";
                                            font-size: root.trigger-font;
                                            color: text-muted;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: 12px;
            color: text-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;
            horizontal-stretch: block ? 1 : 0;

            Image {
                width: 16px;
                height: 16px;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ? @image-url("../../assets/16px/alert.svg") : @image-url("../../assets/16px/check-circle.svg");
                colorize: validation-status == ValidationStatus.error ? text-error : text-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: 13px;
                color: validation-status == ValidationStatus.error ? text-error : text-success;
                wrap: word-wrap;
            }
        }
    }
}
