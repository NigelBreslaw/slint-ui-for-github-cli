// Primer-style Select (dark only). Reference: https://primer.style/product/components/select/
// Layered drop-shadow: same pattern as ButtonGreen in buttons.slint.

import { ListView } from "std-widgets.slint";

export struct SelectOption {
    value: string,
    label: string,
}

export enum SelectSize {
    small,
    medium,
    large,
}

export enum ValidationStatus {
    none,
    error,
    success,
}

export component PrimerSelect {
    in property <string> label-text: "";
    in-out property <string> selected-value: "";
    in-out property <string> selected-label: "";
    in property <string> placeholder: "Select…";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <SelectSize> size: medium;
    in property <[SelectOption]> options;
    callback selected-changed(string);

    private property <bool> menu-open: false;

    horizontal-stretch: block ? 1 : 0;
    min-width: 200px;

    // --- Dark tokens (GitHub-ish) ---
    private property <length> trigger-height: size == SelectSize.small ? 28px : size == SelectSize.large ? 40px : 32px;
    private property <length> trigger-font: size == SelectSize.small ? 12px : size == SelectSize.large ? 15px : 14px;
    private property <color> border-default: #30363d;
    private property <color> border-error: #f85149;
    private property <color> border-success: #238636;
    private property <color> fill-bg: #0d1117;
    private property <color> fill-hover: #161b22;
    private property <color> text-primary: #f0f6fc;
    private property <color> text-muted: #8b949e;
    private property <color> text-error: #f85149;
    private property <color> text-success: #3fb950;

    private property <color> trigger-border-color:
        validation-status == ValidationStatus.error ? border-error :
        validation-status == ValidationStatus.success ? border-success : border-default;

    VerticalLayout {
        spacing: 6px;
        horizontal-stretch: block ? 1 : 0;

        if label-text != "": Text {
            text: label-text;
            font-size: 14px;
            font-weight: 600;
            color: text-primary;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 4px;
            horizontal-stretch: block ? 1 : 0;

            Rectangle {
                horizontal-stretch: block ? 1 : 0;
                height: trigger-height;

                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    border-radius: 6px;
                    drop-shadow-offset-x: 0px;
                    drop-shadow-offset-y: 1px;
                    drop-shadow-blur: 2px;
                    drop-shadow-color: #01040966;
                }

                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    border-radius: 6px;
                    drop-shadow-offset-x: 0px;
                    drop-shadow-offset-y: 1px;
                    drop-shadow-blur: 1px;
                    drop-shadow-color: #01040999;
                }

                trigger-bg := Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: disabled ? fill-bg : ta.has-hover ? fill-hover : fill-bg;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: trigger-border-color;
                    clip: false;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 8px;
                        spacing: 8px;
                        width: 100%;
                        height: 100%;

                        Text {
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            text: selected-label != "" ? selected-label : placeholder;
                            font-size: trigger-font;
                            color: selected-label != "" ? text-primary : text-muted;
                            overflow: elide;
                        }

                        Image {
                            width: 16px;
                            height: 16px;
                            vertical-alignment: center;
                            source: @image-url("../../assets/16px/chevron-down.svg");
                            colorize: text-muted;
                        }
                    }
                }

                ta := TouchArea {
                    clicked => {
                        if !disabled {
                            menu-open = !menu-open;
                        }
                    }
                }
            }

            if menu-open && !disabled: Rectangle {
                horizontal-stretch: block ? 1 : 0;
                max-height: 220px;
                background: fill-bg;
                border-radius: 6px;
                border-width: 1px;
                border-color: border-default;
                clip: true;

                VerticalLayout {
                    padding: 4px;
                    horizontal-stretch: block ? 1 : 0;
                    height: 100%;

                    ListView {
                        horizontal-stretch: block ? 1 : 0;
                        height: 100%;
                        for opt[index] in options: Rectangle {
                            height: root.trigger-height;
                            background: row-ta.has-hover ? fill-hover : #00000000;

                            row-ta := TouchArea {
                                clicked => {
                                    root.selected-value = opt.value;
                                    root.selected-label = opt.label;
                                    root.menu-open = false;
                                    root.selected-changed(opt.value);
                                }

                                Text {
                                    x: 10px;
                                    y: 0;
                                    width: parent.width - 20px;
                                    height: parent.height;
                                    text: opt.label;
                                    font-size: root.trigger-font;
                                    color: text-primary;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: 12px;
            color: text-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;
            horizontal-stretch: block ? 1 : 0;

            Image {
                width: 16px;
                height: 16px;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ?
                    @image-url("../../assets/16px/alert.svg") :
                    @image-url("../../assets/16px/check-circle.svg");
                colorize: validation-status == ValidationStatus.error ? text-error : text-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: 13px;
                color: validation-status == ValidationStatus.error ? text-error : text-success;
                wrap: word-wrap;
            }
        }
    }
}
