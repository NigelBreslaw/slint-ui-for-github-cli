import { SettingsState } from "settings-state.slint";

component TableRow {

    in property <string> label-text;
    in property <string> value-text;
    in property <bool> header-row: false;

    min-height: 40px;
    width: 450px;

    HorizontalLayout {
        spacing: 0;
        width: 100%;

        Rectangle {
            width: 190px;
            min-height: 40px;
            background: header-row ? #21262d : #0d1117;
            border-width: 1px;
            border-color: #30363d;

            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: label-text;
                font-size: header-row ? 14px : 15px;
                font-weight: header-row ? 600 : 400;
                color: #f0f6fc;
                wrap: word-wrap;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-height: 40px;
            background: header-row ? #21262d : #161b22;
            border-width: 1px;
            border-color: #30363d;

            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: value-text;
                font-size: header-row ? 14px : 15px;
                font-weight: header-row ? 600 : 400;
                color: header-row ? #f0f6fc : #c9d1d9;
                wrap: word-wrap;
            }
        }
    }
}

export component Settings {
    width: 100%;
    height: 100%;

    init => {
        SettingsState.settings-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: #0d1117;

        VerticalLayout {
            padding: 16px;
            spacing: 0;
            width: self.preferred-width;
            height: self.preferred-height;

            VerticalLayout {
                spacing: 0;
                width: self.preferred-width;
                height: self.preferred-height;

                TableRow {
                    label-text: "Version";
                    value-text: SettingsState.settings-debug-commit-label;
                }

                TableRow {
                    label-text: "GitHub CLI";
                    value-text: SettingsState.settings-debug-gh-version;
                }

                TableRow {
                    label-text: "GraphQL rate limit";
                    value-text: SettingsState.settings-debug-rate-limit;
                }

                TableRow {
                    label-text: "Resets at (local time)";
                    value-text: SettingsState.settings-debug-reset-at;
                }

                TableRow {
                    label-text: "Time until reset";
                    value-text: SettingsState.settings-debug-countdown;
                }
            }

            if SettingsState.settings-debug-error != "": Text {
                padding-top: 12px;
                text: SettingsState.settings-debug-error;
                color: #f85149;
                font-size: 13px;
                wrap: word-wrap;
            }
        }
    }
}
