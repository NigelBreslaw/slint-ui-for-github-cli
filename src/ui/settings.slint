import { ListView, VerticalBox } from "std-widgets.slint";
import { AppState } from "app-state.slint";

export component Settings {
    width: 100%;
    height: 100%;
    callback open-project-url(string);

    Rectangle {
        width: 100%;
        height: 100%;
        background: #020408;

        VerticalBox {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            Text {
                text: "Settings";
                font-size: 20px;
                font-weight: 700;
                color: #f0f6fc;
            }

            Text {
                text: "Search projects";
                font-size: 12px;
                color: #8b949e;
            }

            TextInput {
                text <=> AppState.projects-search;
                edited => {
                    AppState.project-search-changed(self.text);
                }
            }

            if AppState.projects-load-status != "": Text {
                text: AppState.projects-load-status;
                color: #8b949e;
                wrap: word-wrap;
            }

            ListView {
                width: 100%;
                for row[index] in AppState.projects-filtered-model: Rectangle {
                    height: 56px;
                    background: mod(index, 2) == 0 ? #0d1116 : #161b22;

                    TouchArea {
                        clicked => {
                            root.open-project-url(row.url);
                        }

                        VerticalBox {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: row.title;
                                color: #f0f6fc;
                                overflow: elide;
                            }

                            Text {
                                text: "#" + row.number;
                                font-size: 12px;
                                color: #8b949e;
                            }
                        }
                    }
                }
            }
        }
    }
}
