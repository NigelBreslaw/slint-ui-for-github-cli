import { SettingsState } from "../../data-bridges/settings-state.slint";
import { PrimerSelect, ValidationStatus } from "../components/primer-select.slint";

component TableRow {

    in property <string> label-text;
    in property <string> value-text;
    in property <bool> header-row: false;

    min-height: 40px;
    width: 450px;

    HorizontalLayout {
        spacing: 0;
        width: 100%;

        Rectangle {
            width: 190px;
            min-height: 40px;
            background: header-row ? #21262d : #0d1117;
            border-width: 1px;
            border-color: #30363d;

            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: label-text;
                font-size: header-row ? 14px : 15px;
                font-weight: header-row ? 600 : 400;
                color: #f0f6fc;
                wrap: word-wrap;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-height: 40px;
            background: header-row ? #21262d : #161b22;
            border-width: 1px;
            border-color: #30363d;

            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: value-text;
                font-size: header-row ? 14px : 15px;
                font-weight: header-row ? 600 : 400;
                color: header-row ? #f0f6fc : #c9d1d9;
                wrap: word-wrap;
            }
        }
    }
}

