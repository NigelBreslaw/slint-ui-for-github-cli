import { ListView } from "std-widgets.slint";
import { AppState } from "../../data-bridges/app-state.slint";
import { TimeReportingState } from "../../data-bridges/time-reporting-state.slint";
import { ButtonBlack } from "../components/buttons.slint";
import { PrimerSpinner } from "../components/primer-spinner.slint";

export component TimeReporting {
    width: 100%;
    height: 100%;

    init => {
        TimeReportingState.time-reporting-view-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: #0d1117;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if TimeReportingState.has-selected-project: VerticalLayout {
                spacing: 10px;
                vertical-stretch: 1;

                Text {
                    text: TimeReportingState.selected-project-label;
                    font-size: 16px;
                    font-weight: 600;
                    color: #f0f6fc;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    x: 0;
                    width: self.preferred-width;
                    spacing: 8px;
                    alignment: center;

                    ButtonBlack {
                        label: "←";
                        clicked => {
                            TimeReportingState.time-reporting-week-prev();
                        }
                    }

                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;

                        Text {
                            text: TimeReportingState.week-label;
                            font-size: 15px;
                            font-weight: 600;
                            color: #f0f6fc;
                            horizontal-alignment: center;
                        }

                        if TimeReportingState.week-range-subtitle != "": Text {
                            text: TimeReportingState.week-range-subtitle;
                            font-size: 12px;
                            color: #8b949e;
                            horizontal-alignment: center;
                        }
                    }

                    ButtonBlack {
                        label: "→";
                        clicked => {
                            TimeReportingState.time-reporting-week-next();
                        }
                    }

                    ButtonBlack {
                        label: "This week";
                        clicked => {
                            TimeReportingState.time-reporting-week-this();
                        }
                    }

                    ButtonBlack {
                        label: "Refresh";
                        clicked => {
                            TimeReportingState.time-reporting-refresh();
                        }
                    }
                }

                if TimeReportingState.items-load-status == "Loading board items…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    PrimerSpinner {
                        size: small;
                    }
                }

                if TimeReportingState.items-load-status != "" && TimeReportingState.items-load-status != "Loading board items…": Text {
                    text: TimeReportingState.items-load-status;
                    color: #8b949e;
                    wrap: word-wrap;
                    font-size: 13px;
                }

                Rectangle {
                    vertical-stretch: 1;
                    width: 100%;
                    min-height: 120px;
                    background: #0d1117;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #30363d;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 0;
                        width: parent.width - 16px;
                        height: parent.height - 16px;

                        HorizontalLayout {
                            spacing: 4px;
                            height: 28px;

                            Text {
                                horizontal-stretch: 1;
                                text: "Task";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                            }

                            Text {
                                width: 44px;
                                text: "Mo";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "Tu";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "We";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "Th";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "Fr";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 52px;
                                text: "Total";
                                font-size: 11px;
                                font-weight: 600;
                                color: #8b949e;
                                horizontal-alignment: right;
                            }
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            height: 20px;

                            Text {
                                horizontal-stretch: 1;
                                text: "";
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-mo;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6e7681;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-tu;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6e7681;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-we;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6e7681;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-th;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6e7681;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-fr;
                                font-size: 10px;
                                font-weight: 500;
                                color: #6e7681;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 52px;
                                text: "";
                            }
                        }

                        Rectangle {
                            height: 1px;
                            background: #30363d;
                        }

                        if TimeReportingState.week-grid-hint != "": VerticalLayout {
                            padding: 16px;
                            alignment: center;

                            Text {
                                text: TimeReportingState.week-grid-hint;
                                color: #8b949e;
                                font-size: 13px;
                                wrap: word-wrap;
                                horizontal-alignment: center;
                            }
                        }

                        if TimeReportingState.week-grid-hint == "": ListView {
                            width: 100%;
                            for week_row[row_ix] in TimeReportingState.week-rows-model: Rectangle {
                                height: 36px;
                                background: mod(row_ix, 2) == 0 ? #0d1117 : #161b22;

                                Text {
                                    width: 1px;
                                    height: 1px;
                                    x: 0;
                                    y: 0;
                                    font-size: 1px;
                                    color: #f0f6fc00;
                                    text: week_row.grid-week-key;
                                }

                                HorizontalLayout {
                                    spacing: 4px;
                                    width: 100%;
                                    height: 100%;

                                    title_ta := TouchArea {
                                        horizontal-stretch: 1;
                                        clicked => {
                                            TimeReportingState.time-reporting-open-row-url(week_row.url);
                                        }

                                        Text {
                                            text: week_row.title;
                                            color: title_ta.has-hover ? #58a6ff : #f0f6fc;
                                            overflow: elide;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                        }
                                    }

                                    mo_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 0);
                                        }

                                        Text {
                                            text: week_row.mon;
                                            color: #c9d1d9;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    tu_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 1);
                                        }

                                        Text {
                                            text: week_row.tue;
                                            color: #c9d1d9;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    we_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 2);
                                        }

                                        Text {
                                            text: week_row.wed;
                                            color: #c9d1d9;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    th_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 3);
                                        }

                                        Text {
                                            text: week_row.thu;
                                            color: #c9d1d9;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    fr_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 4);
                                        }

                                        Text {
                                            text: week_row.fri;
                                            color: #c9d1d9;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    tot_ta := TouchArea {
                                        width: 52px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 5);
                                        }

                                        Text {
                                            text: week_row.total;
                                            color: #c9d1d9;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !TimeReportingState.has-selected-project: Text {
                text: "Choose a GitHub Project (classic board) for time entries. Open the dialog when prompted.";
                font-size: 14px;
                color: #8b949e;
                wrap: word-wrap;
            }

            if AppState.projects-load-status == "Loading projects…": HorizontalLayout {
                spacing: 10px;
                alignment: start;

                PrimerSpinner {
                    size: small;
                }
            }

            if AppState.projects-load-status != "" && AppState.projects-load-status != "Loading projects…": Text {
                text: AppState.projects-load-status;
                color: #8b949e;
                wrap: word-wrap;
            }
        }

        if TimeReportingState.picker-open: Rectangle {
            width: parent.width;
            height: parent.height;
            y: 0;
            x: 0;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: #010409aa;

                TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => {
                        if TimeReportingState.picker-allow-cancel {
                            TimeReportingState.time-reporting-picker-cancel();
                        }
                    }
                }
            }

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                alignment: center;

                Rectangle {
                    width: 440px;
                    background: #161b22;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #30363d;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 16px;
                        width: parent.width - 40px;

                        Text {
                            text: "Select time keeping project";
                            font-size: 18px;
                            font-weight: 600;
                            color: #f0f6fc;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Search by title, number, or URL";
                            font-size: 12px;
                            color: #8b949e;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            width: 100%;
                            height: 40px;
                            background: #0d1117;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #30363d;
                            clip: true;

                            TextInput {
                                x: 10px;
                                y: 0;
                                width: parent.width - 20px;
                                height: parent.height;
                                text: AppState.projects-search;
                                font-size: 14px;
                                color: #f0f6fc;
                                edited => {
                                    AppState.projects-search = self.text;
                                    AppState.project_search_changed(self.text);
                                }
                            }
                        }

                        Rectangle {
                            height: 220px;
                            width: 100%;
                            background: #0d1117;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #30363d;

                            ListView {
                                width: parent.width - 2px;
                                height: parent.height - 2px;
                                x: 1px;
                                y: 1px;
                                for row[index] in AppState.projects-filtered-model: Rectangle {
                                    height: 52px;
                                    background: mod(index, 2) == 0 ? #0d1117 : #161b22;

                                    TouchArea {
                                        clicked => {
                                            TimeReportingState.time-reporting-project-chosen(row.id);
                                        }

                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 2px;
                                            Text {
                                                text: row.title;
                                                color: #f0f6fc;
                                                overflow: elide;
                                                font-size: 14px;
                                            }

                                            Text {
                                                text: "#" + row.number + " · slint-ui";
                                                font-size: 12px;
                                                color: #8b949e;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 1px;
                            }

                            ButtonBlack {
                                visible: TimeReportingState.picker-allow-cancel;
                                label: "Cancel";
                                clicked => {
                                    TimeReportingState.time-reporting-picker-cancel();
                                }
                            }
                        }
                    }
                }
            }
        }

        if TimeReportingState.detail-open: Rectangle {
            width: parent.width;
            height: parent.height;
            y: 0;
            x: 0;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: #010409aa;

                TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => {
                        TimeReportingState.time-reporting-detail-close();
                    }
                }
            }

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                alignment: center;

                Rectangle {
                    width: min(parent.width - 48px, 520px);
                    background: #161b22;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #30363d;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 12px;
                        width: parent.width - 40px;

                        Text {
                            text: TimeReportingState.detail-title;
                            font-size: 17px;
                            font-weight: 600;
                            color: #f0f6fc;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            height: 1px;
                            background: #30363d;
                        }

                        Flickable {
                            width: 100%;
                            height: 240px;
                            viewport-width: parent.width;
                            viewport-height: detail-body-text.preferred-height;

                            detail-body-text := Text {
                                width: 100%;
                                text: TimeReportingState.detail-body;
                                color: #c9d1d9;
                                font-size: 13px;
                                wrap: word-wrap;
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            ButtonBlack {
                                label: "Close";
                                clicked => {
                                    TimeReportingState.time-reporting-detail-close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
