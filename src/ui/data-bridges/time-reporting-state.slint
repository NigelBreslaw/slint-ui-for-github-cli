export struct TimeReportingWeekRow {
    item-id: string,
    /** Changes with `week-label` so ListView delegates refresh even when time cells look identical. */
    grid-week-key: string,
    title: string,
    url: string,
    mon: string,
    tue: string,
    wed: string,
    thu: string,
    fri: string,
    total: string,
}

export global TimeReportingState {
    callback time-reporting-view-init;
    callback time-reporting-view-exited;
    callback time-reporting-project-chosen(string);
    callback time-reporting-picker-cancel;
    callback time-reporting-open-change-project;

    callback time-reporting-week-prev;
    callback time-reporting-week-next;
    callback time-reporting-week-this;
    callback time-reporting-refresh;
    /** `day_index`: 0..4 = Mo..Fr, 5 = Total column. */
    callback time-reporting-time-cell-clicked(int, int);
    callback time-reporting-open-row-url(string);
    callback time-reporting-detail-close;

    in-out property <bool> picker-allow-cancel: false;
    in-out property <bool> picker-open: false;
    in-out property <bool> has-selected-project: false;
    in-out property <string> selected-project-label: "";

    /** `in-out` so native code can replace the `ArrayModel` reference (same pattern as project search). */
    in-out property <[TimeReportingWeekRow]> week-rows-model;
    in-out property <string> items-load-status: "";
    in-out property <string> week-label: "";
    /** Mon–Fri date range subtitle for the selected ISO week (e.g. `2026-03-23 – 2026-03-27`). */
    in-out property <string> week-range-subtitle: "";
    /** `MM-DD` under Mo..Fr headers for the selected ISO week (UTC). */
    in-out property <string> week-hdr-mo: "";
    in-out property <string> week-hdr-tu: "";
    in-out property <string> week-hdr-we: "";
    in-out property <string> week-hdr-th: "";
    in-out property <string> week-hdr-fr: "";
    in-out property <string> week-grid-hint: "";
    in-out property <bool> detail-open: false;
    in-out property <string> detail-title: "";
    in-out property <string> detail-body: "";
}
