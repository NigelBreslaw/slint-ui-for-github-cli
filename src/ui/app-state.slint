import { SettingsState } from "settings-state.slint";

export struct ProjectRow {
    id: string,
    title: string,
    number: int,
    url: string,
}

export struct ReviewRequestRow {
    title: string,
    url: string,
    repo_label: string,
}

export enum Authed {
    loggedOut,
    noGhCliInstalled,
    loggedIn,
    authorizing,
}

export enum View {
    none,
    dashboard,
    settings,
    timeReporting,
}

export global AppState {
    in-out property <Authed> auth: loggedOut;
    in-out property <string> user_login: "";
    in-out property <string> user_name: "";
    in-out property <string> user_profile_url: "";
    in-out property <string> user_status_message: "";
    in-out property <string> user_status_emoji: "";
    in-out property <image> avatar;

    in-out property <bool> review-requests-data-ready: false;
    in-out property <int> review-requests-total: 0;
    in-out property <string> review-requests-load-status: "";
    in property <[ReviewRequestRow]> review-requests-model;

    in-out property <View> view: none;
    callback set-view(View);
    callback dashboard-init;

    set-view(v) => {
        if v == self.view {
            if self.view == View.settings {
                SettingsState.settings-exited();
            }
            self.view = View.none;
        } else {
            if self.view == View.settings {
                SettingsState.settings-exited();
            }
            self.view = v;
        }
    }

    in-out property <string> projects-search: "";
    in-out property <string> projects-load-status: "";
    in property <[ProjectRow]> projects-filtered-model;
    callback project_search_changed(string);
    callback sign_in;
    callback sign-out;
    callback open_project_url(string);
}
