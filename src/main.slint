import { VerticalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    in property <string> gh-label: "";
    in property <image> avatar;

    width: 400px;
    height: 240px;
    title: "GitHub CLI";

    VerticalBox {
        alignment: center;
        spacing: 12px;

        Image {
            source: avatar;
            width: 64px;
            height: 64px;
            image-fit: cover;
            accessible-label: "GitHub avatar";
        }

        Text {
            text: gh-label;
            font-size: 18px;
            horizontal-alignment: center;
        }
    }
}
