import { Button, HorizontalBox, Spinner, VerticalBox } from "std-widgets.slint";

export enum Authed {
    loggedOut,
    loggedIn,
    authorizing,
}

export global AppState {
    in-out property <Authed> auth: loggedOut;
}

export component MainWindow inherits Window {
    callback login-clicked;
    callback logout-clicked;

    in property <string> gh-label: "";
    in property <image> avatar;

    width: 400px;
    height: 280px;
    title: "GitHub CLI";

    Rectangle {
        width: 100%;
        height: 100%;

        VerticalBox {
            alignment: center;
            spacing: 12px;
            width: 100%;
            height: 100%;

            Rectangle {
                width: 64px;
                height: 64px;
                border-radius: self.width / 2;
                border-width: 1px;
                border-color: white;
                clip: true;
                Image {
                    source: avatar;
                    width: 64px;
                    height: 64px;
                    image-fit: cover;
                    accessible-label: "GitHub avatar";
                }
            }

            Text {
                text: gh-label;
                font-size: 18px;
                horizontal-alignment: center;
            }

            HorizontalBox {
                alignment: center;
                spacing: 8px;

                Button {
                    text: "Login";
                    visible: AppState.auth == Authed.loggedOut;
                    clicked => {
                        root.login-clicked();
                    }
                }

                Button {
                    text: "Logout";
                    visible: AppState.auth == Authed.loggedIn;
                    clicked => {
                        root.logout-clicked();
                    }
                }
            }
        }

        Rectangle {
            visible: AppState.auth == Authed.authorizing;
            width: 100%;
            height: 100%;
            x: 0;
            y: 0;
            background: #00000099;

            TouchArea {
                width: 100%;
                height: 100%;
            }

            VerticalBox {
                alignment: center;
                spacing: 16px;
                width: 100%;
                height: 100%;

                Text {
                    text: "Carry on logging in via the terminal";
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Spinner {
                    indeterminate: true;
                }
            }
        }
    }
}
