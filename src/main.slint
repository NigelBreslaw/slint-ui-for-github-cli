import { Button } from "std-widgets.slint";

export global AppState {
    in-out property <bool> is-logged-in: false;
}

export component MainWindow inherits Window {
    callback login-clicked;
    callback logout-clicked;

    in property <string> gh-label: "";
    in property <image> avatar;

    width: 400px;
    height: 280px;
    title: "GitHub CLI";

    VerticalLayout {
        alignment: center;
        spacing: 12px;

        Rectangle {
            width: 64px;
            height: 64px;
            border-radius: self.width / 2;
            border-width: 1px;
            border-color: white;
            clip: true;
            Image {
                source: avatar;
                width: 64px;
                height: 64px;
                image-fit: cover;
                accessible-label: "GitHub avatar";
            }
        }

        Text {
            text: gh-label;
            font-size: 18px;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            alignment: center;
            spacing: 8px;

            Button {
                text: "Login";
                visible: !AppState.is-logged-in;
                clicked => {
                    root.login-clicked();
                }
            }

            Button {
                text: "Logout";
                visible: AppState.is-logged-in;
                clicked => {
                    root.logout-clicked();
                }
            }
        }
    }
}
