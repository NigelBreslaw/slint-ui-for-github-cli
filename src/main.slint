import { Button, HorizontalBox, Spinner, VerticalBox } from "std-widgets.slint";

export enum Authed {
    loggedOut,
    loggedIn,
    needsScopes,
    authorizing,
}

export global AppState {
    in-out property <Authed> auth: loggedOut;
}

export component MainWindow inherits Window {
    callback login-clicked;
    callback logout-clicked;
    callback add-scopes-clicked;
    callback close-auth-window;

    close-auth-window => {
        auth_window.close();
    }

    in property <string> gh-label: "";
    in property <string> scope-message: "";
    in property <image> avatar;

    width: 400px;
    height: 280px;
    title: "GitHub CLI";

    VerticalBox {
        alignment: center;
        spacing: 12px;
        width: 100%;
        height: 100%;

        Rectangle {
            width: 64px;
            height: 64px;
            border-radius: self.width / 2;
            border-width: 1px;
            border-color: white;
            clip: true;
            Image {
                source: avatar;
                width: 64px;
                height: 64px;
                image-fit: cover;
                accessible-label: "GitHub avatar";
            }
        }

        Text {
            text: AppState.auth == Authed.needsScopes ? scope-message : gh-label;
            font-size: 18px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        HorizontalBox {
            alignment: center;
            spacing: 8px;

            Button {
                text: "Login";
                visible: AppState.auth == Authed.loggedOut;
                clicked => {
                    auth_window.show();
                    root.login-clicked();
                }
            }

            Button {
                text: "Add missing scopes";
                visible: AppState.auth == Authed.needsScopes;
                clicked => {
                    auth_window.show();
                    root.add-scopes-clicked();
                }
            }

            Button {
                text: "Logout";
                visible: AppState.auth == Authed.loggedIn || AppState.auth == Authed.needsScopes;
                clicked => {
                    root.logout-clicked();
                }
            }
        }
    }

    auth_window := PopupWindow {
        width: root.width;
        height: root.height;
        x: 0;
        y: 0;

        close-policy: no-auto-close;

        Rectangle {
            background: black.with-alpha(0.9);

            TouchArea {
                width: 100%;
                height: 100%;
            }

            VerticalBox {
                alignment: center;
                spacing: 16px;
                width: 100%;
                height: 100%;

                Text {
                    text: "Finish in the terminal (browser or device flow)";
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Spinner {
                    indeterminate: true;
                }
            }
        }
    }
}
