import { Button, HorizontalBox, Spinner, VerticalBox, Palette, StyleMetrics } from "std-widgets.slint";
import { Authed, AppState } from "app-state.slint";
import { Header } from "header.slint";

export component MainWindow inherits Window {
    callback login-clicked;
    callback logout-clicked;
    callback close-auth-window;
    callback open-github-device-clicked;
    callback show-no-gh-cli-installed;
    callback open-cli-install-page;

    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    close-auth-window => {
        auth_window.close();
    }

    show-no-gh-cli-installed => {
        no_gh_cli_installed_window.show();
    }

    in property <string> status_message: "";
    in property <string> auth-device-code: "";
    in property <string> auth-device-url: "";

    min-width: 400px;
    min-height: 280px;
    preferred-width: 400px;
    preferred-height: 280px;
    title: "GitHub CLI";

    HorizontalBox {
        alignment: center;
        width: 100%;
        height: 100%;

        VerticalBox {
            alignment: center;
            spacing: 12px;
            width: 100%;
            height: 100%;

            Text {
                text: status_message;
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            HorizontalBox {
                alignment: center;
                spacing: 8px;

                Button {
                    text: "Login";
                    visible: AppState.auth == Authed.loggedOut;
                    clicked => {
                        auth_window.show();
                        root.login-clicked();
                    }
                }

                Button {
                    text: "Logout";
                    visible: AppState.auth == Authed.loggedIn;
                    clicked => {
                        root.logout-clicked();
                    }
                }
            }
        }
    }
    Header {
        y: 0;
    }

    no_gh_cli_installed_window := PopupWindow {
        width: root.width;
        height: root.height;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black.with-alpha(0.9);
        }

        VerticalLayout{
            x: (root.width - self.preferred-width) / 2;
            y: (root.height - self.preferred-height) / 2;
            width: self.preferred-width;
            height: self.preferred-height;
            spacing: 20px;
            Text {
                text: "GitHub CLI is not installed";
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Button {
                width: self.preferred-width;
                height: self.preferred-height;
                text: "Open CLI install page";
                clicked => {
                    root.open-cli-install-page();
                }
            }
        }
        close-policy: no-auto-close;
    }

    auth_window := PopupWindow {
        width: root.width;
        height: root.height;
        x: 0;
        y: 0;

        close-policy: no-auto-close;

        Rectangle {
            background: black.with-alpha(0.9);

            TouchArea {
                width: 100%;
                height: 100%;
            }

            VerticalBox {
                alignment: center;
                spacing: 16px;
                width: 100%;
                height: 100%;

                Text {
                    text: "Finish in the terminal (browser or device flow)";
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Text {
                    visible: root.auth-device-code != "";
                    text: "Your code: ";
                    font-size: 18px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                TextInput {
                    visible: root.auth-device-code != "";
                    text: root.auth-device-code;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    read-only: true;
                    changed has-focus => {
                        if (self.has-focus) {
                            self.select-all();
                        }
                    }
                }

                Button {
                    visible: root.auth-device-code != "";
                    text: "Copy code to clipboard and open web login";
                    clicked => {
                        root.open-github-device-clicked();
                    }
                }

                Spinner {
                    indeterminate: true;
                }
            }
        }
    }
}
