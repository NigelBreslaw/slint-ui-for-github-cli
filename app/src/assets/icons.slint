// Central `@image-url` registry so Slint bundles only icons we reference here.
// Add more properties as other screens need them; map from TS via `window.Icons.*`.
export global Icons {
    out property <image> pr: @image-url("16px/git-pull-request.svg");
    out property <image> issue: @image-url("16px/issue-opened.svg");
    out property <image> issue_draft: @image-url("16px/issue-draft.svg");
    out property <image> cell_placeholder: @image-url("16px/dot-fill.svg");
}
