import { DataTableRow } from "../../ui/Primer/DataTable/types.slint";

export enum ProjectBoardItemKind {
    pullRequest,
    issue,
    draftIssue,
}

export struct ProjectBoardListRow {
    kind: ProjectBoardItemKind,
    /** GraphQL `OPEN` / `CLOSED` / `MERGED`; empty for draft issues. */
    state: string,
    /** `0` when not applicable (draft). */
    number: int,
    title: string,
    subtitle: string,
    url: string,
}

export global ProjectBoardListState {
    callback project-board-list-view-init;
    callback project-board-list-view-exited;
    callback project-board-list-refresh;
    callback project-board-list-open-row-url(string);

    in-out property <bool> has-selected-project: false;
    in-out property <string> selected-project-label: "";
    in-out property <string> items-load-status: "";
    /** Row count for empty-state copy (`board-rows-model` length is not always visible in Slint). */
    in-out property <int> board-items-count: 0;
    in-out property <[ProjectBoardListRow]> board-rows-model;
    /** `DataTable` rows mirroring `board-rows-model` (bridge-built; for PR9 `DataTable` UI). Row **`id`** is the item URL. */
    in-out property <[DataTableRow]> board-data-table-rows;
}

