export struct ProjectBoardListRow {
    title: string,
    subtitle: string,
    url: string,
}

export global ProjectBoardListState {
    callback project-board-list-view-init;
    callback project-board-list-view-exited;
    callback project-board-list-refresh;
    callback project-board-list-open-row-url(string);

    in-out property <bool> has-selected-project: false;
    in-out property <string> selected-project-label: "";
    in-out property <string> items-load-status: "";
    /** Filled in later PRs; scaffold uses an empty model. */
    in-out property <[ProjectBoardListRow]> board-rows-model;
}
