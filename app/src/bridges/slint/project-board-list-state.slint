import { DataTableRow } from "../../ui/Primer/DataTable/types.slint";
import { SelectOption } from "../../ui/Primer/Select/select.slint";

export enum ProjectBoardItemKind {
    pullRequest,
    issue,
    draftIssue,
}

export struct ProjectBoardListRow {
    kind: ProjectBoardItemKind,
    /** GraphQL `OPEN` / `CLOSED` / `MERGED`; empty for draft issues. */
    state: string,
    /** `0` when not applicable (draft). */
    number: int,
    title: string,
    subtitle: string,
    url: string,
}

/** One row from `fetchRepoCandidatesPageGraphql` (open issues + open PRs; PR6/7). */
export struct ImportCandidateRow {
    /** GraphQL `node` id (ProjectV2 item content id target). */
    node-id: string,
    kind: ProjectBoardItemKind,
    number: int,
    title: string,
    url: string,
    selected: bool,
}

export global ProjectBoardListState {
    callback project-board-list-view-init;
    callback project-board-list-view-exited;
    callback project-board-list-refresh;
    callback project-board-list-open-row-url(string);
    callback project-board-page-changed(int);
    /** Invoked when the import dialog is dismissed (backdrop, ×, Escape). Node sets `import-dialog-open` false. */
    callback project-board-import-dialog-closed;
    /** Invoked when the import dialog is shown; Node loads slint-ui org repos (PR5). */
    callback project-board-import-dialog-opened;
    /** Filter text for the repo list; Node applies client-side filter to cached repos. */
    callback project-board-import-repos-search-changed(string);
    /** User picked a repository in the import dialog; Node loads open issues/PRs (GraphQL, PR6). */
    callback project-board-import-repo-selected-changed(int);
    /** Filter loaded candidates by title / number (client-side, PR7). */
    callback project-board-import-candidates-search-changed(string);
    /** Append next GraphQL page (issues + PR cursors, PR7). */
    callback project-board-import-candidates-load-more;
    /** Select every row currently shown after search filter (PR7). */
    callback project-board-import-candidates-select-all-on-page;
    /** Toggle checkbox for one candidate (`node-id`). */
    callback project-board-import-candidate-toggled(string);
    /** Add checked candidates to the current Project V2 (`addProjectV2ItemById`, PR10). Closes the dialog when every mutation succeeds (PR12). */
    callback project-board-import-add-selected-to-project;
    /** Dismiss the post-import success banner (PR13). */
    callback project-board-import-success-dismissed;

    /** Import-from-repositories modal (PR1 shell; later PRs add repo/issue UI). */
    in-out property <bool> import-dialog-open: false;
    /** Search query for repository names (`owner/name`); bound to import dialog **SelectPanel** filter (PR8). */
    in-out property <string> import-repos-search: "";
    /** Empty, `"Loading repositories…"`, or an error message from `gh`. */
    in-out property <string> import-repos-load-status: "";
    /** Row count for the filtered repo `Select` options (Slint cannot always read `ArrayModel` length). */
    in-out property <int> import-repo-options-count: 0;
    in-out property <int> import-repo-selected-index: -1;
    in-out property <[SelectOption]> import-repo-select-options;
    /** Empty, loading line, or error from GraphQL candidates fetch (PR6). */
    in-out property <string> import-candidates-load-status: "";
    /** Row count for `import-candidate-rows` (Slint cannot rely on `ArrayModel` length). */
    in-out property <int> import-candidate-count: 0;
    in-out property <[ImportCandidateRow]> import-candidate-rows;
    /** Client-side filter on loaded candidate rows (title / #). */
    in-out property <string> import-candidates-search: "";
    /** More pages available from GraphQL (either connection). */
    in-out property <bool> import-candidates-has-more: false;
    /** True while a "Load more" request is in flight. */
    in-out property <bool> import-candidates-load-more-busy: false;
    /** Total issues + PRs loaded from GraphQL (before client-side search filter). */
    in-out property <int> import-candidates-total-loaded: 0;
    /** Checked rows in the import list (Node-maintained; Slint cannot count `Set` in TS). */
    in-out property <int> import-selected-count: 0;
    in-out property <bool> import-add-selected-busy: false;
    /** Result or error from **Add selected to project** (PR10). */
    in-out property <string> import-add-selected-message: "";

    in-out property <bool> has-selected-project: false;
    in-out property <string> selected-project-label: "";
    /** Shown on the board after a full import success + successful reload (PR13); empty hides. */
    in-out property <string> board-import-success-message: "";
    in-out property <string> items-load-status: "";
    /** Row count for empty-state copy (`board-rows-model` length is not always visible in Slint). */
    in-out property <int> board-items-count: 0;
    /** 0-based page index for `board-data-table-rows` (paged slice of the full board). */
    in-out property <int> board-page-index: 0;
    /** Rows per page — set from the Node bridge (`main.ts`) and bound to `Pagination`. */
    in property <int> board-page-size: 25;
    in-out property <[ProjectBoardListRow]> board-rows-model;
    /** `DataTable` rows mirroring `board-rows-model` (bridge-built). Row **`id`** is the issue/PR URL for `row-clicked` → open in browser. */
    in-out property <[DataTableRow]> board-data-table-rows;
}

