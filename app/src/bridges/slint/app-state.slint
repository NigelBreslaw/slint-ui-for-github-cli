import { ProjectBoardListState } from "project-board-list-state.slint";
import { SettingsState } from "settings-state.slint";
import { TimeReportingState } from "time-reporting-state.slint";

export struct ProjectRow {
    id: string,
    title: string,
    number: int,
    url: string,
}

export struct ReviewRequestRow {
    title: string,
    url: string,
    repo_label: string,
    author_login: string,
}

export struct SecurityAlertRow {
    title: string,
    subtitle: string,
    url: string,
}

export enum DashboardTab {
    itemsToReview,
    securityAlerts,
}

export enum Authed {
    loggedOut,
    noGhCliInstalled,
    ghCliVersionTooOld,
    loggedIn,
    authorizing,
}

export enum AppView {
    dashboard,
    settings,
    timeReporting,
    projectBoardList,
}

export global AppState {
    in-out property <Authed> auth: loggedOut;
    in-out property <string> user_login: "";
    in-out property <string> user_name: "";
    in-out property <string> user_profile_url: "";
    in-out property <string> user_status_message: "";
    in-out property <string> user_status_emoji: "";
    in-out property <image> avatar;

    in-out property <bool> review-requests-data-ready: false;
    in-out property <int> review-requests-total: 0;
    in-out property <string> review-requests-load-status: "";
    in property <[ReviewRequestRow]> review-requests-model;

    in-out property <DashboardTab> dashboard-active-tab: itemsToReview;
    in-out property <bool> security-alerts-data-ready: false;
    in-out property <int> security-alerts-total: 0;
    in-out property <string> security-alerts-load-status: "";
    in property <[SecurityAlertRow]> security-alerts-model;
    callback dashboard-tab-changed(DashboardTab);

    in-out property <AppView> view: projectBoardList;
    callback set-view(AppView);
    callback dashboard-init;

    set-view(v) => {
        if v != self.view {
            if self.view == AppView.settings {
                SettingsState.settings-exited();
            }
            if self.view == AppView.timeReporting {
                TimeReportingState.time-reporting-view-exited();
            }
            if self.view == AppView.projectBoardList {
                ProjectBoardListState.project-board-list-view-exited();
            }
            self.view = v;
            if v == AppView.settings {
                SettingsState.settings-init();
            }

        }
    }

    in-out property <string> projects-search: "";
    in-out property <string> projects-load-status: "";
    in property <[ProjectRow]> projects-filtered-model;
    /** Total rows matching the filter; `projects-filtered-model` holds one page. */
    in-out property <int> projects-filtered-count: 0;
    in-out property <int> projects-picker-page-index: 0;
    /** Rows per page — set from the Node bridge (`main.ts`) and bound to picker `Pagination`. */
    in property <int> projects-picker-page-size: 25;
    callback project_search_changed(string);
    callback projects-picker-page-changed(int);
    callback window_geometry_changed(length, length);
    callback sign_in;
    callback sign-out;
    callback open_project_url(string);
}
