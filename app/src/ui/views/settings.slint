import { SettingsState } from "../../bridges/slint/settings-state.slint";
import {
    DataTable,
    DataTableCellAlign,
    DataTableCellKind,
    DataTableCellPadding,
    DataTableColumn,
    DataTableIconTint,
    DataTableSortDirection,
    Icons,
    LabelSize,
    LabelVariant,
} from "../../../../packages/primer-slint/slint/primer.slint";
import { PrimerColors } from "../../../../packages/primer-slint/slint/tokens.slint";

export component Settings {
    width: 100%;
    height: 100%;

    private property <[DataTableColumn]> settings-debug-columns: [
        {
            header: "Field",
            id: "field",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 1,
            min-width: 0px,
            width: 0px,
            monospace: false,
        },
        {
            header: "Value",
            id: "value",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 1,
            min-width: 0px,
            width: 0px,
            monospace: true,
        },
    ];

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 0;
            width: self.preferred-width;
            height: self.preferred-height;

            VerticalLayout {
                spacing: 0;
                width: self.preferred-width;
                height: self.preferred-height;

                Rectangle {
                    width: 450px;

                    DataTable {
                        width: 100%;
                        columns: settings-debug-columns;
                        rows: [
                            { id: "build", cells: [{ kind: DataTableCellKind.text, text: "Build", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-commit-label, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }] },
                            { id: "gh", cells: [{ kind: DataTableCellKind.text, text: "GitHub CLI", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-gh-version, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }] },
                            { id: "rate", cells: [{ kind: DataTableCellKind.text, text: "GraphQL rate limit", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-rate-limit, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }] },
                            { id: "reset", cells: [{ kind: DataTableCellKind.text, text: "Resets at (local time)", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-reset-at, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }] },
                            { id: "countdown", cells: [{ kind: DataTableCellKind.text, text: "Time until reset", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-countdown, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: Icons.dot_fill, icon-tint: DataTableIconTint.default }] },
                        ];
                        cell-padding: DataTableCellPadding.normal;
                        sorted-column-id: "";
                        sort-direction: DataTableSortDirection.none;
                        external-sorting: true;
                        sort-toggled => { }
                        row-action => { }
                    }
                }
            }

            if SettingsState.settings-debug-error != "": Text {
                text: SettingsState.settings-debug-error;
                color: PrimerColors.fgColor-danger;
                font-size: 13px;
                wrap: word-wrap;
            }
        }
    }
}
