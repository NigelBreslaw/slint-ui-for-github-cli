import { SettingsState } from "../../bridges/slint/settings-state.slint";
import { Button, ButtonVariant } from "../Primer/Buttons/buttons.slint";
import { Size } from "../Primer/tokens.slint";
import { PrimerDialog } from "../components/primer-dialog.slint";
import { Select, Spinner, ValidationStatus } from "../Primer/primer.slint";
import { PrimerColors } from "../Primer/tokens.slint";

component TableRow {

    in property <string> label-text;
    in property <string> value-text;
    in property <bool> header-row: false;

    min-height: 40px;
    width: 450px;

    HorizontalLayout {
        spacing: 0;
        width: 100%;

        Rectangle {
            width: 190px;
            min-height: 40px;
            background: header-row ? PrimerColors.borderColor-muted : PrimerColors.bgColor-neutral-muted;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;

            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: label-text;
                font-size: header-row ? 14px : 15px;
                font-weight: header-row ? 600 : 400;
                color: PrimerColors.fgColor-default;
                wrap: word-wrap;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-height: 40px;
            background: header-row ? PrimerColors.borderColor-muted : PrimerColors.bgColor-canvas-subtle;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;

            Text {
                x: 12px;
                y: 10px;
                width: parent.width - 24px;
                text: value-text;
                font-size: header-row ? 14px : 15px;
                font-weight: header-row ? 600 : 400;
                color: header-row ? PrimerColors.fgColor-default : PrimerColors.fgColor-subtle;
                wrap: word-wrap;
            }
        }
    }
}

export component Settings {
    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 0;
            width: self.preferred-width;
            height: self.preferred-height;

            // VerticalLayout {
            //     spacing: 8px;
            //     width: 450px;
            //     padding-bottom: 16px;

                Select {
                    block: true;
                    label-text: "GitHub host";
                    placeholder: "Choose host…";
                    caption: "Example Primer-style select; choice is not persisted.";
                    options: SettingsState.primer-demo-select-options;
                    selected-value <=> SettingsState.primer-demo-selected-value;
                    selected-label <=> SettingsState.primer-demo-selected-label;
                    validation-status: SettingsState.primer-demo-selected-value != "" ? ValidationStatus.success : ValidationStatus.none;
                    validation-message: SettingsState.primer-demo-selected-value != "" ? "Host selected for this session." : "";
                    selected-changed(v) => {
                        SettingsState.primer-demo-select-changed(v);
                    }
                }

                Button {
                    label: "Open Primer dialog demo";
                    clicked => {
                        primer-demo-popup.show();
                    }
                }

                Rectangle {
                    height: 8px;
                }

