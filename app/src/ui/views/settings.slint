            //     Rectangle {
            //         width: 100%;
            //         height: 40px;
            //         background: #0d1117;
            //         border-radius: 6px;
            //         border-width: 1px;
            //         border-color: #30363d;
            //         clip: true;

            //         TextInput {
            //             x: 10px;
            //             y: 0;
            //             width: parent.width - 20px;
            //             height: parent.height;
            //             text: SettingsState.security-alerts-repo-input;
            //             font-size: 14px;
            //             color: #f0f6fc;
            //             edited => {
            //                 SettingsState.security-alerts-repo-input = self.text;
            //                 SettingsState.security-alerts-repo-edited(self.text);
