            VerticalLayout {
                spacing: 0;
                width: self.preferred-width;
                height: self.preferred-height;

                TableRow {
                    label-text: "Build";
                    value-text: SettingsState.settings-debug-commit-label;
                }

                TableRow {
                    label-text: "GitHub CLI";
                    value-text: SettingsState.settings-debug-gh-version;
                }

                TableRow {
                    label-text: "GraphQL rate limit";
                    value-text: SettingsState.settings-debug-rate-limit;
                }

                TableRow {
                    label-text: "Resets at (local time)";
                    value-text: SettingsState.settings-debug-reset-at;
                }

                TableRow {
                    label-text: "Time until reset";
                    value-text: SettingsState.settings-debug-countdown;
                }
            }

            if SettingsState.settings-debug-error != "": Text {
                text: SettingsState.settings-debug-error;
                color: #f85149;
                font-size: 13px;
                wrap: word-wrap;
            }
        }

        primer-demo-popup := PopupWindow {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            close-policy: no-auto-close;



            PrimerDialog {
                x: 0;
                y: 0;
                width: 100%;
                height: 100%;
                title: "Loading";
                allow-dismiss: true;
                close => {
                    primer-demo-popup.close();
                }

                VerticalLayout {
                    alignment: center;
                    width: 100%;

                    Spinner {
                        size: medium;
                    }
                }
            }
        }
    }
