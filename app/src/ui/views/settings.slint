                Rectangle {
                    height: 8px;
                }

                Button {
                    label: "Large primary (demo)";
                    variant: ButtonVariant.primary;
                    size: Size.large;
                    clicked => { }
                }

                Rectangle {
                    height: 8px;
                }

                Button {
                    label: "Danger button (demo)";
                    variant: ButtonVariant.danger;
