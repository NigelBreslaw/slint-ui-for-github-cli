import { SettingsState } from "../../bridges/slint/settings-state.slint";
import { PrimerDialog } from "../components/primer-dialog.slint";
import {
    DataTable,
    DataTableCellAlign,
    DataTableCellKind,
    DataTableCellPadding,
    DataTableColumn,
    DataTableSortDirection,
    LabelSize,
    LabelVariant,
    Spinner,
} from "../Primer/primer.slint";
import { PrimerColors } from "../Primer/tokens.slint";

export component Settings {
    width: 100%;
    height: 100%;

    private property <[DataTableColumn]> settings-debug-columns: [
        {
            header: "Field",
            id: "field",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 1,
            min-width: 0px,
            width: 0px,
            monospace: false,
        },
        {
            header: "Value",
            id: "value",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 1,
            min-width: 0px,
            width: 0px,
            monospace: true,
        },
    ];

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 0;
            width: self.preferred-width;
            height: self.preferred-height;

            VerticalLayout {
                spacing: 0;
                width: self.preferred-width;
                height: self.preferred-height;

                Rectangle {
                    width: 450px;

                    DataTable {
                        width: 100%;
                        columns: settings-debug-columns;
                        rows: [
                            { id: "build", cells: [{ kind: DataTableCellKind.text, text: "Build", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-commit-label, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }] },
                            { id: "gh", cells: [{ kind: DataTableCellKind.text, text: "GitHub CLI", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-gh-version, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }] },
                            { id: "rate", cells: [{ kind: DataTableCellKind.text, text: "GraphQL rate limit", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-rate-limit, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }] },
                            { id: "reset", cells: [{ kind: DataTableCellKind.text, text: "Resets at (local time)", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-reset-at, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }] },
                            { id: "countdown", cells: [{ kind: DataTableCellKind.text, text: "Time until reset", label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }, { kind: DataTableCellKind.text, text: SettingsState.settings-debug-countdown, label-variant: LabelVariant.default, label-size: LabelSize.small, icon: @image-url("../../assets/16px/dot-fill.svg") }] },
                        ];
                        cell-padding: DataTableCellPadding.normal;
                        sorted-column-id: "";
                        sort-direction: DataTableSortDirection.none;
                        external-sorting: true;
                        sort-toggled => { }
                    }
                }
            }

            if SettingsState.settings-debug-error != "": Text {
                text: SettingsState.settings-debug-error;
                color: #f85149;
                font-size: 13px;
                wrap: word-wrap;
            }
        }

        primer-demo-popup := PopupWindow {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            close-policy: no-auto-close;

            PrimerDialog {
                x: 0;
                y: 0;
                width: 100%;
                height: 100%;
                title: "Loading";
                allow-dismiss: true;
                close => {
                    primer-demo-popup.close();
                }

                VerticalLayout {
                    alignment: center;
                    width: 100%;

                    Spinner {
                        size: medium;
                    }
                }
            }
        }
    }
}
