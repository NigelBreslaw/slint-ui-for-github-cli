                }

                Rectangle {
                    height: 8px;
                }

                Button {
                    label: "Invisible button (demo)";
                    variant: ButtonVariant.invisible;
                    clicked => { }
                }

                Rectangle {
                    height: 8px;
                }

                Button {
                    label: "Link-style button (demo)";
                    variant: ButtonVariant.link;
                    clicked => { }
                }

