import { ListView } from "std-widgets.slint";
import { AppState, DashboardTab } from "../../bridges/slint/app-state.slint";
import {
    Banner,
    BannerVariant,
    ButtonVariant,
    Spinner,
    UnderlineNav,
    UnderlineNavItem,
} from "../../../../packages/primer-slint/primer.slint";
import { LayoutTokens, PrimerColors, Size } from "../../../../packages/primer-slint/tokens.slint";

export component Dashboard {
    width: 100%;
    height: 100%;

    private property <[UnderlineNavItem]> dashboard-nav-items: [
        { label: "Items to review", enabled: true, counter: "" },
        { label: "Security alerts", enabled: true, counter: "" },
    ];

    init => {
        AppState.dashboard-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;
    }

    VerticalLayout {
        padding: 16px;
        spacing: 12px;
        height: 100%;

        UnderlineNav {
            width: 100%;
            items: dashboard-nav-items;
            selected-index: AppState.dashboard-active-tab == DashboardTab.itemsToReview ? 0 : 1;
            accessible-name: "Dashboard";
            item-activated(idx) => {
                if idx == 0 {
                    AppState.dashboard-active-tab = DashboardTab.itemsToReview;
                    AppState.dashboard-tab-changed(DashboardTab.itemsToReview);
                }
                if idx == 1 {
                    AppState.dashboard-active-tab = DashboardTab.securityAlerts;
                    AppState.dashboard-tab-changed(DashboardTab.securityAlerts);
                }
            }
        }

        if AppState.dashboard-active-tab == DashboardTab.itemsToReview: VerticalLayout {
            spacing: 12px;
            width: 100%;
            height: 100%;

            Text {
                text: "Review requests";
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-semibold;
                color: PrimerColors.fgColor-subtle;
            }

            if AppState.review-requests-total > 0: Banner {
                width: 100%;
                variant: BannerVariant.info;
                title: "Open reviews";
                description: AppState.review-requests-total == 1 ? "1 pull request is waiting on your review." : AppState.review-requests-total + " pull requests are waiting on your review.";
            }

            if AppState.review-requests-load-status == "Loading review requests…": HorizontalLayout {
                spacing: 10px;
                alignment: start;

                Spinner {
                    size: Size.small;
                }
            }

            if AppState.review-requests-load-status != "" && AppState.review-requests-load-status != "Loading review requests…": Text {
                text: AppState.review-requests-load-status;
                color: PrimerColors.fgColor-muted;
                wrap: word-wrap;
            }

            Rectangle {
                vertical-stretch: 1;
                width: 100%;
                min-height: 120px;
                clip: true;

                review-flick := Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-width: self.width;
                    viewport-height: review-banners.preferred-height;

                    review-banners := VerticalLayout {
                        width: review-flick.width;
                        spacing: 10px;

                        for row in AppState.review-requests-model: Banner {
                            width: 100%;
                            variant: BannerVariant.warning;
                            hide-title: true;
                            title: row.author_login != ""
                                ? row.author_login + " requested your review on this pull request. " + row.repo_label + " · " + row.title
                                : "Someone requested your review on this pull request. " + row.repo_label + " · " + row.title;
                            description-emphasis: row.author_login;
                            description: row.author_login != ""
                                ? " requested your review on this pull request."
                                : "Someone requested your review on this pull request.";
                            subtitle: row.repo_label + " · " + row.title;
                            // actions-trailing: true;
                            primary-action-label: "Add your review";
                            primary-action-variant: ButtonVariant.primary;
                            primary-action => {
                                AppState.open_project_url(row.url);
                            }
                        }
                    }
                }
            }
        }

        if AppState.dashboard-active-tab == DashboardTab.securityAlerts: VerticalLayout {
            spacing: 12px;
            width: 100%;
            height: 100%;

            Text {
                text: "Dependabot alerts";
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-semibold;
                color: PrimerColors.fgColor-subtle;
            }

            if AppState.security-alerts-load-status == "Loading security alerts…": HorizontalLayout {
                spacing: 10px;
                alignment: start;

                Spinner {
                    size: small;
                }
            }

            if AppState.security-alerts-load-status != "" && AppState.security-alerts-load-status != "Loading security alerts…": Text {
                text: AppState.security-alerts-load-status;
                color: PrimerColors.fgColor-muted;
                wrap: word-wrap;
            }

            if AppState.security-alerts-data-ready && AppState.security-alerts-total == 0 && AppState.security-alerts-load-status == "": Text {
                text: "No Dependabot alerts returned for this repository.";
                color: PrimerColors.fgColor-muted;
                font-size: 13px;
                wrap: word-wrap;
            }

            ListView {
                width: 100%;
                for row[index] in AppState.security-alerts-model: Rectangle {
                    height: 56px;
                    background: mod(index, 2) == 0 ? PrimerColors.bgColor-default : PrimerColors.bgColor-canvas-subtle;

                    TouchArea {
                        clicked => {
                            AppState.open_project_url(row.url);
                        }

                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: row.title;
                                color: PrimerColors.fgColor-default;
                                overflow: elide;
                            }

                            Text {
                                text: row.subtitle;
                                font-size: 12px;
                                color: PrimerColors.fgColor-muted;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}
