import { ListView } from "std-widgets.slint";
import {
    ProjectBoardItemKind,
    ProjectBoardListState,
} from "../../bridges/slint/project-board-list-state.slint";
import { Button, Spinner } from "../Primer/primer.slint";
import { PrimerColors } from "../Primer/tokens.slint";

export component ProjectBoardList {
    width: 100%;
    height: 100%;

    init => {
        ProjectBoardListState.project-board-list-view-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if !ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 8px;
                width: 100%;

                Text {
                    text: "No project selected";
                    font-size: 16px;
                    font-weight: 600;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                Text {
                    text: "Choose a GitHub Project in Time reporting (clock icon). This list shows every issue and pull request on that board.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 10px;
                width: 100%;
                vertical-stretch: 1;

                Text {
                    text: ProjectBoardListState.selected-project-label;
                    font-size: 16px;
                    font-weight: 600;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Button {
                        label: "Refresh";
                        clicked => {
                            ProjectBoardListState.project-board-list-refresh();
                        }
                    }
                }

                if ProjectBoardListState.items-load-status == "Loading board items…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Spinner {
                        size: small;
                    }
                }

                if ProjectBoardListState.items-load-status != "" && ProjectBoardListState.items-load-status != "Loading board items…": Text {
                    text: ProjectBoardListState.items-load-status;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                    font-size: 13px;
                }

                if ProjectBoardListState.items-load-status == "" && ProjectBoardListState.board-items-count == 0: Text {
                    text: "No items on this board.";
                    color: PrimerColors.fgColor-muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Rectangle {
                    vertical-stretch: 1;
                    width: 100%;
                    min-height: 120px;
                    clip: true;
                    background: PrimerColors.bgColor-neutral-muted;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: PrimerColors.borderColor-muted;
                    visible: ProjectBoardListState.items-load-status == "" && ProjectBoardListState.board-items-count > 0;

                    VerticalLayout {
                        width: parent.width - 16px;
                        height: parent.height - 16px;
                        x: 8px;
                        y: 8px;
                        spacing: 0px;

                        HorizontalLayout {
                            height: 28px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                width: 32px;
                                text: "";
                                horizontal-alignment: right;
                            }

                            Rectangle {
                                width: 16px;
                                height: 16px;
                            }

                            Rectangle {
                                width: 10px;
                                height: 10px;
                            }

                            Text {
                                text: "Title";
                                font-size: 12px;
                                font-weight: 600;
                                color: PrimerColors.fgColor-muted;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            height: 1px;
                            width: 100%;
                            background: PrimerColors.borderColor-muted;
                        }

                        ListView {
                            vertical-stretch: 1;
                            width: 100%;
                            height: 100%;

                            for row[index] in ProjectBoardListState.board-rows-model: Rectangle {
                                height: 56px;
                                background: mod(index, 2) == 0 ? PrimerColors.bgColor-default : PrimerColors.bgColor-canvas-subtle;

                                TouchArea {
                                    clicked => {
                                        ProjectBoardListState.project-board-list-open-row-url(row.url);
                                    }

                                    HorizontalLayout {
                                        padding: 8px;
                                        spacing: 6px;
                                        width: 100%;
                                        height: 100%;
                                        alignment: center;

                                        Text {
                                            width: 32px;
                                            text: index + 1;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                            color: PrimerColors.fgColor-muted;
                                        }

                                        Image {
                                            width: 16px;
                                            height: 16px;
                                            vertical-alignment: center;
                                            colorize: PrimerColors.fgColor-muted;
                                            source: row.kind == ProjectBoardItemKind.pullRequest ? @image-url("../../assets/16px/git-pull-request.svg") : row.kind == ProjectBoardItemKind.issue ? @image-url("../../assets/16px/issue-opened.svg") : @image-url("../../assets/16px/issue-draft.svg");
                                        }

                                        Rectangle {
                                            width: 10px;
                                            height: 10px;
                                            border-radius: 5px;
                                            background: row.kind == ProjectBoardItemKind.draftIssue ? PrimerColors.fgColor-muted : row.state == "OPEN" ? PrimerColors.fgColor-success : row.kind == ProjectBoardItemKind.pullRequest && row.state == "MERGED" ? PrimerColors.fgColor-done : row.kind == ProjectBoardItemKind.pullRequest && row.state == "CLOSED" ? PrimerColors.fgColor-danger : row.state == "CLOSED" ? PrimerColors.fgColor-done : PrimerColors.fgColor-muted;
                                        }

                                        VerticalLayout {
                                            horizontal-stretch: 1;
                                            spacing: 4px;

                                            HorizontalLayout {
                                                spacing: 6px;
                                                alignment: center;

                                                Text {
                                                    horizontal-stretch: 1;
                                                    text: row.title;
                                                    color: PrimerColors.fgColor-default;
                                                    overflow: elide;
                                                    vertical-alignment: center;
                                                }

                                                if row.kind == ProjectBoardItemKind.draftIssue: Text {
                                                    text: "Draft";
                                                    font-size: 13px;
                                                    color: PrimerColors.fgColor-muted;
                                                    vertical-alignment: center;
                                                }

                                                if row.kind != ProjectBoardItemKind.draftIssue && row.number > 0: Text {
                                                    text: "#" + row.number;
                                                    font-size: 13px;
                                                    color: PrimerColors.fgColor-muted;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            if row.subtitle != "": Text {
                                                text: row.subtitle;
                                                font-size: 12px;
                                                color: PrimerColors.fgColor-muted;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
