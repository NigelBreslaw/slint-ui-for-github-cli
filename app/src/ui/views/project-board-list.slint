import { ProjectBoardListState } from "../../bridges/slint/project-board-list-state.slint";
import { PrimerDialog, PrimerDialogWidth } from "../components/primer-dialog.slint";
import {
    DataTable,
    DataTableCellAlign,
    DataTableCellKind,
    DataTableColumn,
    DataTableSortDirection,
    Pagination,
    Select,
    Size,
    Spinner,
    TableContainer,
} from "../Primer/primer.slint";
import { PrimerColors } from "../Primer/tokens.slint";
import { ProjectBoardTableLayout } from "project-board-table-layout.slint";

export component ProjectBoardList {
    width: 100%;
    height: 100%;

    // Column definitions: widths come from `ProjectBoardTableLayout.widths` (edit in project-board-table-layout.slint).
    private property <[DataTableColumn]> project-board-columns: [
        {
            header: "#",
            id: "idx",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.idx-px,
            width: ProjectBoardTableLayout.widths.idx-px,
            monospace: true,
        },
        {
            header: "Type",
            id: "kind",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.iconText,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.type-px,
            width: ProjectBoardTableLayout.widths.type-px,
            monospace: false,
        },
        {
            header: "Title",
            id: "title",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.title-px,
            width: ProjectBoardTableLayout.widths.title-px,
            monospace: false,
        },
        {
            header: "Meta",
            id: "meta",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.meta-px,
            width: ProjectBoardTableLayout.widths.meta-px,
            monospace: false,
        },
    ];

    init => {
        ProjectBoardListState.project-board-list-view-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if !ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 8px;
                width: 100%;

                Text {
                    text: "No project selected";
                    font-size: 16px;
                    font-weight: 600;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                Text {
                    text: "Choose a GitHub Project in Time reporting (clock icon). This list shows every issue and pull request on that board.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 10px;
                width: 100%;
                vertical-stretch: 1;

                if ProjectBoardListState.items-load-status == "Loading board items…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Spinner {
                        size: small;
                    }
                }

                if ProjectBoardListState.items-load-status != "" && ProjectBoardListState.items-load-status != "Loading board items…": Text {
                    text: ProjectBoardListState.items-load-status;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                    font-size: 13px;
                }

                if ProjectBoardListState.items-load-status == "": VerticalLayout {
                    width: 100%;
                    vertical-stretch: 1;
                    spacing: 0;

                    Rectangle {
                        vertical-stretch: 1;
                        width: 100%;
                        min-height: 120px;
                        clip: true;

                        board-flick := Flickable {
                            width: parent.width;
                            height: parent.height;
                            viewport-width: self.width;
                            viewport-height: self.height;

                            board-inner := VerticalLayout {
                                width: max(board-flick.width, ProjectBoardTableLayout.total-width);
                                height: board-flick.height;
                                spacing: 0;

                                TableContainer {
                                    width: 100%;
                                    vertical-stretch: 1;
                                    min-height: 120px;
                                    title: ProjectBoardListState.selected-project-label;
                                    subtitle: ProjectBoardListState.board-items-count == 0 ? "No items on this board." : "";
                                    secondary-action-label: "Import from repositories";
                                    secondary-action => {
                                        ProjectBoardListState.project-board-import-dialog-opened();
                                    }
                                    primary-action-label: "Refresh";
                                    primary-action => {
                                        ProjectBoardListState.project-board-list-refresh();
                                    }

                                    DataTable {
                                        width: 100%;
                                        columns: project-board-columns;
                                        rows: ProjectBoardListState.board-data-table-rows;
                                        sorted-column-id: "";
                                        sort-direction: DataTableSortDirection.none;
                                        sort-toggled(_cid, _dir) => { }
                                        row-action(_rid, _cid, _aid) => { }
                                        row-clicked(rid) => {
                                            ProjectBoardListState.project-board-list-open-row-url(rid);
                                        }
                                    }
                                }

                                Pagination {
                                    width: 100%;
                                    vertical-stretch: 0;
                                    total-count: ProjectBoardListState.board-items-count;
                                    page-size: ProjectBoardListState.board-page-size;
                                    page-index: ProjectBoardListState.board-page-index;
                                    page-changed(idx) => {
                                        ProjectBoardListState.project-board-page-changed(idx);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if ProjectBoardListState.import-dialog-open: Rectangle {
            width: parent.width;
            height: parent.height;
            y: 0;
            x: 0;

            PrimerDialog {
                width: 100%;
                height: 100%;
                title: "Import from repositories";
                subtitle: "Organization slint-ui — pick a repository (issues/PRs next).";
                width-preset: PrimerDialogWidth.xlarge;
                close => {
                    ProjectBoardListState.project-board-import-dialog-closed();
                }

                VerticalLayout {
                    spacing: 12px;
                    width: 100%;
                    min-height: 320px;

                    if ProjectBoardListState.import-repos-load-status == "Loading repositories…": HorizontalLayout {
                        spacing: 10px;
                        alignment: start;

                        Spinner {
                            size: small;
                        }

                        Text {
                            text: "Loading repositories…";
                            font-size: 13px;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }
                    }

                    if ProjectBoardListState.import-repos-load-status != "Loading repositories…": VerticalLayout {
                        spacing: 12px;
                        width: 100%;
                        vertical-stretch: 1;

                        if ProjectBoardListState.import-repos-load-status != "": Text {
                            text: ProjectBoardListState.import-repos-load-status;
                            color: PrimerColors.fgColor-default;
                            font-size: 13px;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Filter by repository name";
                            font-size: 12px;
                            font-weight: 600;
                            color: PrimerColors.fgColor-default;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            width: 100%;
                            height: 40px;
                            background: PrimerColors.bgColor-neutral-muted;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: PrimerColors.borderColor-muted;
                            clip: true;

                            TextInput {
                                x: 10px;
                                y: 0;
                                width: parent.width - 20px;
                                height: parent.height;
                                read-only: ProjectBoardListState.import-repos-load-status != "";
                                text: ProjectBoardListState.import-repos-search;
                                font-size: 14px;
                                color: PrimerColors.fgColor-default;
                                edited => {
                                    ProjectBoardListState.project-board-import-repos-search-changed(self.text);
                                }
                            }
                        }

                        Select {
                            width: 100%;
                            block: true;
                            size: Size.medium;
                            label-text: "Repository";
                            placeholder: "Select a repository…";
                            options: ProjectBoardListState.import-repo-select-options;
                            option-count: ProjectBoardListState.import-repo-options-count;
                            selected-index <=> ProjectBoardListState.import-repo-selected-index;
                            disabled: ProjectBoardListState.import-repos-load-status != ""
                                || ProjectBoardListState.import-repo-options-count == 0;
                        }
                    }
                }
            }
        }
    }
}
