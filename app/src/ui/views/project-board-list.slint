import { ProjectBoardListState } from "../../bridges/slint/project-board-list-state.slint";
import {
    Banner,
    BannerVariant,
    Checkbox,
    DataTable,
    DataTableCellAlign,
    DataTableCellKind,
    DataTableColumn,
    DataTableSortDirection,
    Pagination,
    Spinner,
    TableContainer,
    Button,
} from "../../../../packages/primer-slint/primer.slint";
import { PaginationLogic } from "../../../../packages/primer-slint/Pagination/pagination-logic.slint";
import { LayoutTokens, PrimerColors } from "../../../../packages/primer-slint/tokens.slint";
import { ProjectBoardTableLayout } from "project-board-table-layout.slint";

/// DataTable footer: range label + `Pagination` strip; `page-index` is 0-based (two-way to bridge).
component ProjectBoardPaginationFooter {
    in-out property <int> page-index;
    in property <int> total-count;
    in property <int> page-size;
    callback page-changed(int);

    property <int> page-count: PaginationLogic.page_count_from_total(total-count, page-size);
    property <int> idx-clamped: PaginationLogic.clamp_page_index(page-index, page-count);
    property <int> range-start: PaginationLogic.range_display_start(total-count, idx-clamped, page-size);
    property <int> range-end: PaginationLogic.range_display_end(total-count, idx-clamped, page-size);
    /// 1-based page for `Pagination`; derived from 0-based `page-index` (single source of truth).
    property <int> pagination-current-1based: PaginationLogic.clamp_current_page_1based(page-index + 1, page-count);

    width: 100%;
    vertical-stretch: 0;
    min-height: LayoutTokens.control-small-size;

    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        border-width: 1px;
        border-color: PrimerColors.borderColor-default;
        border-radius: LayoutTokens.table-border-radius;

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding-top: LayoutTokens.table-cell-padding-block-normal;
            padding-bottom: LayoutTokens.table-cell-padding-block-normal;
            padding-left: LayoutTokens.stack-padding-normal;
            padding-right: LayoutTokens.stack-padding-normal;
            spacing: LayoutTokens.stack-padding-normal;
            alignment: stretch;

            Text {
                horizontal-stretch: 0;
                text: total-count <= 0
                    ? "0‒0 of 0"
                    : "" + range-start + "‒" + range-end + " of " + total-count;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                vertical-alignment: center;
                wrap: no-wrap;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: LayoutTokens.button-content-gap;
                alignment: space-around;

                Pagination {
                    width: 100%;
                    page-count: page-count;
                    current-page: pagination-current-1based;
                    page-changed(idx) => {
                        root.page-changed(idx);
                    }
                }
            }
        }
    }
}

export component ProjectBoardList {
    width: 100%;
    height: 100%;

    // Column definitions: widths come from `ProjectBoardTableLayout.widths` (edit in project-board-table-layout.slint).
    property <[DataTableColumn]> project-board-columns: [
        {
            header: "#",
            id: "idx",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.idx-px,
            width: ProjectBoardTableLayout.widths.idx-px,
            monospace: true,
        },
        {
            header: "Type",
            id: "kind",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.iconText,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.type-px,
            width: ProjectBoardTableLayout.widths.type-px,
            monospace: false,
        },
        {
            header: "Title",
            id: "title",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.title-px,
            width: ProjectBoardTableLayout.widths.title-px,
            monospace: false,
        },
        {
            header: "Meta",
            id: "meta",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.meta-px,
            width: ProjectBoardTableLayout.widths.meta-px,
            monospace: false,
        },
    ];

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if !ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 8px;
                width: 100%;

                Text {
                    text: "No project selected";
                    font-size: LayoutTokens.text-body-size-large;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                Text {
                    text: "Choose a GitHub Project in Time reporting (clock icon). This list shows every issue and pull request on that board.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 10px;
                width: 100%;
                vertical-stretch: 1;

                if ProjectBoardListState.board-import-success-message != ""
                    && ProjectBoardListState.items-load-status != "Loading board items…"
                    && ProjectBoardListState.items-load-status == "": Banner {
                    width: 100%;
                    variant: BannerVariant.success;
                    dismissible: true;
                    title: "Import complete";
                    description: ProjectBoardListState.board-import-success-message;
                    dismiss => {
                        ProjectBoardListState.project-board-import-success-dismissed();
                    }
                }

                if ProjectBoardListState.items-load-status == "Loading board items…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Spinner {
                        size: small;
                    }
                }

                if ProjectBoardListState.items-load-status != "" && ProjectBoardListState.items-load-status != "Loading board items…": Text {
                    text: ProjectBoardListState.items-load-status;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                    font-size: 13px;
                }

                if ProjectBoardListState.items-load-status == "": VerticalLayout {
                    width: 100%;
                    vertical-stretch: 1;

                    Rectangle {
                        vertical-stretch: 1;
                        width: 100%;
                        min-height: 120px;
                        clip: true;

                        board-flick := Flickable {
                            width: parent.width;
                            height: parent.height;
                            viewport-width: max(self.width, ProjectBoardTableLayout.total-width);
                            viewport-height: self.height;

                            board-inner := VerticalLayout {
                                width: max(board-flick.width, ProjectBoardTableLayout.total-width);
                                height: board-flick.height;

                                TableContainer {
                                    vertical-stretch: 1;
                                    min-height: 120px;
                                    title: ProjectBoardListState.selected-project-label;
                                    subtitle: ProjectBoardListState.board-items-count == 0 ? "No items on this board." : "";
                                    secondary-action-label: "Import from repositories";
                                    secondary-action => {
                                        ProjectBoardListState.project-board-import-dialog-opened();
                                    }
                                    primary-action-label: "Refresh";
                                    primary-action => {
                                        ProjectBoardListState.project-board-list-refresh();
                                    }

                                    DataTable {
                                        width: 100%;
                                        columns: project-board-columns;
                                        rows: ProjectBoardListState.board-data-table-rows;
                                        sorted-column-id: "";
                                        sort-direction: DataTableSortDirection.none;
                                        sort-toggled(_cid, _dir) => { }
                                        row-action(_rid, _cid, _aid) => { }
                                        row-clicked(rid) => {
                                            ProjectBoardListState.project-board-list-open-row-url(rid);
                                        }
                                    }
                                }

                                ProjectBoardPaginationFooter {
                                    page-index: ProjectBoardListState.board-page-index;
                                    total-count: ProjectBoardListState.board-items-count;
                                    page-size: ProjectBoardListState.board-page-size;
                                    page-changed(idx) => {
                                        ProjectBoardListState.project-board-page-changed(idx);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
