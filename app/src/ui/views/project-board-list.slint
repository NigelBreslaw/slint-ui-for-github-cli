import { ListView } from "std-widgets.slint";
import { ProjectBoardItemKind, ProjectBoardListState } from "../../bridges/slint/project-board-list-state.slint";
import { PrimerDialog, PrimerDialogWidth } from "../components/primer-dialog.slint";
import {
    Banner,
    BannerVariant,
    Checkbox,
    DataTable,
    DataTableCellAlign,
    DataTableCellKind,
    DataTableColumn,
    DataTableSortDirection,
    Pagination,
    PrimerTextInput,
    SelectPanel,
    SelectPanelMode,
    Size,
    Spinner,
    TableContainer,
    Button,
    ButtonVariant,
} from "../../../../packages/primer-slint/primer.slint";
import { LayoutTokens, PrimerColors } from "../../../../packages/primer-slint/tokens.slint";
import { ProjectBoardTableLayout } from "project-board-table-layout.slint";

export component ProjectBoardList {
    width: 100%;
    height: 100%;

    // Column definitions: widths come from `ProjectBoardTableLayout.widths` (edit in project-board-table-layout.slint).
    private property <[DataTableColumn]> project-board-columns: [
        {
            header: "#",
            id: "idx",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.idx-px,
            width: ProjectBoardTableLayout.widths.idx-px,
            monospace: true,
        },
        {
            header: "Type",
            id: "kind",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.iconText,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.type-px,
            width: ProjectBoardTableLayout.widths.type-px,
            monospace: false,
        },
        {
            header: "Title",
            id: "title",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.title-px,
            width: ProjectBoardTableLayout.widths.title-px,
            monospace: false,
        },
        {
            header: "Meta",
            id: "meta",
            sortable: false,
            align: DataTableCellAlign.start,
            row-header: false,
            cell-kind: DataTableCellKind.text,
            horizontal-stretch: 0,
            min-width: ProjectBoardTableLayout.widths.meta-px,
            width: ProjectBoardTableLayout.widths.meta-px,
            monospace: false,
        },
    ];

    init => {
        ProjectBoardListState.project-board-list-view-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if !ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 8px;
                width: 100%;

                Text {
                    text: "No project selected";
                    font-size: LayoutTokens.text-body-size-large;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                Text {
                    text: "Choose a GitHub Project in Time reporting (clock icon). This list shows every issue and pull request on that board.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if ProjectBoardListState.has-selected-project: VerticalLayout {
                spacing: 10px;
                width: 100%;
                vertical-stretch: 1;

                if ProjectBoardListState.board-import-success-message != ""
                    && ProjectBoardListState.items-load-status != "Loading board items…"
                    && ProjectBoardListState.items-load-status == "": Banner {
                    width: 100%;
                    variant: BannerVariant.success;
                    dismissible: true;
                    title: "Import complete";
                    description: ProjectBoardListState.board-import-success-message;
                    dismiss => {
                        ProjectBoardListState.project-board-import-success-dismissed();
                    }
                }

                if ProjectBoardListState.items-load-status == "Loading board items…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Spinner {
                        size: small;
                    }
                }

                if ProjectBoardListState.items-load-status != "" && ProjectBoardListState.items-load-status != "Loading board items…": Text {
                    text: ProjectBoardListState.items-load-status;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                    font-size: 13px;
                }

                if ProjectBoardListState.items-load-status == "": VerticalLayout {
                    width: 100%;
                    vertical-stretch: 1;
                    spacing: 0;

                    Rectangle {
                        vertical-stretch: 1;
                        width: 100%;
                        min-height: 120px;
                        clip: true;

                        board-flick := Flickable {
                            width: parent.width;
                            height: parent.height;
                            viewport-width: max(self.width, ProjectBoardTableLayout.total-width);
                            viewport-height: self.height;

                            board-inner := VerticalLayout {
                                width: max(board-flick.width, ProjectBoardTableLayout.total-width);
                                height: board-flick.height;
                                spacing: 0;

                                TableContainer {
                                    width: 100%;
                                    vertical-stretch: 1;
                                    min-height: 120px;
                                    title: ProjectBoardListState.selected-project-label;
                                    subtitle: ProjectBoardListState.board-items-count == 0 ? "No items on this board." : "";
                                    secondary-action-label: "Import from repositories";
                                    secondary-action => {
                                        ProjectBoardListState.project-board-import-dialog-opened();
                                    }
                                    primary-action-label: "Refresh";
                                    primary-action => {
                                        ProjectBoardListState.project-board-list-refresh();
                                    }

                                    DataTable {
                                        width: 100%;
                                        columns: project-board-columns;
                                        rows: ProjectBoardListState.board-data-table-rows;
                                        sorted-column-id: "";
                                        sort-direction: DataTableSortDirection.none;
                                        sort-toggled(_cid, _dir) => { }
                                        row-action(_rid, _cid, _aid) => { }
                                        row-clicked(rid) => {
                                            ProjectBoardListState.project-board-list-open-row-url(rid);
                                        }
                                    }
                                }

                                Pagination {
                                    width: 100%;
                                    vertical-stretch: 0;
                                    total-count: ProjectBoardListState.board-items-count;
                                    page-size: ProjectBoardListState.board-page-size;
                                    page-index: ProjectBoardListState.board-page-index;
                                    page-changed(idx) => {
                                        ProjectBoardListState.project-board-page-changed(idx);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if ProjectBoardListState.import-dialog-open: Rectangle {
            width: parent.width;
            height: parent.height;
            y: 0;
            x: 0;

            PrimerDialog {
                width: 100%;
                height: 100%;
                title: "Import from repositories";
                subtitle: "Organization slint-ui — pick a repository, then review open issues and PRs (first page).";
                width-preset: PrimerDialogWidth.xlarge;
                close => {
                    ProjectBoardListState.project-board-import-dialog-closed();
                }

                VerticalLayout {
                    spacing: 12px;
                    width: 100%;
                    min-height: 320px;

                    if ProjectBoardListState.import-repos-load-status == "Loading repositories…": HorizontalLayout {
                        spacing: 10px;
                        alignment: start;

                        Spinner {
                            size: small;
                        }

                        Text {
                            text: "Loading repositories…";
                            font-size: 13px;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }
                    }

                    if ProjectBoardListState.import-repos-load-status != "Loading repositories…": VerticalLayout {
                        spacing: 12px;
                        width: 100%;
                        vertical-stretch: 1;

                        if ProjectBoardListState.import-repos-load-status != "": Text {
                            text: ProjectBoardListState.import-repos-load-status;
                            color: PrimerColors.fgColor-default;
                            font-size: 13px;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Repository";
                            font-size: LayoutTokens.text-body-size-small;
                            font-weight: LayoutTokens.base-text-weight-semibold;
                            color: PrimerColors.fgColor-default;
                            wrap: word-wrap;
                        }

                        SelectPanel {
                            width: 100%;
                            mode: SelectPanelMode.single;
                            filter-text <=> ProjectBoardListState.import-repos-search;
                            filter-placeholder: "Filter by name…";
                            single-items: ProjectBoardListState.import-repo-select-options;
                            item-count: ProjectBoardListState.import-repo-options-count;
                            selected-index <=> ProjectBoardListState.import-repo-selected-index;
                            list-max-height: 200px;
                            empty-message: "No repositories match your search.";
                            disabled: ProjectBoardListState.import-repos-load-status != ""
                                || ProjectBoardListState.import-repo-options-count == 0;
                            filter-changed(q) => {
                                ProjectBoardListState.project-board-import-repos-search-changed(q);
                            }
                            single-selected-changed(ix) => {
                                ProjectBoardListState.project-board-import-repo-selected-changed(ix);
                            }
                        }

                        Text {
                            text: "Open issues and pull requests";
                            font-size: LayoutTokens.text-body-size-small;
                            font-weight: LayoutTokens.base-text-weight-semibold;
                            color: PrimerColors.fgColor-default;
                            wrap: word-wrap;
                        }

                        if ProjectBoardListState.import-repo-selected-index < 0: Text {
                            text: "Select a repository to load open issues and pull requests.";
                            font-size: 13px;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }

                        if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…": HorizontalLayout {
                            spacing: 10px;
                            alignment: start;

                            Spinner {
                                size: small;
                            }

                            Text {
                                text: "Loading issues and pull requests…";
                                font-size: 13px;
                                color: PrimerColors.fgColor-muted;
                                wrap: word-wrap;
                            }
                        }

                        if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status != "" && ProjectBoardListState.import-candidates-load-status != "Loading issues and pull requests…": Text {
                            text: ProjectBoardListState.import-candidates-load-status;
                            color: PrimerColors.fgColor-default;
                            font-size: 13px;
                            wrap: word-wrap;
                        }

                        if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status != "Loading issues and pull requests…" && (ProjectBoardListState.import-candidates-load-status == "" || ProjectBoardListState.import-candidates-total-loaded > 0): VerticalLayout {
                            spacing: 10px;

                            PrimerTextInput {
                                width: 100%;
                                block: true;
                                label-text: "Filter loaded issues and PRs";
                                placeholder: "Search issues and PRs…";
                                disabled: ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…";
                                text: ProjectBoardListState.import-candidates-search;
                                edited(t) => {
                                    ProjectBoardListState.project-board-import-candidates-search-changed(t);
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;

                                Button {
                                    variant: ButtonVariant.default;
                                    size: Size.small;
                                    label: "Select all on page";
                                    disabled: ProjectBoardListState.import-candidate-count == 0;
                                    clicked => {
                                        ProjectBoardListState.project-board-import-candidates-select-all-on-page();
                                    }
                                }

                                Button {
                                    variant: ButtonVariant.default;
                                    size: Size.small;
                                    label: "Load more";
                                    loading: ProjectBoardListState.import-candidates-load-more-busy;
                                    disabled: !ProjectBoardListState.import-candidates-has-more
                                        || ProjectBoardListState.import-candidates-load-more-busy
                                        || ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…";
                                    clicked => {
                                        ProjectBoardListState.project-board-import-candidates-load-more();
                                    }
                                }

                                Button {
                                    variant: ButtonVariant.primary;
                                    size: Size.small;
                                    label: "Add selected to project";
                                    loading: ProjectBoardListState.import-add-selected-busy;
                                    disabled: !ProjectBoardListState.has-selected-project
                                        || ProjectBoardListState.import-selected-count == 0
                                        || ProjectBoardListState.import-add-selected-busy
                                        || ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…";
                                    clicked => {
                                        ProjectBoardListState.project-board-import-add-selected-to-project();
                                    }
                                }
                            }

                            if ProjectBoardListState.import-add-selected-message != "": Text {
                                text: ProjectBoardListState.import-add-selected-message;
                                font-size: 12px;
                                color: PrimerColors.fgColor-default;
                                wrap: word-wrap;
                            }
                        }

                        if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status == "" && ProjectBoardListState.import-candidate-count == 0 && ProjectBoardListState.import-candidates-total-loaded == 0: Text {
                            text: "No open issues or pull requests on this page.";
                            font-size: 13px;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }

                        if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status == "" && ProjectBoardListState.import-candidate-count == 0 && ProjectBoardListState.import-candidates-total-loaded > 0 && ProjectBoardListState.import-candidates-search != "": Text {
                            text: "No issues or pull requests match your search.";
                            font-size: 13px;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }

                        if ProjectBoardListState.import-candidate-count > 0: Rectangle {
                            height: 220px;
                            width: 100%;
                            background: PrimerColors.bgColor-neutral-muted;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: PrimerColors.borderColor-muted;
                            clip: true;

                            ListView {
                                width: parent.width - 2px;
                                height: parent.height - 2px;
                                x: 1px;
                                y: 1px;
                                for row[index] in ProjectBoardListState.import-candidate-rows: Rectangle {
                                    height: 56px;
                                    background: mod(index, 2) == 0 ? PrimerColors.bgColor-neutral-muted : PrimerColors.bgColor-canvas-subtle;

                                    HorizontalLayout {
                                        padding-left: 6px;
                                        padding-right: 8px;
                                        spacing: 4px;
                                        alignment: center;

                                        Checkbox {
                                            horizontal-stretch: 0;
                                            vertical-stretch: 0;
                                            checked: row.selected;
                                            label: "";
                                            toggled => {
                                                ProjectBoardListState.project-board-import-candidate-toggled(row.node-id);
                                            }
                                        }

                                        TouchArea {
                                            horizontal-stretch: 1;
                                            height: parent.height;

                                            clicked => {
                                                ProjectBoardListState.project-board-list-open-row-url(row.url);
                                            }

                                            VerticalLayout {
                                                padding-top: 8px;
                                                padding-bottom: 8px;
                                                spacing: 2px;
                                                Text {
                                                    text: row.title;
                                                    color: PrimerColors.fgColor-default;
                                                    overflow: elide;
                                                    font-size: 14px;
                                                }

                                                Text {
                                                    text: (row.kind == ProjectBoardItemKind.issue ? "Issue" : "PR") + " #" + row.number;
                                                    font-size: 12px;
                                                    color: PrimerColors.fgColor-muted;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
