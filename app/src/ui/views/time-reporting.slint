import { ListView } from "std-widgets.slint";
import { AppState } from "../../bridges/slint/app-state.slint";
import { TimeReportingState } from "../../bridges/slint/time-reporting-state.slint";
import { Button } from "../Primer/Buttons/buttons.slint";
import { PrimerDialog } from "../components/primer-dialog.slint";
import { Spinner } from "../Primer/primer.slint";
import { Tokens } from "../Primer/tokens.slint";

export component TimeReporting {
    width: 100%;
    height: 100%;

    init => {
        TimeReportingState.time-reporting-view-init();
    }

    Rectangle {
        width: 100%;
        height: 100%;
        background: Tokens.bgColor-default;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if TimeReportingState.has-selected-project: VerticalLayout {
                spacing: 10px;
                vertical-stretch: 1;

                Text {
                    text: TimeReportingState.selected-project-label;
                    font-size: 16px;
                    font-weight: 600;
                    color: Tokens.fgColor-default;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    x: 0;
                    width: self.preferred-width;
                    spacing: 8px;
                    alignment: center;

                    Button {
                        label: "←";
                        clicked => {
                            TimeReportingState.time-reporting-week-prev();
                        }
                    }

                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;

                        Text {
                            text: TimeReportingState.week-label;
                            font-size: 15px;
                            font-weight: 600;
                            color: Tokens.fgColor-default;
                            horizontal-alignment: center;
                        }

                        if TimeReportingState.week-range-subtitle != "": Text {
                            text: TimeReportingState.week-range-subtitle;
                            font-size: 12px;
                            color: Tokens.fgColor-muted;
                            horizontal-alignment: center;
                        }
                    }

                    Button {
                        label: "→";
                        clicked => {
                            TimeReportingState.time-reporting-week-next();
                        }
                    }

                    Button {
                        label: "This week";
                        clicked => {
                            TimeReportingState.time-reporting-week-this();
                        }
                    }

                    Button {
                        label: "Refresh";
                        clicked => {
                            TimeReportingState.time-reporting-refresh();
                        }
                    }
                }

                if TimeReportingState.items-load-status == "Loading board items…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Spinner {
                        size: small;
                    }
                }

                if TimeReportingState.items-load-status != "" && TimeReportingState.items-load-status != "Loading board items…": Text {
                    text: TimeReportingState.items-load-status;
                    color: Tokens.fgColor-muted;
                    wrap: word-wrap;
                    font-size: 13px;
                }

                Rectangle {
                    vertical-stretch: 1;
                    width: 100%;
                    min-height: 120px;
                    background: Tokens.bgColor-neutral-muted;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Tokens.borderColor-muted;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 0;
                        width: parent.width - 16px;
                        height: parent.height - 16px;

                        HorizontalLayout {
                            spacing: 4px;
                            height: 28px;

                            Text {
                                horizontal-stretch: 1;
                                text: "Task";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                            }

                            Text {
                                width: 44px;
                                text: "Mo";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "Tu";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "We";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "Th";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: "Fr";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 52px;
                                text: "Total";
                                font-size: 11px;
                                font-weight: 600;
                                color: Tokens.fgColor-muted;
                                horizontal-alignment: right;
                            }
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            height: 20px;

                            Text {
                                horizontal-stretch: 1;
                                text: "";
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-mo;
                                font-size: 10px;
                                font-weight: 500;
                                color: Tokens.fgColor-placeholder;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-tu;
                                font-size: 10px;
                                font-weight: 500;
                                color: Tokens.fgColor-placeholder;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-we;
                                font-size: 10px;
                                font-weight: 500;
                                color: Tokens.fgColor-placeholder;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-th;
                                font-size: 10px;
                                font-weight: 500;
                                color: Tokens.fgColor-placeholder;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 44px;
                                text: TimeReportingState.week-hdr-fr;
                                font-size: 10px;
                                font-weight: 500;
                                color: Tokens.fgColor-placeholder;
                                horizontal-alignment: right;
                            }

                            Text {
                                width: 52px;
                                text: "";
                            }
                        }

                        Rectangle {
                            height: 1px;
                            background: Tokens.borderColor-muted;
                        }

                        if TimeReportingState.week-grid-hint != "": VerticalLayout {
                            padding: 16px;
                            alignment: center;

                            Text {
                                text: TimeReportingState.week-grid-hint;
                                color: Tokens.fgColor-muted;
                                font-size: 13px;
                                wrap: word-wrap;
                                horizontal-alignment: center;
                            }
                        }

                        if TimeReportingState.week-grid-hint == "": ListView {
                            width: 100%;
                            for week_row[row_ix] in TimeReportingState.week-rows-model: Rectangle {
                                height: 36px;
                                background: mod(row_ix, 2) == 0 ? Tokens.bgColor-neutral-muted : Tokens.bgColor-canvas-subtle;

                                Text {
                                    width: 1px;
                                    height: 1px;
                                    x: 0;
                                    y: 0;
                                    font-size: 1px;
                                    color: Tokens.fgColor-default;
                                    text: week_row.grid-week-key;
                                }

                                HorizontalLayout {
                                    spacing: 4px;
                                    width: 100%;
                                    height: 100%;

                                    title_ta := TouchArea {
                                        horizontal-stretch: 1;
                                        clicked => {
                                            TimeReportingState.time-reporting-open-row-url(week_row.url);
                                        }

                                        Text {
                                            text: week_row.title;
                                            color: title_ta.has-hover ? Tokens.fgColor-link : Tokens.fgColor-default;
                                            overflow: elide;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                        }
                                    }

                                    mo_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 0);
                                        }

                                        Text {
                                            text: week_row.mon;
                                            color: Tokens.fgColor-subtle;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    tu_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 1);
                                        }

                                        Text {
                                            text: week_row.tue;
                                            color: Tokens.fgColor-subtle;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    we_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 2);
                                        }

                                        Text {
                                            text: week_row.wed;
                                            color: Tokens.fgColor-subtle;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    th_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 3);
                                        }

                                        Text {
                                            text: week_row.thu;
                                            color: Tokens.fgColor-subtle;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    fr_ta := TouchArea {
                                        width: 44px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 4);
                                        }

                                        Text {
                                            text: week_row.fri;
                                            color: Tokens.fgColor-subtle;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }

                                    tot_ta := TouchArea {
                                        width: 52px;
                                        clicked => {
                                            TimeReportingState.time-reporting-time-cell-clicked(row_ix, 5);
                                        }

                                        Text {
                                            text: week_row.total;
                                            color: Tokens.fgColor-subtle;
                                            font-size: 13px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !TimeReportingState.has-selected-project: Text {
                text: "Choose a GitHub Project (classic board) for time entries. Open the dialog when prompted.";
                font-size: 14px;
                color: Tokens.fgColor-muted;
                wrap: word-wrap;
            }

            if AppState.projects-load-status == "Loading projects…": HorizontalLayout {
                spacing: 10px;
                alignment: start;

                Spinner {
                    size: small;
                }
            }

            if AppState.projects-load-status != "" && AppState.projects-load-status != "Loading projects…": Text {
                text: AppState.projects-load-status;
                color: Tokens.fgColor-muted;
                wrap: word-wrap;
            }
        }

        if TimeReportingState.picker-open: Rectangle {
            width: parent.width;
            height: parent.height;
            y: 0;
            x: 0;

            PrimerDialog {
                width: 100%;
                height: 100%;
                title: "Select time keeping project";
                subtitle: "Search by title, number, or URL";
                width-preset: large;
                allow-dismiss: TimeReportingState.picker-allow-cancel;
                close => {
                    TimeReportingState.time-reporting-picker-cancel();
                }

                VerticalLayout {
                    spacing: 16px;
                    width: 100%;

                    Rectangle {
                        width: 100%;
                        height: 40px;
                        background: Tokens.bgColor-neutral-muted;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Tokens.borderColor-muted;
                        clip: true;

                        TextInput {
                            x: 10px;
                            y: 0;
                            width: parent.width - 20px;
                            height: parent.height;
                            text: AppState.projects-search;
                            font-size: 14px;
                            color: Tokens.fgColor-default;
                            edited => {
                                AppState.projects-search = self.text;
                                AppState.project_search_changed(self.text);
                            }
                        }
                    }

                    Rectangle {
                        height: 220px;
                        width: 100%;
                        background: Tokens.bgColor-neutral-muted;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Tokens.borderColor-muted;

                        ListView {
                            width: parent.width - 2px;
                            height: parent.height - 2px;
                            x: 1px;
                            y: 1px;
                            for row[index] in AppState.projects-filtered-model: Rectangle {
                                height: 52px;
                                background: mod(index, 2) == 0 ? Tokens.bgColor-neutral-muted : Tokens.bgColor-canvas-subtle;

                                TouchArea {
                                    clicked => {
                                        TimeReportingState.time-reporting-project-chosen(row.id);
                                    }

                                    VerticalLayout {
                                        padding: 8px;
                                        spacing: 2px;
                                        Text {
                                            text: row.title;
                                            color: Tokens.fgColor-default;
                                            overflow: elide;
                                            font-size: 14px;
                                        }

                                        Text {
                                            text: "#" + row.number + " · slint-ui";
                                            font-size: 12px;
                                            color: Tokens.fgColor-muted;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        width: 100%;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 1px;
                        }

                        Button {
                            visible: TimeReportingState.picker-allow-cancel;
                            label: "Cancel";
                            clicked => {
                                TimeReportingState.time-reporting-picker-cancel();
                            }
                        }
                    }
                }
            }
        }

        if TimeReportingState.detail-open: Rectangle {
            width: parent.width;
            height: parent.height;
            y: 0;
            x: 0;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: Tokens.overlay-scrim;

                TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => {
                        TimeReportingState.time-reporting-detail-close();
                    }
                }
            }

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                alignment: center;

                Rectangle {
                    width: min(parent.width - 48px, 520px);
                    background: Tokens.bgColor-canvas-subtle;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Tokens.borderColor-muted;

                    VerticalLayout {
                        padding: 20px;
                        spacing: 12px;
                        width: parent.width - 40px;

                        Text {
                            text: TimeReportingState.detail-title;
                            font-size: 17px;
                            font-weight: 600;
                            color: Tokens.fgColor-default;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            height: 1px;
                            background: Tokens.borderColor-muted;
                        }

                        Flickable {
                            width: 100%;
                            height: 240px;
                            viewport-width: parent.width;
                            viewport-height: detail-body-text.preferred-height;

                            detail-body-text := Text {
                                width: 100%;
                                text: TimeReportingState.detail-body;
                                color: Tokens.fgColor-subtle;
                                font-size: 13px;
                                wrap: word-wrap;
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            Button {
                                label: "Close";
                                clicked => {
                                    TimeReportingState.time-reporting-detail-close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
