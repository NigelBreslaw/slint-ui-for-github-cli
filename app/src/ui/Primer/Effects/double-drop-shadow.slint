// Two stacked Rectangle drop-shadows (Slint has no multi-layer shadow API).
// UserMenu-style panel: offset-y 6px, blurs 18+12, Tokens.drop-shadow.
// Select / default button: offset-y 1px, blurs 2+1, semi-transparent #010409 (dark).

export struct DropShadowLayer {
    offset-x: length,
    offset-y: length,
    blur: length,
    color: color,
}

export component DoubleDropShadow {
    in property <length> border-radius;
    in property <DropShadowLayer> back-layer;
    in property <DropShadowLayer> front-layer;

    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: border-radius;
        drop-shadow-offset-x: back-layer.offset-x;
        drop-shadow-offset-y: back-layer.offset-y;
        drop-shadow-blur: back-layer.blur;
        drop-shadow-color: back-layer.color;
    }

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: border-radius;
        drop-shadow-offset-x: front-layer.offset-x;
        drop-shadow-offset-y: front-layer.offset-y;
        drop-shadow-blur: front-layer.blur;
        drop-shadow-color: front-layer.color;
    }
}
