import { Palette } from "std-widgets.slint";
import { DropShadowLayer } from "./Effects/multi-drop-shadow.slint";

export enum Size {
    small,
    medium,
    large,
}

export global ShadowTokens {

    property <[DropShadowLayer]> shadow-floating-small-light: [
        { color: #d1d9e080, offset-x: 0px, offset-y: 0px, blur: 1px },
        { color: #25292e0a, offset-x: 0px, offset-y: 6px, blur: 12px },
        { color: #25292e1f, offset-x: 0px, offset-y: 6px, blur: 18px },
    ];
    property <[DropShadowLayer]> shadow-floating-small-dark: [
        { color: #3d444d, offset-x: 0px, offset-y: 0px, blur: 1px },
        { color: #01040966, offset-x: 0px, offset-y: 6px, blur: 12px },
        { color: #01040966, offset-x: 0px, offset-y: 6px, blur: 18px },
    ];

    out property <[DropShadowLayer]> shadow-floating-small: Palette.color-scheme == ColorScheme.dark ? shadow-floating-small-dark : shadow-floating-small-light;

}

// Primer functional/size + typography (no color-scheme). Matches ButtonBase.module.css variable names.
export global LayoutTokens {
    out property <length> text-body-size-small: 12px;
    out property <length> text-body-size-medium: 14px;
    out property <length> text-body-size-large: 16px;

    out property <length> text-body-lineHeight-small: 18px;
    out property <length> text-body-lineHeight-medium: 20px;
    out property <length> text-body-lineHeight-large: 24px;

    out property <int> base-text-weight-medium: 500;

    out property <length> control-small-size: 28px;
    out property <length> control-medium-size: 32px;
    out property <length> control-large-size: 40px;
    // UnderlineTabbedInterface.module.css — .UnderlineWrapper min-height (--control-xlarge-size)
    out property <length> control-xlarge-size: 48px;
    // Primer stack padding (--stack-padding-normal); UnderlineWrapper inset horizontal padding
    out property <length> stack-padding-normal: 16px;

    out property <length> control-small-paddingInline-condensed: 6px;
    out property <length> control-medium-paddingInline-normal: 8px;
    out property <length> control-large-paddingInline-spacious: 10px;

    out property <length> iconButton-icon-size-small: 14px;
    out property <length> iconButton-icon-size-medium: 16px;
    out property <length> iconButton-icon-size-large: 18px;

    out property <length> borderRadius-medium: 6px;

    // Banner (Banner.module.css padding / icon box; legacy-theme base-size-8 / base-size-4 / base-size-20 / base-size-16)
    out property <length> banner-padding-default: 8px;
    out property <length> banner-padding-compact: 4px;
    out property <length> banner-icon-size-default: 20px;
    out property <length> banner-icon-size-title-hidden: 16px;
    out property <length> banner-icon-container-padding: 8px;
    out property <int> base-text-weight-semibold: 600;
    // BannerActions: Banner.module.css --base-size-12 column-gap, --base-size-2 dismiss margin when data-has-actions
    out property <length> banner-actions-gap: 12px;
    out property <length> banner-dismiss-margin-when-actions: 2px;

    // Button inner row: Primer ButtonBase.module.css .ButtonContent gap (--base-size-8)
    out property <length> button-content-gap: 8px;

    // CounterLabel.module.css: padding --base-size-2 --base-size-6, border-radius 20px, border thin
    out property <length> counter-label-padding-block: 2px;
    out property <length> counter-label-padding-inline: 6px;
    out property <length> counter-label-border-radius: 20px;
    out property <length> counter-label-border-width: 1px;
}

// Semantic fg/bg/border/canvas (Primer functional/color). Shared across views; includes primitives reused by ButtonTokens (greens, fg-on-emphasis).
export global PrimerColors {

    property <ColorScheme> color-scheme: Palette.color-scheme;

    // Private literals from primer-ui-react legacy-theme colors/dark.ts + light.ts innermost fallbacks.
    // Single storage per hex/rgb/hsv; semantic tokens alias primitives (also shared with ButtonTokens via `out`).
    property <color> bgColor-inset-dark: #010409;
    property <color> canvas-subtle-light: #f6f8fa;
    property <color> bgColor-inset-light: canvas-subtle-light;
    property <color> bgColor-default-dark: #0d1117;
    property <color> bgColor-default-light: #ffffff;
    property <color> fgColor-default-dark: #e6edf3;
    property <color> fgColor-default-light: #1f2328;
    property <color> borderColor-default-dark: #30363d;
    property <color> borderColor-default-light: #d0d7de;

    property <color> fgColor-muted-dark: #848d97;
    property <color> fgColor-muted-light: #656d76;
    property <color> fgColor-subtle-dark: #6e7681;
    property <color> fgColor-subtle-light: #6e7781;

    property <color> bgColor-canvas-subtle-dark: #161b22;
    property <color> bgColor-canvas-subtle-light: canvas-subtle-light;

    property <color> bgColor-neutral-muted-dark: rgba(110, 118, 129, 0.1);
    property <color> bgColor-neutral-muted-light: rgba(234, 238, 242, 0.5);

    property <color> borderColor-muted-dark: #21262d;

    property <color> borderColor-muted-light: hsv(210, 5.263157894736848%, 89.41176470588236%, 1);

    property <color> accent-underline-dark: #f78166;
    property <color> accent-underline-light: #fd8c73;

    property <color> fgColor-placeholder-dark: #6e7681;
    property <color> fgColor-placeholder-light: #8c959f;

    property <color> fgColor-link-dark: #2f81f7;
    property <color> fgColor-link-light: #0969da;

    property <color> overlay-scrim-dark: rgba(1, 4, 9, 0.8);
    property <color> overlay-scrim-light: rgba(31, 35, 40, 0.5);

    property <color> drop-shadow-dark: #010409;
    property <color> drop-shadow-light: rgba(140, 149, 159, 0.15);

    property <color> actionListItem-inline-divider-dark: rgba(48, 54, 61, 0.48);
    property <color> actionListItem-inline-divider-light: rgba(208, 215, 222, 0.48);

    // Greens: primer scale / success fg + success emphasis (same hex as GitHub primary button bg in each mode).
    property <color> green-success-fg-light: #1a7f37;
    property <color> fgColor-success-dark: #3fb950;
    property <color> fgColor-success-light: green-success-fg-light;
    property <color> green-emphasis-dark: #238636;
    property <color> green-emphasis-light: #1f883d;
    property <color> borderColor-success-emphasis-dark: green-emphasis-dark;
    property <color> borderColor-success-emphasis-light: green-emphasis-light;
    // Primary button selected bg (light): hsv from legacy theme — stored once here for ButtonTokens.
    property <color> button-primary-selected-bg-light: hsv(137.053, 0.798319, 0.466667, 1);
    property <color> fg-on-emphasis: #ffffff;
    property <color> green-primary-hover-dark: #2ea043;
    property <color> green-primary-disabled-bg-dark: rgba(35, 134, 54, 0.6);

    // Stacked inset shadow on control triggers (Select); dark: #010409 @ ~40% / ~60% alpha. Light: soft neutral layers.
    property <color> shadow-controlTrigger-back-dark: #01040966;
    property <color> shadow-controlTrigger-front-dark: #01040999;
    property <color> shadow-controlTrigger-back-light: rgba(31, 35, 40, 0.12);
    property <color> shadow-controlTrigger-front-light: rgba(31, 35, 40, 0.18);

    // Banner surfaces: primer-tokens bgColor/borderColor/fgColor + primer-ui-react legacy-theme light.ts / dark.ts fallbacks.
    property <color> bgColor-accent-muted-light: #ddf4ff;
    property <color> bgColor-accent-muted-dark: rgba(56, 139, 253, 0.1);
    property <color> borderColor-accent-muted-light: rgba(84, 174, 255, 0.4);
    property <color> borderColor-accent-muted-dark: rgba(56, 139, 253, 0.4);

    property <color> bgColor-success-muted-light: #dafbe1;
    property <color> bgColor-success-muted-dark: rgba(46, 160, 67, 0.15);
    property <color> borderColor-success-muted-light: rgba(74, 194, 107, 0.4);
    property <color> borderColor-success-muted-dark: rgba(46, 160, 67, 0.4);

    property <color> bgColor-attention-muted-light: #fff8c5;
    property <color> bgColor-attention-muted-dark: rgba(187, 128, 9, 0.15);
    property <color> borderColor-attention-muted-light: rgba(212, 167, 44, 0.4);
    property <color> borderColor-attention-muted-dark: rgba(187, 128, 9, 0.4);
    property <color> fgColor-attention-light: #9a6700;
    property <color> fgColor-attention-dark: #d29922;

    property <color> bgColor-danger-muted-light: #ffebe9;
    property <color> bgColor-danger-muted-dark: rgba(248, 81, 73, 0.1);
    property <color> borderColor-danger-muted-light: rgba(255, 129, 130, 0.4);
    property <color> borderColor-danger-muted-dark: rgba(248, 81, 73, 0.4);
    property <color> fgColor-danger-light: #d1242f;
    property <color> fgColor-danger-dark: #f85149;

    // upsell banner uses done.* muted surfaces; fgColor-upsell aliases fgColor.done in primer-tokens.
    property <color> bgColor-done-muted-light: #fbefff;
    property <color> bgColor-done-muted-dark: rgba(163, 113, 247, 0.1);
    property <color> borderColor-done-muted-light: rgba(194, 151, 255, 0.4);
    property <color> borderColor-done-muted-dark: rgba(163, 113, 247, 0.4);
    property <color> fgColor-done-light: #8250df;
    property <color> fgColor-done-dark: #a371f7;

    out property <color> bgColor-inset: color-scheme == ColorScheme.dark ? bgColor-inset-dark : bgColor-inset-light;
    out property <color> bgColor-default: color-scheme == ColorScheme.dark ? bgColor-default-dark : bgColor-default-light;
    out property <color> fgColor-default: color-scheme == ColorScheme.dark ? fgColor-default-dark : fgColor-default-light;
    out property <color> borderColor-default: color-scheme == ColorScheme.dark ? borderColor-default-dark : borderColor-default-light;

    out property <color> fgColor-muted: color-scheme == ColorScheme.dark ? fgColor-muted-dark : fgColor-muted-light;
    out property <color> fgColor-subtle: color-scheme == ColorScheme.dark ? fgColor-subtle-dark : fgColor-subtle-light;
    out property <color> bgColor-canvas-subtle: color-scheme == ColorScheme.dark ? bgColor-canvas-subtle-dark : bgColor-canvas-subtle-light;
    out property <color> bgColor-muted: color-scheme == ColorScheme.dark ? bgColor-canvas-subtle-dark : bgColor-canvas-subtle-light;
    out property <color> bgColor-neutral-muted: color-scheme == ColorScheme.dark ? bgColor-neutral-muted-dark : bgColor-neutral-muted-light;
    out property <color> borderColor-muted: color-scheme == ColorScheme.dark ? borderColor-muted-dark : borderColor-muted-light;
    out property <color> accent-underline: color-scheme == ColorScheme.dark ? accent-underline-dark : accent-underline-light;
    out property <color> fgColor-placeholder: color-scheme == ColorScheme.dark ? fgColor-placeholder-dark : fgColor-placeholder-light;
    out property <color> fgColor-link: color-scheme == ColorScheme.dark ? fgColor-link-dark : fgColor-link-light;
    out property <color> overlay-scrim: color-scheme == ColorScheme.dark ? overlay-scrim-dark : overlay-scrim-light;
    out property <color> drop-shadow: color-scheme == ColorScheme.dark ? drop-shadow-dark : drop-shadow-light;
    out property <color> actionListItem-inline-divider: color-scheme == ColorScheme.dark ? actionListItem-inline-divider-dark : actionListItem-inline-divider-light;
    out property <color> fgColor-success: color-scheme == ColorScheme.dark ? fgColor-success-dark : fgColor-success-light;
    out property <color> borderColor-success-emphasis: color-scheme == ColorScheme.dark ? borderColor-success-emphasis-dark : borderColor-success-emphasis-light;
    out property <color> shadow-controlTrigger-back: color-scheme == ColorScheme.dark ? shadow-controlTrigger-back-dark : shadow-controlTrigger-back-light;
    out property <color> shadow-controlTrigger-front: color-scheme == ColorScheme.dark ? shadow-controlTrigger-front-dark : shadow-controlTrigger-front-light;
    out property <color> buttonPrimarySelectedBackgroundLight: button-primary-selected-bg-light;
    out property <color> fgOnEmphasis: fg-on-emphasis;
    out property <color> greenPrimaryHoverDark: green-primary-hover-dark;
    out property <color> greenPrimaryDisabledBgDark: green-primary-disabled-bg-dark;

    out property <color> fgColor-accent: fgColor-link;
    out property <color> bgColor-accent-muted: color-scheme == ColorScheme.dark ? bgColor-accent-muted-dark : bgColor-accent-muted-light;
    out property <color> borderColor-accent-muted: color-scheme == ColorScheme.dark ? borderColor-accent-muted-dark : borderColor-accent-muted-light;
    out property <color> bgColor-success-muted: color-scheme == ColorScheme.dark ? bgColor-success-muted-dark : bgColor-success-muted-light;
    out property <color> borderColor-success-muted: color-scheme == ColorScheme.dark ? borderColor-success-muted-dark : borderColor-success-muted-light;
    out property <color> bgColor-attention-muted: color-scheme == ColorScheme.dark ? bgColor-attention-muted-dark : bgColor-attention-muted-light;
    out property <color> borderColor-attention-muted: color-scheme == ColorScheme.dark ? borderColor-attention-muted-dark : borderColor-attention-muted-light;
    out property <color> fgColor-attention: color-scheme == ColorScheme.dark ? fgColor-attention-dark : fgColor-attention-light;
    out property <color> bgColor-danger-muted: color-scheme == ColorScheme.dark ? bgColor-danger-muted-dark : bgColor-danger-muted-light;
    out property <color> borderColor-danger-muted: color-scheme == ColorScheme.dark ? borderColor-danger-muted-dark : borderColor-danger-muted-light;
    out property <color> fgColor-danger: color-scheme == ColorScheme.dark ? fgColor-danger-dark : fgColor-danger-light;
    out property <color> bgColor-done-muted: color-scheme == ColorScheme.dark ? bgColor-done-muted-dark : bgColor-done-muted-light;
    out property <color> borderColor-done-muted: color-scheme == ColorScheme.dark ? borderColor-done-muted-dark : borderColor-done-muted-light;
    out property <color> fgColor-done: color-scheme == ColorScheme.dark ? fgColor-done-dark : fgColor-done-light;
    out property <color> bgColor-upsell-muted: bgColor-done-muted;
    out property <color> borderColor-upsell-muted: borderColor-done-muted;
    out property <color> fgColor-upsell: fgColor-done;
}

// color-btn-*, button-*, filled-button shadows, iconButton palette, control disabled fg. Used by Button / IconButton.
// Hex/rgb/hsv literals live in PrimerColors when shared; this global only composes scheme + internal aliases.
export global ButtonTokens {

    property <ColorScheme> color-scheme: Palette.color-scheme;

    property <color> color-btn-text-dark: #c9d1d9;
    property <color> color-btn-text-light: #24292f;

    property <color> color-btn-neutral-border-dark: #3f444c;
    property <color> color-btn-neutral-border-light: #d3d9df;

    property <color> color-btn-hover-bg-dark: #252b33;
    property <color> color-btn-hover-bg-light: #eff2f5;

    property <color> color-btn-active-bg-dark: hsv(207.273, 0.215686, 0.2, 1);
    property <color> color-btn-active-bg-light: hsv(228, 0.020833, 0.941176, 1);

    property <color> color-btn-primary-border-on-dark: rgba(240, 246, 252, 0.1);
    property <color> color-btn-primary-border-on-light: rgba(31, 35, 40, 0.15);

    property <color> color-btn-primary-disabled-bg-light: #94d3a2;

    property <color> color-btn-primary-disabled-text-dark: rgba(255, 255, 255, 0.5);
    property <color> color-btn-primary-disabled-text-light: rgba(255, 255, 255, 0.8);

    property <color> color-btn-danger-fg-dark: #f85149;
    property <color> color-btn-danger-fg-light: #cf222e;

    property <color> color-btn-danger-hover-bg-dark: #da3633;

    property <color> color-btn-danger-selected-bg-dark: #b62324;
    property <color> color-btn-danger-selected-bg-light: #a40e26;

    property <color> color-btn-danger-selected-border-dark: #ff7b72;

    property <color> color-btn-danger-disabled-text-dark: rgba(248, 81, 73, 0.5);
    property <color> color-btn-danger-disabled-text-light: rgba(207, 34, 46, 0.5);

    property <color> color-action-list-item-default-hover-bg-dark: rgba(177, 186, 196, 0.12);
    property <color> color-action-list-item-default-hover-bg-light: rgba(208, 215, 222, 0.32);

    property <color> color-action-list-item-default-active-bg-dark: rgba(177, 186, 196, 0.2);
    property <color> color-action-list-item-default-active-bg-light: rgba(208, 215, 222, 0.48);

    property <color> color-action-list-item-default-selected-bg-dark: rgba(177, 186, 196, 0.08);
    property <color> color-action-list-item-default-selected-bg-light: rgba(208, 215, 222, 0.24);

    property <color> color-primer-fg-disabled-dark: #484f58;
    property <color> color-primer-fg-disabled-light: #8c959f;

    // IconButton (toolbar) grays — distinct from color-btn-text on purpose for current UI
    property <color> iconButton-fgColor-rest-dark: #9398a0;
    property <color> iconButton-fgColor-rest-light: #59636e;
    property <color> iconButton-bgColor-hover-dark: #16191e;

    // --- Scheme-resolved color-btn-* (alias targets for button-* below)
    out property <color> color-btn-text: color-scheme == ColorScheme.dark ? color-btn-text-dark : color-btn-text-light;
    out property <color> color-btn-bg: color-scheme == ColorScheme.dark ? PrimerColors.borderColor-muted : PrimerColors.bgColor-canvas-subtle;
    out property <color> color-btn-border: color-scheme == ColorScheme.dark ? color-btn-neutral-border-dark : color-btn-neutral-border-light;
    out property <color> color-btn-hover-bg: color-scheme == ColorScheme.dark ? color-btn-hover-bg-dark : color-btn-hover-bg-light;
    out property <color> color-btn-hover-border: color-scheme == ColorScheme.dark ? color-btn-neutral-border-dark : color-btn-neutral-border-light;
    out property <color> color-btn-active-bg: color-scheme == ColorScheme.dark ? color-btn-active-bg-dark : color-btn-active-bg-light;
    out property <color> color-btn-active-border: color-scheme == ColorScheme.dark ? color-btn-neutral-border-dark : color-btn-neutral-border-light;

    out property <color> color-btn-primary-bg: PrimerColors.borderColor-success-emphasis;
    out property <color> color-btn-primary-border: color-scheme == ColorScheme.dark ? color-btn-primary-border-on-dark : color-btn-primary-border-on-light;
    out property <color> color-btn-primary-hover-bg: color-scheme == ColorScheme.dark ? PrimerColors.greenPrimaryHoverDark : PrimerColors.fgColor-success;
    out property <color> color-btn-primary-hover-border: color-scheme == ColorScheme.dark ? color-btn-primary-border-on-dark : color-btn-primary-border-on-light;
    out property <color> color-btn-primary-selected-bg: color-scheme == ColorScheme.dark ? PrimerColors.borderColor-success-emphasis : PrimerColors.buttonPrimarySelectedBackgroundLight;
    out property <color> color-btn-primary-disabled-text: color-scheme == ColorScheme.dark ? color-btn-primary-disabled-text-dark : color-btn-primary-disabled-text-light;
    out property <color> color-btn-primary-disabled-bg: color-scheme == ColorScheme.dark ? PrimerColors.greenPrimaryDisabledBgDark : color-btn-primary-disabled-bg-light;
    out property <color> color-btn-primary-disabled-border: color-scheme == ColorScheme.dark ? color-btn-primary-border-on-dark : color-btn-primary-border-on-light;

    out property <color> color-btn-danger-text: color-scheme == ColorScheme.dark ? color-btn-danger-fg-dark : color-btn-danger-fg-light;
    out property <color> color-btn-danger-hover-bg: color-scheme == ColorScheme.dark ? color-btn-danger-hover-bg-dark : color-btn-danger-fg-light;
    out property <color> color-btn-danger-hover-border: color-scheme == ColorScheme.dark ? color-btn-danger-fg-dark : color-btn-primary-border-on-light;
    out property <color> color-btn-danger-selected-bg: color-scheme == ColorScheme.dark ? color-btn-danger-selected-bg-dark : color-btn-danger-selected-bg-light;
    out property <color> color-btn-danger-selected-border: color-scheme == ColorScheme.dark ? color-btn-danger-selected-border-dark : color-btn-primary-border-on-light;
    out property <color> color-btn-danger-disabled-text: color-scheme == ColorScheme.dark ? color-btn-danger-disabled-text-dark : color-btn-danger-disabled-text-light;

    out property <color> color-action-list-item-default-hover-bg: color-scheme == ColorScheme.dark ? color-action-list-item-default-hover-bg-dark : color-action-list-item-default-hover-bg-light;
    out property <color> color-action-list-item-default-active-bg: color-scheme == ColorScheme.dark ? color-action-list-item-default-active-bg-dark : color-action-list-item-default-active-bg-light;
    out property <color> color-action-list-item-default-selected-bg: color-scheme == ColorScheme.dark ? color-action-list-item-default-selected-bg-dark : color-action-list-item-default-selected-bg-light;

    out property <color> control-fgColor-disabled: color-scheme == ColorScheme.dark ? color-primer-fg-disabled-dark : color-primer-fg-disabled-light;

    out property <color> iconButton-fgColor-rest: color-scheme == ColorScheme.dark ? iconButton-fgColor-rest-dark : iconButton-fgColor-rest-light;
    out property <color> iconButton-bgColor-hover: color-scheme == ColorScheme.dark ? iconButton-bgColor-hover-dark : color-btn-hover-bg-light;

    // --- Semantic button-* (primer-tokens color-fallbacks / ButtonBase.module.css naming)
    out property <color> button-default-fgColor-rest: color-btn-text;
    out property <color> button-default-bgColor-rest: color-btn-bg;
    out property <color> button-default-bgColor-hover: color-btn-hover-bg;
    out property <color> button-default-bgColor-active: color-btn-active-bg;
    out property <color> button-default-bgColor-disabled: color-btn-bg;
    out property <color> button-default-borderColor-rest: color-btn-border;
    out property <color> button-default-borderColor-hover: color-btn-hover-border;
    out property <color> button-default-borderColor-active: color-btn-active-border;
    out property <color> button-default-borderColor-disabled: color-btn-border;

    out property <color> button-primary-fgColor-rest: PrimerColors.fgOnEmphasis;
    out property <color> button-primary-fgColor-disabled: color-btn-primary-disabled-text;
    out property <color> button-primary-bgColor-rest: color-btn-primary-bg;
    out property <color> button-primary-bgColor-hover: color-btn-primary-hover-bg;
    out property <color> button-primary-bgColor-active: color-btn-primary-selected-bg;
    out property <color> button-primary-bgColor-disabled: color-btn-primary-disabled-bg;
    out property <color> button-primary-borderColor-rest: color-btn-primary-border;
    out property <color> button-primary-borderColor-hover: color-btn-primary-hover-border;
    out property <color> button-primary-borderColor-disabled: color-btn-primary-disabled-border;

    out property <color> button-danger-fgColor-rest: color-btn-danger-text;
    out property <color> button-danger-fgColor-hover: PrimerColors.fgOnEmphasis;
    out property <color> button-danger-fgColor-active: PrimerColors.fgOnEmphasis;
    out property <color> button-danger-fgColor-disabled: color-btn-danger-disabled-text;
    out property <color> button-danger-bgColor-rest: color-btn-bg;
    out property <color> button-danger-bgColor-hover: color-btn-danger-hover-bg;
    out property <color> button-danger-bgColor-active: color-btn-danger-selected-bg;
    out property <color> button-danger-bgColor-disabled: color-scheme == ColorScheme.dark ? PrimerColors.bgColor-default : PrimerColors.bgColor-canvas-subtle;
    out property <color> button-danger-borderColor-rest: color-btn-border;
    out property <color> button-danger-borderColor-hover: color-btn-danger-hover-border;
    out property <color> button-danger-borderColor-active: color-btn-danger-selected-border;
    out property <color> button-danger-borderColor-disabled: color-btn-border;

    out property <color> button-invisible-fgColor-rest: color-btn-text;
    out property <color> button-invisible-fgColor-disabled: control-fgColor-disabled;
    out property <color> button-invisible-bgColor-rest: #00000000;
    out property <color> button-invisible-bgColor-hover: color-action-list-item-default-hover-bg;
    out property <color> button-invisible-bgColor-active: color-action-list-item-default-active-bg;
    out property <color> button-invisible-bgColor-disabled: color-action-list-item-default-selected-bg;
    out property <color> button-invisible-borderColor-rest: #00000000;
    out property <color> button-invisible-borderColor-hover: #00000000;
    out property <color> button-invisible-borderColor-disabled: color-action-list-item-default-selected-bg;

    out property <color> button-link-bgColor-rest: #00000000;
    out property <color> button-link-borderColor-rest: #00000000;

    // Filled-button shadows (rgba; light vs dark tuned for contrast on canvas)
    out property <color> button-shadow-ambient-light: rgba(31, 35, 40, 0.04);
    out property <color> button-shadow-elevated-light: rgba(31, 35, 40, 0.1);
    out property <color> button-shadow-danger-back-pressed-light: rgba(76, 0, 20, 0.2);
    out property <color> button-shadow-primary-back-pressed-light: rgba(0, 45, 17, 0.2);
    out property <color> button-shadow-danger-front-pressed-light: rgba(76, 0, 20, 0.14);
    out property <color> button-shadow-primary-front-pressed-light: rgba(0, 45, 17, 0.14);

    out property <color> button-shadow-ambient-dark: rgba(0, 0, 0, 0.32);
    out property <color> button-shadow-elevated-dark: rgba(0, 0, 0, 0.52);
    out property <color> button-shadow-danger-back-pressed-dark: rgba(0, 0, 0, 0.45);
    out property <color> button-shadow-primary-back-pressed-dark: rgba(0, 0, 0, 0.42);
    out property <color> button-shadow-danger-front-pressed-dark: rgba(0, 0, 0, 0.32);
    out property <color> button-shadow-primary-front-pressed-dark: rgba(0, 0, 0, 0.28);

    // CounterLabel inside Button (ButtonBase.module.css .CounterLabel + legacy-theme light.ts / dark.ts fallbacks)
    property <color> buttonCounter-default-bg-rest-light: rgba(31, 35, 40, 0.08);
    property <color> buttonCounter-default-bg-rest-dark: #30363d;
    property <color> buttonCounter-primary-bg-rest-light: rgba(0, 45, 17, 0.2);
    property <color> buttonCounter-primary-bg-rest-dark: rgba(4, 38, 15, 0.2);
    property <color> buttonCounter-danger-bg-rest-light: rgba(207, 34, 46, 0.1);
    property <color> buttonCounter-danger-bg-rest-dark: rgba(73, 2, 2, 0.2);
    property <color> buttonCounter-danger-fg-rest-light: #a40e26;
    property <color> buttonCounter-danger-fg-rest-dark: #f85149;
    property <color> buttonCounter-danger-bg-hover: rgba(255, 255, 255, 0.2);
    property <color> buttonCounter-danger-bg-disabled-light: rgba(207, 34, 46, 0.05);
    property <color> buttonCounter-danger-bg-disabled-dark: rgba(218, 54, 51, 0.05);
    property <color> buttonCounter-danger-fg-disabled-light: rgba(207, 34, 46, 0.5);
    property <color> buttonCounter-danger-fg-disabled-dark: rgba(248, 81, 73, 0.5);

    out property <color> buttonCounter-borderColor: #00000000;
    out property <color> buttonCounter-default-bgColor-rest: color-scheme == ColorScheme.dark ? buttonCounter-default-bg-rest-dark : buttonCounter-default-bg-rest-light;
    out property <color> buttonCounter-default-fgColor-rest: button-default-fgColor-rest;
    out property <color> buttonCounter-primary-bgColor-rest: color-scheme == ColorScheme.dark ? buttonCounter-primary-bg-rest-dark : buttonCounter-primary-bg-rest-light;
    out property <color> buttonCounter-primary-fgColor-rest: button-primary-fgColor-rest;
    out property <color> buttonCounter-danger-bgColor-rest: color-scheme == ColorScheme.dark ? buttonCounter-danger-bg-rest-dark : buttonCounter-danger-bg-rest-light;
    out property <color> buttonCounter-danger-fgColor-rest: color-scheme == ColorScheme.dark ? buttonCounter-danger-fg-rest-dark : buttonCounter-danger-fg-rest-light;
    out property <color> buttonCounter-danger-bgColor-hover: buttonCounter-danger-bg-hover;
    out property <color> buttonCounter-danger-fgColor-hover: PrimerColors.fgOnEmphasis;
    out property <color> buttonCounter-danger-bgColor-disabled: color-scheme == ColorScheme.dark ? buttonCounter-danger-bg-disabled-dark : buttonCounter-danger-bg-disabled-light;
    out property <color> buttonCounter-danger-fgColor-disabled: color-scheme == ColorScheme.dark ? buttonCounter-danger-fg-disabled-dark : buttonCounter-danger-fg-disabled-light;
    out property <color> buttonCounter-invisible-bgColor-rest: buttonCounter-default-bgColor-rest;
    out property <color> buttonCounter-invisible-fgColor-rest: button-invisible-fgColor-rest;
}

// Banner.module.css --banner-* per variant; values are PrimerColors functional tokens only (no literals here).
export global BannerTokens {
    out property <color> banner-bgColor-critical: PrimerColors.bgColor-danger-muted;
    out property <color> banner-borderColor-critical: PrimerColors.borderColor-danger-muted;
    out property <color> banner-icon-fgColor-critical: PrimerColors.fgColor-danger;

    out property <color> banner-bgColor-info: PrimerColors.bgColor-accent-muted;
    out property <color> banner-borderColor-info: PrimerColors.borderColor-accent-muted;
    out property <color> banner-icon-fgColor-info: PrimerColors.fgColor-accent;

    out property <color> banner-bgColor-success: PrimerColors.bgColor-success-muted;
    out property <color> banner-borderColor-success: PrimerColors.borderColor-success-muted;
    out property <color> banner-icon-fgColor-success: PrimerColors.fgColor-success;

    out property <color> banner-bgColor-upsell: PrimerColors.bgColor-upsell-muted;
    out property <color> banner-borderColor-upsell: PrimerColors.borderColor-upsell-muted;
    out property <color> banner-icon-fgColor-upsell: PrimerColors.fgColor-upsell;

    out property <color> banner-bgColor-warning: PrimerColors.bgColor-attention-muted;
    out property <color> banner-borderColor-warning: PrimerColors.borderColor-attention-muted;
    out property <color> banner-icon-fgColor-warning: PrimerColors.fgColor-attention;
}
