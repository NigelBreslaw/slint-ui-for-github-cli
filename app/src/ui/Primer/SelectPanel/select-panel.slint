// Primer-style SelectPanel — filter field + scrollable list of choices (single-select).
// Upstream: https://primer.style/product/components/select-panel/ (parent filters items; this view is in-panel only).

import { ActionListRow } from "../ActionList/action-list-row.slint";
import { Spinner } from "../Progress/spinner.slint";
import { SelectOption } from "../Select/select.slint";
import { LayoutTokens, PrimerColors, Size } from "../tokens.slint";

export component SelectPanel {
    /// Filter query; bind from the parent and/or react to [`filter-changed`].
    in-out property <string> filter-text: "";
    in property <string> filter-placeholder: "Filter…";
    /// Row model (typically **pre-filtered** by the parent from `filter-text`).
    in property <[SelectOption]> items: [];
    /// When `>= 0`, bounds checks use this instead of `items.length` (Slint `ArrayModel` length quirk).
    in property <int> item-count: -1;
    in-out property <int> selected-index: -1;
    in property <bool> loading: false;
    in property <string> empty-message: "No results";
    in property <bool> disabled: false;
    /// Scroll viewport height for the list body.
    in property <length> list-max-height: 240px;

    callback filter-changed(string);
    callback selected-changed(int);

    private property <int> effective-len: item-count >= 0 ? item-count : items.length;

    horizontal-stretch: 1;
    vertical-stretch: 0;

    VerticalLayout {
        spacing: 8px;
        width: 100%;

        Rectangle {
            width: 100%;
            height: 40px;
            background: PrimerColors.bgColor-neutral-muted;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;
            clip: true;

            TextInput {
                x: 10px;
                y: 0;
                width: parent.width - 20px;
                height: parent.height;
                read-only: root.disabled;
                text: root.filter-text;
                font-size: LayoutTokens.text-body-size-medium;
                color: PrimerColors.fgColor-default;
                edited => {
                    root.filter-text = self.text;
                    root.filter-changed(self.text);
                }
            }
        }

        Rectangle {
            width: 100%;
            height: root.list-max-height;
            background: PrimerColors.bgColor-canvas-subtle;
            border-radius: LayoutTokens.borderRadius-medium;
            border-width: 1px;
            border-color: PrimerColors.borderColor-muted;
            clip: true;

            VerticalLayout {
                width: 100%;
                height: 100%;
                alignment: stretch;

                if root.loading: VerticalLayout {
                    padding: 16px;
                    spacing: 10px;
                    alignment: center;

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: center;

                        Spinner {
                            size: Size.small;
                        }

                        Text {
                            text: "Loading…";
                            font-size: LayoutTokens.text-body-size-small;
                            color: PrimerColors.fgColor-muted;
                            wrap: word-wrap;
                        }
                    }
                }

                if !root.loading && root.effective-len == 0: VerticalLayout {
                    padding: 16px;
                    alignment: center;

                    Text {
                        horizontal-alignment: center;
                        text: root.empty-message;
                        font-size: LayoutTokens.text-body-size-small;
                        color: PrimerColors.fgColor-muted;
                        wrap: word-wrap;
                    }
                }

                if !root.loading && root.effective-len > 0: Flickable {
                    width: 100%;
                    height: parent.height;
                    viewport-width: parent.width;
                    viewport-height: list-vl.preferred-height;

                    list-vl := VerticalLayout {
                        width: parent.width;
                        spacing: 0px;

                        for ix in root.effective-len: ActionListRow {
                            width: 100%;
                            label: root.items[ix].label;
                            selected: ix == root.selected-index;
                            disabled: root.disabled || !root.items[ix].enabled;
                            clicked => {
                                if !root.items[ix].enabled || root.disabled {
                                    return;
                                }
                                root.selected-index = ix;
                                root.selected-changed(ix);
                            }
                        }
                    }
                }
            }
        }
    }
}
