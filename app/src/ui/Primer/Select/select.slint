// Primer-style Select trigger (theme-aware via PrimerColors / ButtonTokens). Reference: https://primer.style/product/components/select/
// Options open via Slint ContextMenuArea (native menu).
// When `selected-value` or `options` change from TypeScript, keep `selected-label` in sync there
// (Slint cannot scan the options model in a `changed` handler in this toolchain).

import { DoubleDropShadow } from "../Effects/double-drop-shadow.slint";
import { ButtonTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";

export struct SelectOption {
    value: string,
    label: string,
    enabled: bool,
}

export enum ValidationStatus {
    none,
    error,
    success,
}

export component Select {
    in property <string> label-text: "";
    in-out property <string> selected-value: "";
    in-out property <string> selected-label: "";
    in-out property <int> selected-index: -1;
    in property <string> placeholder: "Select…";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <Size> size: medium;
    in property <[SelectOption]> options;
    callback selected-changed(string);

    horizontal-stretch: block ? 1 : 0;
    min-width: 200px;

    private property <length> trigger-height:
        size == Size.small
        ? LayoutTokens.control-small-size
        : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    // Match Button filled label sizing; large uses medium body (Primer TextInputBaseWrapper).
    private property <length> trigger-font:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    private property <color> trigger-border-color:
        validation-status == ValidationStatus.error
        ? ButtonTokens.color-btn-danger-text
        : validation-status == ValidationStatus.success ? PrimerColors.borderColor-success-emphasis : PrimerColors.borderColor-default;

    function apply-pick-at(ix: int) {
        if ix < 0 || ix >= options.length {
            return;
        }
        if !options[ix].enabled {
            return;
        }
        root.selected-value = options[ix].value;
        root.selected-label = options[ix].label;
        root.selected-index = ix;
        root.selected-changed(options[ix].value);
    }

    VerticalLayout {
        spacing: 6px;
        horizontal-stretch: block ? 1 : 0;

        if label-text != "": Text {
            text: label-text;
            font-size: LayoutTokens.text-body-size-medium;
            font-weight: 600;
            color: PrimerColors.fgColor-default;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0;
            horizontal-stretch: block ? 1 : 0;

            trigger-wrap := Rectangle {
                horizontal-stretch: block ? 1 : 0;
                height: trigger-height;

                select-ctx := ContextMenuArea {
                    width: 100%;
                    height: 100%;
                    enabled: !root.disabled && root.options.length > 0;

                    Menu {
                        for opt[index] in options: MenuItem {
                            title: opt.label;
                            enabled: opt.enabled;
                            activated => {
                                root.apply-pick-at(index);
                            }
                        }
                    }

                    DoubleDropShadow {
                        width: parent.width;
                        height: parent.height;
                        border-radius: LayoutTokens.borderRadius-medium;
                        back-layer: { offset-x: 0px, offset-y: 1px, blur: 2px, color: PrimerColors.shadow-controlTrigger-back };
                        front-layer: { offset-x: 0px, offset-y: 1px, blur: 1px, color: PrimerColors.shadow-controlTrigger-front };
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: disabled
                            ? PrimerColors.bgColor-default
                            : ta.has-hover ? PrimerColors.bgColor-canvas-subtle : PrimerColors.bgColor-default;
                        border-radius: LayoutTokens.borderRadius-medium;
                        border-width: 1px;
                        border-color: trigger-border-color;
                        clip: false;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 8px;
                            spacing: 8px;
                            width: 100%;
                            height: 100%;

                            Text {
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                                text: selected-label != "" ? selected-label : placeholder;
                                font-size: trigger-font;
                                color: selected-label != "" ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                                overflow: elide;
                            }

                            Image {
                                width: LayoutTokens.iconButton-icon-size-medium;
                                height: LayoutTokens.iconButton-icon-size-medium;
                                vertical-alignment: center;
                                source: @image-url("../../../assets/16px/chevron-down.svg");
                                colorize: PrimerColors.fgColor-muted;
                            }
                        }
                    }

                    ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            if !root.disabled && root.options.length > 0 {
                                select-ctx.show({ x: 0px, y: 0px });
                            }
                        }
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: LayoutTokens.text-body-size-small;
            color: PrimerColors.fgColor-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;
            horizontal-stretch: block ? 1 : 0;

            Image {
                width: LayoutTokens.iconButton-icon-size-medium;
                height: LayoutTokens.iconButton-icon-size-medium;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ? @image-url("../../../assets/16px/alert.svg") : @image-url("../../../assets/16px/check-circle.svg");
                colorize: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: LayoutTokens.text-body-size-medium;
                color: validation-status == ValidationStatus.error ? ButtonTokens.color-btn-danger-text : PrimerColors.fgColor-success;
                wrap: word-wrap;
            }
        }
    }
}
