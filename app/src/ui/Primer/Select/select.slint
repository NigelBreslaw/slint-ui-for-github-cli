// Primer-style Select trigger (dark only). Reference: https://primer.style/product/components/select/
// Options open via Slint ContextMenuArea (native menu). Layered drop-shadow: same pattern as ButtonGreen in buttons.slint.
// When `selected-value` or `options` change from TypeScript, keep `selected-label` in sync there
// (Slint cannot scan the options model in a `changed` handler in this toolchain).

import { Size, Tokens } from "../tokens.slint";

export struct SelectOption {
    value: string,
    label: string,
    enabled: bool,
}

export enum ValidationStatus {
    none,
    error,
    success,
}

export component Select {
    in property <string> label-text: "";
    in-out property <string> selected-value: "";
    in-out property <string> selected-label: "";
    in-out property <int> selected-index: -1;
    in property <string> placeholder: "Select…";
    in property <string> caption: "";
    in property <ValidationStatus> validation-status: none;
    in property <string> validation-message: "";
    in property <bool> disabled: false;
    in property <bool> block: false;
    in property <Size> size: medium;
    in property <[SelectOption]> options;
    callback selected-changed(string);

    horizontal-stretch: block ? 1 : 0;
    min-width: 200px;

    private property <length> trigger-height: size == Size.small ? 28px : size == Size.large ? 40px : 32px;
    private property <length> trigger-font: size == Size.small ? 12px : size == Size.large ? 15px : 14px;
    private property <color> border-default: #30363d;
    private property <color> border-error: #f85149;
    private property <color> border-success: #238636;
    private property <color> fill-bg: #0d1117;
    private property <color> fill-hover: #161b22;
    private property <color> text-primary: Tokens.fgColor-default;
    private property <color> text-muted: #8b949e;
    private property <color> text-error: #f85149;
    private property <color> text-success: #3fb950;

    private property <color> trigger-border-color:
        validation-status == ValidationStatus.error ? border-error : validation-status == ValidationStatus.success ? border-success : border-default;

    function apply-pick-at(ix: int) {
        if ix < 0 || ix >= options.length {
            return;
        }
        if !options[ix].enabled {
            return;
        }
        root.selected-value = options[ix].value;
        root.selected-label = options[ix].label;
        root.selected-index = ix;
        root.selected-changed(options[ix].value);
    }

    VerticalLayout {
        spacing: 6px;
        horizontal-stretch: block ? 1 : 0;

        if label-text != "": Text {
            text: label-text;
            font-size: 14px;
            font-weight: 600;
            color: text-primary;
            wrap: word-wrap;
        }

        VerticalLayout {
            spacing: 0;
            horizontal-stretch: block ? 1 : 0;

            trigger-wrap := Rectangle {
                horizontal-stretch: block ? 1 : 0;
                height: trigger-height;

                select-ctx := ContextMenuArea {
                    width: 100%;
                    height: 100%;
                    enabled: !root.disabled && root.options.length > 0;

                    Menu {
                        for opt[index] in options: MenuItem {
                            title: opt.label;
                            enabled: opt.enabled;
                            activated => {
                                root.apply-pick-at(index);
                            }
                        }
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        border-radius: 6px;
                        drop-shadow-offset-x: 0px;
                        drop-shadow-offset-y: 1px;
                        drop-shadow-blur: 2px;
                        drop-shadow-color: #01040966;
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        border-radius: 6px;
                        drop-shadow-offset-x: 0px;
                        drop-shadow-offset-y: 1px;
                        drop-shadow-blur: 1px;
                        drop-shadow-color: #01040999;
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: disabled ? fill-bg : ta.has-hover ? fill-hover : fill-bg;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: trigger-border-color;
                        clip: false;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 8px;
                            spacing: 8px;
                            width: 100%;
                            height: 100%;

                            Text {
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                                text: selected-label != "" ? selected-label : placeholder;
                                font-size: trigger-font;
                                color: selected-label != "" ? text-primary : text-muted;
                                overflow: elide;
                            }

                            Image {
                                width: 16px;
                                height: 16px;
                                vertical-alignment: center;
                                source: @image-url("../../../assets/16px/chevron-down.svg");
                                colorize: text-muted;
                            }
                        }
                    }

                    ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            if !root.disabled && root.options.length > 0 {
                                select-ctx.show({ x: 0px, y: 0px });
                            }
                        }
                    }
                }
            }
        }

        if caption != "": Text {
            text: caption;
            font-size: 12px;
            color: text-muted;
            wrap: word-wrap;
        }

        if validation-message != "" && validation-status != ValidationStatus.none: HorizontalLayout {
            spacing: 6px;
            horizontal-stretch: block ? 1 : 0;

            Image {
                width: 16px;
                height: 16px;
                vertical-alignment: top;
                source: validation-status == ValidationStatus.error ? @image-url("../../../assets/16px/alert.svg") : @image-url("../../../assets/16px/check-circle.svg");
                colorize: validation-status == ValidationStatus.error ? text-error : text-success;
            }

            Text {
                horizontal-stretch: 1;
                text: validation-message;
                font-size: 13px;
                color: validation-status == ValidationStatus.error ? text-error : text-success;
                wrap: word-wrap;
            }
        }
    }
}
