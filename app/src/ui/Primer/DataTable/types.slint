// Primer DataTable — column/row models (primer/react DataTable / column.ts). Sort: `DataTableSortDirection` + `sort-toggled` in `data-table.slint`.

import { LabelSize, LabelVariant } from "../Label/types.slint";

export enum DataTableSortDirection {
    none,
    ascending,
    descending,
}

export enum DataTableCellPadding {
    condensed,
    normal,
    spacious,
}

export enum DataTableCellAlign {
    start,
    end,
}

/// Body cell content kind; must match the column’s `cell-kind` for that index. More kinds in follow-up PRs.
export enum DataTableCellKind {
    text,
    label,
    /// Icon + label (JS bridge: use **`iconText`**, not `icon_text` — that spelling breaks Node **`Model`** marshalling).
    iconText,
    action,
}

/// Semantic tint for **`iconText`** icons (maps to **`PrimerColors`** in **`data-table.slint`**). Ignored for other cell kinds.
export enum DataTableIconTint {
    default,
    success,
    done,
}

export struct DataTableColumn {
    header: string,
    id: string,
    sortable: bool,
    align: DataTableCellAlign,
    row-header: bool,
    /// What each body cell in this column carries (`text` | `label` | `iconText` | `action`; more kinds later).
    cell-kind: DataTableCellKind,
    /// Horizontal flex factor for distributing **extra** table width after `min-width` is satisfied.
    /// `0` = column stays at its minimum width only; `> 0` shares leftover space with other stretchy columns (Title often uses `1`).
    horizontal-stretch: float,
    /// Minimum width; combined with `width` for layout min (see `StandardTableView` column sizing).
    min-width: length,
    /// If **≥ 1px**, column is fixed at that width; if **0px**, column is flexible (`preferred-width` 0, large max-width) and uses `horizontal-stretch` + `min-width`.
    width: length,
    /// When true, header and body cells in this column use a monospaced font (e.g. debug values).
    monospace: bool,
}

export struct DataTableCell {
    kind: DataTableCellKind,
    /// Plain text when `kind == text`; chip text when `kind == label`; label next to **`icon`** when `kind == iconText`; **action id** (opaque) when `kind == action` (passed to **`row-action`**).
    text: string,
    /// When `kind == label`, passed to **Label**; for `text` / `iconText` cells use **`LabelVariant.default`** / **`LabelSize.small`** as placeholders.
    label-variant: LabelVariant,
    label-size: LabelSize,
    /// When `kind == iconText` or **`action`**, **`Image`** / **IconButton** source; for `text` / `label` supply any placeholder (ignored).
    icon: image,
    /// When `kind == iconText`, tints **`icon`** only; ignored otherwise.
    icon-tint: DataTableIconTint,
}

export struct DataTableRow {
    id: string,
    cells: [DataTableCell],
}
