// Primer DataTable — column/row models (primer/react DataTable / column.ts). Sort: `DataTableSortDirection` + `sort-toggled` in `data-table.slint`.

export enum DataTableSortDirection {
    none,
    ascending,
    descending,
}

export enum DataTableCellPadding {
    condensed,
    normal,
    spacious,
}

export enum DataTableCellAlign {
    start,
    end,
}

export struct DataTableColumn {
    header: string,
    id: string,
    sortable: bool,
    align: DataTableCellAlign,
    row-header: bool,
}

export struct DataTableRow {
    id: string,
    cells: [string],
}
