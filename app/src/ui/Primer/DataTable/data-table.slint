// Primer DataTable — Table.module.css spacing/colors; sort headers + callback (primer/react DataTable onToggleSort).
//
// Layout lesson: header and body must share one *column width model*. Separate HorizontalLayouts per row each run flex
// independently; we align columns by binding the same per-index constraints on header and body cells (horizontal-stretch,
// min-width, preferred-width — 0 for flexible columns so text does not set column width — and max-width), mirroring
// material StandardTableView in the Slint repo: internal/compiler/widgets/material/tableview.slint (TableViewColumn / TableViewCell).
// Slint docs: HorizontalLayout and GridLayout (stretch, min/preferred/max). A single GridLayout would unify column tracks,
// but nested repeaters in GridLayout (for rows × for cells) have panicked the interpreter (dynamic_item_tree repeater lookup);
// see Primer readme.md DataTable "Layout" paragraph.
import { IconButton, IconButtonVariant } from "../Buttons/buttons.slint";
import { Label } from "../Label/label.slint";
import { LayoutTokens, PrimerColors, Size } from "../tokens.slint";
import {
    DataTableCellAlign,
    DataTableCellKind,
    DataTableCellPadding,
    DataTableColumn,
    DataTableRow,
    DataTableSortDirection,
} from "./types.slint";

export component DataTable {
    in property <[DataTableColumn]> columns: [];
    in property <[DataTableRow]> rows: [];
    in property <DataTableCellPadding> cell-padding: DataTableCellPadding.normal;
    /// Active sort column id; empty means none (controlled; parent updates after `sort-toggled`).
    in property <string> sorted-column-id: "";
    in property <DataTableSortDirection> sort-direction: DataTableSortDirection.none;
    /// When true, sorting is owned outside the table (e.g. server); `sort-toggled` still fires so parent can refresh rows.
    in property <bool> external-sorting: true;
    callback sort-toggled(column-id: string, direction: DataTableSortDirection);
    /// Fired when a body cell with `kind == action` is activated; **`action-id`** is that cell’s **`text`**.
    callback row-action(row-id: string, column-id: string, action-id: string);

    private property <length> pad-block:
        cell-padding == DataTableCellPadding.condensed ? LayoutTokens.table-cell-padding-block-condensed
        : cell-padding == DataTableCellPadding.spacious ? LayoutTokens.table-cell-padding-block-spacious
        : LayoutTokens.table-cell-padding-block-normal;

    private property <length> pad-inline:
        cell-padding == DataTableCellPadding.condensed ? LayoutTokens.table-cell-padding-inline-condensed
        : cell-padding == DataTableCellPadding.spacious ? LayoutTokens.table-cell-padding-inline-spacious
        : LayoutTokens.table-cell-padding-inline-normal;

    // Header must not use min-height: 0 with TouchArea — Slint can collapse the row to zero height.
    private property <length> header-row-min-height:
        pad-block + pad-block + LayoutTokens.text-body-lineHeight-medium;

    pure function col-max-width(col: DataTableColumn) -> length {
        col.width >= 1px ? max(col.min-width, col.width) : 100000px;
    }

    pure function col-min-width(col: DataTableColumn) -> length {
        max(col.min-width, col.width);
    }

    /// Flexible columns use 0 preferred width so each row splits parent width evenly (avoids content-driven column widths).
    pure function col-preferred-width(col: DataTableColumn) -> length {
        col.width >= 1px ? max(col.min-width, col.width) : 0px;
    }

    pure function body-cell-stretch(index: int) -> float {
        index < columns.length ? columns[index].horizontal-stretch : 1;
    }

    pure function body-cell-min-w(index: int) -> length {
        index < columns.length ? col-min-width(columns[index]) : 0px;
    }

    pure function body-cell-max-w(index: int) -> length {
        index < columns.length ? col-max-width(columns[index]) : 100000px;
    }

    pure function body-cell-preferred-w(index: int) -> length {
        index < columns.length ? col-preferred-width(columns[index]) : 0px;
    }

    Rectangle {
        width: 100%;
        clip: true;
        border-radius: LayoutTokens.table-border-radius;
        border-width: LayoutTokens.table-border-width;
        border-color: PrimerColors.borderColor-default;
        background: PrimerColors.bgColor-default;

        VerticalLayout {
            width: 100%;
            spacing: 0;

            // Header row
            HorizontalLayout {
                width: 100%;
                min-height: header-row-min-height;
                spacing: 0;

                for col[index] in columns: Rectangle {
                    horizontal-stretch: col.horizontal-stretch;
                    min-width: col-min-width(col);
                    preferred-width: col-preferred-width(col);
                    max-width: col-max-width(col);
                    min-height: header-row-min-height;
                    background: PrimerColors.bgColor-muted;
                    clip: true;

                    if col.sortable: header-ta := TouchArea {
                        width: 100%;
                        height: 100%;
                        min-height: header-row-min-height;
                        clicked => {
                            if sorted-column-id != col.id || sort-direction == DataTableSortDirection.none {
                                root.sort-toggled(col.id, DataTableSortDirection.ascending);
                            } else if sort-direction == DataTableSortDirection.ascending {
                                root.sort-toggled(col.id, DataTableSortDirection.descending);
                            } else {
                                root.sort-toggled(col.id, DataTableSortDirection.ascending);
                            }
                        }

                        HorizontalLayout {
                            padding-left: pad-inline + (index == 0 ? LayoutTokens.table-cell-edge-inset-inline : 0px);
                            padding-right: pad-inline + (index == columns.length - 1 ? LayoutTokens.table-cell-edge-inset-inline : 0px);
                            padding-top: pad-block;
                            padding-bottom: pad-block;
                            width: 100%;
                            min-width: 0px;
                            min-height: header-row-min-height;
                            spacing: 4px;
                            alignment: col.align == DataTableCellAlign.end ? end : start;

                            if col.align == DataTableCellAlign.end: Image {
                                width: LayoutTokens.iconButton-icon-size-medium;
                                height: LayoutTokens.iconButton-icon-size-medium;
                                vertical-alignment: center;
                                visible: sort-icon-visible(col.id, header-ta.has-hover);
                                source: sort-icon-desc(col.id) ? @image-url("../../../assets/16px/sort-desc.svg") : @image-url("../../../assets/16px/sort-asc.svg");
                                colorize: sort-column-active(col.id) ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                            }

                            if col.monospace: Text {
                                horizontal-stretch: 1;
                                min-width: 0px;
                                text: col.header;
                                font-size: LayoutTokens.text-body-size-small;
                                font-family: "Bitstream Vera Sans Mono";
                                color: sort-header-fg(col.id);
                                font-weight: LayoutTokens.base-text-weight-semibold;
                                horizontal-alignment: col.align == DataTableCellAlign.end ? right : left;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }

                            if !col.monospace: Text {
                                horizontal-stretch: 1;
                                min-width: 0px;
                                text: col.header;
                                font-size: LayoutTokens.text-body-size-small;
                                color: sort-header-fg(col.id);
                                font-weight: LayoutTokens.base-text-weight-semibold;
                                horizontal-alignment: col.align == DataTableCellAlign.end ? right : left;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }

                            if col.align == DataTableCellAlign.start: Image {
                                width: LayoutTokens.iconButton-icon-size-medium;
                                height: LayoutTokens.iconButton-icon-size-medium;
                                vertical-alignment: center;
                                visible: sort-icon-visible(col.id, header-ta.has-hover);
                                source: sort-icon-desc(col.id) ? @image-url("../../../assets/16px/sort-desc.svg") : @image-url("../../../assets/16px/sort-asc.svg");
                                colorize: sort-column-active(col.id) ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
                            }
                        }
                    }

                    if !col.sortable: HorizontalLayout {
                        padding-left: pad-inline + (index == 0 ? LayoutTokens.table-cell-edge-inset-inline : 0px);
                        padding-right: pad-inline + (index == columns.length - 1 ? LayoutTokens.table-cell-edge-inset-inline : 0px);
                        padding-top: pad-block;
                        padding-bottom: pad-block;
                        width: 100%;
                        min-width: 0px;
                        min-height: header-row-min-height;
                        alignment: col.align == DataTableCellAlign.end ? end : start;

                        if col.monospace: Text {
                            width: 100%;
                            min-width: 0px;
                            text: col.header;
                            font-size: LayoutTokens.text-body-size-small;
                            font-family: "Bitstream Vera Sans Mono";
                            color: PrimerColors.fgColor-muted;
                            font-weight: LayoutTokens.base-text-weight-semibold;
                            horizontal-alignment: col.align == DataTableCellAlign.end ? right : left;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }

                        if !col.monospace: Text {
                            width: 100%;
                            min-width: 0px;
                            text: col.header;
                            font-size: LayoutTokens.text-body-size-small;
                            color: PrimerColors.fgColor-muted;
                            font-weight: LayoutTokens.base-text-weight-semibold;
                            horizontal-alignment: col.align == DataTableCellAlign.end ? right : left;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            Rectangle {
                width: 100%;
                height: LayoutTokens.table-border-width;
                background: PrimerColors.borderColor-default;
            }

            for row in rows: VerticalLayout {
                width: 100%;
                spacing: 0;

                row-ta := TouchArea {
                    width: 100%;

                    Rectangle {
                        width: 100%;
                        background: row-ta.has-hover ? PrimerColors.table-row-bgColor-hover : PrimerColors.bgColor-default;

                        HorizontalLayout {
                            width: 100%;
                            spacing: 0;

                            for cell[index] in row.cells: Rectangle {
                                horizontal-stretch: body-cell-stretch(index);
                                min-width: body-cell-min-w(index);
                                preferred-width: body-cell-preferred-w(index);
                                max-width: body-cell-max-w(index);
                                background: #00000000;
                                clip: true;

                                HorizontalLayout {
                                    padding-left: pad-inline + (index == 0 ? LayoutTokens.table-cell-edge-inset-inline : 0px);
                                    padding-right: pad-inline + (index == columns.length - 1 ? LayoutTokens.table-cell-edge-inset-inline : 0px);
                                    padding-top: pad-block;
                                    padding-bottom: pad-block;
                                    width: 100%;
                                    min-width: 0px;
                                    min-height: 0;

                                    if cell.kind == DataTableCellKind.text && index < columns.length && columns[index].monospace: Text {
                                        width: 100%;
                                        min-width: 0px;
                                        text: cell.text;
                                        font-size: LayoutTokens.text-body-size-small;
                                        font-family: "Bitstream Vera Sans Mono";
                                        color: PrimerColors.fgColor-default;
                                        font-weight: index < columns.length && columns[index].row-header ? LayoutTokens.base-text-weight-semibold : 400;
                                        horizontal-alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? right : left;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }

                                    if cell.kind == DataTableCellKind.text && !(index < columns.length && columns[index].monospace): Text {
                                        width: 100%;
                                        min-width: 0px;
                                        text: cell.text;
                                        font-size: LayoutTokens.text-body-size-small;
                                        color: PrimerColors.fgColor-default;
                                        font-weight: index < columns.length && columns[index].row-header ? LayoutTokens.base-text-weight-semibold : 400;
                                        horizontal-alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? right : left;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }

                                    if cell.kind == DataTableCellKind.label: HorizontalLayout {
                                        width: 100%;
                                        min-width: 0px;
                                        alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? end : start;

                                        Label {
                                            text: cell.text;
                                            variant: cell.label-variant;
                                            size: cell.label-size;
                                        }
                                    }

                                    if cell.kind == DataTableCellKind.icon_text: HorizontalLayout {
                                        width: 100%;
                                        min-width: 0px;
                                        spacing: 6px;
                                        alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? end : start;

                                        Image {
                                            width: LayoutTokens.iconButton-icon-size-medium;
                                            height: LayoutTokens.iconButton-icon-size-medium;
                                            vertical-alignment: center;
                                            source: cell.icon;
                                            colorize: PrimerColors.fgColor-default;
                                        }

                                        if index < columns.length && columns[index].monospace: Text {
                                            horizontal-stretch: index < columns.length && columns[index].align == DataTableCellAlign.end ? 0 : 1;
                                            min-width: 0px;
                                            text: cell.text;
                                            font-size: LayoutTokens.text-body-size-small;
                                            font-family: "Bitstream Vera Sans Mono";
                                            color: PrimerColors.fgColor-default;
                                            font-weight: index < columns.length && columns[index].row-header ? LayoutTokens.base-text-weight-semibold : 400;
                                            horizontal-alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? right : left;
                                            vertical-alignment: center;
                                            wrap: word-wrap;
                                        }

                                        if index < columns.length && !(columns[index].monospace): Text {
                                            horizontal-stretch: index < columns.length && columns[index].align == DataTableCellAlign.end ? 0 : 1;
                                            min-width: 0px;
                                            text: cell.text;
                                            font-size: LayoutTokens.text-body-size-small;
                                            color: PrimerColors.fgColor-default;
                                            font-weight: index < columns.length && columns[index].row-header ? LayoutTokens.base-text-weight-semibold : 400;
                                            horizontal-alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? right : left;
                                            vertical-alignment: center;
                                            wrap: word-wrap;
                                        }
                                    }

                                    if cell.kind == DataTableCellKind.action && cell.text != "": HorizontalLayout {
                                        width: 100%;
                                        min-width: 0px;
                                        alignment: index < columns.length && columns[index].align == DataTableCellAlign.end ? end : start;

                                        IconButton {
                                            variant: IconButtonVariant.invisible;
                                            size: Size.small;
                                            icon-source: cell.icon;
                                            clicked => {
                                                root.row-action(row.id, index < columns.length ? columns[index].id : "", cell.text);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: 100%;
                    height: LayoutTokens.table-border-width;
                    background: PrimerColors.borderColor-default;
                }
            }
        }
    }

    // --- Sort header helpers (Table.module.css — sorted header fg default; icons on hover / active)
    pure function sort-column-active(cid: string) -> bool {
        return sorted-column-id == cid && sort-direction != DataTableSortDirection.none;
    }

    pure function sort-header-fg(cid: string) -> color {
        return sort-column-active(cid) ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
    }

    pure function sort-icon-desc(cid: string) -> bool {
        return sorted-column-id == cid && sort-direction == DataTableSortDirection.descending;
    }

    pure function sort-icon-visible(cid: string, header-hover: bool) -> bool {
        return sort-column-active(cid) || header-hover;
    }
}
