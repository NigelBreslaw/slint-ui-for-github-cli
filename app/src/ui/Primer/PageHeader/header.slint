import { PrimerColors } from "../tokens.slint";

export component PageHeader {
    width: 100%;
    height: 64px;

    Rectangle {
        Rectangle {
            background: PrimerColors.bgColor-inset;
        }

        Rectangle {
            y: parent.height - self.height;
            width: 100%;
            height: 1px;
            background: PrimerColors.borderColor-default;
        }
    }
    @children
}
