import { Palette } from "std-widgets.slint";
import { DoubleDropShadow } from "../Effects/double-drop-shadow.slint";
import { Size, Tokens } from "../tokens.slint";


export enum ButtonVariant {
    default,
    primary,
    danger,
    invisible,
    link,
}

// PR1–4: medium for filled variants; link is content-sized (PR5 for full Size wiring).
// Link label: StyledText + @markdown (see https://snapshots.slint.dev/master/docs/slint/reference/elements/styled-text/ ).
export component Button {
    in property <ButtonVariant> variant: ButtonVariant.default;
    in property <bool> disabled: false;
    in property <string> label: "";
    callback clicked <=> ta.clicked;

    private property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;

    // colors.btn + colors.btn.primary — legacy-theme dark.ts / light.ts innermost fallbacks
    private property <color> default-fg: is-dark ? #c9d1d9 : #24292f;
    private property <color> default-bg-rest: is-dark ? #21262d : #f6f8fa;
    private property <color> default-border: is-dark ? #3f444c : #d3d9df;
    private property <color> default-bg-hover: is-dark ? #252b33 : #eff2f5;
    private property <color> default-bg-active: is-dark ? hsv(207.273, 0.215686, 0.2, 1) : hsv(228, 0.020833, 0.941176, 1);

    private property <color> primary-fg: #ffffff;
    private property <color> primary-bg-rest: is-dark ? #238636 : #1f883d;
    private property <color> primary-border: is-dark ? rgba(240, 246, 252, 0.1) : rgba(31, 35, 40, 0.15);
    private property <color> primary-bg-hover: is-dark ? #2ea043 : #1a7f37;
    private property <color> primary-bg-active: is-dark ? #238636 : hsv(137.053, 0.798319, 0.466667, 1);
    private property <color> primary-fg-disabled: is-dark ? rgba(255, 255, 255, 0.5) : rgba(255, 255, 255, 0.8);
    private property <color> primary-bg-disabled: is-dark ? rgba(35, 134, 54, 0.6) : #94d3a2;

    private property <color> danger-bg-rest: default-bg-rest;
    private property <color> danger-border-rest: default-border;
    private property <color> danger-fg-rest: is-dark ? #f85149 : #cf222e;
    private property <color> danger-fg-hover: #ffffff;
    private property <color> danger-bg-hover: is-dark ? #da3633 : #cf222e;
    private property <color> danger-border-hover: is-dark ? #f85149 : rgba(31, 35, 40, 0.15);
    private property <color> danger-fg-active: #ffffff;
    private property <color> danger-bg-active: is-dark ? #b62324 : #a40e26;
    private property <color> danger-border-active: is-dark ? #ff7b72 : rgba(31, 35, 40, 0.15);
    private property <color> danger-fg-disabled: is-dark ? rgba(248, 81, 73, 0.5) : rgba(207, 34, 46, 0.5);
    private property <color> danger-bg-disabled: is-dark ? #0d1117 : #f6f8fa;

    private property <color> invisible-bg-rest: #00000000;
    private property <color> invisible-border-rest: #00000000;
    private property <color> invisible-bg-hover: is-dark ? rgba(177, 186, 196, 0.12) : rgba(208, 215, 222, 0.32);
    private property <color> invisible-bg-active: is-dark ? rgba(177, 186, 196, 0.2) : rgba(208, 215, 222, 0.48);
    private property <color> invisible-bg-disabled: is-dark ? rgba(177, 186, 196, 0.08) : rgba(208, 215, 222, 0.24);
    private property <color> invisible-border-disabled: invisible-bg-disabled;
    private property <color> invisible-fg-disabled: is-dark ? #484f58 : #8c959f;
    private property <color> link-fg-disabled: invisible-fg-disabled;

    private property <color> default-fg-disabled: Tokens.fgColor-muted;

    private property <bool> is-link: variant == ButtonVariant.link;

    private property <color> fill-bg:
        disabled
        ? (
            variant == ButtonVariant.link ? #00000000
            : variant == ButtonVariant.invisible ? invisible-bg-disabled
            : variant == ButtonVariant.danger ? danger-bg-disabled
            : variant == ButtonVariant.primary ? primary-bg-disabled
            : default-bg-rest
        )
        : variant == ButtonVariant.link
        ? #00000000
        : variant == ButtonVariant.primary
        ? (ta.pressed ? primary-bg-active : ta.has-hover ? primary-bg-hover : primary-bg-rest)
        : variant == ButtonVariant.danger
        ? (ta.pressed ? danger-bg-active : ta.has-hover ? danger-bg-hover : danger-bg-rest)
        : variant == ButtonVariant.invisible
        ? (ta.pressed ? invisible-bg-active : ta.has-hover ? invisible-bg-hover : invisible-bg-rest)
        : (ta.pressed ? default-bg-active : ta.has-hover ? default-bg-hover : default-bg-rest);

    private property <color> fill-border:
        disabled
        ? (
            variant == ButtonVariant.link ? #00000000
            : variant == ButtonVariant.invisible ? invisible-border-disabled
            : variant == ButtonVariant.danger ? danger-border-rest
            : variant == ButtonVariant.primary ? primary-border
            : default-border
        )
        : variant == ButtonVariant.link
        ? #00000000
        : variant == ButtonVariant.primary
        ? primary-border
        : variant == ButtonVariant.danger
        ? (ta.pressed ? danger-border-active : ta.has-hover ? danger-border-hover : danger-border-rest)
        : variant == ButtonVariant.invisible
        ? invisible-border-rest
        : default-border;

    private property <color> label-color:
        disabled
        ? (
            variant == ButtonVariant.link ? link-fg-disabled
            : variant == ButtonVariant.invisible ? invisible-fg-disabled
            : variant == ButtonVariant.danger ? danger-fg-disabled
            : variant == ButtonVariant.primary ? primary-fg-disabled
            : default-fg-disabled
        )
        : variant == ButtonVariant.link
        ? Tokens.fgColor-link
        : variant == ButtonVariant.primary
        ? primary-fg
        : variant == ButtonVariant.danger
        ? (ta.pressed ? danger-fg-active : ta.has-hover ? danger-fg-hover : danger-fg-rest)
        : default-fg;

    private property <color> shadow-none: #00000000;
    private property <bool> primary-pressed-light: variant == ButtonVariant.primary && !is-dark && ta.pressed;
    private property <bool> danger-pressed-light: variant == ButtonVariant.danger && !is-dark && ta.pressed;
    private property <bool> danger-hover-light: variant == ButtonVariant.danger && !is-dark && ta.has-hover && !ta.pressed;

    private property <color> btn-shadow-back-color:
        variant == ButtonVariant.invisible || variant == ButtonVariant.link || disabled || is-dark
        ? shadow-none
        : danger-pressed-light
        ? rgba(76, 0, 20, 0.2)
        : primary-pressed-light
        ? rgba(0, 45, 17, 0.2)
        : danger-hover-light
        ? rgba(31, 35, 40, 0.1)
        : variant == ButtonVariant.primary
        ? rgba(31, 35, 40, 0.1)
        : variant == ButtonVariant.danger
        ? rgba(31, 35, 40, 0.04)
        : rgba(31, 35, 40, 0.04);

    private property <length> btn-shadow-back-blur:
        variant == ButtonVariant.invisible || variant == ButtonVariant.link || disabled || is-dark ? 0px : danger-pressed-light || primary-pressed-light ? 3px : 0px;

    private property <length> btn-shadow-back-y:
        variant == ButtonVariant.invisible || variant == ButtonVariant.link || disabled || is-dark ? 0px : danger-pressed-light || primary-pressed-light ? 2px : 1px;

    private property <color> btn-shadow-front-color:
        variant == ButtonVariant.invisible || variant == ButtonVariant.link || disabled || is-dark
        ? shadow-none
        : danger-pressed-light
        ? rgba(76, 0, 20, 0.14)
        : primary-pressed-light
        ? rgba(0, 45, 17, 0.14)
        : shadow-none;

    private property <length> btn-shadow-front-blur:
        variant != ButtonVariant.invisible && variant != ButtonVariant.link && !disabled && !is-dark && (danger-pressed-light || primary-pressed-light) ? 1px : 0px;

    private property <length> btn-shadow-front-y:
        variant != ButtonVariant.invisible && variant != ButtonVariant.link && !disabled && !is-dark && (danger-pressed-light || primary-pressed-light) ? 1px : 0px;

    DoubleDropShadow {
        width: parent.width;
        height: parent.height;
        border-radius: 6px;
        back-layer: { offset-x: 0px, offset-y: btn-shadow-back-y, blur: btn-shadow-back-blur, color: btn-shadow-back-color };
        front-layer: { offset-x: 0px, offset-y: btn-shadow-front-y, blur: btn-shadow-front-blur, color: btn-shadow-front-color };
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: fill-bg;
        border-radius: is-link ? 0px : 6px;
        border-width: is-link ? 0px : 1px;
        border-color: fill-border;
    }

    text-label := Text {
        visible: !is-link;
        width: 100%;
        height: 100%;
        text: root.label;
        color: label-color;
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    // Link: separate StyledText per hover (each @markdown is a single literal). TouchArea on top for hover + click.
    link-text-disabled := Text {
        visible: is-link && disabled;
        width: 100%;
        height: 100%;
        text: root.label;
        color: label-color;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    link-md := StyledText {
        visible: is-link && !disabled && !ta.has-hover;
        width: 100%;
        height: 100%;
        text: @markdown("\{label}");
        horizontal-alignment: left;
        vertical-alignment: center;
        link-color: Tokens.fgColor-link;
    }

    link-md-hover := StyledText {
        visible: is-link && !disabled && ta.has-hover;
        width: 100%;
        height: 100%;
        text: @markdown("[\{label}](#)");
        horizontal-alignment: left;
        vertical-alignment: center;
        link-color: Tokens.fgColor-link;
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: !disabled;
    }

    width: is-link
        ? (disabled ? link-text-disabled.preferred-width : max(link-md.preferred-width, link-md-hover.preferred-width))
        : text-label.preferred-width + (2 * 16px);
    height: is-link
        ? (disabled ? link-text-disabled.preferred-height : max(link-md.preferred-height, link-md-hover.preferred-height))
        : 32px;
}


enum Variant {
    default,
    primary,
    danger,
    invisible
}

struct ButtonStyle {
    button-default-fgColor-rest: color,
    button-default-bgColor-active: color,
    button-default-bgColor-hover: color,
    button-default-borderColor-active: color,
}

export component IconButton {

    in property <Size> size: medium;
    in property <Variant> variant: Variant.default;
    in property icon-source <=> img.source;
    callback clicked <=> ta.clicked;

    in property <ButtonStyle> style: {
        button-default-fgColor-rest: Tokens.iconButton-fgColor-rest,
        button-default-bgColor-active: Tokens.bgColor-inset,
        button-default-bgColor-hover: Tokens.iconButton-bgColor-hover,
        button-default-borderColor-active: Tokens.color-btn-border,
    };

    width: size == Size.small ? 28px : size == Size.medium ? 32px : 40px;
    height: self.width;

    Rectangle {
        border-radius: 6px;
        border-width: 1px;
        border-color: style.button-default-borderColor-active;
        background: ta.has-hover ? style.button-default-bgColor-hover : style.button-default-bgColor-active;

    }

    img := Image {
        width: 16px;
        height: self.width;
        colorize: style.button-default-fgColor-rest;
    }

    ta := TouchArea {

    }
}
