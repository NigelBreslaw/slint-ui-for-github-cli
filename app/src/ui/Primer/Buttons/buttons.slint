import { Palette } from "std-widgets.slint";
import { DoubleDropShadow } from "../Effects/double-drop-shadow.slint";
import { Size, Tokens } from "../tokens.slint";


export enum ButtonVariant {
    default,
    primary,
    danger,
    invisible,
    link,
}

struct ButtonPaint {
    bg: color,
    border: color,
    fg: color,
}

struct ButtonShadowState {
    back-color: color,
    back-blur: length,
    back-y: length,
    front-color: color,
    front-blur: length,
    front-y: length,
}

// Medium filled variants; link is content-sized (PR5 for full Size wiring).
// Colors: Tokens (primer-tokens naming). Link label: StyledText + @markdown.
export component Button {
    in property <ButtonVariant> variant: ButtonVariant.default;
    in property <bool> disabled: false;
    in property <string> label: "";
    callback clicked <=> ta.clicked;

    private property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;
    private property <bool> is-link: variant == ButtonVariant.link;
    private property <bool> primary-pressed-light: variant == ButtonVariant.primary && !is-dark && ta.pressed;
    private property <bool> danger-pressed-light: variant == ButtonVariant.danger && !is-dark && ta.pressed;
    private property <bool> danger-hover-light: variant == ButtonVariant.danger && !is-dark && ta.has-hover && !ta.pressed;

    pure function button-paint(v: ButtonVariant, dis: bool, hover: bool, pressed: bool) -> ButtonPaint {
        if dis {
            if v == ButtonVariant.link {
                return {
                    bg: Tokens.button-link-bgColor-rest,
                    border: Tokens.button-link-borderColor-rest,
                    fg: Tokens.control-fgColor-disabled,
                };
            }
            if v == ButtonVariant.invisible {
                return {
                    bg: Tokens.button-invisible-bgColor-disabled,
                    border: Tokens.button-invisible-borderColor-disabled,
                    fg: Tokens.button-invisible-fgColor-disabled,
                };
            }
            if v == ButtonVariant.danger {
                return {
                    bg: Tokens.button-danger-bgColor-disabled,
                    border: Tokens.button-danger-borderColor-disabled,
                    fg: Tokens.button-danger-fgColor-disabled,
                };
            }
            if v == ButtonVariant.primary {
                return {
                    bg: Tokens.button-primary-bgColor-disabled,
                    border: Tokens.button-primary-borderColor-disabled,
                    fg: Tokens.button-primary-fgColor-disabled,
                };
            }
            return {
                bg: Tokens.button-default-bgColor-disabled,
                border: Tokens.button-default-borderColor-disabled,
                fg: Tokens.control-fgColor-disabled,
            };
        }
        if v == ButtonVariant.link {
            return {
                bg: Tokens.button-link-bgColor-rest,
                border: Tokens.button-link-borderColor-rest,
                fg: Tokens.fgColor-link,
            };
        }
        if v == ButtonVariant.primary {
            if pressed {
                return {
                    bg: Tokens.button-primary-bgColor-active,
                    border: Tokens.button-primary-borderColor-rest,
                    fg: Tokens.button-primary-fgColor-rest,
                };
            }
            if hover {
                return {
                    bg: Tokens.button-primary-bgColor-hover,
                    border: Tokens.button-primary-borderColor-rest,
                    fg: Tokens.button-primary-fgColor-rest,
                };
            }
            return {
                bg: Tokens.button-primary-bgColor-rest,
                border: Tokens.button-primary-borderColor-rest,
                fg: Tokens.button-primary-fgColor-rest,
            };
        }
        if v == ButtonVariant.danger {
            if pressed {
                return {
                    bg: Tokens.button-danger-bgColor-active,
                    border: Tokens.button-danger-borderColor-active,
                    fg: Tokens.button-danger-fgColor-active,
                };
            }
            if hover {
                return {
                    bg: Tokens.button-danger-bgColor-hover,
                    border: Tokens.button-danger-borderColor-hover,
                    fg: Tokens.button-danger-fgColor-hover,
                };
            }
            return {
                bg: Tokens.button-danger-bgColor-rest,
                border: Tokens.button-danger-borderColor-rest,
                fg: Tokens.button-danger-fgColor-rest,
            };
        }
        if v == ButtonVariant.invisible {
            if pressed {
                return {
                    bg: Tokens.button-invisible-bgColor-active,
                    border: Tokens.button-invisible-borderColor-rest,
                    fg: Tokens.button-invisible-fgColor-rest,
                };
            }
            if hover {
                return {
                    bg: Tokens.button-invisible-bgColor-hover,
                    border: Tokens.button-invisible-borderColor-rest,
                    fg: Tokens.button-invisible-fgColor-rest,
                };
            }
            return {
                bg: Tokens.button-invisible-bgColor-rest,
                border: Tokens.button-invisible-borderColor-rest,
                fg: Tokens.button-invisible-fgColor-rest,
            };
        }
        // default — border matches legacy filled default (same rest border for hover/active)
        if pressed {
            return {
                bg: Tokens.button-default-bgColor-active,
                border: Tokens.button-default-borderColor-rest,
                fg: Tokens.button-default-fgColor-rest,
            };
        }
        if hover {
            return {
                bg: Tokens.button-default-bgColor-hover,
                border: Tokens.button-default-borderColor-rest,
                fg: Tokens.button-default-fgColor-rest,
            };
        }
        return {
            bg: Tokens.button-default-bgColor-rest,
            border: Tokens.button-default-borderColor-rest,
            fg: Tokens.button-default-fgColor-rest,
        };
    }

    pure function button-shadow(
        v: ButtonVariant,
        dis: bool,
        dark: bool,
        d-pl: bool,
        p-pl: bool,
        d-hv: bool,
    ) -> ButtonShadowState {
        if v == ButtonVariant.invisible || v == ButtonVariant.link || dis || dark {
            return {
                back-color: #00000000,
                back-blur: 0px,
                back-y: 0px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if d-pl {
            return {
                back-color: Tokens.button-shadow-danger-back-pressed-light,
                back-blur: 3px,
                back-y: 2px,
                front-color: Tokens.button-shadow-danger-front-pressed-light,
                front-blur: 1px,
                front-y: 1px,
            };
        }
        if p-pl {
            return {
                back-color: Tokens.button-shadow-primary-back-pressed-light,
                back-blur: 3px,
                back-y: 2px,
                front-color: Tokens.button-shadow-primary-front-pressed-light,
                front-blur: 1px,
                front-y: 1px,
            };
        }
        if d-hv {
            return {
                back-color: Tokens.button-shadow-elevated-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if v == ButtonVariant.primary {
            return {
                back-color: Tokens.button-shadow-elevated-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if v == ButtonVariant.danger {
            return {
                back-color: Tokens.button-shadow-ambient-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        return {
            back-color: Tokens.button-shadow-ambient-light,
            back-blur: 0px,
            back-y: 1px,
            front-color: #00000000,
            front-blur: 0px,
            front-y: 0px,
        };
    }

    private property <ButtonPaint> paint: button-paint(variant, disabled, ta.has-hover, ta.pressed);
    private property <ButtonShadowState> btn-sh: button-shadow(variant, disabled, is-dark, danger-pressed-light, primary-pressed-light, danger-hover-light);

    DoubleDropShadow {
        width: parent.width;
        height: parent.height;
        border-radius: 6px;
        back-layer: { offset-x: 0px, offset-y: btn-sh.back-y, blur: btn-sh.back-blur, color: btn-sh.back-color };
        front-layer: { offset-x: 0px, offset-y: btn-sh.front-y, blur: btn-sh.front-blur, color: btn-sh.front-color };
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: paint.bg;
        border-radius: is-link ? 0px : 6px;
        border-width: is-link ? 0px : 1px;
        border-color: paint.border;
    }

    text-label := Text {
        visible: !is-link;
        width: 100%;
        height: 100%;
        text: root.label;
        color: paint.fg;
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    // Link: separate StyledText per hover (each @markdown is a single literal). TouchArea on top for hover + click.
    link-text-disabled := Text {
        visible: is-link && disabled;
        width: 100%;
        height: 100%;
        text: root.label;
        color: paint.fg;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    link-md := StyledText {
        visible: is-link && !disabled && !ta.has-hover;
        width: 100%;
        height: 100%;
        text: @markdown("[\{label}](#)");
        horizontal-alignment: left;
        vertical-alignment: center;
        link-color: Tokens.fgColor-link;
    }

    link-md-hover := StyledText {
        visible: is-link && !disabled && ta.has-hover;
        width: 100%;
        height: 100%;
        text: @markdown("[<u>\{label}</u>](#)");
        horizontal-alignment: left;
        vertical-alignment: center;
        link-color: Tokens.fgColor-link;
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: !disabled;
    }

    width: is-link
        ? (disabled ? link-text-disabled.preferred-width : max(link-md.preferred-width, link-md-hover.preferred-width))
        : text-label.preferred-width + (2 * 16px);
    height: is-link
        ? (disabled ? link-text-disabled.preferred-height : max(link-md.preferred-height, link-md-hover.preferred-height))
        : 32px;
}


enum Variant {
    default,
    primary,
    danger,
    invisible
}

struct ButtonStyle {
    button-default-fgColor-rest: color,
    button-default-bgColor-active: color,
    button-default-bgColor-hover: color,
    button-default-borderColor-active: color,
}

export component IconButton {

    in property <Size> size: medium;
    in property <Variant> variant: Variant.default;
    in property icon-source <=> img.source;
    callback clicked <=> ta.clicked;

    in property <ButtonStyle> style: {
        button-default-fgColor-rest: Tokens.iconButton-fgColor-rest,
        button-default-bgColor-active: Tokens.bgColor-inset,
        button-default-bgColor-hover: Tokens.iconButton-bgColor-hover,
        button-default-borderColor-active: Tokens.color-btn-border,
    };

    width: size == Size.small ? 28px : size == Size.medium ? 32px : 40px;
    height: self.width;

    Rectangle {
        border-radius: 6px;
        border-width: 1px;
        border-color: style.button-default-borderColor-active;
        background: ta.has-hover ? style.button-default-bgColor-hover : style.button-default-bgColor-active;

    }

    img := Image {
        width: 16px;
        height: self.width;
        colorize: style.button-default-fgColor-rest;
    }

    ta := TouchArea {

    }
}
