import { Palette } from "std-widgets.slint";
import { DoubleDropShadow } from "../Effects/double-drop-shadow.slint";
import { ButtonTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";


export enum ButtonVariant {
    default,
    primary,
    danger,
    invisible,
    link,
}

struct ButtonPaint {
    bg: color,
    border: color,
    fg: color,
}

struct ButtonShadowState {
    back-color: color,
    back-blur: length,
    back-y: length,
    front-color: color,
    front-blur: length,
    front-y: length,
}

// Filled height/padding follow `size`; link is content-sized (StyledText has no font-size in Slint).
// Colors: ButtonTokens (button palette) + PrimerColors (semantic fg/link/inset). Link label: StyledText + @markdown.
export component Button {
    in property <ButtonVariant> variant: ButtonVariant.default;
    in property <Size> size: Size.medium;
    in property <bool> disabled: false;
    in property <string> label: "";
    callback clicked <=> ta.clicked;

    // Primer ButtonBase: only [data-size='small'] changes font-size; large keeps text-body-size-medium (L9 + L165–179).
    private property <length> filled-label-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    private property <length> btn-padding-inline:
        size == Size.small
        ? LayoutTokens.control-small-paddingInline-condensed
        : size == Size.large ? LayoutTokens.control-large-paddingInline-spacious : LayoutTokens.control-medium-paddingInline-normal;

    private property <length> btn-control-height:
        size == Size.small
        ? LayoutTokens.control-small-size
        : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    private property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;
    private property <bool> is-link: variant == ButtonVariant.link;
    private property <bool> primary-pressed-light: variant == ButtonVariant.primary && !is-dark && ta.pressed;
    private property <bool> danger-pressed-light: variant == ButtonVariant.danger && !is-dark && ta.pressed;
    private property <bool> danger-hover-light: variant == ButtonVariant.danger && !is-dark && ta.has-hover && !ta.pressed;

    pure function button-paint(v: ButtonVariant, dis: bool, hover: bool, pressed: bool) -> ButtonPaint {
        if dis {
            if v == ButtonVariant.link {
                return {
                    bg: ButtonTokens.button-link-bgColor-rest,
                    border: ButtonTokens.button-link-borderColor-rest,
                    fg: ButtonTokens.control-fgColor-disabled,
                };
            }
            if v == ButtonVariant.invisible {
                return {
                    bg: ButtonTokens.button-invisible-bgColor-disabled,
                    border: ButtonTokens.button-invisible-borderColor-disabled,
                    fg: ButtonTokens.button-invisible-fgColor-disabled,
                };
            }
            if v == ButtonVariant.danger {
                return {
                    bg: ButtonTokens.button-danger-bgColor-disabled,
                    border: ButtonTokens.button-danger-borderColor-disabled,
                    fg: ButtonTokens.button-danger-fgColor-disabled,
                };
            }
            if v == ButtonVariant.primary {
                return {
                    bg: ButtonTokens.button-primary-bgColor-disabled,
                    border: ButtonTokens.button-primary-borderColor-disabled,
                    fg: ButtonTokens.button-primary-fgColor-disabled,
                };
            }
            return {
                bg: ButtonTokens.button-default-bgColor-disabled,
                border: ButtonTokens.button-default-borderColor-disabled,
                fg: ButtonTokens.control-fgColor-disabled,
            };
        }
        if v == ButtonVariant.link {
            return {
                bg: ButtonTokens.button-link-bgColor-rest,
                border: ButtonTokens.button-link-borderColor-rest,
                fg: PrimerColors.fgColor-link,
            };
        }
        if v == ButtonVariant.primary {
            if pressed {
                return {
                    bg: ButtonTokens.button-primary-bgColor-active,
                    border: ButtonTokens.button-primary-borderColor-rest,
                    fg: ButtonTokens.button-primary-fgColor-rest,
                };
            }
            if hover {
                return {
                    bg: ButtonTokens.button-primary-bgColor-hover,
                    border: ButtonTokens.button-primary-borderColor-rest,
                    fg: ButtonTokens.button-primary-fgColor-rest,
                };
            }
            return {
                bg: ButtonTokens.button-primary-bgColor-rest,
                border: ButtonTokens.button-primary-borderColor-rest,
                fg: ButtonTokens.button-primary-fgColor-rest,
            };
        }
        if v == ButtonVariant.danger {
            if pressed {
                return {
                    bg: ButtonTokens.button-danger-bgColor-active,
                    border: ButtonTokens.button-danger-borderColor-active,
                    fg: ButtonTokens.button-danger-fgColor-active,
                };
            }
            if hover {
                return {
                    bg: ButtonTokens.button-danger-bgColor-hover,
                    border: ButtonTokens.button-danger-borderColor-hover,
                    fg: ButtonTokens.button-danger-fgColor-hover,
                };
            }
            return {
                bg: ButtonTokens.button-danger-bgColor-rest,
                border: ButtonTokens.button-danger-borderColor-rest,
                fg: ButtonTokens.button-danger-fgColor-rest,
            };
        }
        if v == ButtonVariant.invisible {
            if pressed {
                return {
                    bg: ButtonTokens.button-invisible-bgColor-active,
                    border: ButtonTokens.button-invisible-borderColor-rest,
                    fg: ButtonTokens.button-invisible-fgColor-rest,
                };
            }
            if hover {
                return {
                    bg: ButtonTokens.button-invisible-bgColor-hover,
                    border: ButtonTokens.button-invisible-borderColor-rest,
                    fg: ButtonTokens.button-invisible-fgColor-rest,
                };
            }
            return {
                bg: ButtonTokens.button-invisible-bgColor-rest,
                border: ButtonTokens.button-invisible-borderColor-rest,
                fg: ButtonTokens.button-invisible-fgColor-rest,
            };
        }
        // default — border matches legacy filled default (same rest border for hover/active)
        if pressed {
            return {
                bg: ButtonTokens.button-default-bgColor-active,
                border: ButtonTokens.button-default-borderColor-rest,
                fg: ButtonTokens.button-default-fgColor-rest,
            };
        }
        if hover {
            return {
                bg: ButtonTokens.button-default-bgColor-hover,
                border: ButtonTokens.button-default-borderColor-rest,
                fg: ButtonTokens.button-default-fgColor-rest,
            };
        }
        return {
            bg: ButtonTokens.button-default-bgColor-rest,
            border: ButtonTokens.button-default-borderColor-rest,
            fg: ButtonTokens.button-default-fgColor-rest,
        };
    }

    pure function button-shadow(
        v: ButtonVariant,
        dis: bool,
        dark: bool,
        d-pl: bool,
        p-pl: bool,
        d-hv: bool,
    ) -> ButtonShadowState {
        if v == ButtonVariant.invisible || v == ButtonVariant.link || dis || dark {
            return {
                back-color: #00000000,
                back-blur: 0px,
                back-y: 0px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if d-pl {
            return {
                back-color: ButtonTokens.button-shadow-danger-back-pressed-light,
                back-blur: 3px,
                back-y: 2px,
                front-color: ButtonTokens.button-shadow-danger-front-pressed-light,
                front-blur: 1px,
                front-y: 1px,
            };
        }
        if p-pl {
            return {
                back-color: ButtonTokens.button-shadow-primary-back-pressed-light,
                back-blur: 3px,
                back-y: 2px,
                front-color: ButtonTokens.button-shadow-primary-front-pressed-light,
                front-blur: 1px,
                front-y: 1px,
            };
        }
        if d-hv {
            return {
                back-color: ButtonTokens.button-shadow-elevated-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if v == ButtonVariant.primary {
            return {
                back-color: ButtonTokens.button-shadow-elevated-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if v == ButtonVariant.danger {
            return {
                back-color: ButtonTokens.button-shadow-ambient-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        return {
            back-color: ButtonTokens.button-shadow-ambient-light,
            back-blur: 0px,
            back-y: 1px,
            front-color: #00000000,
            front-blur: 0px,
            front-y: 0px,
        };
    }

    private property <ButtonPaint> paint: button-paint(variant, disabled, ta.has-hover, ta.pressed);
    private property <ButtonShadowState> btn-sh: button-shadow(variant, disabled, is-dark, danger-pressed-light, primary-pressed-light, danger-hover-light);

    DoubleDropShadow {
        width: parent.width;
        height: parent.height;
        border-radius: is-link ? 0px : LayoutTokens.borderRadius-medium;
        back-layer: { offset-x: 0px, offset-y: btn-sh.back-y, blur: btn-sh.back-blur, color: btn-sh.back-color };
        front-layer: { offset-x: 0px, offset-y: btn-sh.front-y, blur: btn-sh.front-blur, color: btn-sh.front-color };
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: paint.bg;
        border-radius: is-link ? 0px : LayoutTokens.borderRadius-medium;
        border-width: is-link ? 0px : 1px;
        border-color: paint.border;
    }

    text-label := Text {
        visible: !is-link;
        width: 100%;
        height: 100%;
        text: root.label;
        color: paint.fg;
        font-size: filled-label-font-size;
        font-weight: LayoutTokens.base-text-weight-medium;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    // Link: separate StyledText per hover (each @markdown is a single literal). TouchArea on top for hover + click.
    link-text-disabled := Text {
        visible: is-link && disabled;
        width: 100%;
        height: 100%;
        text: root.label;
        color: paint.fg;
        // Primer link uses font-size: inherit; Slint has no inherit — use body medium as default context.
        font-size: LayoutTokens.text-body-size-medium;
        font-weight: LayoutTokens.base-text-weight-medium;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    link-md := StyledText {
        visible: is-link && !disabled && !ta.has-hover;
        width: 100%;
        height: 100%;
        text: @markdown("[\{label}](#)");
        horizontal-alignment: left;
        vertical-alignment: center;
        link-color: PrimerColors.fgColor-link;
    }

    link-md-hover := StyledText {
        visible: is-link && !disabled && ta.has-hover;
        width: 100%;
        height: 100%;
        text: @markdown("[<u>\{label}</u>](#)");
        horizontal-alignment: left;
        vertical-alignment: center;
        link-color: PrimerColors.fgColor-link;
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: !disabled;
    }

    width: is-link
        ? (disabled ? link-text-disabled.preferred-width : max(link-md.preferred-width, link-md-hover.preferred-width))
        : text-label.preferred-width + (2 * btn-padding-inline);
    height: is-link
        ? (disabled ? link-text-disabled.preferred-height : max(link-md.preferred-height, link-md-hover.preferred-height))
        : btn-control-height;
}


enum Variant {
    default,
    primary,
    danger,
    invisible
}

struct ButtonStyle {
    button-default-fgColor-rest: color,
    button-default-bgColor-active: color,
    button-default-bgColor-hover: color,
    button-default-borderColor-active: color,
}

export component IconButton {

    in property <Size> size: Size.medium;
    in property <Variant> variant: Variant.default;
    in property icon-source <=> img.source;
    callback clicked <=> ta.clicked;

    in property <ButtonStyle> style: {
        button-default-fgColor-rest: ButtonTokens.iconButton-fgColor-rest,
        button-default-bgColor-active: PrimerColors.bgColor-inset,
        button-default-bgColor-hover: ButtonTokens.iconButton-bgColor-hover,
        button-default-borderColor-active: ButtonTokens.color-btn-border,
    };

    private property <length> icon-img-size:
        size == Size.small
        ? LayoutTokens.iconButton-icon-size-small
        : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;

    width: size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;
    height: self.width;

    Rectangle {
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: 1px;
        border-color: style.button-default-borderColor-active;
        background: ta.has-hover ? style.button-default-bgColor-hover : style.button-default-bgColor-active;

    }

    img := Image {
        width: icon-img-size;
        height: icon-img-size;
        colorize: style.button-default-fgColor-rest;
    }

    ta := TouchArea {

    }
}
