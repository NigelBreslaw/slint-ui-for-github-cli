import { Palette } from "std-widgets.slint";
import { MultiDropShadow } from "../Effects/multi-drop-shadow.slint";
import { Spinner } from "../Progress/spinner.slint";
import { ButtonTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";

export enum ButtonAlignContent {
    center,
    start,
}

export enum ButtonVariant {
    default,
    primary,
    danger,
    invisible,
    link,
}

struct ButtonPaint {
    bg: color,
    border: color,
    fg: color,
}

struct ButtonShadowState {
    back-color: color,
    back-blur: length,
    back-y: length,
    front-color: color,
    front-blur: length,
    front-y: length,
}

struct ButtonCounterPaint {
    bg: color,
    fg: color,
}

// Filled height/padding follow `size`; link is content-sized (StyledText has no font-size in Slint).
// Colors: ButtonTokens (button palette) + PrimerColors (semantic fg/link/inset). Link label: StyledText + @markdown.
export component Button {
    in property <ButtonVariant> variant: ButtonVariant.default;
    in property <Size> size: Size.medium;
    in property <bool> disabled: false;
    in property <string> label: "";
    in property <bool> loading: false;
    in property <ButtonAlignContent> align-content: ButtonAlignContent.center;
    in property <string> count: "";
    in property <bool> has-leading-icon: false;
    in property <image> leading-icon;
    in property <string> leading-text: "";
    in property <bool> has-trailing-icon: false;
    in property <image> trailing-icon;
    in property <string> trailing-text: "";
    callback clicked <=> ta.clicked;

    // Primer ButtonBase: only [data-size='small'] changes font-size; large keeps text-body-size-medium (L9 + L165–179).
    private property <length> filled-label-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;

    private property <length> btn-padding-inline:
        size == Size.small
        ? LayoutTokens.control-small-paddingInline-condensed
        : size == Size.large ? LayoutTokens.control-large-paddingInline-spacious : LayoutTokens.control-medium-paddingInline-normal;

    private property <length> btn-control-height:
        size == Size.small
        ? LayoutTokens.control-small-size
        : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;

    private property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;
    private property <bool> is-link: variant == ButtonVariant.link;
    private property <bool> primary-pressed: variant == ButtonVariant.primary && ta.pressed;
    private property <bool> danger-pressed: variant == ButtonVariant.danger && ta.pressed;
    private property <bool> danger-hover: variant == ButtonVariant.danger && ta.has-hover && !ta.pressed;
    private property <bool> has-leading-slot: leading-text != "" || has-leading-icon;
    private property <bool> show-trailing-visual: trailing-text != "" || has-trailing-icon;
    private property <bool> show-count: count != "" && !show-trailing-visual;
    private property <bool> loading-replaces-leading: loading && has-leading-slot;
    private property <bool> loading-replaces-trailing: loading && !has-leading-slot && (show-trailing-visual || show-count);
    private property <bool> loading-only-spinner: loading && !has-leading-slot && !show-trailing-visual && !show-count;
    private property <bool> danger-counter-hover: variant == ButtonVariant.danger && !disabled && (ta.has-hover || ta.pressed);
    private property <length> btn-icon-size:
        size == Size.small
        ? LayoutTokens.iconButton-icon-size-small
        : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;
    private property <Size> btn-spinner-size: size == Size.large ? Size.medium : Size.small;
    private property <color> btn-spinner-track: is-dark ? #ffffff30 : #1f232830;

    pure function button-counter-paint(
        v: ButtonVariant,
        dis: bool,
        d-hv: bool,
        fg-disabled: color,
    ) -> ButtonCounterPaint {
        if dis {
            if v == ButtonVariant.danger {
                return {
                    bg: ButtonTokens.buttonCounter-danger-bgColor-disabled,
                    fg: ButtonTokens.buttonCounter-danger-fgColor-disabled,
                };
            }
            if v == ButtonVariant.primary {
                return {
                    bg: ButtonTokens.buttonCounter-primary-bgColor-rest,
                    fg: fg-disabled,
                };
            }
            if v == ButtonVariant.invisible {
                return {
                    bg: ButtonTokens.buttonCounter-invisible-bgColor-rest,
                    fg: fg-disabled,
                };
            }
            return {
                bg: ButtonTokens.buttonCounter-default-bgColor-rest,
                fg: fg-disabled,
            };
        }
        if v == ButtonVariant.danger {
            if d-hv {
                return {
                    bg: ButtonTokens.buttonCounter-danger-bgColor-hover,
                    fg: ButtonTokens.buttonCounter-danger-fgColor-hover,
                };
            }
            return {
                bg: ButtonTokens.buttonCounter-danger-bgColor-rest,
                fg: ButtonTokens.buttonCounter-danger-fgColor-rest,
            };
        }
        if v == ButtonVariant.primary {
            return {
                bg: ButtonTokens.buttonCounter-primary-bgColor-rest,
                fg: ButtonTokens.buttonCounter-primary-fgColor-rest,
            };
        }
        if v == ButtonVariant.invisible {
            return {
                bg: ButtonTokens.buttonCounter-invisible-bgColor-rest,
                fg: ButtonTokens.buttonCounter-invisible-fgColor-rest,
            };
        }
        if v == ButtonVariant.link {
            if dis {
                return {
                    bg: ButtonTokens.buttonCounter-default-bgColor-rest,
                    fg: fg-disabled,
                };
            }
            return {
                bg: ButtonTokens.buttonCounter-default-bgColor-rest,
                fg: PrimerColors.fgColor-default,
            };
        }
        return {
            bg: ButtonTokens.buttonCounter-default-bgColor-rest,
            fg: ButtonTokens.buttonCounter-default-fgColor-rest,
        };
    }

    pure function button-paint(v: ButtonVariant, dis: bool, hover: bool, pressed: bool) -> ButtonPaint {
        if dis {
            if v == ButtonVariant.link {
                return {
                    bg: ButtonTokens.button-link-bgColor-rest,
                    border: ButtonTokens.button-link-borderColor-rest,
                    fg: ButtonTokens.control-fgColor-disabled,
                };
            }
            if v == ButtonVariant.invisible {
                return {
                    bg: ButtonTokens.button-invisible-bgColor-disabled,
                    border: ButtonTokens.button-invisible-borderColor-disabled,
                    fg: ButtonTokens.button-invisible-fgColor-disabled,
                };
            }
            if v == ButtonVariant.danger {
                return {
                    bg: ButtonTokens.button-danger-bgColor-disabled,
                    border: ButtonTokens.button-danger-borderColor-disabled,
                    fg: ButtonTokens.button-danger-fgColor-disabled,
                };
            }
            if v == ButtonVariant.primary {
                return {
                    bg: ButtonTokens.button-primary-bgColor-disabled,
                    border: ButtonTokens.button-primary-borderColor-disabled,
                    fg: ButtonTokens.button-primary-fgColor-disabled,
                };
            }
            return {
                bg: ButtonTokens.button-default-bgColor-disabled,
                border: ButtonTokens.button-default-borderColor-disabled,
                fg: ButtonTokens.control-fgColor-disabled,
            };
        }
        if v == ButtonVariant.link {
            return {
                bg: ButtonTokens.button-link-bgColor-rest,
                border: ButtonTokens.button-link-borderColor-rest,
                fg: PrimerColors.fgColor-link,
            };
        }
        if v == ButtonVariant.primary {
            if pressed {
                return {
                    bg: ButtonTokens.button-primary-bgColor-active,
                    border: ButtonTokens.button-primary-borderColor-rest,
                    fg: ButtonTokens.button-primary-fgColor-rest,
                };
            }
            if hover {
                return {
                    bg: ButtonTokens.button-primary-bgColor-hover,
                    border: ButtonTokens.button-primary-borderColor-rest,
                    fg: ButtonTokens.button-primary-fgColor-rest,
                };
            }
            return {
                bg: ButtonTokens.button-primary-bgColor-rest,
                border: ButtonTokens.button-primary-borderColor-rest,
                fg: ButtonTokens.button-primary-fgColor-rest,
            };
        }
        if v == ButtonVariant.danger {
            if pressed {
                return {
                    bg: ButtonTokens.button-danger-bgColor-active,
                    border: ButtonTokens.button-danger-borderColor-active,
                    fg: ButtonTokens.button-danger-fgColor-active,
                };
            }
            if hover {
                return {
                    bg: ButtonTokens.button-danger-bgColor-hover,
                    border: ButtonTokens.button-danger-borderColor-hover,
                    fg: ButtonTokens.button-danger-fgColor-hover,
                };
            }
            return {
                bg: ButtonTokens.button-danger-bgColor-rest,
                border: ButtonTokens.button-danger-borderColor-rest,
                fg: ButtonTokens.button-danger-fgColor-rest,
            };
        }
        if v == ButtonVariant.invisible {
            if pressed {
                return {
                    bg: ButtonTokens.button-invisible-bgColor-active,
                    border: ButtonTokens.button-invisible-borderColor-rest,
                    fg: ButtonTokens.button-invisible-fgColor-rest,
                };
            }
            if hover {
                return {
                    bg: ButtonTokens.button-invisible-bgColor-hover,
                    border: ButtonTokens.button-invisible-borderColor-rest,
                    fg: ButtonTokens.button-invisible-fgColor-rest,
                };
            }
            return {
                bg: ButtonTokens.button-invisible-bgColor-rest,
                border: ButtonTokens.button-invisible-borderColor-rest,
                fg: ButtonTokens.button-invisible-fgColor-rest,
            };
        }
        // default — border matches legacy filled default (same rest border for hover/active)
        if pressed {
            return {
                bg: ButtonTokens.button-default-bgColor-active,
                border: ButtonTokens.button-default-borderColor-rest,
                fg: ButtonTokens.button-default-fgColor-rest,
            };
        }
        if hover {
            return {
                bg: ButtonTokens.button-default-bgColor-hover,
                border: ButtonTokens.button-default-borderColor-rest,
                fg: ButtonTokens.button-default-fgColor-rest,
            };
        }
        return {
            bg: ButtonTokens.button-default-bgColor-rest,
            border: ButtonTokens.button-default-borderColor-rest,
            fg: ButtonTokens.button-default-fgColor-rest,
        };
    }

    pure function button-shadow(
        v: ButtonVariant,
        dis: bool,
        dark: bool,
        d-pl: bool,
        p-pl: bool,
        d-hv: bool,
    ) -> ButtonShadowState {
        if v == ButtonVariant.invisible || v == ButtonVariant.link || dis {
            return {
                back-color: #00000000,
                back-blur: 0px,
                back-y: 0px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if dark {
            if d-pl {
                return {
                    back-color: ButtonTokens.button-shadow-danger-back-pressed-dark,
                    back-blur: 3px,
                    back-y: 2px,
                    front-color: ButtonTokens.button-shadow-danger-front-pressed-dark,
                    front-blur: 1px,
                    front-y: 1px,
                };
            }
            if p-pl {
                return {
                    back-color: ButtonTokens.button-shadow-primary-back-pressed-dark,
                    back-blur: 3px,
                    back-y: 2px,
                    front-color: ButtonTokens.button-shadow-primary-front-pressed-dark,
                    front-blur: 1px,
                    front-y: 1px,
                };
            }
            if d-hv {
                return {
                    back-color: ButtonTokens.button-shadow-elevated-dark,
                    back-blur: 0px,
                    back-y: 1px,
                    front-color: #00000000,
                    front-blur: 0px,
                    front-y: 0px,
                };
            }
            if v == ButtonVariant.primary {
                return {
                    back-color: ButtonTokens.button-shadow-elevated-dark,
                    back-blur: 2px,
                    back-y: 2px,
                    front-color: #00000000,
                    front-blur: 0px,
                    front-y: 0px,
                };
            }
            if v == ButtonVariant.danger {
                return {
                    back-color: ButtonTokens.button-shadow-ambient-dark,
                    back-blur: 0px,
                    back-y: 1px,
                    front-color: #00000000,
                    front-blur: 0px,
                    front-y: 0px,
                };
            }
            return {
                back-color: ButtonTokens.button-shadow-ambient-dark,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if d-pl {
            return {
                back-color: ButtonTokens.button-shadow-danger-back-pressed-light,
                back-blur: 3px,
                back-y: 2px,
                front-color: ButtonTokens.button-shadow-danger-front-pressed-light,
                front-blur: 1px,
                front-y: 1px,
            };
        }
        if p-pl {
            return {
                back-color: ButtonTokens.button-shadow-primary-back-pressed-light,
                back-blur: 3px,
                back-y: 2px,
                front-color: ButtonTokens.button-shadow-primary-front-pressed-light,
                front-blur: 1px,
                front-y: 1px,
            };
        }
        if d-hv {
            return {
                back-color: ButtonTokens.button-shadow-elevated-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if v == ButtonVariant.primary {
            return {
                back-color: ButtonTokens.button-shadow-elevated-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        if v == ButtonVariant.danger {
            return {
                back-color: ButtonTokens.button-shadow-ambient-light,
                back-blur: 0px,
                back-y: 1px,
                front-color: #00000000,
                front-blur: 0px,
                front-y: 0px,
            };
        }
        return {
            back-color: ButtonTokens.button-shadow-ambient-light,
            back-blur: 0px,
            back-y: 1px,
            front-color: #00000000,
            front-blur: 0px,
            front-y: 0px,
        };
    }

    private property <ButtonPaint> paint: button-paint(variant, disabled, ta.has-hover, ta.pressed);
    private property <ButtonCounterPaint> btn-counter-paint: button-counter-paint(variant, disabled, danger-counter-hover, paint.fg);
    private property <ButtonShadowState> btn-sh: button-shadow(variant, disabled, is-dark, danger-pressed, primary-pressed, danger-hover);

    MultiDropShadow {
        width: parent.width;
        height: parent.height;
        border-radius: is-link ? 0px : LayoutTokens.borderRadius-medium;
        shadows: [
            { color: btn-sh.back-color, offset-x: 0px, offset-y: btn-sh.back-y, blur: btn-sh.back-blur },
            { color: btn-sh.front-color, offset-x: 0px, offset-y: btn-sh.front-y, blur: btn-sh.front-blur },
        ];
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: paint.bg;
        border-radius: is-link ? 0px : LayoutTokens.borderRadius-medium;
        border-width: is-link ? 0px : 1px;
        border-color: paint.border;
    }

    // HorizontalLayout.alignment is main-axis (horizontal) only; cross-axis defaults to top. Center the row vertically.
    filled-outer := VerticalLayout {
        visible: !is-link;
        height: 100%;
        alignment: center;

        filled-row := HorizontalLayout {
            padding-left: btn-padding-inline;
            padding-right: btn-padding-inline;
            spacing: LayoutTokens.button-content-gap;
            alignment: align-content == ButtonAlignContent.center ? LayoutAlignment.center : LayoutAlignment.start;

            if loading-only-spinner: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if loading-replaces-leading: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-leading && leading-text != "": Text {
                text: leading-text;
                color: paint.fg;
                font-size: filled-label-font-size;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }

            if !loading-replaces-leading && leading-text == "" && has-leading-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: leading-icon;
                colorize: paint.fg;
            }

            if !loading-only-spinner: Text {
                text: root.label;
                color: paint.fg;
                font-size: filled-label-font-size;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                min-width: 0px;
                overflow: elide;
            }

            if loading-replaces-trailing: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-trailing && show-count: Rectangle {
                border-radius: 20px;
                border-width: 1px;
                border-color: ButtonTokens.buttonCounter-borderColor;
                background: btn-counter-paint.bg;
                horizontal-stretch: 0;

                HorizontalLayout {
                    padding-top: 2px;
                    padding-bottom: 2px;
                    padding-left: 6px;
                    padding-right: 6px;
                    alignment: center;

                    Text {
                        text: count;
                        color: btn-counter-paint.fg;
                        font-size: LayoutTokens.text-body-size-small;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                        vertical-alignment: center;
                    }
                }
            }

            if !loading-replaces-trailing && !show-count && trailing-text != "": Text {
                text: trailing-text;
                color: paint.fg;
                font-size: filled-label-font-size;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }

            if !loading-replaces-trailing && !show-count && trailing-text == "" && has-trailing-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: trailing-icon;
                colorize: paint.fg;
            }
        }
    }

    // Link: same slot model as filled (leading / trailing / count / loading); label uses StyledText + @markdown per hover.
    link-outer := VerticalLayout {
        visible: is-link;
        height: 100%;
        alignment: center;

        link-row := HorizontalLayout {
            spacing: LayoutTokens.button-content-gap;
            alignment: align-content == ButtonAlignContent.center ? LayoutAlignment.center : LayoutAlignment.start;

            if loading-only-spinner: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if loading-replaces-leading: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-leading && leading-text != "": Text {
                text: leading-text;
                color: paint.fg;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }

            if !loading-replaces-leading && leading-text == "" && has-leading-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: leading-icon;
                colorize: paint.fg;
            }

            if is-link && disabled && !loading-only-spinner: Text {
                text: root.label;
                color: paint.fg;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                min-width: 0px;
                overflow: elide;
            }

            link-md := StyledText {
                visible: is-link && !disabled && !loading-only-spinner && !ta.has-hover;
                text: @markdown("[\{label}](#)");
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                min-width: 0px;
                link-color: PrimerColors.fgColor-link;
            }

            link-md-hover := StyledText {
                visible: is-link && !disabled && !loading-only-spinner && ta.has-hover;
                text: @markdown("[<u>\{label}</u>](#)");
                vertical-alignment: center;
                horizontal-alignment: align-content == ButtonAlignContent.center ? center : left;
                horizontal-stretch: align-content == ButtonAlignContent.start && (has-leading-slot || show-trailing-visual || show-count || loading-replaces-leading || loading-replaces-trailing) ? 1 : 0;
                min-width: 0px;
                link-color: PrimerColors.fgColor-link;
            }

            if loading-replaces-trailing: Spinner {
                size: btn-spinner-size;
                segment-color: paint.fg;
                track-color: btn-spinner-track;
            }

            if !loading-replaces-trailing && show-count: Rectangle {
                border-radius: 20px;
                border-width: 1px;
                border-color: ButtonTokens.buttonCounter-borderColor;
                background: btn-counter-paint.bg;
                horizontal-stretch: 0;

                HorizontalLayout {
                    padding-top: 2px;
                    padding-bottom: 2px;
                    padding-left: 6px;
                    padding-right: 6px;
                    alignment: center;

                    Text {
                        text: count;
                        color: btn-counter-paint.fg;
                        font-size: LayoutTokens.text-body-size-small;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                        vertical-alignment: center;
                    }
                }
            }

            if !loading-replaces-trailing && !show-count && trailing-text != "": Text {
                text: trailing-text;
                color: paint.fg;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                vertical-alignment: center;
            }

            if !loading-replaces-trailing && !show-count && trailing-text == "" && has-trailing-icon: Image {
                width: btn-icon-size;
                height: btn-icon-size;
                source: trailing-icon;
                colorize: paint.fg;
            }
        }
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: !disabled && !loading;
    }

    width: is-link ? link-row.preferred-width : filled-row.preferred-width;
    height: is-link ? link-outer.preferred-height : btn-control-height;
}


enum Variant {
    default,
    primary,
    danger,
    invisible
}

struct ButtonStyle {
    button-default-fgColor-rest: color,
    button-default-bgColor-active: color,
    button-default-bgColor-hover: color,
    button-default-borderColor-active: color,
}

export component IconButton {

    in property <Size> size: Size.medium;
    in property <Variant> variant: Variant.default;
    in property icon-source <=> img.source;
    callback clicked <=> ta.clicked;

    in property <ButtonStyle> style: {
        button-default-fgColor-rest: ButtonTokens.iconButton-fgColor-rest,
        button-default-bgColor-active: PrimerColors.bgColor-inset,
        button-default-bgColor-hover: ButtonTokens.iconButton-bgColor-hover,
        button-default-borderColor-active: ButtonTokens.color-btn-border,
    };

    private property <length> icon-img-size:
        size == Size.small
        ? LayoutTokens.iconButton-icon-size-small
        : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;

    width: size == Size.small ? LayoutTokens.control-small-size : size == Size.large ? LayoutTokens.control-large-size : LayoutTokens.control-medium-size;
    height: self.width;

    Rectangle {
        border-radius: LayoutTokens.borderRadius-medium;
        border-width: 1px;
        border-color: style.button-default-borderColor-active;
        background: ta.has-hover ? style.button-default-bgColor-hover : style.button-default-bgColor-active;

    }

    img := Image {
        width: icon-img-size;
        height: icon-img-size;
        colorize: style.button-default-fgColor-rest;
    }

    ta := TouchArea {

    }
}
