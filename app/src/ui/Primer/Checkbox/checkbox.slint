// Primer-style checkbox — upstream: https://primer.style/product/components/checkbox/

import { Icons } from "../assets/icons.slint";
import { CheckboxTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";

export component Checkbox {
    in-out property <bool> checked: false;
    in-out property <bool> indeterminate: false;
    in property <bool> disabled: false;
    in property <Size> size: Size.medium;
    in property <string> label: "";
    in property <bool> has-leading-icon: false;
    in property <image> leading-icon;
    callback toggled;

    private property <length> focus-ring: 2px;
    private property <length> box-size:
        size == Size.small ? LayoutTokens.iconButton-icon-size-small : size == Size.large ? LayoutTokens.iconButton-icon-size-large : LayoutTokens.iconButton-icon-size-medium;
    private property <length> label-font-size:
        size == Size.small ? LayoutTokens.text-body-size-small : LayoutTokens.text-body-size-medium;
    private property <length> leading-icon-size: box-size;

    touch := TouchArea {
        enabled: !root.disabled;
        clicked => {
            root.checked = root.indeterminate ? true : !root.checked;
            root.indeterminate = false;
            root.toggled();
        }

        Rectangle {
            opacity: root.disabled ? 0.5 : 1.0;
            background: #00000000;

            HorizontalLayout {
                spacing: LayoutTokens.button-content-gap;
                alignment: center;

                focus-scope := FocusScope {
                    width: box-size + 2 * focus-ring;
                    height: box-size + 2 * focus-ring;

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        border-width: focus-scope.has-focus ? focus-ring : 0px;
                        border-color: CheckboxTokens.checkbox-borderColor-focus;
                        border-radius: LayoutTokens.checkbox-border-radius + focus-ring;
                        background: #00000000;

                        Rectangle {
                            width: box-size;
                            height: box-size;
                            x: (parent.width - box-size) / 2;
                            y: (parent.height - box-size) / 2;
                            border-radius: LayoutTokens.checkbox-border-radius;
                            border-width: 1px;
                            border-color: root.disabled ? CheckboxTokens.checkbox-borderColor-rest : root.indeterminate ? CheckboxTokens.checkbox-borderColor-rest : root.checked ? CheckboxTokens.checkbox-borderColor-checked : CheckboxTokens.checkbox-borderColor-rest;
                            background: root.disabled ? CheckboxTokens.checkbox-bgColor-rest : touch.pressed ? CheckboxTokens.checkbox-bgColor-active : touch.has-hover ? CheckboxTokens.checkbox-bgColor-hover : CheckboxTokens.checkbox-bgColor-rest;

                            if root.indeterminate: Rectangle {
                                width: box-size * 0.45;
                                height: 2px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                background: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : PrimerColors.fgColor-default;
                                border-radius: 1px;
                            }

                            if !root.indeterminate && root.checked: Image {
                                width: parent.width;
                                height: parent.height;
                                source: Icons.checkbox_fill;
                                colorize: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : CheckboxTokens.checkbox-iconColor-checked;
                            }

                            if !root.indeterminate && !root.checked: Image {
                                width: parent.width;
                                height: parent.height;
                                source: Icons.checkbox;
                                colorize: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : CheckboxTokens.checkbox-iconColor-unchecked;
                            }
                        }
                    }
                }

                if has-leading-icon: Image {
                    width: leading-icon-size;
                    height: leading-icon-size;
                    source: leading-icon;
                    colorize: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : PrimerColors.fgColor-default;
                }

                if label != "": Text {
                    text: label;
                    color: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : PrimerColors.fgColor-default;
                    font-size: label-font-size;
                    font-weight: LayoutTokens.base-text-weight-medium;
                    wrap: word-wrap;
                    vertical-alignment: center;
                }
            }
        }
    }
}
