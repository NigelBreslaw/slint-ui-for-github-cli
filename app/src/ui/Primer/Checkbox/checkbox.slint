// Primer-style checkbox — spike (PR1): checked box, disabled, tap toggles. Upstream: https://primer.style/product/components/checkbox/

import { Icons } from "../assets/icons.slint";
import { LayoutTokens, PrimerColors } from "../tokens.slint";

export component Checkbox {
    in-out property <bool> checked: false;
    in property <bool> disabled: false;
    callback toggled;

    width: box-size;
    height: box-size;

    private property <length> box-size: LayoutTokens.iconButton-icon-size-medium;

    Rectangle {
        width: 100%;
        height: 100%;
        opacity: root.disabled ? 0.5 : 1.0;
        border-radius: 4px;

        TouchArea {
            width: 100%;
            height: 100%;
            enabled: !root.disabled;

            clicked => {
                root.checked = !root.checked;
                root.toggled();
            }

            Image {
                width: parent.width;
                height: parent.height;
                source: root.checked ? Icons.checkbox_fill : Icons.checkbox;
                colorize: PrimerColors.fgColor-default;
            }
        }
    }
}
