// Primer-style checkbox — upstream: https://primer.style/product/components/checkbox/

import { Icons } from "../assets/icons.slint";
import { CheckboxTokens, LayoutTokens } from "../tokens.slint";

export component Checkbox {
    in-out property <bool> checked: false;
    in property <bool> disabled: false;
    callback toggled;

    private property <length> box-size: LayoutTokens.iconButton-icon-size-medium;
    private property <length> focus-ring: 2px;

    width: box-size + 2 * focus-ring;
    height: box-size + 2 * focus-ring;

    focus-scope := FocusScope {
        width: 100%;
        height: 100%;
        opacity: root.disabled ? 0.5 : 1.0;

        Rectangle {
            width: parent.width;
            height: parent.height;
            border-width: focus-scope.has-focus ? focus-ring : 0px;
            border-color: CheckboxTokens.checkbox-borderColor-focus;
            border-radius: LayoutTokens.checkbox-border-radius + focus-ring;
            background: #00000000;

            Rectangle {
                width: box-size;
                height: box-size;
                x: (parent.width - box-size) / 2;
                y: (parent.height - box-size) / 2;
                border-radius: LayoutTokens.checkbox-border-radius;
                border-width: 1px;
                border-color: root.disabled ? CheckboxTokens.checkbox-borderColor-rest : root.checked ? CheckboxTokens.checkbox-borderColor-checked : CheckboxTokens.checkbox-borderColor-rest;
                background: root.disabled ? CheckboxTokens.checkbox-bgColor-rest : ta.pressed ? CheckboxTokens.checkbox-bgColor-active : ta.has-hover ? CheckboxTokens.checkbox-bgColor-hover : CheckboxTokens.checkbox-bgColor-rest;

                ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    enabled: !root.disabled;

                    clicked => {
                        root.checked = !root.checked;
                        root.toggled();
                    }

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.checked ? Icons.checkbox_fill : Icons.checkbox;
                        colorize: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : root.checked ? CheckboxTokens.checkbox-iconColor-checked : CheckboxTokens.checkbox-iconColor-unchecked;
                    }
                }
            }
        }
    }
}
