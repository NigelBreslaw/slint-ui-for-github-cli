// Primer-style checkbox — upstream: https://primer.style/product/components/checkbox/ + Checkbox.module.css (16px control, borderRadius-small, control-checked-bgColor-rest when checked/indeterminate).

import { Icons } from "../assets/icons.slint";
import { CheckboxTokens, LayoutTokens, PrimerColors } from "../tokens.slint";

export component Checkbox {
    in-out property <bool> checked: false;
    in-out property <bool> indeterminate: false;
    in property <bool> disabled: false;
    in property <string> label: "";

    callback toggled;

    private property <length> box-size: LayoutTokens.iconButton-icon-size-medium;
    private property <length> leading-icon-size: box-size;

    private property <bool> filled: root.checked || root.indeterminate;

    touch := TouchArea {
        enabled: !root.disabled;
        clicked => {
            root.checked = root.indeterminate ? true : !root.checked;
            root.indeterminate = false;
            root.toggled();
        }

        HorizontalLayout {
            spacing: LayoutTokens.button-content-gap;
            alignment: center;

            check-visuals := Rectangle {
                width: box-size;
                height: box-size;
                border-radius: LayoutTokens.checkbox-border-radius;
                border-width: 1px;
                border-color:
                    root.disabled && root.filled ? CheckboxTokens.checkbox-borderColor-checked-disabled
                    : root.disabled ? CheckboxTokens.checkbox-borderColor-rest
                    : root.filled
                    ? (touch.pressed ? CheckboxTokens.checkbox-borderColor-checked-active : touch.has-hover ? CheckboxTokens.checkbox-borderColor-checked-hover : CheckboxTokens.checkbox-borderColor-checked)
                    : CheckboxTokens.checkbox-borderColor-rest;
                background:
                    root.disabled && root.filled ? CheckboxTokens.checkbox-bgColor-checked-disabled
                    : root.disabled ? CheckboxTokens.checkbox-bgColor-rest
                    : root.filled
                    ? (touch.pressed ? CheckboxTokens.checkbox-bgColor-checked-active : touch.has-hover ? CheckboxTokens.checkbox-bgColor-checked-hover : CheckboxTokens.checkbox-bgColor-checked)
                    : (touch.pressed ? CheckboxTokens.checkbox-bgColor-active : touch.has-hover ? CheckboxTokens.checkbox-bgColor-hover : CheckboxTokens.checkbox-bgColor-rest);

                if root.indeterminate: Rectangle {
                    width: box-size * 0.45;
                    height: 2px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    background: root.disabled ? CheckboxTokens.checkbox-fgColor-checked-disabled : PrimerColors.fgOnEmphasis;
                    border-radius: 1px;
                }

                if !root.indeterminate && root.checked: Image {
                    width: parent.width;
                    height: parent.height;
                    source: Icons.checkbox_fill;
                    colorize:  root.disabled ? CheckboxTokens.checkbox-fgColor-checked-disabled : PrimerColors.fgOnEmphasis;
                }

            }

            if label != "": Text {
                text: label;
                color: root.disabled ? CheckboxTokens.checkbox-iconColor-disabled : PrimerColors.fgColor-default;
                font-size: LayoutTokens.text-body-size-medium;
                font-weight: LayoutTokens.base-text-weight-medium;
                wrap: word-wrap;
                vertical-alignment: center;
            }
        }
    }
}
