import { ButtonVariant } from "../Buttons/types.slint";
import { Button } from "../Buttons/buttons.slint";
import { BannerTokens, LayoutTokens, PrimerColors, Size } from "../tokens.slint";

// Mirrors @primer/react Banner variants (Banner.tsx / Banner.module.css).
export enum BannerVariant {
    critical,
    info,
    success,
    upsell,
    warning,
}

export enum BannerLayout {
    default,
    compact,
}

export component Banner {
    in property <string> title: "";
    in property <string> description: "";
    /// When non-empty, shown bold via `@markdown` as the first segment; use `description` for the plain remainder (often a leading space + rest of sentence). Empty uses a single plain `description` line.
    in property <string> description-emphasis: "";
    /// Optional secondary line (Slint extension; React Banner uses `title` + `description` only). Muted small body text.
    in property <string> subtitle: "";
    in property <BannerVariant> variant: BannerVariant.info;
    in property <BannerLayout> layout: BannerLayout.default;
    in property <bool> flush: false;
    in property <bool> hide-title: false;
    /// When true and variant is `info` or `upsell`, `leading-icon` replaces the default icon.
    in property <bool> has-custom-leading-icon: false;
    in property <image> leading-icon;
    /// When true, shows a dismiss control (Primer `onDismiss`). Wire `dismiss` to hide the banner.
    in property <bool> dismissible: false;
    callback dismiss;
    /// Primary action (React `Banner.PrimaryAction` uses Button `default`; set `primary-action-variant` to `primary` for green CTA).
    in property <string> primary-action-label: "";
    in property <ButtonVariant> primary-action-variant: ButtonVariant.default;
    in property <Size> action-size: Size.medium;
    callback primary-action;
    /// Secondary action (React `Banner.SecondaryAction` uses Button `invisible`).
    in property <string> secondary-action-label: "";
    callback secondary-action;
    /// When true and actions are present, primary/secondary render in the top row after the text column (full-width notice). Default stacks actions below the description.
    in property <bool> actions-trailing: false;

    private property <length> dismiss-icon-side: 16px;
    private property <length> dismiss-cell-width:
        LayoutTokens.banner-icon-container-padding * 2 + dismiss-icon-side;

    private property <length> pad-inline:
        layout == BannerLayout.compact ? LayoutTokens.banner-padding-compact : LayoutTokens.banner-padding-default;
    private property <length> pad-block: pad-inline;

    private property <bool> has-actions: primary-action-label != "" || secondary-action-label != "";

    // Matches Banner.module.css: 20px default; 16px only when title hidden and no actions.
    private property <length> icon-size:
        hide-title && !has-actions ? LayoutTokens.banner-icon-size-title-hidden : LayoutTokens.banner-icon-size-default;

    private property <length> icon-cell-width:
        LayoutTokens.banner-icon-container-padding * 2 + icon-size;

    private property <bool> use-custom-leading:
        has-custom-leading-icon && (variant == BannerVariant.info || variant == BannerVariant.upsell);

    private property <bool> use-trailing-actions: actions-trailing && has-actions;

    /// Matches legacy dismiss sizing when actions sit below the description (not when `actions-trailing`).
    private property <length> stacked-actions-dismiss-nudge:
        has-actions && !actions-trailing ? LayoutTokens.banner-dismiss-margin-when-actions : 0px;

    private property <length> dismiss-icon-y:
        LayoutTokens.banner-icon-container-padding
        + (dismissible ? stacked-actions-dismiss-nudge : 0px);

    private property <length> dismiss-cell-extra-height: stacked-actions-dismiss-nudge;

    private property <color> banner-bg:
        variant == BannerVariant.critical ? BannerTokens.banner-bgColor-critical
        : variant == BannerVariant.info ? BannerTokens.banner-bgColor-info
        : variant == BannerVariant.success ? BannerTokens.banner-bgColor-success
        : variant == BannerVariant.upsell ? BannerTokens.banner-bgColor-upsell
        : BannerTokens.banner-bgColor-warning;

    private property <color> banner-border:
        variant == BannerVariant.critical ? BannerTokens.banner-borderColor-critical
        : variant == BannerVariant.info ? BannerTokens.banner-borderColor-info
        : variant == BannerVariant.success ? BannerTokens.banner-borderColor-success
        : variant == BannerVariant.upsell ? BannerTokens.banner-borderColor-upsell
        : BannerTokens.banner-borderColor-warning;

    private property <color> banner-icon-fg:
        variant == BannerVariant.critical ? BannerTokens.banner-icon-fgColor-critical
        : variant == BannerVariant.info ? BannerTokens.banner-icon-fgColor-info
        : variant == BannerVariant.success ? BannerTokens.banner-icon-fgColor-success
        : variant == BannerVariant.upsell ? BannerTokens.banner-icon-fgColor-upsell
        : BannerTokens.banner-icon-fgColor-warning;

    private property <image> default-leading-source:
        variant == BannerVariant.critical ? @image-url("../../../assets/16px/stop.svg")
        : variant == BannerVariant.info ? @image-url("../../../assets/16px/info.svg")
        : variant == BannerVariant.success ? @image-url("../../../assets/16px/circle-check.svg")
        : variant == BannerVariant.upsell ? @image-url("../../../assets/16px/info.svg")
        : @image-url("../../../assets/16px/alert.svg");

    private property <image> resolved-leading-source: use-custom-leading ? leading-icon : default-leading-source;

    min-width: 120px;
    preferred-width: 100%;

    Rectangle {
        width: 100%;
        background: banner-bg;
        border-radius: flush ? 0px : LayoutTokens.borderRadius-medium;
        border-width: flush ? 0px : 1px;
        border-color: banner-border;
        accessible-role: AccessibleRole.none;

        VerticalLayout {
            // width: 100%;
            spacing: 0;

            if flush: Rectangle {
                height: 1px;
                width: 100%;
                background: banner-border;
            }

            HorizontalLayout {
                padding-left: pad-inline;
                padding-right: pad-inline;
                padding-top: pad-block;
                padding-bottom: pad-block;
                spacing: 4px;
                // width: 100%;
                alignment: start;
                // width: self.preferred-width;

                Rectangle {
                    width: icon-cell-width;
                    height: icon-size + LayoutTokens.banner-icon-container-padding * 2;

                    Image {
                        x: (parent.width - self.width) / 2;
                        y: LayoutTokens.banner-icon-container-padding;
                        width: icon-size;
                        height: icon-size;
                        source: resolved-leading-source;
                        colorize: banner-icon-fg;
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    width: self.preferred-width;
                    horizontal-stretch: 0;

                    if !hide-title: Text {
                        text: title;
                        color: PrimerColors.fgColor-default;
                        font-size: LayoutTokens.text-body-size-medium;
                        font-weight: LayoutTokens.base-text-weight-semibold;
                        wrap: word-wrap;
                    }

                    if description-emphasis != "": HorizontalLayout {
                        width: 100%;
                        min-width: 0px;
                        spacing: 0px;

                        StyledText {
                            text: @markdown("**\{description-emphasis}**");
                            horizontal-alignment: left;
                            vertical-alignment: top;
                            accessible-role: AccessibleRole.text;
                            accessible-label: hide-title && title != "" ? title : "";
                        }

                        Text {
                            horizontal-stretch: 1;
                            min-width: 0px;
                            text: description;
                            color: PrimerColors.fgColor-default;
                            font-size: LayoutTokens.text-body-size-medium;
                            wrap: word-wrap;
                            vertical-alignment: top;
                        }
                    }

                    if description-emphasis == "": Text {
                        text: description;
                        color: PrimerColors.fgColor-default;
                        font-size: LayoutTokens.text-body-size-medium;
                        wrap: word-wrap;
                        accessible-role: AccessibleRole.text;
                        accessible-label: hide-title && title != "" ? title : "";
                        accessible-description: hide-title && title != "" ? description : "";
                    }

                    if subtitle != "": Text {
                        text: subtitle;
                        color: PrimerColors.fgColor-muted;
                        font-size: LayoutTokens.text-body-size-small;
                        wrap: word-wrap;
                        width: 100%;
                    }

                    if has-actions && !use-trailing-actions: HorizontalLayout {
                        spacing: LayoutTokens.banner-actions-gap;
                        width: 100%;
                        alignment: start;

                        if secondary-action-label != "": Button {
                            label: secondary-action-label;
                            variant: ButtonVariant.invisible;
                            size: action-size;
                            clicked => {
                                root.secondary-action();
                            }
                        }

                        if primary-action-label != "": Button {
                            label: primary-action-label;
                            variant: primary-action-variant;
                            size: action-size;
                            clicked => {
                                root.primary-action();
                            }
                        }
                    }
                }


                if use-trailing-actions: HorizontalLayout {
                    spacing: LayoutTokens.banner-actions-gap;
                    if secondary-action-label != "": Button {
                        label: secondary-action-label;
                        variant: ButtonVariant.invisible;
                        size: action-size;
                        clicked => {
                            root.secondary-action();
                        }
                    }

                    if primary-action-label != "": Button {
                        label: primary-action-label;
                        variant: primary-action-variant;
                        size: action-size;
                        clicked => {
                            root.primary-action();
                        }
                    }
                }

                if dismissible: Rectangle {
                    width: dismiss-cell-width;
                    height: icon-size + LayoutTokens.banner-icon-container-padding * 2 + dismiss-cell-extra-height;

                    Image {
                        x: (parent.width - self.width) / 2;
                        y: dismiss-icon-y;
                        width: dismiss-icon-side;
                        height: dismiss-icon-side;
                        source: @image-url("../../../assets/16px/x.svg");
                        colorize: banner-icon-fg;
                    }

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        accessible-role: AccessibleRole.button;
                        accessible-label: "Dismiss";
                        clicked => {
                            root.dismiss();
                        }
                    }
                }
            }

            if flush: Rectangle {
                height: 1px;
                width: 100%;
                background: banner-border;
            }
        }
    }
}
