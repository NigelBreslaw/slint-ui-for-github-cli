// Primer DataTable footer pagination — upstream: primer-ui-react `DataTable/Pagination.tsx` + `Pagination/model.tsx`.
import { Button } from "../Buttons/buttons.slint";
import { ButtonVariant } from "../Buttons/types.slint";
import { Icons } from "../assets/icons.slint";
import { LayoutTokens, PrimerColors, Size } from "../tokens.slint";
import { PaginationPiece, PaginationPieceKind } from "./types.slint";
import { PaginationLogic } from "./pagination-logic.slint";

export component Pagination {
    in property <int> total-count: 0;
    in property <int> page-size: 25;
    in-out property <int> page-index: 0;
    in property <bool> show-pages: true;
    in property <int> margin-page-count: 1;
    in property <int> surrounding-page-count: 2;
    callback page-changed(int);

    private property <int> page-count: PaginationLogic.page_count_from_total(total-count, page-size);
    private property <int> idx-clamped: PaginationLogic.clamp_page_index(page-index, page-count);
    private property <int> current-1based: idx-clamped + 1;
    private property <int> model-len: PaginationLogic.model_len(
        page-count,
        current-1based,
        show-pages,
        margin-page-count,
        surrounding-page-count,
    );
    private property <int> range-start: PaginationLogic.range_display_start(total-count, idx-clamped, page-size);
    private property <int> range-end: PaginationLogic.range_display_end(total-count, idx-clamped, page-size);

    width: 100%;
    min-height: LayoutTokens.control-small-size;

    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        border-width: 1px;
        border-color: PrimerColors.borderColor-default;
        border-radius: LayoutTokens.table-border-radius;

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding-top: LayoutTokens.table-cell-padding-block-normal;
            padding-bottom: LayoutTokens.table-cell-padding-block-normal;
            padding-left: LayoutTokens.stack-padding-normal;
            padding-right: LayoutTokens.stack-padding-normal;
            spacing: LayoutTokens.stack-padding-normal;
            alignment: center;

            Text {
                text: total-count <= 0
                    ? "0‒0 of 0"
                    : "" + range-start + "‒" + range-end + " of " + total-count;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                vertical-alignment: center;
                wrap: no-wrap;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: LayoutTokens.button-content-gap;
                alignment: end;

                for i in model-len: Rectangle {
                    private property <PaginationPiece> p: PaginationLogic.piece_at(
                        i,
                        page-count,
                        current-1based,
                        show-pages,
                        margin-page-count,
                        surrounding-page-count,
                    );

                    min-height: LayoutTokens.control-small-size;

                    if p.kind == PaginationPieceKind.Prev: Button {
                        variant: ButtonVariant.invisible;
                        size: Size.small;
                        disabled: p.disabled;
                        has-leading-icon: true;
                        leading-icon: Icons.chevron_left;
                        label: "Previous";
                        clicked => {
                            root.page-changed(p.page_num - 1);
                        }
                    }

                    if p.kind == PaginationPieceKind.Next: Button {
                        variant: ButtonVariant.invisible;
                        size: Size.small;
                        disabled: p.disabled;
                        has-trailing-icon: true;
                        trailing-icon: Icons.chevron_right;
                        label: "Next";
                        clicked => {
                            root.page-changed(p.page_num - 1);
                        }
                    }

                    if p.kind == PaginationPieceKind.Num: Button {
                        variant: p.selected ? ButtonVariant.default : ButtonVariant.invisible;
                        size: Size.small;
                        disabled: p.disabled;
                        label: "" + p.page_num;
                        clicked => {
                            root.page-changed(p.page_num - 1);
                        }
                    }

                    if p.kind == PaginationPieceKind.Break: Text {
                        text: "…";
                        color: PrimerColors.fgColor-muted;
                        font-size: LayoutTokens.text-body-size-medium;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
