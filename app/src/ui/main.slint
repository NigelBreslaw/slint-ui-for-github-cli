import { ListView, Palette, StyleMetrics } from "std-widgets.slint";
import {
    AppView,
    Authed,
    AppState,
    DashboardTab,
    ProjectRow,
    ReviewRequestRow,
    SecurityAlertRow,
} from "../bridges/slint/app-state.slint";
import { AppHeader } from "components/AppHeader.slint";
import { SettingsState } from "../bridges/slint/settings-state.slint";
import {
    ProjectBoardItemKind,
    ProjectBoardListRow,
    ProjectBoardListState,
} from "../bridges/slint/project-board-list-state.slint";
import { DataTableRow } from "../../../packages/primer-slint/DataTable/types.slint";
import { TimeReportingState, TimeReportingWeekRow } from "../bridges/slint/time-reporting-state.slint";
import {
    Button,
    ButtonVariant,
    Checkbox,
    DialogAlignPreset,
    DialogNarrowPositionPreset,
    DialogPositionPreset,
    Icons,
    ModalOverlay,
    Pagination,
    PrimerTextInput,
    SelectPanel,
    SelectPanelMode,
    Size,
    Spinner,
} from "../../../packages/primer-slint/primer.slint";
import { AppWindow, DialogTokens, LayoutTokens, OverlayTokens, PrimerColors } from "../../../packages/primer-slint/tokens.slint";
import { Settings } from "views/settings.slint";
import { Dashboard } from "views/dashboard.slint";
import { SideBar } from "components/sideBar.slint";
import { ProjectBoardList } from "views/project-board-list.slint";
import { TimeReporting } from "views/time-reporting.slint";

// import fonts
import "../../../packages/primer-slint/assets/fonts/MonaSans-VariableFont.ttf"; // "Mona Sans"
import "../../../packages/primer-slint/assets/fonts/MonaSans-Italic-VariableFont.ttf"; // "Mona Sans"
import "../../../packages/primer-slint/assets/fonts/VeraMono.ttf"; // "Bitstream Vera Sans Mono"


// Export so backend can access the enums and global state.
export { AppView, AppWindow, Authed, AppState, DashboardTab, DataTableRow, Icons, ProjectBoardItemKind, ProjectBoardListRow, ProjectBoardListState, ProjectRow, ReviewRequestRow, SecurityAlertRow, SettingsState, TimeReportingState, TimeReportingWeekRow }

export component MainWindow inherits Window {

    /** Fired after **`AppWindow`** is synced (debounced persist in **`main.ts`**). */
    callback viewport-changed;

    callback close-auth-window;
    callback show_auth_window;
    callback open-github-device-clicked;
    callback show_no_gh_cli_installed;
    callback show_gh_cli_version_too_old;
    callback open_cli_install_page;
    in property <string> gh-cli-version-block-detail: "";

    close-auth-window => {
        auth_window.close();
    }

    show_auth_window => {
        auth_window.show();
    }

    show_no_gh_cli_installed => {
        no_gh_cli_installed_window.show();
    }

    show_gh_cli_version_too_old => {
        gh_cli_version_too_old_window.show();
    }

    in property <string> status_message: "";
    in property <string> auth-device-code: "";
    in property <string> auth-device-url: "";

    preferred-width: 800px;
    preferred-height: 540px;
    min-width: 400px;
    min-height: 400px;
    title: "GitHub CLI";

    init => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
    }

    changed width => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
        root.viewport-changed();
    }
    changed height => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
        root.viewport-changed();
    }
    default-font-family: "Mona Sans";
    default-font-size: 14px;

    HorizontalLayout {
        alignment: center;
        width: 100%;
        height: 100%;

        VerticalLayout {
            alignment: center;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if root.status_message == "Loading…" || root.status_message == "Checking…": Spinner {
                size: large;
            }

            if root.status_message != "" && root.status_message != "Loading…" && root.status_message != "Checking…": Text {
                text: status_message;
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }

    side-bar := SideBar {
        x: 0;
        y: header.header-height;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;
    }

    content := Rectangle {
        x: side-bar.width;
        y: header.header-height;
        width: root.width - self.x;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;

        if AppState.view == AppView.dashboard: Dashboard { }

        if AppState.view == AppView.settings: Settings { }

        if AppState.view == AppView.timeReporting: TimeReporting { }

        if AppState.view == AppView.projectBoardList: ProjectBoardList { }
    }

    header := AppHeader { }

    no_gh_cli_installed_window := PopupWindow {
        width: root.width;
        height: root.height;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black;
        }

        VerticalLayout {
            x: (root.width - self.preferred-width) / 2;
            y: (root.height - self.preferred-height) / 2;
            width: self.preferred-width;
            height: self.preferred-height;
            spacing: 20px;
            Text {
                text: "GitHub CLI is not installed";
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Button {
                label: "Open CLI install page";
                clicked => {
                    root.open_cli_install_page();
                }
            }
        }

        close-policy: no-auto-close;
    }

    gh_cli_version_too_old_window := PopupWindow {
        width: root.width;
        height: root.height;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black;
        }

        VerticalLayout {
            x: (root.width - self.preferred-width) / 2;
            y: (root.height - self.preferred-height) / 2;
            width: self.preferred-width;
            height: self.preferred-height;
            spacing: 16px;
            Text {
                text: "GitHub CLI must be updated to at least version 2.89.0";
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Text {
                visible: root.gh-cli-version-block-detail != "";
                text: root.gh-cli-version-block-detail;
                font-size: 14px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-muted;
                wrap: word-wrap;
            }

            Button {
                label: "Open GitHub CLI install page";
                clicked => {
                    root.open_cli_install_page();
                }
            }
        }

        close-policy: no-auto-close;
    }

    auth_window := PopupWindow {
        width: root.width;
        height: root.height;
        x: 0;
        y: 0;

        close-policy: no-auto-close;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black.with-alpha(0.9);

            TouchArea {
                width: 100%;
                height: 100%;
            }

            vl := VerticalLayout {
                alignment: center;
                spacing: 16px;
                width: self.preferred-width;
                height: 100%;

                Text {
                    text: "Finish in the terminal (browser or device flow)";
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Text {
                    visible: root.auth-device-code != "";
                    text: "Your code: ";
                    font-size: 18px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                TextInput {
                    visible: root.auth-device-code != "";
                    text: root.auth-device-code;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    read-only: true;
                    changed has-focus => {
                        if (self.has-focus) {
                            self.select-all();
                        }
                    }
                }

                Button {
                    visible: root.auth-device-code != "";
                    label: "Copy code to clipboard and open web login";
                    clicked => {
                        root.open-github-device-clicked();
                    }
                }

                Spinner {
                    size: medium;
                }
            }
        }
    }

    time-reporting-project-picker-overlay := ModalOverlay {
        open <=> TimeReportingState.picker-open;
        allow-dismiss: TimeReportingState.picker-allow-cancel;
        panel-width: DialogTokens.width-large;
        panel-max-height: OverlayTokens.modal-viewport-max-height;
        panel-vertical-align: DialogAlignPreset.center;
        panel-position: DialogPositionPreset.center;
        narrow-viewport: AppWindow.window-width <= DialogTokens.narrow-max-width;
        narrow-position: DialogNarrowPositionPreset.center;
        slot-padding: DialogTokens.body-padding;
        close-requested => {
            TimeReportingState.time-reporting-picker-cancel();
        }

        VerticalLayout {
            width: 100%;
            spacing: 16px;

            SelectPanel {
                width: 100%;
                title: "Select time keeping project";
                subtitle: "Search by title, number, or URL";
                mode: SelectPanelMode.single;
                filter-text <=> AppState.projects-search;
                filter-placeholder: "Search by title, number, or URL…";
                single-items: AppState.projects-picker-select-options;
                item-count: AppState.projects-picker-options-count;
                selected-index <=> AppState.projects-picker-selected-index;
                list-max-height: 220px;
                empty-message: "No projects match your search.";
                loading: AppState.projects-load-status == "Loading projects…";
                disabled: AppState.projects-load-status != ""
                    && AppState.projects-load-status != "Loading projects…";
                filter-changed(q) => {
                    AppState.project_search_changed(q);
                }
                single-selected-changed(ix) => {
                    if ix < 0 || ix >= AppState.projects-picker-options-count {
                        return;
                    }
                    TimeReportingState.time-reporting-project-chosen(
                        AppState.projects-picker-select-options[ix].value,
                    );
                }
            }

            if AppState.projects-filtered-count > 0: Pagination {
                width: 100%;
                vertical-stretch: 0;
                total-count: AppState.projects-filtered-count;
                page-size: AppState.projects-picker-page-size;
                page-index: AppState.projects-picker-page-index;
                page-changed(idx) => {
                    AppState.projects-picker-page-changed(idx);
                }
            }

            HorizontalLayout {
                spacing: 8px;
                width: 100%;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 1px;
                }

                Button {
                    visible: TimeReportingState.picker-allow-cancel;
                    label: "Cancel";
                    clicked => {
                        TimeReportingState.time-reporting-picker-cancel();
                    }
                }
            }
        }
    }

    project-board-import-overlay := ModalOverlay {
        open <=> ProjectBoardListState.import-dialog-open;
        allow-dismiss: true;
        panel-width: DialogTokens.width-xlarge;
        panel-max-height: OverlayTokens.modal-viewport-max-height;
        panel-vertical-align: DialogAlignPreset.center;
        panel-position: DialogPositionPreset.center;
        narrow-viewport: AppWindow.window-width <= DialogTokens.narrow-max-width;
        narrow-position: DialogNarrowPositionPreset.center;
        slot-padding: DialogTokens.body-padding;
        close-requested => {
            ProjectBoardListState.project-board-import-dialog-closed();
        }

        VerticalLayout {
            spacing: 12px;
            width: 100%;
            min-height: 320px;

            Text {
                text: "Import from repositories";
                color: PrimerColors.fgColor-default;
                font-size: DialogTokens.title-font-size;
                font-weight: DialogTokens.title-font-weight;
                wrap: word-wrap;
            }

            Text {
                text: "Organization slint-ui — pick a repository, then review open issues and PRs (first page).";
                color: PrimerColors.fgColor-muted;
                font-size: DialogTokens.subtitle-font-size;
                font-weight: DialogTokens.subtitle-font-weight;
                wrap: word-wrap;
            }

            if ProjectBoardListState.import-repos-load-status == "Loading repositories…": HorizontalLayout {
                spacing: 10px;
                alignment: start;

                Spinner {
                    size: small;
                }

                Text {
                    text: "Loading repositories…";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }
            }

            if ProjectBoardListState.import-repos-load-status != "Loading repositories…": VerticalLayout {
                spacing: 12px;
                width: 100%;
                vertical-stretch: 1;

                if ProjectBoardListState.import-repos-load-status != "": Text {
                    text: ProjectBoardListState.import-repos-load-status;
                    color: PrimerColors.fgColor-default;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Text {
                    text: "Repository";
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                SelectPanel {
                    width: 100%;
                    mode: SelectPanelMode.single;
                    filter-text <=> ProjectBoardListState.import-repos-search;
                    filter-placeholder: "Filter by name…";
                    single-items: ProjectBoardListState.import-repo-select-options;
                    item-count: ProjectBoardListState.import-repo-options-count;
                    selected-index <=> ProjectBoardListState.import-repo-selected-index;
                    list-max-height: 200px;
                    empty-message: "No repositories match your search.";
                    disabled: ProjectBoardListState.import-repos-load-status != ""
                        || ProjectBoardListState.import-repo-options-count == 0;
                    filter-changed(q) => {
                        ProjectBoardListState.project-board-import-repos-search-changed(q);
                    }
                    single-selected-changed(ix) => {
                        ProjectBoardListState.project-board-import-repo-selected-changed(ix);
                    }
                }

                Text {
                    text: "Open issues and pull requests";
                    font-size: LayoutTokens.text-body-size-small;
                    font-weight: LayoutTokens.base-text-weight-semibold;
                    color: PrimerColors.fgColor-default;
                    wrap: word-wrap;
                }

                if ProjectBoardListState.import-repo-selected-index < 0: Text {
                    text: "Select a repository to load open issues and pull requests.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…": HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Spinner {
                        size: small;
                    }

                    Text {
                        text: "Loading issues and pull requests…";
                        font-size: 13px;
                        color: PrimerColors.fgColor-muted;
                        wrap: word-wrap;
                    }
                }

                if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status != "" && ProjectBoardListState.import-candidates-load-status != "Loading issues and pull requests…": Text {
                    text: ProjectBoardListState.import-candidates-load-status;
                    color: PrimerColors.fgColor-default;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status != "Loading issues and pull requests…" && (ProjectBoardListState.import-candidates-load-status == "" || ProjectBoardListState.import-candidates-total-loaded > 0): VerticalLayout {
                    spacing: 10px;

                    PrimerTextInput {
                        width: 100%;
                        block: true;
                        label-text: "Filter loaded issues and PRs";
                        placeholder: "Search issues and PRs…";
                        disabled: ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…";
                        text: ProjectBoardListState.import-candidates-search;
                        edited(t) => {
                            ProjectBoardListState.project-board-import-candidates-search-changed(t);
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        Button {
                            variant: ButtonVariant.default;
                            size: Size.small;
                            label: "Select all on page";
                            disabled: ProjectBoardListState.import-candidate-count == 0;
                            clicked => {
                                ProjectBoardListState.project-board-import-candidates-select-all-on-page();
                            }
                        }

                        Button {
                            variant: ButtonVariant.default;
                            size: Size.small;
                            label: "Load more";
                            loading: ProjectBoardListState.import-candidates-load-more-busy;
                            disabled: !ProjectBoardListState.import-candidates-has-more
                                || ProjectBoardListState.import-candidates-load-more-busy
                                || ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…";
                            clicked => {
                                ProjectBoardListState.project-board-import-candidates-load-more();
                            }
                        }

                        Button {
                            variant: ButtonVariant.primary;
                            size: Size.small;
                            label: "Add selected to project";
                            loading: ProjectBoardListState.import-add-selected-busy;
                            disabled: !ProjectBoardListState.has-selected-project
                                || ProjectBoardListState.import-selected-count == 0
                                || ProjectBoardListState.import-add-selected-busy
                                || ProjectBoardListState.import-candidates-load-status == "Loading issues and pull requests…";
                            clicked => {
                                ProjectBoardListState.project-board-import-add-selected-to-project();
                            }
                        }
                    }

                    if ProjectBoardListState.import-add-selected-message != "": Text {
                        text: ProjectBoardListState.import-add-selected-message;
                        font-size: 12px;
                        color: PrimerColors.fgColor-default;
                        wrap: word-wrap;
                    }
                }

                if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status == "" && ProjectBoardListState.import-candidate-count == 0 && ProjectBoardListState.import-candidates-total-loaded == 0: Text {
                    text: "No open issues or pull requests on this page.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                if ProjectBoardListState.import-repo-selected-index >= 0 && ProjectBoardListState.import-candidates-load-status == "" && ProjectBoardListState.import-candidate-count == 0 && ProjectBoardListState.import-candidates-total-loaded > 0 && ProjectBoardListState.import-candidates-search != "": Text {
                    text: "No issues or pull requests match your search.";
                    font-size: 13px;
                    color: PrimerColors.fgColor-muted;
                    wrap: word-wrap;
                }

                if ProjectBoardListState.import-candidate-count > 0: Rectangle {
                    height: 220px;
                    width: 100%;
                    background: PrimerColors.bgColor-neutral-muted;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: PrimerColors.borderColor-muted;
                    clip: true;

                    ListView {
                        width: parent.width - 2px;
                        height: parent.height - 2px;
                        x: 1px;
                        y: 1px;
                        for row[index] in ProjectBoardListState.import-candidate-rows: Rectangle {
                            height: 56px;
                            background: mod(index, 2) == 0 ? PrimerColors.bgColor-neutral-muted : PrimerColors.bgColor-canvas-subtle;

                            HorizontalLayout {
                                padding-left: 6px;
                                padding-right: 8px;
                                spacing: 4px;
                                alignment: center;

                                Checkbox {
                                    horizontal-stretch: 0;
                                    vertical-stretch: 0;
                                    checked: row.selected;
                                    label: "";
                                    toggled => {
                                        ProjectBoardListState.project-board-import-candidate-toggled(row.node-id);
                                    }
                                }

                                TouchArea {
                                    horizontal-stretch: 1;
                                    height: parent.height;

                                    clicked => {
                                        ProjectBoardListState.project-board-list-open-row-url(row.url);
                                    }

                                    VerticalLayout {
                                        padding-top: 8px;
                                        padding-bottom: 8px;
                                        spacing: 2px;
                                        Text {
                                            text: row.title;
                                            color: PrimerColors.fgColor-default;
                                            overflow: elide;
                                            font-size: 14px;
                                        }

                                        Text {
                                            text: (row.kind == ProjectBoardItemKind.issue ? "Issue" : "PR") + " #" + row.number;
                                            font-size: 12px;
                                            color: PrimerColors.fgColor-muted;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
