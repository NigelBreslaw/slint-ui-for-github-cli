import {
    AppView,
    Authed,
    AppState,
    DashboardTab,
    ProjectRow,
    ReviewRequestRow,
    SecurityAlertRow,
} from "../bridges/slint/app-state.slint";
import { AppHeader } from "components/AppHeader.slint";
import { DeviceFlowAuthOverlay } from "components/DeviceFlowAuthOverlay.slint";
import { GhCliVersionDialogOverlay } from "components/GhCliVersionDialogOverlay.slint";
import { NoGhCliDialogOverlay } from "components/NoGhCliDialogOverlay.slint";
import { ProjectBoardImportOverlay } from "components/ProjectBoardImportOverlay.slint";
import { TimeReportingProjectPickerOverlay } from "components/TimeReportingProjectPickerOverlay.slint";
import { SettingsState } from "../bridges/slint/settings-state.slint";
import { ShellDialogsState } from "../bridges/slint/shell-dialogs-state.slint";
import {
    ProjectBoardItemKind,
    ProjectBoardListRow,
    ProjectBoardListState,
} from "../bridges/slint/project-board-list-state.slint";
import { DataTableRow } from "../../../packages/primer-slint/DataTable/types.slint";
import { TimeReportingState, TimeReportingWeekRow } from "../bridges/slint/time-reporting-state.slint";
import { Button, Icons, Spinner } from "../../../packages/primer-slint/primer.slint";
import { AppWindow } from "../../../packages/primer-slint/tokens.slint";
import { Settings } from "views/settings.slint";
import { Dashboard } from "views/dashboard.slint";
import { SideBar } from "components/sideBar.slint";
import { ProjectBoardList } from "views/project-board-list.slint";
import { TimeReporting } from "views/time-reporting.slint";

// import fonts
import "../../../packages/primer-slint/assets/fonts/MonaSans-VariableFont.ttf"; // "Mona Sans"
import "../../../packages/primer-slint/assets/fonts/MonaSans-Italic-VariableFont.ttf"; // "Mona Sans"
import "../../../packages/primer-slint/assets/fonts/VeraMono.ttf"; // "Bitstream Vera Sans Mono"


// Export so backend can access the enums and global state.
export { AppView, AppWindow, Authed, AppState, DashboardTab, DataTableRow, Icons, ProjectBoardItemKind, ProjectBoardListRow, ProjectBoardListState, ProjectRow, ReviewRequestRow, SecurityAlertRow, SettingsState, ShellDialogsState, TimeReportingState, TimeReportingWeekRow }

export component MainWindow inherits Window {

    /** Fired after **`AppWindow`** is synced (debounced persist in **`main.ts`**). */
    callback viewport-changed;

    in property <string> status_message: "";

    preferred-width: 800px;
    preferred-height: 540px;
    min-width: 400px;
    min-height: 400px;
    title: "GitHub CLI";

    init => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
    }

    changed width => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
        root.viewport-changed();
    }
    changed height => {
        AppWindow.window-width = root.width;
        AppWindow.window-height = root.height;
        root.viewport-changed();
    }
    default-font-family: "Mona Sans";
    default-font-size: 14px;

    HorizontalLayout {
        alignment: center;
        width: 100%;
        height: 100%;

        VerticalLayout {
            alignment: center;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if root.status_message == "Loading…" || root.status_message == "Checking…": Spinner {
                size: large;
            }

            if root.status_message != "" && root.status_message != "Loading…" && root.status_message != "Checking…": Text {
                text: status_message;
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }

    side-bar := SideBar {
        x: 0;
        y: header.header-height;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;
    }

    content := Rectangle {
        x: side-bar.width;
        y: header.header-height;
        width: root.width - self.x;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;

        if AppState.view == AppView.dashboard: Dashboard { }

        if AppState.view == AppView.settings: Settings { }

        if AppState.view == AppView.timeReporting: TimeReporting { }

        if AppState.view == AppView.projectBoardList: ProjectBoardList { }
    }

    header := AppHeader { }

    NoGhCliDialogOverlay { }

    GhCliVersionDialogOverlay { }

    DeviceFlowAuthOverlay { }

    TimeReportingProjectPickerOverlay { }

    ProjectBoardImportOverlay { }
}
