import { Palette, StyleMetrics } from "std-widgets.slint";
import {
    AppView,
    Authed,
    AppState,
    DashboardTab,
    ProjectRow,
    ReviewRequestRow,
    SecurityAlertRow,
} from "../bridges/slint/app-state.slint";
import { AppHeader } from "components/AppHeader.slint";
import { SettingsState } from "../bridges/slint/settings-state.slint";
import {
    ProjectBoardItemKind,
    ProjectBoardListRow,
    ProjectBoardListState,
} from "../bridges/slint/project-board-list-state.slint";
import { DataTableRow } from "Primer/DataTable/types.slint";
import { TimeReportingState, TimeReportingWeekRow } from "../bridges/slint/time-reporting-state.slint";
import { Button, Spinner, Icons } from "Primer/primer.slint";
import { PrimerColors } from "Primer/tokens.slint";
import { Settings } from "views/settings.slint";
import { Dashboard } from "views/dashboard.slint";
import { PrimerGallery } from "views/primer-gallery.slint";
import { SideBar } from "components/sideBar.slint";
import { ProjectBoardList } from "views/project-board-list.slint";
import { TimeReporting } from "views/time-reporting.slint";

// import fonts
import "./Primer/assets/fonts/MonaSans-VariableFont.ttf"; // "Mona Sans"
import "./Primer/assets/fonts/MonaSans-Italic-VariableFont.ttf"; // "Mona Sans"
import "./Primer/assets/fonts/VeraMono.ttf"; // "Bitstream Vera Sans Mono"


// Export so backend can access the enums and global state.
export { AppView, Authed, AppState, DashboardTab, DataTableRow, Icons, ProjectBoardItemKind, ProjectBoardListRow, ProjectBoardListState, ProjectRow, ReviewRequestRow, SecurityAlertRow, SettingsState, TimeReportingState, TimeReportingWeekRow }

export component MainWindow inherits Window {

    callback close-auth-window;
    callback show_auth_window;
    callback open-github-device-clicked;
    callback show_no_gh_cli_installed;
    callback show_gh_cli_version_too_old;
    callback open_cli_install_page;

    in property <string> gh-cli-version-block-detail: "";

    close-auth-window => {
        auth_window.close();
    }

    show_auth_window => {
        auth_window.show();
    }

    show_no_gh_cli_installed => {
        no_gh_cli_installed_window.show();
    }

    show_gh_cli_version_too_old => {
        gh_cli_version_too_old_window.show();
    }

    in property <string> status_message: "";
    in property <string> auth-device-code: "";
    in property <string> auth-device-url: "";

    preferred-width: 800px;
    preferred-height: 540px;
    min-width: 400px;
    min-height: 400px;
    title: "GitHub CLI";

    changed width => {
        AppState.window_geometry_changed(root.width, root.height);
    }
    changed height => {
        AppState.window_geometry_changed(root.width, root.height);
    }
    default-font-family: "Mona Sans";
    default-font-size: 14px;

    HorizontalLayout {
        alignment: center;
        width: 100%;
        height: 100%;

        VerticalLayout {
            alignment: center;
            spacing: 12px;
            width: 100%;
            height: 100%;

            if root.status_message == "Loading…" || root.status_message == "Checking…": Spinner {
                size: large;
            }

            if root.status_message != "" && root.status_message != "Loading…" && root.status_message != "Checking…": Text {
                text: status_message;
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }

    side-bar := SideBar {
        x: 0;
        y: header.header-height;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;
    }

    content := Rectangle {
        x: side-bar.width;
        y: header.header-height;
        width: root.width - self.x;
        height: root.height - self.y;
        visible: AppState.auth == Authed.loggedIn;

        if AppState.view == AppView.dashboard: Dashboard { }

        if AppState.view == AppView.settings: Settings { }

        if AppState.view == AppView.timeReporting: TimeReporting { }

        if AppState.view == AppView.projectBoardList: ProjectBoardList { }

        if AppState.view == AppView.primerGallery: PrimerGallery { }
    }

    header := AppHeader { }

    no_gh_cli_installed_window := PopupWindow {
        width: root.width;
        height: root.height;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black;
        }

        VerticalLayout {
            x: (root.width - self.preferred-width) / 2;
            y: (root.height - self.preferred-height) / 2;
            width: self.preferred-width;
            height: self.preferred-height;
            spacing: 20px;
            Text {
                text: "GitHub CLI is not installed";
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Button {
                label: "Open CLI install page";
                clicked => {
                    root.open_cli_install_page();
                }
            }
        }

        close-policy: no-auto-close;
    }

    gh_cli_version_too_old_window := PopupWindow {
        width: root.width;
        height: root.height;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black;
        }

        VerticalLayout {
            x: (root.width - self.preferred-width) / 2;
            y: (root.height - self.preferred-height) / 2;
            width: self.preferred-width;
            height: self.preferred-height;
            spacing: 16px;
            Text {
                text: "GitHub CLI must be updated to at least version 2.89.0";
                font-size: 18px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Text {
                visible: root.gh-cli-version-block-detail != "";
                text: root.gh-cli-version-block-detail;
                font-size: 14px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-muted;
                wrap: word-wrap;
            }

            Button {
                label: "Open GitHub CLI install page";
                clicked => {
                    root.open_cli_install_page();
                }
            }
        }

        close-policy: no-auto-close;
    }

    auth_window := PopupWindow {
        width: root.width;
        height: root.height;
        x: 0;
        y: 0;

        close-policy: no-auto-close;

        Rectangle {
            x: 0;
            y: 0;
            width: root.width;
            height: root.height;
            background: black.with-alpha(0.9);

            TouchArea {
                width: 100%;
                height: 100%;
            }

            vl := VerticalLayout {
                alignment: center;
                spacing: 16px;
                width: self.preferred-width;
                height: 100%;

                Text {
                    text: "Finish in the terminal (browser or device flow)";
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Text {
                    visible: root.auth-device-code != "";
                    text: "Your code: ";
                    font-size: 18px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                TextInput {
                    visible: root.auth-device-code != "";
                    text: root.auth-device-code;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    read-only: true;
                    changed has-focus => {
                        if (self.has-focus) {
                            self.select-all();
                        }
                    }
                }

                Button {
                    visible: root.auth-device-code != "";
                    label: "Copy code to clipboard and open web login";
                    clicked => {
                        root.open-github-device-clicked();
                    }
                }

                Spinner {
                    size: medium;
                }
            }
        }
    }
}
