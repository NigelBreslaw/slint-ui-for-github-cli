import { AppState, AppView } from "../../bridges/slint/app-state.slint";
import { IconButton, IconButtonVariant, Icons, Size } from "../../../../packages/primer-slint/slint/primer.slint";
import { PrimerColors } from "../../../../packages/primer-slint/slint/tokens.slint";

export component SideBar {
    width: 24px + (16px * 2);
    height: 100%;
    Rectangle {
        height: root.height;
        background: PrimerColors.bgColor-inset;

        Rectangle {
            x: parent.width - self.width;
            width: 1px;
            height: 100%;
            background: PrimerColors.borderColor-default;
        }

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-top: 16px;
            padding-bottom: 16px;
            padding-left: 14px;
            spacing: 12px;
            alignment: start;

            IconButton {
                size: Size.small;
                variant: IconButtonVariant.invisible;
                icon-source: Icons.inbox;
                clicked => {
                    AppState.set-view(AppView.dashboard);
                }
            }

            IconButton {
                size: Size.small;
                variant: IconButtonVariant.invisible;
                icon-source: Icons.history;
                clicked => {
                    AppState.set-view(AppView.timeReporting);
                }
            }

            IconButton {
                size: Size.small;
                variant: IconButtonVariant.invisible;
                icon-source: Icons.layout_grid;
                clicked => {
                    AppState.set-view(AppView.projectBoardList);
                }
            }

            Rectangle {
                vertical-stretch: 1;
                width: 1px;
            }

            IconButton {
                size: Size.small;
                variant: IconButtonVariant.invisible;
                icon-source: Icons.gear_24;
                clicked => {
                    AppState.set-view(AppView.settings);
                }
            }
        }
    }
}