// Primer-style Dialog shell (dark only). Modeled on Primer React Dialog:
// https://github.com/primer/react/blob/main/packages/react/src/Dialog/Dialog.tsx
// In-window overlay (Rectangle). For a floating layer, wrap this component in a PopupWindow
// and call show()/close() on that window from the parent — do not use PopupWindow + init { show() } here.

import { Tokens } from "../Primer/Tokens/tokens.slint";

export enum PrimerDialogWidth {
    small,
    medium,
    large,
    xlarge,
}

export component PrimerDialog {
    in property <string> title;
    in property <string> subtitle: "";
    /** Default `medium` (320px); React defaults to `xlarge` (640px) — we use a narrower default for this app. */
    in property <PrimerDialogWidth> width-preset: medium;
    /** When false, backdrop, ×, and Escape do not call `close()` (e.g. required modal). */
    in property <bool> allow-dismiss: true;
    callback close();

    width: 100%;
    height: 100%;

    private property <length> preset-w:
        width-preset == PrimerDialogWidth.small ? 296px : width-preset == PrimerDialogWidth.large ? 480px : width-preset == PrimerDialogWidth.xlarge ? 640px : 320px;

    private property <length> panel-max-w: max(root.width - 64px, 120px);
    private property <length> panel-w: min(root.preset-w, root.panel-max-w);
    private property <length> panel-max-h: max(root.height - 64px, 120px);

    Rectangle {
        width: 100%;
        height: 100%;
        background: #010409aa;

        TouchArea {
            width: 100%;
            height: 100%;
            enabled: root.allow-dismiss;
            clicked => {
                root.close();
            }
        }

        vl := VerticalLayout {
            width: 100%;
            height: 100%;
            alignment: center;

            FocusScope {
                width: root.panel-w;
                max-height: root.panel-max-h;

                key-pressed(event) => {
                    if root.allow-dismiss && event.text == Key.Escape {
                        root.close();
                        return accept;
                    }
                    return reject;
                }

                Rectangle {
                    width: root.panel-w;
                    max-height: root.panel-max-h;
                    background: #161b22;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #30363d;
                    clip: true;
                    drop-shadow-offset-x: 0px;
                    drop-shadow-offset-y: 4px;
                    drop-shadow-blur: 16px;
                    drop-shadow-color: #01040966;

                    VerticalLayout {
                        spacing: 0;
                        width: 100%;
                        max-height: root.panel-max-h;

                        VerticalLayout {
                            spacing: 0;
                            width: 100%;

                            Rectangle {
                                width: 100%;
                                background: #161b22;

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 4px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    spacing: 8px;
                                    width: 100%;

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        padding-top: 6px;
                                        padding-bottom: 6px;
                                        spacing: 0;

                                        Text {
                                            text: root.title;
                                            font-size: 16px;
                                            font-weight: 600;
                                            color: Tokens.fgColor-default;
                                            wrap: word-wrap;
                                        }

                                        if root.subtitle != "": Text {
                                            text: root.subtitle;
                                            font-size: 12px;
                                            font-weight: 400;
                                            color: #8b949e;
                                            wrap: word-wrap;
                                        }
                                    }

                                    TouchArea {
                                        width: 32px;
                                        height: 32px;
                                        visible: root.allow-dismiss;

                                        Text {
                                            width: 32px;
                                            height: 32px;
                                            text: "×";
                                            font-size: 22px;
                                            font-weight: 400;
                                            color: #8b949e;
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                        }

                                        clicked => {
                                            root.close();
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            width: 100%;
                            height: 1px;
                            background: #30363d;
                        }
                    }

                    VerticalLayout {
                        padding: 16px;
                        spacing: 0;
                        width: 100%;
                        max-height: root.panel-max-h;

                        @children
                    }
                }
            }
        }
    }
}
