// Host on **MainWindow** (not under **TimeReporting**) so **Dialog** / **ModalOverlay**’s
// **PopupWindow** is not parented through the view subtree while actions fire from **AppHeader**
// (“Change project”) — avoids interpreter **accessing deleted parent** (Slint #6426).

import { AppState } from "../../bridges/slint/app-state.slint";
import { TimeReportingState } from "../../bridges/slint/time-reporting-state.slint";
import {
    Button,
    Dialog,
    DialogHeightPreset,
    DialogWidthPreset,
    Pagination,
    SelectPanel,
    SelectPanelMode,
} from "../../../../packages/primer-slint/primer.slint";
import { PrimerColors } from "../../../../packages/primer-slint/tokens.slint";

export component TimeReportingProjectPickerDialog {

    Dialog {
        open <=> TimeReportingState.picker-open;
        show-header: false;
        show-footer: false;
        allow-dismiss: TimeReportingState.picker-allow-cancel;
        width-preset: DialogWidthPreset.large;
        height-preset: DialogHeightPreset.auto;
        on-close(_gesture) => {
            TimeReportingState.time-reporting-picker-cancel();
        }

        VerticalLayout {
            spacing: 16px;
            width: 100%;

            Text {
                text: "Select time keeping project";
                color: PrimerColors.fgColor-default;
                font-size: 16px;
                font-weight: 600;
                wrap: word-wrap;
            }

            Text {
                text: "Search by title, number, or URL";
                color: PrimerColors.fgColor-muted;
                font-size: 12px;
                wrap: word-wrap;
            }

            VerticalLayout {
                width: 100%;
                spacing: 10px;

                SelectPanel {
                    width: 100%;
                    mode: SelectPanelMode.single;
                    filter-text <=> AppState.projects-search;
                    filter-placeholder: "Search by title, number, or URL…";
                    single-items: AppState.projects-picker-select-options;
                    item-count: AppState.projects-picker-options-count;
                    selected-index <=> AppState.projects-picker-selected-index;
                    list-max-height: 220px;
                    empty-message: "No projects match your search.";
                    loading: AppState.projects-load-status == "Loading projects…";
                    disabled: AppState.projects-load-status != ""
                        && AppState.projects-load-status != "Loading projects…";
                    filter-changed(q) => {
                        AppState.project_search_changed(q);
                    }
                    single-selected-changed(ix) => {
                        if ix < 0 || ix >= AppState.projects-picker-options-count {
                            return;
                        }
                        TimeReportingState.time-reporting-project-chosen(
                            AppState.projects-picker-select-options[ix].value,
                        );
                    }
                }

                if AppState.projects-filtered-count > 0: Pagination {
                    width: 100%;
                    vertical-stretch: 0;
                    total-count: AppState.projects-filtered-count;
                    page-size: AppState.projects-picker-page-size;
                    page-index: AppState.projects-picker-page-index;
                    page-changed(idx) => {
                        AppState.projects-picker-page-changed(idx);
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                width: 100%;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 1px;
                }

                Button {
                    visible: TimeReportingState.picker-allow-cancel;
                    label: "Cancel";
                    clicked => {
                        TimeReportingState.time-reporting-picker-cancel();
                    }
                }
            }
        }
    }
}
