import { ShellDialogsState } from "../../bridges/slint/shell-dialogs-state.slint";
import {
    Button,
    Dialog2,
    Spinner,
} from "../../../../packages/primer-slint/primer.slint";
import { AppWindow, DialogTokens, OverlayTokens, PrimerColors } from "../../../../packages/primer-slint/tokens.slint";

export component DeviceFlowAuthOverlay {
    Dialog2 {
        open <=> ShellDialogsState.auth-device-flow-open;
        allow-dismiss: false;
        default-width: DialogTokens.width-large;
        default-height: OverlayTokens.modal-viewport-max-height;
        align-preset: OverlayAlign.center;
        panel-padding: DialogTokens.body-padding;

        VerticalLayout {
            width: 100%;
            spacing: 16px;
            Text {
                text: "Finish in the terminal (browser or device flow)";
                font-size: 16px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            Text {
                visible: ShellDialogsState.auth-device-code != "";
                text: "Your code: ";
                font-size: 18px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            TextInput {
                visible: ShellDialogsState.auth-device-code != "";
                text: ShellDialogsState.auth-device-code;
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-default;
                wrap: word-wrap;
                read-only: true;
                changed has-focus => {
                    if (self.has-focus) {
                        self.select-all();
                    }
                }
            }

            Button {
                visible: ShellDialogsState.auth-device-code != "";
                label: "Copy code to clipboard and open web login";
                clicked => {
                    ShellDialogsState.open-github-device-clicked();
                }
            }

            HorizontalLayout {
                alignment: center;
                width: 100%;
                Spinner {
                    size: medium;
                }
            }
        }
    }
}
