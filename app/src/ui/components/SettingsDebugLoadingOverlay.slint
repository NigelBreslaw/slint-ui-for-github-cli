import { SettingsState } from "../../bridges/slint/settings-state.slint";
import { ModalOverlay, OverlayAlign, OverlayHeight, OverlayWidth, Spinner } from "../../../../packages/primer-slint/primer.slint";
import { PrimerColors } from "../../../../packages/primer-slint/tokens.slint";

/// Hosts the settings **Loading** state at the shell level so it is not a child of the
/// conditionally-instantiated **`Settings`** view — Slint can panic with
/// *accessing deleted parent* (#6426) when **`Dialog2`**/dialog chrome lives under `if` view branches.
export component SettingsDebugLoadingOverlay {
    loading-dialog := ModalOverlay {
        allow-dismiss: false;
        width-preset: OverlayWidth.large;
        height-preset: OverlayHeight.auto;
        align-preset: OverlayAlign.center;
        panel-padding: 24px;
        closed => {
            SettingsState.settings-debug-panel-loading = false;
        }

        VerticalLayout {
            alignment: center;
            spacing: 12px;
            width: 100%;

            Text {
                text: "Loading";
                color: PrimerColors.fgColor-default;
                font-size: 16px;
                font-weight: 600;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                width: 100%;
                alignment: center;
                Spinner {
                    size: medium;
                }
            }
        }
    }

    property <bool> settings-debug-panel-loading-sync: SettingsState.settings-debug-panel-loading;

    changed settings-debug-panel-loading-sync => {
        if settings-debug-panel-loading-sync {
            loading-dialog.show();
        } else {
            loading-dialog.close();
        }
    }
}
