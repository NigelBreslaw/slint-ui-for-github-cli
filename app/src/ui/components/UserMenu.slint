import { Avatar, Button, ButtonAlignContent, ButtonVariant, MultiDropShadow } from "../Primer/primer.slint";
import { PrimerColors } from "../Primer/tokens.slint";
import { AppState } from "../../bridges/slint/app-state.slint";
import { ShadowTokens } from "../primer/tokens.slint";

global MenuStyle {
    out property <length> border-radius: 12px;
    out property <length> menu-width: 256px;
}

export global HeaderState {
    in-out property <bool> menu-visible: false;
}

component MenuSeparator inherits VerticalLayout {
    height: self.preferred-height;
    width: 100%;
    padding-left: 8px;
    padding-right: 8px;
    Rectangle {
        height: 8px;
    }

    Rectangle {
        height: 1px;
        background: PrimerColors.actionListItem-inline-divider;
    }

    Rectangle {
        height: 8px;
    }
}

export component UserMenu {

    in-out property <image> avatar-source <=> avatar.source;
    in property <string> user_status_emoji;
    in property <string> user_status_message;

    width: MenuStyle.menu-width;
    height: content.preferred-height;

    // Block clicks
    TouchArea { }

    MultiDropShadow {
        border-radius: MenuStyle.border-radius;
        shadows: ShadowTokens.shadow-floating-small;
    }

    Rectangle {
        border-radius: MenuStyle.border-radius;
        border-width: 1px;
        border-color: PrimerColors.borderColor-default;
        background: PrimerColors.bgColor-inset;
    }

    content := VerticalLayout {
        y: 0;
        height: self.preferred-height;
        Rectangle {
            height: 16px;
        }

        header-content := Rectangle {
            x: 16px;
            width: parent.width - (2 * self.x);
            height: 100px - 16px;

            VerticalLayout {
                spacing: 8px;
                width: parent.width;
                HorizontalLayout {
                    spacing: 8px;
                    width: self.preferred-width;

                    avatar := Avatar { }

                    VerticalLayout {
                        height: self.preferred-height;
                        spacing: -3px;
                        Text {
                            width: 120px;
                            text: AppState.user_login;
                            visible: AppState.user_login != "";
                            font-size: 14px;
                            font-weight: 600;
                            color: PrimerColors.fgColor-default;
                            overflow: elide;
                        }

                        Text {
                            width: 120px;
                            text: AppState.user_name;
                            visible: AppState.user_name != "";
                            font-size: 14px;
                            color: PrimerColors.fgColor-muted;
                            font-weight: 400;
                            overflow: elide;
                        }
                    }
                }
            }

            status-button := Button {
                x: 0px;
                y: parent.height - self.height - 14px;
                width: parent.width;
                variant: ButtonVariant.invisible;
                align-content: ButtonAlignContent.start;
                leading-text: root.user_status_emoji;
                label: root.user_status_message;
                clicked => {
                }
            }
        }

        MenuSeparator { }

        Button {
            width: 100%;
            variant: ButtonVariant.invisible;
            align-content: ButtonAlignContent.start;
            has-leading-icon: true;
            leading-icon: @image-url("../../assets/16px/sign-out.svg");
            label: "Sign out";
            clicked => {
                HeaderState.menu-visible = false;
                AppState.sign-out();
            }
        }

        Rectangle {
            height: 16px;
        }
    }
}
