import { ShellDialogsState } from "../../bridges/slint/shell-dialogs-state.slint";
import {
    Button,
    ModalOverlay,
    OverlayAlign,
    OverlayHeight,
    OverlayWidth,
} from "../../../../packages/primer-slint/primer.slint";
import { DialogTokens, PrimerColors } from "../../../../packages/primer-slint/tokens.slint";

export component NoGhCliDialogOverlay {
    no-gh-cli-dialog := ModalOverlay {
        allow-dismiss: false;
        width-preset: OverlayWidth.large;
        height-preset: OverlayHeight.auto;
        align-preset: OverlayAlign.center;
        panel-padding: DialogTokens.body-padding;
        closed => {
            ShellDialogsState.no-gh-cli-dialog-open = false;
        }

        VerticalLayout {
            width: 100%;
            spacing: 20px;
            Text {
                text: "GitHub CLI is not installed";
                font-size: 18px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            Button {
                label: "Open CLI install page";
                clicked => {
                    ShellDialogsState.open-cli-install-page();
                }
            }
        }
    }

    property <bool> no-gh-cli-dialog-open-sync: ShellDialogsState.no-gh-cli-dialog-open;

    changed no-gh-cli-dialog-open-sync => {
        if no-gh-cli-dialog-open-sync {
            no-gh-cli-dialog.show();
        } else {
            no-gh-cli-dialog.close();
        }
    }
}
