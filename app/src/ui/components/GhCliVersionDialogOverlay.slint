import { ShellDialogsState } from "../../bridges/slint/shell-dialogs-state.slint";
import {
    Button,
    Dialog2,
    OverlayAlign,
    OverlayHeight,
    OverlayWidth,
} from "../../../../packages/primer-slint/primer.slint";
import { DialogTokens, PrimerColors } from "../../../../packages/primer-slint/tokens.slint";

export component GhCliVersionDialogOverlay {
    gh-cli-version-dialog := Dialog2 {
        allow-dismiss: false;
        width-preset: OverlayWidth.large;
        height-preset: OverlayHeight.auto;
        align-preset: OverlayAlign.center;
        panel-padding: DialogTokens.body-padding;
        closed => {
            ShellDialogsState.gh-cli-version-dialog-open = false;
        }

        VerticalLayout {
            width: 100%;
            spacing: 16px;
            Text {
                text: "GitHub CLI must be updated to at least version 2.89.0";
                font-size: 18px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-default;
                wrap: word-wrap;
            }

            Text {
                visible: ShellDialogsState.gh-cli-version-block-detail != "";
                text: ShellDialogsState.gh-cli-version-block-detail;
                font-size: 14px;
                horizontal-alignment: center;
                color: PrimerColors.fgColor-muted;
                wrap: word-wrap;
            }

            Button {
                label: "Open GitHub CLI install page";
                clicked => {
                    ShellDialogsState.open-cli-install-page();
                }
            }
        }
    }

    property <bool> gh-cli-version-dialog-open-sync: ShellDialogsState.gh-cli-version-dialog-open;

    changed gh-cli-version-dialog-open-sync => {
        if gh-cli-version-dialog-open-sync {
            gh-cli-version-dialog.show();
        } else {
            gh-cli-version-dialog.close();
        }
    }
}
