import { AppState } from "../../bridges/slint/app-state.slint";
import { TimeReportingState } from "../../bridges/slint/time-reporting-state.slint";
import {
    ActionList2ListRole,
    ActionList2SelectionMode,
    AnchoredOverlayWidth,
    Button,
    ModalOverlay,
    OverlayAlign,
    OverlayHeight,
    OverlayWidth,
    Pagination,
    SelectPanel2,
} from "../../../../packages/primer-slint/primer.slint";
import { PaginationLogic } from "../../../../packages/primer-slint/Pagination/pagination-logic.slint";
import { DialogTokens, LayoutTokens, PrimerColors } from "../../../../packages/primer-slint/tokens.slint";

/// Range label + `Pagination` strip; `page-index` is 0-based (two-way to `AppState`).
component TimeReportingPickerPaginationFooter {
    in-out property <int> page-index;
    in property <int> total-count;
    in property <int> page-size;
    callback page-changed(int);

    property <int> page-count: PaginationLogic.page_count_from_total(total-count, page-size);
    property <int> idx-clamped: PaginationLogic.clamp_page_index(page-index, page-count);
    property <int> range-start: PaginationLogic.range_display_start(total-count, idx-clamped, page-size);
    property <int> range-end: PaginationLogic.range_display_end(total-count, idx-clamped, page-size);
    /// 1-based page for `Pagination`; derived from 0-based `page-index` (single source of truth).
    property <int> pagination-current-1based: PaginationLogic.clamp_current_page_1based(page-index + 1, page-count);

    width: 100%;
    vertical-stretch: 0;
    min-height: LayoutTokens.control-small-size;

    Rectangle {
        border-width: 1px;
        border-color: PrimerColors.borderColor-default;
        border-radius: LayoutTokens.table-border-radius;

        HorizontalLayout {
            padding-top: LayoutTokens.table-cell-padding-block-normal;
            padding-bottom: LayoutTokens.table-cell-padding-block-normal;
            padding-left: LayoutTokens.stack-padding-normal;
            padding-right: LayoutTokens.stack-padding-normal;
            spacing: LayoutTokens.stack-padding-normal;

            Text {
                horizontal-stretch: 0;
                text: total-count <= 0
                    ? "0‒0 of 0"
                    : "" + range-start + "‒" + range-end + " of " + total-count;
                color: PrimerColors.fgColor-muted;
                font-size: LayoutTokens.text-body-size-small;
                vertical-alignment: center;
                wrap: no-wrap;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: LayoutTokens.button-content-gap;
                alignment: space-around;

                Pagination {
                    width: 100%;
                    page-count: page-count;
                    current-page: pagination-current-1based;
                    page-changed(idx) => {
                        root.page-changed(idx);
                    }
                }
            }
        }
    }
}

export component TimeReportingProjectPickerOverlay {
    picker-dialog := ModalOverlay {
        allow-dismiss: TimeReportingState.picker-allow-cancel;
        width-preset: OverlayWidth.large;
        height-preset: OverlayHeight.auto;
        align-preset: OverlayAlign.center;
        panel-padding: DialogTokens.body-padding;
        closed => {
            TimeReportingState.time-reporting-picker-cancel();
        }

        VerticalLayout {
            width: 100%;
            spacing: 16px;

            SelectPanel2 {
                width: 100%;
                has-built-in-anchor: false;
                open: TimeReportingState.picker-open;
                close-on-single-select: false;
                allow-dismiss: false;
                show-backdrop: false;
                width-preset: AnchoredOverlayWidth.large;
                title: "Select time keeping project";
                subtitle: "Search by title, number, or URL";
                filter-text <=> AppState.projects-search;
                filter-placeholder: "Search by title, number, or URL…";
                lines: AppState.projects-picker-lines;
                list-role: ActionList2ListRole.listbox;
                selection-mode: ActionList2SelectionMode.single;
                selected-index <=> AppState.projects-picker-selected-index;
                body-region-height: 220px;
                empty-message: "No projects match your search.";
                loading: AppState.projects-load-status == "Loading projects…";
                filter-changed(q) => {
                    AppState.project_search_changed(q);
                }
                single-selected-changed(ix) => {
                    if ix < 0 || ix >= AppState.projects-picker-options-count {
                        return;
                    }
                    TimeReportingState.time-reporting-project-chosen(ix);
                }
            }

            if AppState.projects-filtered-count > 0: TimeReportingPickerPaginationFooter {
                width: 100%;
                vertical-stretch: 0;
                total-count: AppState.projects-filtered-count;
                page-size: AppState.projects-picker-page-size;
                page-index: AppState.projects-picker-page-index;
                page-changed(idx) => {
                    AppState.projects-picker-page-changed(idx);
                }
            }

            HorizontalLayout {
                spacing: 8px;
                width: 100%;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 1px;
                }

                Button {
                    visible: TimeReportingState.picker-allow-cancel;
                    label: "Cancel";
                    clicked => {
                        TimeReportingState.time-reporting-picker-cancel();
                    }
                }
            }
        }
    }

    property <bool> picker-open-sync: TimeReportingState.picker-open;

    changed picker-open-sync => {
        if picker-open-sync {
            picker-dialog.show();
        } else {
            picker-dialog.close();
        }
    }
}
