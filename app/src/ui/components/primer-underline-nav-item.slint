// Primer-style UnderlineNav item (dark only): label + 2px accent when selected; TouchArea for tap targets.

import { PrimerColors } from "../Primer/tokens.slint";

export component PrimerUnderlineNavItem {
    in property <string> label;
    in property <bool> selected;
    callback clicked <=> ta.clicked;

    min-height: 44px;
    width: self.preferred-width;

    VerticalLayout {
        padding-top: 10px;
        padding-bottom: 6px;
        padding-left: 16px;
        padding-right: 16px;
        spacing: 6px;
        width: self.preferred-width;
        height: self.preferred-height;

        label-text := Text {
            text: root.label;
            font-size: 13px;
            font-weight: root.selected ? 600 : 500;
            color: root.selected ? PrimerColors.fgColor-default : PrimerColors.fgColor-muted;
            vertical-alignment: center;
        }
    }

    Rectangle {
        y: parent.height - self.height;
        height: 2px;
        width: 100%;
        background: root.selected ? PrimerColors.accent-underline : #00000000;
    }

    ta := TouchArea { }
}
